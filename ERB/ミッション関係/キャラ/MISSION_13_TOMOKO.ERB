;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_13
ADDCHARA 212
LOADGLOBAL
GLOBAL:412 += 1
SAVEGLOBAL
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(212)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_13
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(212)
LOCAL:1 = 0
LOCAL:4 = 0
SIF GETCHARA(5, 0) >= 0
	LOCAL:2 = GETCHARA(5)
SIF GETCHARA(11, 0) >= 0
	LOCAL:3 = GETCHARA(11)

SIF ABL:LOCAL:11 >= 5
	LOCAL:1++
SIF TALENT:LOCAL:0 == 1
	LOCAL:1++
SIF TALENT:LOCAL:2 == 0
	LOCAL:1++
SIF RELATION:LOCAL:(NO:(LOCAL:2)) >= 200
	LOCAL:4++
SIF RELATION:LOCAL:(NO:(LOCAL:3)) >= 200
	LOCAL:4++

SIF LOCAL:1 >= 3 && LOCAL:4 >= 1
	RETURN 1
RETURN 0

