;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_18


LOADGLOBAL
	GLOBAL:417 += 1
SAVEGLOBAL
ADDCHARA 217
TARGET = GETCHARA(217)
CALL CLEARBONUS_CALL


;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_18
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(217)
LOCAL:1 = 0


SIF TALENT:LOCAL:203 == 1
	LOCAL:1++
SIF TALENT:LOCAL:400 == 0
	LOCAL:1++
SIF CFLAG:LOCAL:18 == 0
	LOCAL:1++

IF LOCAL:1 >= 3
	IF TALENT:LOCAL:430
		RETURN 2
	ELSE
		RETURN 1
	ENDIF
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_18(ARG)
LOCAL = GETCHARA(217)

SIF ARG == 0
	TALENT:LOCAL:330 = 0

IF ARG == 1
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
ELSEIF ARG == 2
	PRINTFORML 니콜은【아이돌】로 화려하게 데뷔했지만, %플레이어를()% 향한 마음을 잊지 못한것 같다……
	PRINTFORML 잊기는 커녕 %CALLNAME:MASTER%의 곁에 남고싶다며 억지를 부려왔다
	PRINTFORMW 그게 무슨 뜻인지 알고 있냐고 물으니 니콜은 머뭇거리면서도 천천히 고개를 끄덕였다……
	TALENT:LOCAL:330 = 0
ENDIF

