;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_16
ADDCHARA 215
LOADGLOBAL
GLOBAL:415 += 1
SAVEGLOBAL
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(215)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_16
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(215)
LOCAL:1 = 0

SIF ABL:LOCAL:10 > 6
	LOCAL:1++
SIF ABL:LOCAL:16 > 6
	LOCAL:1++
SIF TALENT:LOCAL:151 == 0
	LOCAL:1++

IF LOCAL:1 >= 3
	RETURN 1
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_16(ARG)
LOCAL = GETCHARA(215)

IF ARG == 1
	MAXBASE:31 += 30
	BASE:31 += 30	
	TALENT:LOCAL:330 = 0
ENDIF

