;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_3
ADDCHARA 202
LOADGLOBAL
GLOBAL:402 += 1
SAVEGLOBAL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_3
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(202)
LOCAL:1 = 0
;아이돌
SIF TALENT:LOCAL:203 == 1
	LOCAL:1++
;美容
SIF ABL:LOCAL:50 >= 5
	LOCAL:1++
SIF LOCAL:1 == 2
	RETURN 1
RETURN 0

