;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_1
ADDCHARA 200
LOADGLOBAL
GLOBAL:400 += 1
SAVEGLOBAL
TARGET = GETCHARA(200)
CALL CLEARBONUS_CALL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_1
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(200)
LOCAL:1 = 0
SIF ABL:LOCAL:17 >= 3
	LOCAL:1++
SIF ABL:LOCAL:10 >= 4
	LOCAL:1++
SIF TALENT:LOCAL:27 == 0
	LOCAL:1++
SIF LOCAL:1 == 3
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_1(ARG)
LOCAL = GETCHARA(200)
TALENT:LOCAL:330 = 0

