;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_12
ADDCHARA 211
LOADGLOBAL
GLOBAL:411 += 1
SAVEGLOBAL
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(211)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_12
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(211)
LOCAL:1 = 0
SIF ABL:LOCAL:70 >= 4
	LOCAL:1++
SIF ABL:LOCAL:10 >= 5
	LOCAL:1++
SIF MAXBASE:LOCAL:31 >= 160
	LOCAL:1++
IF LOCAL:1 == 3
	SIF ABL:LOCAL:22 >= 5 && ABL:LOCAL:33 >= 5
		RETURN 2
	RETURN 1
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_12(ARG)
LOCAL = GETCHARA(211)
IF ARG > 0
	PRINTFORML  자신의 존재감이 올라갔다고 확신한 %타겟은()%, 다른 사람을 끌어당기는 매력을 띠기 시작했다……
	PRINTFORML  %타겟은()%【인기인】가 되었다.
	TALENT:LOCAL:126 = 1
	IF ARG == 2
		PRINTL 
		PRINTFORML  그 밤 자신의 방에서 자고있던%타겟은()%, 침대에 숨어들어온 아카기 유우히에게 덮쳐지고 말았다.
		PRINTFORML  저항하려고 한 %조사처리(CALLNAME:TARGET,"이다")%였지만,
		PRINTFORML  과도한 지도로 레즈끼가 개화해버린 그녀의 몸과 마음은 쉽게 유우히에게 굴복해버렸다……
		PRINTL 
		PRINTL  사랑하는 여동생을 손에 넣은 유우히는 기분좋게 키류 조직에 추가보수를 지급하고, AV 데뷔를 승락했다.
		PRINTL  《아카기 유우히가 여배우 후보에 추가되었습니다》
		;유우히加入処理, 追加報酬30만 pと공헌도10を追加
		ADDCHARA 98
		LOADGLOBAL
			GLOBAL:298 += 1
		SAVEGLOBAL
	ENDIF
ENDIF
TALENT:LOCAL:330 = 0

