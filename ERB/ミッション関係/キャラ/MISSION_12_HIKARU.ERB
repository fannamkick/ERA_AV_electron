;=================================================
; 미션報酬
;--------------------------------------------
; 미션の報酬を記述する
; P:1 報酬포인트
; P:2 報酬공헌도
; P:3 失敗時の没収포인트
; P:4 失敗時の没収공헌도
; P:5 延長期間
;=================================================
@MISSION_FEE_12
P:1 = 10000
; 大成功時に追加報酬30만 포인트
SIF PBAND:12 == 4
	P:1 += 300000
P:2 = 5
; 大成功時に追加報酬10공헌도
SIF PBAND:12 == 4
	P:2 += 10
P:3 = 500000
P:4 = 0
P:5 = 0

