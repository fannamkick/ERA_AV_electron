;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_4
ADDCHARA 203
LOADGLOBAL
GLOBAL:403 += 1
SAVEGLOBAL
	TARGET = GETCHARA(203)
	CALL CLEARBONUS_CALL


;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_4
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(203)
LOCAL:1 = 0
;처녀性
SIF TALENT:LOCAL:0 == 1
	LOCAL:1++
SIF TALENT:LOCAL:2 == 1
	LOCAL:1++
;露出
SIF ABL:LOCAL:17 >= 2
	LOCAL:1++
;소악마
SIF TALENT:LOCAL:87 == 1
	LOCAL:1++
;キス未経験
SIF CFLAG:LOCAL:16 == -1
	LOCAL:1++
;AV배우
SIF TALENT:LOCAL:400 == 1
	LOCAL:1 = 0
SIF LOCAL:1 == 5
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_4(ARG)
LOCAL = GETCHARA(203)
TALENT:LOCAL:330 = 0

