;=================================================
; 미션報酬
;--------------------------------------------
; 미션の報酬を記述する
; P:1 報酬포인트
; P:2 報酬공헌도
; P:3 失敗時の没収포인트
; P:4 失敗時の没収공헌도
; P:5 延長期間
;=================================================
@MISSION_FEE_4
P:1 = 50000
P:2 = 1
P:3 = P:1 * 2
; 条件による違約金追加
LOCAL = GETCHARA(203)
SIF TALENT:LOCAL:0 == 0
	P:3 += 500000
SIF TALENT:LOCAL:2 == 0
	P:3 += 500000
SIF CFLAG:LOCAL:16 != -1
	P:3 += 500000
P:4 = 0
P:5 = 0

