;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_10
ADDCHARA 209
LOADGLOBAL
GLOBAL:409 += 1
SAVEGLOBAL
TARGET = GETCHARA(209)
CALL CLEARBONUS_CALL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_10
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(209)
LOCAL:1 = 0
SIF TALENT:LOCAL:13 == 1
	LOCAL:1++
SIF ABL:LOCAL:21 >= 5
	LOCAL:1++
SIF MARK:LOCAL:2 == 3
	LOCAL:1++
SIF LOCAL:1 == 3
	RETURN 1
RETURN 0

