;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_10(ARG)
LOCAL = GETCHARA(209)
TALENT:LOCAL:330 = 0

