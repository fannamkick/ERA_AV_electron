@NAKADASHI_CHECK
;中出しされた精子量に応じて確率処理

;임신フィルタ部分
SIF FLAG:60 == 1
	RETURN 0
SIF CFLAG:T:33 != 0
	RETURN 0
SIF CFLAG:T:645 != 1
	RETURN 0

;チェックするフラグ設定
F = 101 + P
SIF P == 1
	F = 101
SIF P == 8
	F = 112

;対象が男か미숙함なら関数終了
SIF TALENT:T:122 || TALENT:T:135
	RETURN 0

						;****あなた임신パッチ追加ここから****
						;****追加ここから****(加筆)
;対象が精霊, 幽霊なら関数終了
;素質が消えているのでコメントアウト
;IF (TALENT:T:315 || TALENT:T:316) && (CFLAG:T:109 == 0 || PBAND:303 != 3)
;	CFLAG:T:F = 0
;	RETURN 0
;ENDIF

;対象が가이노이드, サイボーグ, ヒーローなら関数終了
IF (TALENT:T:504 || TALENT:T:505 || TALENT:T:420 || TALENT:T:500 || TALENT:T:501 || TALENT:T:511) && (CFLAG:T:109 == 0 || PBAND:303 != 3)
	CFLAG:T:F = 0
	RETURN 0
ENDIF

;獣姦で対象が동물귀じゃないなら関数終了
IF (P == 5 && TALENT:T:124 == 0) && (CFLAG:T:109 == 0 || PBAND:303 != 3)
	CFLAG:T:F = 0
	RETURN 0
ENDIF
						;****追加ここまで****(加筆)
IF TALENT:T:520 && (CFLAG:T:109 == 0 || PBAND:303 != 3)
	CFLAG:T:F = 0
	RETURN 0
ENDIF
;中だしされてないなら関数終了
SIF CFLAG:T:F == 0
	RETURN 0

;임신が既に確定している場合は関数終了
IF CFLAG:T:110 > 0
	CFLAG:T:F = 0
	RETURN 0
ENDIF

;임신중もしくは육아 중は関数終了
						;****슬라임パッチ追加ここから****
IF TALENT:T:153 || TALENT:T:154 || TALENT:T:157
						;****슬라임パッチ追加ここまで****
	CFLAG:T:F = 0
	RETURN 0
ENDIF

IF CFLAG:T:109 == -1
	CFLAG:T:F = 0
	RETURN 0
ENDIF
						;****あなた임신パッチ追加ここまで****
;排卵剤の有無による定数設定
C = 3 - (CFLAG:T:109 * 2)
SIF C < 0
	C = 1

IF CFLAG:T:F >= 30
	SIF RAND:((1 + TALENT:T:100 * 2) * C) == 0
		CFLAG:T:102 = P
ELSEIF CFLAG:T:F >= 20
	SIF RAND:((2 + TALENT:T:100 * 2) * C) == 0
		CFLAG:T:102 = P
ELSEIF CFLAG:T:F >= 15
	SIF RAND:((3 + TALENT:T:100 * 2) * C) == 0
		CFLAG:T:102 = P
ELSEIF CFLAG:T:F >= 10
	SIF RAND:((4 + TALENT:T:100 * 2) * C) == 0
		CFLAG:T:102 = P
ELSEIF CFLAG:T:F >= 5
	SIF RAND:((5 + TALENT:T:100 * 2) * C) == 0
		CFLAG:T:102 = P
ELSEIF CFLAG:T:F >= 1
	SIF RAND:((6 + TALENT:T:100 * 2) * C) == 0
		CFLAG:T:102 = P
ENDIF

;判定を行った膣射のリセット
CFLAG:T:F = 0

