;親離れ
@DEPEARENT
PRINTFORML %CALLNAME:C%의 육아 중이던 아이가 부모에게서 독립했습니다
PRINTFORML %조사처리(CALLNAME:C,"는")% 다시 지도할 수 있습니다
WAIT
;임신時に減った체력の最大値が回復
MAXBASE:C:0 += 500
TALENT:C:154 = 0
IF TALENT:C:109 == 0 && TALENT:C:116 == 0
	PRINTFORML %NAME:C%의 가슴은 모유를 주는 역할을 끝냈으므로 작아졌습니다
	WAIT
		;모유出なくなる
						;****あなた임신パッチ追加ここから****
	IF TALENT:T:130 == 1 && MARK:T:6 >= 1
		MARK:T:6 = 0
	ELSEIF TALENT:T:130 == 1
						;****あなた임신パッチ追加ここまで****
		PRINTFORML %조사처리(CALLNAME:T,"는")% 모유가 나오지 않게 됐다
		TALENT:T:130 = 0
	ENDIF
	;임신時に大きくなった胸のサイズを一段小さくする
	CALL REVERSE_B_SIZE
ENDIF
CALL CLEAR_FLAG

DRAWLINE

;임신パッチまわりのフラグをリセット
@CLEAR_FLAG
CFLAG:C:101 = 0
CFLAG:C:102 = 0
CFLAG:C:103 = 0
CFLAG:C:104 = 0
CFLAG:C:105 = 0
						;****追加ここから****
CFLAG:C:106 = 0
CFLAG:C:107 = 0
						;****追加ここまで****
CFLAG:C:110 = 0
CFLAG:C:111 = 0
						;****슬라임パッチ追加ここから****
CFLAG:C:112 = 0
						;****슬라임パッチ追加ここまで****


;임신or子育て開始時の胸サイズの膨張処理
@GROW_B_SIZE
;가슴サイズが設定されているキャラは毎日成長なのでスルー
IF BASE:T:22 > 0 && FLAG:38 > 0
ELSE
;乳がワンランクパワーアップする
;絶→貧　貧→普　普→巨　巨→爆　爆→そのまま
	IF TALENT:T:116 == 1
		PRINTFORML %CALLNAME:T%의 가슴이【%TALENTNAME:116%】에서【%TALENTNAME:109%】정도로 커졌다
		TALENT:T:116 = 0
		TALENT:T:109 = 1
	ELSEIF TALENT:T:109 == 1
		PRINTFORML %CALLNAME:T%의 가슴이【%TALENTNAME:109%】에서 평범한 수준으로 커졌다
		TALENT:T:109 = 0
	ELSEIF TALENT:T:110 == 0 && TALENT:T:114 == 0
		PRINTFORML %CALLNAME:T%의 가슴이 평범한 수준에서【%TALENTNAME:110%】사이즈로 커졌다
		TALENT:T:110 = 1
	ELSEIF TALENT:T:110 == 1
		PRINTFORML %CALLNAME:T%의 가슴이【%TALENTNAME:110%】에서【%TALENTNAME:114%】사이즈가 되었다
		TALENT:T:110 = 0
		TALENT:T:114 = 1
						;****あなた임신パッチ追加ここから****
	ELSEIF TALENT:T:114 == 1
		PRINTFORML %CALLNAME:T%의 가슴이【%TALENTNAME:114%】에서 더 커졌다
		MARK:T:5 = 1
						;****あなた임신パッチ追加ここまで****
	ENDIF
ENDIF

;子育て終了or임신強制終了時の胸サイズの縮小処理
@REVERSE_B_SIZE
;가슴サイズが設定されているキャラは3サイズの縮小処理を行う
IF BASE:T:22 > 0 && FLAG:38 > 0
	CALL REVERSE_3_SIZE_IWS
ELSE
;爆→巨　巨→普　普→貧　貧・絶→そのまま
						;****あなた임신パッチ追加ここから****
	IF TALENT:C:114 && MARK:C:5 >= 1
		MARK:C:5 = 0
	ELSEIF TALENT:C:114
						;****あなた임신パッチ追加ここまで****
		TALENT:C:114 = 0
		TALENT:C:110 = 1
	ELSEIF TALENT:C:110
		TALENT:C:110 = 0
	ELSEIF TALENT:C:109 == 0 && TALENT:C:116 == 0
		TALENT:C:109 = 1
	ENDIF
ENDIF

;육아室にいるかの判定
@CHECK_CHILD_CARE
SIF (TALENT:C:153 && CFLAG:C:110 - 3 <= DAY) || (TALENT:C:154 && CFLAG:C:110 + 30 > DAY)
	RETURN 1

RETURN 0
