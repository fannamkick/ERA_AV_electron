;===========================================================
;붕괴の取得
;===========================================================
@ADD_CATASTROPH

FOR LOCAL, 0, 600
	SIF LOCAL == 0 || LOCAL == 1 ||  LOCAL == 2 ||  LOCAL == 121 || LOCAL == 122 || LOCAL == 130 || LOCAL == 153 || LOCAL == 154 || LOCAL == 422 || LOCAL == 424
		CONTINUE
	TALENT:LOCAL = 0
NEXT
	TALENT:9 = 1
	TALENT:101 = 1
	TALENT:103 = 1
	TALENT:105 = 1
	TALENT:107 = 1
	MAXBASE:31 = 10
	SIF BASE:31 >= MAXBASE:31
		BASE:31 = MAXBASE:31
	MAXBASE:0 -= 1500
	SIF MAXBASE:0 < 800
		MAXBASE:0 = 800 
	BASE:0 = MAXBASE:0
	MAXBASE:1 -= 1000
	SIF MAXBASE:1 < 400
		MAXBASE:1 = 400
	BASE:1 = MAXBASE:1

