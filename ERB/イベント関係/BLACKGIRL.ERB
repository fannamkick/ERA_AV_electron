;===========================================================
;흑갸루絡みのイベント
;===========================================================
@BLACKGIRL_EVENT
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF TALENT:LOCAL:153 == 1
		CONTINUE
	ELSEIF TALENT:LOCAL:154 == 1
		CONTINUE
	ELSEIF (TALENT:COUNT:422 == 1 && TALENT:COUNT:432 == 1 && TALENT:COUNT:430 == 0) || (TALENT:COUNT:422 == 1 && TALENT:COUNT:432 == 1 && TALENT:COUNT:430 == 1 && FLAG:545 == 1)
		CALL START_BGEVENT
	ENDIF
REND

;===========================================================
;イベント開始
;===========================================================
@START_BGEVENT
IF RAND:8 == 0
	CALL NOTHING
ELSEIF RAND:7 == 0
	CALL NOTHING
ELSEIF RAND:6 == 0
	CALL NOTHING
ELSEIF RAND:5 == 0
	CALL EVENT_BGGUIDANCE
ELSEIF RAND:4 == 0
	CFLAG:COUNT:692 = 0
	CALL EVENT_BGSEX
ELSEIF RAND:3 == 0
	CALL EVENT_BGTATTO
ELSEIF RAND:2 == 0 && FLAG:540 == 0
	CFLAG:COUNT:692 = 0
	CALL EVENT_BGSEX
ELSEIF RAND:1 == 0
	CALL EVENT_BGGUIDANCE
ELSE
	CALL NOTHING
ENDIF

