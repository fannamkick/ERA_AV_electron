	PRINTFORMW 한가롭게 사무소 뒷정리를 하고있던 중, %CALLNAME:MASTER%의 휴대폰에 한통의 전화가 걸려왔다……
	PRINTFORM 전화를 건 사람은 경찰로, %조사처리(NAME:COUNT,"가")% 
		IF RAND:2 == 0
			PRINTFORML 한밤중에 패밀리 레스토랑에서 흡연하고 있어서 데려왔다고 한다
			PRINTFORMW %플레이어는()% 한숨을 쉬고, %조사처리(CALLNAME:COUNT,"를")% 경찰서까지 마중 나가기로 했다……
			IF TALENT:COUNT:424 == 0
				TALENT:COUNT:424 = 1
				CALL CIGARETTES_4COUNT
			ENDIF
		ELSE
			PRINTFORML 한밤중에 노래방에서 술을 마시고 있어서 데려왔다고한다
			PRINTFORML %플레이어는()% 한숨을 쉬고, %조사처리(CALLNAME:COUNT,"를")% 경찰서까지 마중 나가기로 했다……
		ENDIF
	PRINTL
	PRINTFORML 훈계경험 +1
	PRINTW
	EXP:COUNT:92 += 1
	PRINTW ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
ENDIF


;===========================================================
;갈색피부消失の処理
;===========================================================
@SUNBURN_AFTER

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF TALENT:COUNT:432 == 1
		CONTINUE
	ELSEIF TALENT:COUNT:505 == 1 && TALENT:COUNT:511 == 1
		CONTINUE
	ELSEIF NO:COUNT == 200
		CONTINUE
	ELSEIF TALENT:COUNT:422 == 1
		CFLAG:COUNT:614 -= 1
		IF CFLAG:COUNT:614 <= 0
			PRINTFORML 《%조사처리(NAME:COUNT,"는")% 태닝살롱의 효과가 끊겨 원래 살색으로 돌아왔다》
			TALENT:COUNT:422 = 0
		ENDIF
	ENDIF
REND
