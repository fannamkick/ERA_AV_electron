SIF ABL:22 < 2 || ABL:0 < 3 || ABL:10 < 2 || ABL:11 < 2
	RETURN 0
;調教キャラか助手に레즈중독必要
SIF ABL:33 == 0 && ABL:ASSI:33 == 0
