SIF TALENT:ASSI:81
	N += 2
SIF TALENT:76
	N += 1
SIF TALENT:ASSI:76
	N += 1

;쾌감에 솔직, 쾌감을 부정
IF TALENT:70
	N += 1
ELSEIF TALENT:71
	N -= 2
ENDIF
IF TALENT:ASSI:70
	N += 1
ELSEIF TALENT:ASSI:71
	N -= 2
ENDIF

;回数が0以下になっていたら終了
SIF N <= 0
	RETURN 0

