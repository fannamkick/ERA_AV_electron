SIF ABL:11 >= 4 && ABL:17 >= 3 && PALAM:5 >= PALAMLV:4
	A += 1

;回数が0以下なら終了
SIF A <= 0
	RETURN 0

;자위광によるボーナス
SIF TALENT:74
	TIMES A , 1.50

;助手が鼓舞
IF ASSI >= 0
	SIF TALENT:ASSI:118
		TIMES A , 1.20
ENDIF

;프라이드 낮음, 해방によるボーナス
SIF TALENT:17
	A += 1
SIF TALENT:33
	A += 1

;프라이드 높음, 자제심, 억압によるペナルティ
SIF TALENT:15
	A -= 1
SIF TALENT:20
	A -= 1
SIF TALENT:32
	A -= 1

;쾌감에 솔직, 쾌감을 부정
IF TALENT:70
	A += 1
ELSEIF TALENT:71
	A -= 2
ENDIF

;음란によるボーナス
SIF TALENT:76
	A += 1

;回数が0以下になっていたら終了
SIF A <= 0
	RETURN 0

DRAWLINE
PRINTFORM %타겟은()% 
IF N == 1
	PRINTFORM %조수가()% 나간 뒤에, 
ELSEIF S == 1
	PRINTFORM %플레이어가()% 나간 뒤에, 
ELSE
	PRINT 지도 종료 후에, 
ENDIF

;調教後자위の妄想の相手
;연심がなくかつ助手とのレズセックス後なら레즈끼×20%で助手
IF TALENT:85 == 0 && N == 1 && ABL:22 > RAND:5
	PRINTFORML %조수를()% 생각하면서 {A}번 자위를 한 것 같다.
	Q = 1
;上に該当せずかつ愛がなく아이템に들개があれば, 수간중독×20%で들개
ELSEIF TALENT:85 == 0 && ABL:40 > RAND:5 && ITEM:22
	PRINTFORML 들개와의 교미를 망상하면서 {A}번 자위를 한 것 같다.
	Q = 2
;それ以外なら主人
ELSE
	PRINTFORML %플레이어를()% 생각하면서 {A}번 자위를 한 것 같다.
	Q = 0
ENDIF

;調教後자위口上
TFLAG:13 = 1
CALL SELF_KOJO

;자위경험
PRINTFORML %EXPNAME:10% +{A}
EXP:10 += A

;珠経験
PRINTFORML %PALAMNAME:0%의 구슬 +{A*500}
PRINTFORML %PALAMNAME:4%의 구슬 +{A*100}
PRINTFORMW %PALAMNAME:5%의 구슬 +{A*250}
JUEL:0 += A*500
JUEL:4 += A*100
JUEL:5 += A*250
	
;従順+露出+마조끼が10以上かつ時間が朝なら主人に報告
IF ABL:10+ABL:17+ABL:21 >= 10 && TIME == 0
	PRINTFORML 그 일을 %타겟은(1)% 보고해왔다.
	PRINTFORML %PALAMNAME:8%의 구슬 +{A*200}
	JUEL:8 += A*200
ENDIF
	
IF (ABL:10 >= 5 || ABL:11 >= 5) && Q == 0
	PRINTFORMW 그러나 몇 번이고 자신을 위로해봐도, %플레이어를()% 향한 욕망은 채워지지 않았다.
ELSEIF (ABL:11 >= 5 || ABL:33 >= 3) && Q == 1
	PRINTFORMW 그러나 몇 번이고 자신을 위로해봐도, %조수를()% 향한 욕망은 채워지지 않았다.
ELSEIF (ABL:11 >= 5 || ABL:40 >= 3) && Q == 2
	PRINTFORMW 그러나 몇 번이고 자신을 위로해봐도, 수간을 향한 욕망은 채워지지 않았다.
ENDIF

RETURN 1

