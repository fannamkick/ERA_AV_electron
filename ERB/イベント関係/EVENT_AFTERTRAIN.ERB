	N += 1
ELSEIF ABL:33 == 2
	N += 2
ELSEIF ABL:33 == 3
	N += 3
ELSEIF ABL:33 == 4
	N += 5
ELSEIF ABL:33 == 5
	N += 7
ELSEIF ABL:33 >= 6
	N += 9
ENDIF

;助手の레즈중독
IF ABL:ASSI:33 == 1
	N += 1
ELSEIF ABL:ASSI:33 == 2
	N += 2
ELSEIF ABL:ASSI:33 == 3
	N += 5
ELSEIF ABL:ASSI:33 == 4
	N += 8
ELSEIF ABL:ASSI:33 == 5
	N += 13
ELSEIF ABL:ASSI:33 >= 6
	N += 18
ENDIF

;回数が0以下なら終了
SIF N <= 0
	RETURN 0

;레즈끼によるボーナス
SIF ABL:22 >= 5 && PALAM:5 >= PALAMLV:3
	N += 1

;助手の레즈끼によるボーナス
SIF ABL:ASSI:22 >= 3 && PALAM:5 >= PALAMLV:3
	N += 1

;PALAM:욕정がLV3以上
