;욕망LV4以上で+1
SIF ABL:11 >= 4 && ABL:2 >= 3 && PALAM:5 >= PALAMLV:3
	N += 1

;相性によるボーナス
R = NO:ASSI
	IF RELATION:R > 0
	N *= RELATION:R
	N /= 100
ENDIF

