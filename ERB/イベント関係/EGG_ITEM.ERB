;消費아이템入手判定
@EGG_ITEM_USE
SELECTCASE RAND:2
CASE 0
	IF ITEM:24 >= 99
		PRINTFORML %조사처리(ITEMNAME:24,"가")% 들어있었다
		ITEM:24 += 1
	ELSE
		PRINTFORML 작은 보석이 들어있었다
		MONEY += 500
	ENDIF
CASEELSE
	PRINTFORML 작은 보석이 들어있었다
	MONEY += 500
ENDSELECT