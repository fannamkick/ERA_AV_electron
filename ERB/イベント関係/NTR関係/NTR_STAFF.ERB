;=================================================
;スタッフ寝取られ・準備
;=================================================
@NTR_STAFF_BEGIN
#DIM DYNAMIC C_NUM
#DIM DYNAMIC DANGER_VALUE

FOR C_NUM, 1, CHARANUM
	;남성불신
	SIF TALENT:C_NUM:82
		CONTINUE
	;オトコ
	SIF TALENT:C_NUM:122
		CONTINUE
	;임신
	SIF TALENT:C_NUM:153
		CONTINUE
	;육아 중
	SIF TALENT:C_NUM:154
		CONTINUE
	;남친있음
	SIF TALENT:C_NUM:184
		CONTINUE
	;영원한 사랑
	SIF TALENT:C_NUM:430
		CONTINUE
	;야쿠자의 딸
	SIF TALENT:C_NUM:502
		CONTINUE
	;안드로이드
	SIF TALENT:C_NUM:504
		CONTINUE
	;음마
	SIF TALENT:C_NUM:505
		CONTINUE
	;천사
	SIF TALENT:C_NUM:511
		CONTINUE
	;야쿠자의 아내
	SIF TALENT:C_NUM:516
		CONTINUE
	;탐정
	SIF TALENT:C_NUM:517
		CONTINUE
	;Triptych 어째서?
	SIF TALENT:C_NUM:519
		CONTINUE
	;유령
	SIF TALENT:C_NUM:521
		CONTINUE
	;ONLY ONE EMPRESS
	SIF TALENT:C_NUM:553
		CONTINUE
	;이미 진행중
	SIF CFLAG:C_NUM:661 >= 1
		CONTINUE
	;호위
	SIF CFLAG:C_NUM:633
		CONTINUE
	;기숙사에 들어간 상태, 경찰관
	SIF CFLAG:C_NUM:140 && (FLAG:101 & 128)
		CONTINUE
	;정조대
	SIF CFLAG:C_NUM:40 >= 64 && CFLAG:C_NUM:42 == 79
		CONTINUE
	;리나의 동향 조사
	SIF CFLAG:MASTER:694 == 1
		CONTINUE
	SIF DAY <= 1
		CONTINUE
	;초기치는 0~99에서 랜덤수치
	DANGER_VALUE += RAND:100
	;쉬운 여자/남자
	SIF TALENT:C_NUM:416
		DANGER_VALUE += 20
	;보수적
	SIF TALENT:C_NUM:24
		DANGER_VALUE -= 5
	;일선을 넘지않음
	SIF TALENT:C_NUM:27
		DANGER_VALUE -= 5
	;정조관념
	SIF TALENT:C_NUM:30
		DANGER_VALUE -= 5
	;연심
	SIF TALENT:C_NUM:85
		DANGER_VALUE -= 10
	;망신
	SIF TALENT:C_NUM:86
		DANGER_VALUE -= 10
	;신앙심
	SIF TALENT:C_NUM:428
		DANGER_VALUE -= 5
	;Colorful Pure Girls
	SIF TALENT:C_NUM:509
		DANGER_VALUE -= 10
	;정조무관심
	SIF TALENT:C_NUM:31
		DANGER_VALUE += 5
	;즉각함락
	SIF TALENT:C_NUM:73
		DANGER_VALUE += 50
	;음란
	SIF TALENT:C_NUM:76 && TALENT:C_NUM:85 == 0
		DANGER_VALUE += 15
	;유리멘탈
	SIF TALENT:C_NUM:134
		DANGER_VALUE += 5
	;갸루계
	SIF TALENT:C_NUM:432
		DANGER_VALUE += 10
	;밀어붙이는 데에 약하다
	SIF TALENT:C_NUM:601
		DANGER_VALUE += 20
	;카나데 보정
	SIF NO:C_NUM == 1 || NO:C_NUM == 91
		DANGER_VALUE += 10
	IF DANGER_VALUE >= 95
		;진행 완만하게。
		CFLAG:C_NUM:660 += 1
		IF CFLAG:C_NUM:660 >= 5
			CFLAG:C_NUM:661 = 1
			CFLAG:C_NUM:619 = 0
			CFLAG:C_NUM:621 = 1
			CALL DECIDE_BOYFRIEND, C_NUM
		ENDIF
	ENDIF
	DANGER_VALUE = 0
NEXT
	
;=================================================
;スタッフ寝取られ・ベース
;=================================================
@BASE_NTR_STAFF
#DIM DYNAMIC C_NUM

FOR C_NUM, 1, CHARANUM
	;정조대
	SIF CFLAG:C_NUM:40 >= 64 && CFLAG:C_NUM:42 == 79
		CONTINUE
	;호위
	SIF CFLAG:C_NUM:633
		CONTINUE
	;で, 대상이라면
	IF CFLAG:C_NUM:661 == 1
		CALL EXP_NTR_STAFF
		EXP:C_NUM:108 += 1
	ENDIF
NEXT

;=================================================
;스테프 네토라레・진행 호출
;ARG-캐릭번호
;=================================================
@EXP_NTR_STAFF, ARG
#DIM DYNAMIC C_NUM

;캐릭번호 대입
C_NUM = ARG

IF EXP:C_NUM:108 == 0
	;첫 키스 이벤트
	CALL FIRSTKISS_NTR_STAFF, C_NUM
ELSEIF EXP:C_NUM:108 == 1 && TALENT:C_NUM:0 == 1 && CFLAG:C_NUM:15 == 0
	;처녀상실 이벤트
	CALL LOSTVIRGIN_NTR_STAFF, C_NUM
ELSEIF EXP:C_NUM:108 == 5
	;옷이 바뀐걸 아나타가 보고 이상하게 생각함
	CALL CHANGECLOTH_NTR_STAFF, C_NUM
ELSEIF EXP:C_NUM:108 == 10
	;스태프 네토라레 말로
	CALL NTR_STAFF_LAST
	PRINTW ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
ELSE
	;스태프 네토라레 섹스
	CALL SEX_NTR_STAFF, C_NUM
ENDIF

;=================================================
;스테프 네토라레・첫 키스
;ARG-캐릭번호
;=================================================
@FIRSTKISS_NTR_STAFF, ARG
#DIM DYNAMIC C_NUM

;캐릭번호 대입
C_NUM = ARG

IF CFLAG:C_NUM:16 == -1
	CFLAG:C_NUM:16 = 10
	CSTR:C_NUM:1 = ???
;	CALL DECIDE_BOYFRIEND
	BASE:C_NUM:31 -= 5
	CFLAG:C_NUM:820 = BASE:C_NUM:9
	CFLAG:C_NUM:821 = DAY:1
	CFLAG:C_NUM:822 = DAY:2
ENDIF

;=================================================
;스테프 네토라레・처녀상실
;ARG-캐릭번호
;=================================================
@LOSTVIRGIN_NTR_STAFF, ARG
#DIM DYNAMIC C_NUM
#DIM DYNAMIC V_EXP_VALUE
#DIM DYNAMIC SEMEN_EXP_VALUE
#DIM DYNAMIC IKU_EXP_VALUE

;캐릭번호 대입
C_NUM = ARG

;각 경험 초기치
V_EXP_VALUE = 1
SEMEN_EXP_VALUE = 1
IKU_EXP_VALUE = 1

;각 경험 추가치 가산
;V경험
V_EXP_VALUE += RAND:3
;정액경험
SEMEN_EXP_VALUE += RAND:3
;절정경험
IKU_EXP_VALUE += RAND:2

CFLAG:COUNT:160 = BASE:COUNT:9
CFLAG:COUNT:161 = DAY:1
CFLAG:COUNT:162 = DAY:2
CFLAG:COUNT:163 = 3
CFLAG:COUNT:164 = 3

TALENT:COUNT:0 = 0
CFLAG:COUNT:15 = 10
CSTR:COUNT:0 = ???
EXP:COUNT:0 += V_EXP_VALUE
EXP:COUNT:2 += IKU_EXP_VALUE
EXP:COUNT:5 += V_EXP_VALUE
EXP:COUNT:20 += SEMEN_EXP_VALUE
JUEL:COUNT:1 += 100 * V_EXP_VALUE
JUEL:COUNT:5 += 300 * IKU_EXP_VALUE
JUEL:COUNT:4 -= 200 * (V_EXP_VALUE + IKU_EXP_VALUE)
IF JUEL:COUNT:4 < 0
	ABL:COUNT:10 -= 1
	JUEL:COUNT:4 = 0
	IF ABL:COUNT:10 < 1
		ABL:COUNT:10 = 0
		BASE:COUNT:31 -= 10
	ENDIF
ENDIF
;IF CFLAG:16 != 10
;	CALL DECIDE_BOYFRIEND
;ENDIF

;=================================================
