@COMPA_START

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF CFLAG:COUNT:613 == 1 && CFLAG:COUNT:621 != 1 && TALENT:COUNT:184 == 0
		CALL COMPA_MAIN
	ENDIF
REND

