;元の関数は呼び出し元として残す

@DECIDE_BOYFRIEND, ARG
CALL DECIDE_BOY_NAME, ARG, 0

@DECIDE_SEXFRIEND, ARG
CALL DECIDE_BOY_NAME, ARG, 1


;===========================================================
;이름 랜덤결정。
;ARG=캐릭번호, ARG:1=모드(0이라면 BF, 1이라면 SF)
;===========================================================
@DECIDE_BOY_NAME, ARG, ARG:1
#DIM DYNAMIC LNAMENO, 1
#DIM DYNAMIC FNAMENO, 1


SELECTCASE ARG:1
	CASE 0
		LNAMENO = 7
		FNAMENO = 8
	CASE 1
		LNAMENO = 47
		FNAMENO = 48
ENDSELECT

