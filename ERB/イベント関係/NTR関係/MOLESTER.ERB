;===========================================================
;痴漢発生の処理
;===========================================================
@EVENT_MOLESTER

SIF FLAG:301 == 0
	RETURN 1

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
						;****痴漢誘惑追加ここから****
	ELSEIF NO:COUNT == 1 && NO:MASTER == 0 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF NO:COUNT == 2 && NO:MASTER == 0 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF NO:COUNT == 11 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:122 == 1
		CONTINUE
	ELSEIF CFLAG:COUNT:140 == 1
		CONTINUE
	ELSEIF TALENT:COUNT:502 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:503 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:504 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:505 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:429 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:511 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:516 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:517 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:519 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:521 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF TALENT:COUNT:553 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF CFLAG:COUNT:633 == 1 && CFLAG:COUNT:690 == 0
		CONTINUE
	ELSEIF CFLAG:COUNT:40 >= 64 && CFLAG:COUNT:42 == 79
		CONTINUE
						;****痴漢誘惑追加ここまで****
	ELSE
		LOCAL += RAND:100
			IF TALENT:COUNT:10 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:14 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:33 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:35 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:73 == 1
				LOCAL += 50
			ENDIF
			IF TALENT:COUNT:76 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:113 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:134 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:426 == 1
				LOCAL += RAND:10
			ENDIF
			IF TALENT:COUNT:11 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:12 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:16 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:30 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:34 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:36 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:79 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:82 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:93 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:127 == 1
				LOCAL -= RAND:10
			ENDIF
			IF TALENT:COUNT:184 == 1
				LOCAL -= 50
			ENDIF
			IF TALENT:COUNT:204 == 1
				LOCAL -= RAND:10
			ENDIF
						;****痴漢誘惑追加ここから****
			IF CFLAG:COUNT:690 == 1
				LOCAL += 50
			ENDIF
						;****痴漢誘惑追加ここまで****
			SIF FLAG:301 == 1
				LOCAL += 10
			SIF FLAG:301 == 2
				LOCAL += 20
			SIF FLAG:301 == 3
				LOCAL += 30
		IF LOCAL >= 90
			CALL MOLESTER_BRUNCH
			LOCAL = 0
		ELSE
			LOCAL = 0
		ENDIF
	ENDIF
REND