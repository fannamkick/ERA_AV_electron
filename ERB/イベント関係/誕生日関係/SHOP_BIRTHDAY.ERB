;誕生日イベント
;===========================================================
@EVENT_BIRTHDAY

SIF ABL:10 < 3
	RETURN

PRINTFORML %플레이어는()% 생일을 맞이한 %타겟을()% 축하해 주기로 했다……
PRINTFORML 《%타겟을()% 어떻게 축하해 줍니까?》

PRINTL [0] - 생일선물을 준다
;IF TALENT:85 == 1
;	PRINTL [1] - 데이트에 데려간다
;	PRINTL [2] - 아무것도 안한다
;ELSE
	PRINTL [1] - 아무것도 안한다
;ENDIF
$INPUT_LOOP
INPUT

IF RESULT == 0
	CALL BIRTHDAY_PRESENT
;ELSEIF RESULT == 1 && TALENT:85
;	CALL BIRTHDAY_DATE
ELSEIF RESULT == 1
	PRINTFORMW 《%CALLNAME:TARGET%의 생일을 축하해 주지 않습니다》
	IF TALENT:85
		PRINTFORML 생일축하를 못 받은 %타겟은()% 삐졌다……
		PRINTL
		PRINTFORMW 《%ABLNAME:10%: Lv{ABL:10}　→　Lv{(ABL:10 - 1)}》
		ABL:10 -= 1
	ENDIF
ELSEIF RESULT == 2 && TALENT:85
	PRINTFORMW 《%CALLNAME:TARGET%의 생일을 축하해 주지 않습니다》
	IF TALENT:85
		PRINTFORML 생일축하를 못 받은 %타겟은()% 삐졌다……
		PRINTL
		PRINTFORMW 《%ABLNAME:10%: Lv{ABL:10}　→　Lv{(ABL:10 - 1)}》
		ABL:10 -= 1
	ENDIF
ELSE
	GOTO INPUT_LOOP
ENDIF

RETURN

