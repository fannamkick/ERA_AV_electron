;誕生日イベント
;===========================================================
@BIRTHDAY_PRESENT

VARSET LOCAL, 0
PRINTFORML 《%CALLNAME:TARGET%에게 어떤 선물을 줍니까?》

PRINTL [0] - 화장품　　　　　　　　　(가격: 1000포인트)
PRINTL [1] - 운동기구　　　       　(가격: 5000포인트)
PRINTL [2] - 아로마 캔들 세트     　(가격:  500포인트)
PRINTL [3] - 수제요리              (가격:    0포인트)
$INPUT_LOOP
INPUT

IF RESULT == 0
	PRINTFORML %플레이어는()% %CALLNAME:TARGET%에게 화장품을 선물했다……
	IF CFLAG:760 != 1 || TALENT:430 == 1
		LOCAL = 5
		LOCAL += RAND:6
		SIF TALENT:326
			LOCAL *= 2
		SIF (BASE:31 + LOCAL) >= MAXBASE:31
			LOCAL = MAXBASE:31 - BASE:31
		LOCAL:1 = 1 + RAND:5
		LOCAL:1 *= 10
		PRINTFORML %타겟은()% 선물이 마음에 들었는지 기뻐하고 있다
		PRINTL
		IF BASE:31 < MAXBASE:31
			PRINTFORML 《%CALLNAME:TARGET%의 매력치가 {LOCAL} 회복했다》
			BASE:31 += LOCAL
		ENDIF
		IF TALENT:85 == 0

			PRINTFORML 호감도 +{LOCAL:1}
			CFLAG:2 += (LOCAL:1 * 10)
		ELSE
			PRINTFORML 애정경험 +{LOCAL:1}
			EXP:23 += LOCAL:1
		ENDIF
		WAIT
	ELSE
		LOCAL = 1
		LOCAL += RAND:4
		SIF (BASE:31 + LOCAL) >= MAXBASE:31
			LOCAL = MAXBASE:31 - BASE:31
		LOCAL:1 = 1 + RAND:5
		LOCAL:1 *= 5
		PRINTFORML %타겟은()% 얼굴에 드러내지는 않지만, 작년과 같은 선물인 게 불만인 것 같다……
		PRINTL
		IF BASE:31 < MAXBASE:31
			PRINTFORML 《%CALLNAME:TARGET%의 매력치가 {LOCAL} 회복했다》
			BASE:31 += LOCAL
		ENDIF
		IF TALENT:85 == 0

			PRINTFORML 호감도 +{LOCAL:1}
			CFLAG:2 += (LOCAL:1 * 10)
		ELSE
			PRINTFORML 애정경험 +{LOCAL:1}
			EXP:23 += LOCAL:1
		ENDIF
		WAIT
	ENDIF
	CFLAG:760 = 1
	MONEY -= 1000
ELSEIF RESULT == 1
	PRINTFORML %플레이어는()% %CALLNAME:TARGET%에게 운동기구를 선물했다……
	IF CFLAG:760 != 2 || TALENT:430 == 1
		LOCAL = 100
		LOCAL *= RAND:3
		SIF LOCAL == 0
			LOCAL = 100
		SIF TALENT:518
			LOCAL += 100
		LOCAL:1 = 1 + RAND:5
		LOCAL:1 *= 10
		PRINTFORML %타겟은()% 선물이 마음에 들었는지 기뻐하고 있다
		PRINTL
		PRINTFORML 《%CALLNAME:TARGET%의 최대 체력이 {LOCAL} 증가했다》
		MAXBASE:0 += LOCAL
		IF TALENT:85 == 0
			PRINTFORML 호감도 +{LOCAL:1}
			CFLAG:2 += (LOCAL:1 * 10)
		ELSE
			PRINTFORML 애정경험 +{LOCAL:1}
			EXP:23 += LOCAL:1
		ENDIF
		WAIT
	ELSE
		LOCAL = 100
		SIF TALENT:518
			LOCAL += 100
		LOCAL:1 = 1 + RAND:5
		LOCAL:1 *= 10
		PRINTFORML %타겟은()% 얼굴에 드러내지는 않지만, 작년과 같은 선물인 게 불만인 것 같다……
		PRINTL
		PRINTFORML 《%CALLNAME:TARGET%의 최대 체력이 {LOCAL} 증가했다》
		MAXBASE:0 += LOCAL
		IF TALENT:85 == 0
			PRINTFORML 호감도 +{LOCAL:1}
			CFLAG:2 += (LOCAL:1 * 10)
		ELSE
			PRINTFORML 애정경험 +{LOCAL:1}
			EXP:23 += LOCAL:1
		ENDIF
		WAIT
	ENDIF
	CFLAG:760 = 2
	MONEY -= 5000
ELSEIF RESULT == 2
	PRINTFORML %플레이어는()% %CALLNAME:TARGET%에게 아로마 캔들 세트를 선물했다……
	IF CFLAG:760 != 3 || TALENT:430 == 1
		LOCAL = 100
		LOCAL *= RAND:3
		SIF LOCAL == 0
			LOCAL = 100
		LOCAL:1 = 1 + RAND:5
		LOCAL:1 *= 10
		PRINTFORML %타겟은()% 선물이 마음에 들었는지 기뻐하고 있다
		PRINTL
		PRINTFORML 《%CALLNAME:TARGET%의 최대 기력이 {LOCAL} 증가했다》
		MAXBASE:1 += LOCAL
		IF TALENT:85 == 0
			PRINTFORML 호감도 +{LOCAL:1}
			CFLAG:2 += (LOCAL:1 * 10)
		ELSE
			PRINTFORML 애정경험 +{LOCAL:1}
			EXP:23 += LOCAL:1
		ENDIF
		WAIT
	ELSE
		LOCAL = 100
		SIF TALENT:518
			LOCAL += 100
		LOCAL:1 = 1 + RAND:5
		LOCAL:1 *= 10
		PRINTFORML %타겟은()% 얼굴에 드러내지는 않지만, 작년과 같은 선물인 게 불만인 것 같다……
		PRINTL
		PRINTFORML 《%CALLNAME:TARGET%의 최대 기력이 {LOCAL} 증가했다》
		MAXBASE:0 += LOCAL
		IF TALENT:85 == 0
			PRINTFORML 호감도 +{LOCAL:1}
			CFLAG:2 += (LOCAL:1 * 10)
		ELSE
			PRINTFORML 애정경험 +{LOCAL:1}
			EXP:23 += LOCAL:1
		ENDIF
		WAIT
	ENDIF
	CFLAG:760 = 3
	MONEY -= 500
ELSEIF RESULT == 3
	PRINTFORML %플레이어는()% %CALLNAME:TARGET%에게 직접 요리를 만들어 줬다……
	LOCAL:1 = 1 + RAND:5
	LOCAL:1 *= 10
	PRINTFORML %타겟은()% 선물이 마음에 들었는지 기뻐하고 있다
	PRINTL
	IF TALENT:85 == 0
		PRINTFORML 호감도 +{LOCAL:1}
		CFLAG:2 += (LOCAL:1 * 10)
	ELSE
		PRINTFORML 애정경험 +{LOCAL:1}
		EXP:23 += LOCAL:1
	ENDIF
	WAIT
ELSE
	GOTO INPUT_LOOP
ENDIF

RETURN

