			ELSEIF CFLAG:16 == 4 && TALENT:76 == 1
				CSTR:1 = 모르는 아저씨의 %CSTR:80%
			ENDIF
		CFLAG:820 = BASE:9
		CFLAG:821 = DAY:1
		CFLAG:822 = DAY:2
		CFLAG:823 = 7
		CFLAG:824 = 1
