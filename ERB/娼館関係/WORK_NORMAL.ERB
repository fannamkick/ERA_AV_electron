;===========================================================
;회화영업
;===========================================================
@WORK_1ST

CALL WORK_PERSON_A

;客の욕망(0~2)をチェック
;キャラの욕망が客の욕망を上回れば욕망の二倍, 下回れば等倍を客の満足度に加算
A = RAND:3
IF A <= ABL:11
	D += ABL:11 * 2
ELSE
	D += ABL:11
ENDIF

;봉사정신と노출벽は等倍加算
D += ABL:16
D += ABL:17

E = 0

;従順が2以下なら満足度は半減
IF ABL:10 <= 2
	D /= 2
ENDIF

;화술が2以下なら満足度は半減
IF ABL:15 <= 2
	D /= 2
ENDIF

;普通の会話
IF RAND:2 == 0
	SIF (FLAG:6 & 2) == 0
		PRINTFORML %타겟은()% 고객과 술을 마시면서, 가벼운 잡담을 했다
	TFLAG:13 = 100
	;욕망と봉사정신は等倍, 기교は二倍を加算。화술が기교を上回っていた場合, 代わりに화술の三倍を加算
	B += ABL:11
	B += ABL:16
	IF ABL:12 > ABL:15
		B += ABL:12 * 2
	ELSE
		B += ABL:15 * 3
	ENDIF

	D += B

	CALL WORK_HAPPY

	IF (FLAG:6 & 2) == 0
		IF A >= 2
			PRINTFORML %타겟과()% 즐겁게 대화를 나눠 고객은 만족한 것 같다
		ELSEIF A <= 1
			PRINTL 고객과의 대화는 시들해져, 만족시킬 수는 없었던 것 같다
		ENDIF
	ENDIF

;紳士な会話
ELSE
	SIF (FLAG:6 & 2) == 0
		PRINTFORML %타겟은()% 고객과 술을 마시면서, 음담패설이 들어간 잡담을 했다
	TFLAG:13 = 101
	;従順と기교は等倍, 노출벽はニ倍を加算。화술が기교を上回っていた場合, 代わりに화술の三倍を加算
	B += ABL:10
	B += ABL:17 * 2
	IF ABL:12 > ABL:15
		B += ABL:12
	ELSE
		B += ABL:15 * 3
	ENDIF
	;해방か부끄럼 없음があればボーナス+2
	SIF TALENT:33 || TALENT:36
		B += 2

	D += B
	
	CALL WORK_HAPPY

	IF (FLAG:6 & 2) == 0
		IF A >= 2
			PRINTFORML %CALLNAME:TARGET%의 도발적인 말과 매력적인 거동에, 고객은 만족한 것 같다
		ELSEIF A <= 1
			PRINTL 오히려 분위기가 어색해져, 고객을 만족시킬 수 없었던 것 같다
		ENDIF
	ENDIF
ENDIF

SIF (FLAG:6 & 2)
	PRINT 회화영업

;獲得額補正
T:91 = 1

;체력減少量補正
F = 1

