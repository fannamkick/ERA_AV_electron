		IF TALENT:85 == 0
			TALENT:184 = 1
			CFLAG:621 = 1
			CFLAG:622 += RAND:6
		ENDIF
ENDIF

;---------------------------------------------------------
;獲得額の計算
;---------------------------------------------------------
;計算式は次の通り
;「キャラの元値」×「買った人数」×「プレイ内容補正」×「満足度補正」
;---------------------------------------------------------
@WORK_MONEY

;キャラの元値
CALL WORK_MONEYD

;買った人数
B *= G

;콘돔の代金を引く
B -= CFLAG:13 * G * 200

;マイナスになる事はない
SIF B < 0
	B = 0

;회화영업の場合, 客が多く来るので帳尻あわせを
SIF CFLAG:12 == 1
	TIMES B , 0.75

;プレイ内容補正
B *= T:91

;娼婦だとちょっと増える
SIF TALENT:180
	TIMES B , 1.10
;傾城だと結構増える
SIF TALENT:181
	TIMES B , 1.30

;人気が高いと高さに応じて増える
IF EXP:91 >= 100
	TIMES B , 1.30
ELSEIF EXP:91 >= 80
	TIMES B , 1.20
ELSEIF EXP:91 >= 60
	TIMES B , 1.10
ENDIF

;満足度補正
IF A == 0
	SIF (FLAG:6 & 2) == 0
		PRINTFORML 불친절한 서비스 때문에 대량의 클레임이 들어와 일부 요금을 환불해야했습니다.
	TIMES B , 0.50
ELSEIF A == 1
	TIMES B , 1.00
ELSEIF A == 2
	TIMES B , 1.00
ELSEIF A == 3
	TIMES B , 1.20
ELSEIF A == 4
	TIMES B , 1.30
ENDIF



IF (FLAG:6 & 2) == 0
	IF CFLAG:12 == 6
		PRINTFORML 돌아갈 때 손님에게 오늘분의 요금을 받았습니다
	ELSE
		PRINTFORML 오늘은 {G}명의 고객이 방문했습니다
	ENDIF
	PRINTFORML %타겟은()% 영업으로 {B}포인트를 벌었습니다
ELSE
	IF A == 0
		PRINT 대실패: 
	ELSEIF A == 1
		PRINT 실패: 
	ELSEIF A == 2
		PRINT 보통: 
	ELSEIF A == 3
		PRINT 성공: 
	ELSEIF A == 4
		PRINT 대성공: 
	ENDIF
	PRINTFORM {G}명의 손님에게서 {B}포인트 획득
ENDIF

MONEY += B

;---------------------------------------------------------
;キャラの元値の計算
;---------------------------------------------------------
;;基本費用は200, 素質によってさらに加算されることになります
;;現在はテストも兼ねてわりと適当な値ですが, 追々バランスを取りながら変更していく予定です
;営業が効率良過ぎるので, erapoke導入に際して大幅にダンピング
;HoX_pre2でさらにダンピング
;---------------------------------------------------------
@WORK_MONEYD

;基本額
B = 100

;能力ボーナス: 従順・욕망・화술・봉사정신は営業内容に問わずボーナスとして加算
;従順
IF ABL:10 <= 3
	B += 5
ELSEIF ABL:10 == 4
	B += 10
ELSEIF ABL:10 == 5
	B += 20
ELSEIF ABL:10 == 6
	B += 25
ELSEIF ABL:10 == 7
	B += 30
ELSEIF ABL:10 == 8
	B += 35
ELSEIF ABL:10 == 9
	B += 45
ELSEIF ABL:10 >= 10
	B += 50
ENDIF

;욕망
IF ABL:11 <= 3
	B += 10
ELSEIF ABL:11 == 4
	B += 20
ELSEIF ABL:11 == 5
	B += 30
ELSEIF ABL:11 == 6
	B += 50
ELSEIF ABL:11 == 7
	B += 70
ELSEIF ABL:11 == 8
	B += 90
ELSEIF ABL:11 == 9
	B += 120
ELSEIF ABL:11 >= 10
	B += 150
ENDIF

;화술: 회화영업だった場合通常よりも多く加算
IF CFLAG:12 == 1
	IF ABL:15 == 1
		B += 10
	ELSEIF ABL:15 == 2
		B += 20
	ELSEIF ABL:15 == 3
		B += 40
	ELSEIF ABL:15 == 4
		B += 70
	ELSEIF ABL:15 == 5
		B += 100
	ELSEIF ABL:15 >= 6
		B += 150
	ENDIF
ELSE
	IF ABL:15 == 1
		B += 5
	ELSEIF ABL:15 == 2
		B += 10
	ELSEIF ABL:15 == 3
		B += 20
	ELSEIF ABL:15 == 4
		B += 35
	ELSEIF ABL:15 == 5
		B += 50
	ELSEIF ABL:15 >= 6
		B += 75
	ENDIF
ENDIF

;봉사정신: 출장영업だった場合通常よりも多く加算
IF CFLAG:12 == 6
	IF ABL:16 == 1
		B += 15
	ELSEIF ABL:16 == 2
		B += 30
	ELSEIF ABL:16 == 3
		B += 60
	ELSEIF ABL:16 == 4
		B += 105
	ELSEIF ABL:16 == 5
		B += 150
	ELSEIF ABL:16 >= 6
		B += 225
	ENDIF
ELSE
	IF ABL:16 == 1
		B += 10
	ELSEIF ABL:16 == 2
		B += 20
	ELSEIF ABL:16 == 3
		B += 40
	ELSEIF ABL:16 == 4
		B += 70
	ELSEIF ABL:16 == 5
		B += 100
	ELSEIF ABL:16 >= 6
		B += 150
	ENDIF
ENDIF

;봉사영업だった場合, 봉사기술に応じて加算
IF CFLAG:12 == 2 || CFLAG:12 == 7
	IF ABL:13 == 1
		B += 15
	ELSEIF ABL:13 == 2
		B += 25
	ELSEIF ABL:13 == 3
		B += 40
	ELSEIF ABL:13 == 4
		B += 60
	ELSEIF ABL:13 == 5
		B += 75
	ELSEIF ABL:13 >= 6
		B += 100
	ENDIF
ENDIF

;AorV영업だった場合, 성교기술に応じて加算
IF CFLAG:12 == 3 || CFLAG:12 == 4
	IF ABL:14 == 1
		B += 30
	ELSEIF ABL:14 == 2
		B += 50
	ELSEIF ABL:14 == 3
		B += 75
	ELSEIF ABL:14 == 4
		B += 100
	ELSEIF ABL:14 == 5
		B += 150
	ELSEIF ABL:14 >= 6
		B += 200
	ENDIF
ENDIF

;SM영업だった場合, 새드끼or마조끼に応じて加算(高い方を判定)
IF CFLAG:12 == 5
	IF ABL:20 >= ABL:21
		IF ABL:20 == 1
			B += 15
		ELSEIF ABL:20 == 2
			B += 25
		ELSEIF ABL:20 == 3
			B += 40
		ELSEIF ABL:20 == 4
			B += 60
		ELSEIF ABL:20 == 5
			B += 75
		ELSEIF ABL:20 >= 6
			B += 100
		ENDIF
	ELSEIF ABL:21 > ABL:20
		IF ABL:21 == 1
			B += 15
		ELSEIF ABL:21 == 2
			B += 25
		ELSEIF ABL:21 == 3
			B += 40
		ELSEIF ABL:21 == 4
			B += 60
		ELSEIF ABL:21 == 5
			B += 75
		ELSEIF ABL:21 >= 6
			B += 100
		ENDIF
	ENDIF
ENDIF

;素質ボーナス
;음란
SIF TALENT:76
	B += 20
;매력
SIF TALENT:113
	B += 40
;매혹
SIF TALENT:91
	B += 40
;수수께끼의 매력
SIF TALENT:92
	B += 75
;인기인
SIF TALENT:126
	B += 35
;거유か빈유
SIF TALENT:110 || TALENT:109
	B += 25
;후타나리
SIF TALENT:121
	B += 15
;小柄体系
SIF TALENT:100
	B += 25
;아이돌
SIF TALENT:203
	B += 50

;HoX pre2にて, ビデオバリアントなのに!という声に応えてざっくり切り下げ
B /= 10

;---------------------------------------------------------
;부정의 구슬の計算
;---------------------------------------------------------
;従順が高くないとガンガン溜まっていきます
;従順が高くても溜まるのは溜まります
;---------------------------------------------------------
@WORK_DOWN

A = G
B = 6 - ABL:10
SIF B < 1
	B = 1
A *= 5
A *= B
A *= B

;経験補正
;처녀상실だとかなり増える
SIF CFLAG:50
	TIMES A , 10.00

;V경험が足りないとちょっと増える
SIF CFLAG:51
	TIMES A , 1.50

;A경험が足りないとちょっと増える
SIF CFLAG:52
	TIMES A ,1.50

;売春中毒のレベルに応じてちょっとずつ減る
IF ABL:37 == 1
	TIMES A , 0.90
ELSEIF ABL:37 == 2
	TIMES A , 0.80
ELSEIF ABL:37 == 3
	TIMES A , 0.70
ELSEIF ABL:37 == 4
	TIMES A , 0.60
ELSEIF ABL:37 >= 5
	TIMES A , 0.50
ENDIF

;素質補正
;무관심だと少なくなる
SIF TALENT:21
	TIMES A , 0.90
;감정부족と少なくなる
SIF TALENT:22
	TIMES A , 0.90
;娼婦だとさらに少なくなる
SIF TALENT:180
	TIMES A , 0.80
;求愛だと凄く少なくなる
SIF TALENT:184
	TIMES A , 0.50
;プライドが高いと増える
SIF TALENT:15
	TIMES A , 1.50
;정조관념だと凄く増える
SIF TALENT:30
	TIMES A , 2.50
;음란だとやや少なくなる
SIF TALENT:76
	TIMES A , 0.80
SIF TALENT:440
	TIMES A , 0.01
;【愛】してると嫌な気分
SIF TALENT:85
	TIMES A , 1.20
;질투してるとこれは酷い
SIF TALENT:84
	A *= 100

IF (FLAG:6 & 2) == 0
	PRINT  부정의 구슬　　:
	N = JUEL:100
	CALL FIGURE_INDENT
	PRINTV JUEL:100
	PRINT  + 
	N = A
	CALL FIGURE_INDENT
	PRINTV A
	PRINT  = 
	N = JUEL:100 + A
	CALL FIGURE_INDENT
	PRINTVL JUEL:100 + A
ENDIF

JUEL:100 += A

;부정의 구슬の許容量を決定します
;従順の150倍+100まで許容できます。LV2はルート2倍, LV3はルート3倍
A = ABL:10
A *= 150
A += 100
B = A
TIMES B , 1.41
C = A
TIMES C , 1.73

IF (FLAG:6 & 2) == 0
	PRINT  허용량　　　: 
	IF MARK:3 == 0
		BAR JUEL:100, A, 32
		PRINTFORML ({JUEL:100}/{A})
	ELSEIF MARK:3 == 1
		BAR JUEL:100, B, 32
		PRINTFORML ({JUEL:100}/{B})
	ELSE
		BAR JUEL:100, C, 32
		PRINTFORML ({JUEL:100}/{C})
	ENDIF
ENDIF

IF MARK:3 != 3 && JUEL:100 > C
	PRINTL 반발각인 LV3을 습득
	PRINTL 더 이상 매춘을 계속할 수 없습니다
	MARK:3 = 3
	CFLAG:12 = 0
ELSEIF MARK:3 != 2 && JUEL:100 > B
	PRINTL 반발각인 LV2를 습득
	PRINTL 더 이상 매춘을 계속할 수 없습니다
	MARK:3 = 2
	CFLAG:12 = 0
ELSEIF MARK:3 != 1 && JUEL:100 > A
	PRINTL 반발각인 LV1을 습득
	MARK:3 = 1
ENDIF


;---------------------------------------------------------
;消費체력の計算
;---------------------------------------------------------
@WORK_BASE
;人数に応じて, ダメージの基準値を決定します
IF G > 45
	LOSEBASE:0 = 50
ELSEIF G > 34
	LOSEBASE:0 = 45
ELSEIF G > 24
	LOSEBASE:0 = 40
ELSEIF G > 15
	LOSEBASE:0 = 35
ELSEIF G > 7
	LOSEBASE:0 = 30
ELSE
	LOSEBASE:0 = 25
ENDIF

;営業種目による補正
LOSEBASE:0 *= F

;経験補正
;처녀상실だとかなり増える
IF CFLAG:50
	TIMES LOSEBASE:0 , 2.00
	BASE:31 -= 20
ENDIF

;V경험が足りないとちょっと増える
IF CFLAG:51
	TIMES LOSEBASE:0 , 1.10
	BASE:31 -= 2
ENDIF

;A경험が足りないとちょっと増える
IF CFLAG:52
	TIMES LOSEBASE:0 , 1.20
	BASE:31 -= 2
ENDIF

;음란だとちょっと少なくなる
SIF TALENT:76
	TIMES LOSEBASE:0 , 0.80

;売春中毒のレベルに応じてちょっとずつ減る
IF ABL:37 == 1
	TIMES LOSEBASE:0 , 0.90
ELSEIF ABL:37 == 2
	TIMES LOSEBASE:0 , 0.80
ELSEIF ABL:37 == 3
	TIMES LOSEBASE:0 , 0.70
ELSEIF ABL:37 == 4
	TIMES LOSEBASE:0 , 0.60
ELSEIF ABL:37 >= 5
	TIMES LOSEBASE:0 , 0.50
ENDIF

IF (FLAG:6 & 2) == 0
	PRINT  체력 소비　　: 
	N = BASE:0
	CALL FIGURE_INDENT
	PRINTV BASE:0
	PRINT  - 
	N = LOSEBASE:0
	CALL FIGURE_INDENT
	PRINTV LOSEBASE:0
	PRINT  = 
	N = BASE:0 - LOSEBASE:0
	CALL FIGURE_INDENT
	PRINTVL BASE:0 - LOSEBASE:0
	BASE:31 -= RAND:6
ENDIF

BASE:0 -= LOSEBASE:0
LOSEBASE:0 = 0

IF (FLAG:6 & 2) == 0
	PRINT  체력　　　　:
	BAR BASE:0, MAXBASE:0, 32
	PRINTFORML ({BASE:0}/{MAXBASE:0})
ENDIF
