	ELSEIF ABL:51 >= 10
		TIMES LOSEBASE:0 , 0.50
	ENDIF
	
	SIF LOSEBASE:0 >= BASE:0
		LOSEBASE:0 = BASE:0
	
	PRINT  체력소비　　: 
	N = BASE:0
	CALL FIGURE_INDENT
	PRINTV BASE:0
	PRINT  - 
	N = LOSEBASE:0
	CALL FIGURE_INDENT
	PRINTV LOSEBASE:0
	PRINT  = 
	N = BASE:0 - LOSEBASE:0
	CALL FIGURE_INDENT
	PRINTVL BASE:0 - LOSEBASE:0
	
	BASE:0 -= LOSEBASE:0
	
	PRINT  체력　　　　:
	BAR BASE:0, MAXBASE:0, 32
	PRINTFORML ({BASE:0}/{MAXBASE:0})
	
	;체력が0以下, または500以下だった場合の処理
	IF BASE:0 <= 0
		PRINTFORML %타겟은()%, 포장마차를 연 직후 넙죽 엎드리듯 쓰러져버렸다
		PRINTFORML 무슨짓을 해도 반응이 없다……
		WAIT
