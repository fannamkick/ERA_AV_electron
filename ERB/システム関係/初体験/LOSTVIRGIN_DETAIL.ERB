;===========================================================
;처녀상실の状況
;===========================================================
@LOSTVIRGIN_DETAIL_CALC

VARSET LOCAL, 0
IF CFLAG:165 == 0
	IF CFLAG:161 == 1 || CFLAG:161 == 2 || CFLAG:161 == 4 || CFLAG:161 == 6 || CFLAG:161 == 7 || CFLAG:161 == 9 || CFLAG:161 == 11 
		IF CFLAG:162 == 1
			CFLAG:165 = RAND:7
				SIF CFLAG:165 == 0
					CFLAG:165 = 1
		ELSEIF CFLAG:162 == 2
			CFLAG:165 = 8 + RAND:7
		ELSEIF CFLAG:162 == 3
			CFLAG:165 = 15 + RAND:8
			SIF CFLAG:165 == 14
				CFLAG:165 = 15
		ELSEIF CFLAG:162 == 4
			CFLAG:165 = 23 + RAND:7
		ENDIF
	ELSE
		IF CFLAG:162 == 1
			CFLAG:165 = RAND:7
				SIF CFLAG:165 == 0
					CFLAG:165 = 1
		ELSEIF CFLAG:162 == 2
			CFLAG:165 = 7 + RAND:7
		ELSEIF CFLAG:162 == 3
			CFLAG:165 = 14 + RAND:7
			SIF CFLAG:165 == 14
				CFLAG:165 = 15
		ELSEIF CFLAG:162 == 4
			CFLAG:165 = 21 + RAND:7
		ELSEIF CFLAG:162 == 5
			CFLAG:165 = 28 + RAND:7
			SIF CFLAG:165 >= 31
				CFLAG:165 = 31
		ENDIF		
	ENDIF
	SIF CFLAG:165 == MAXBASE:12 && CFLAG:161 == MAXBASE:11
		CFLAG:166 = 1
ENDIF

;===========================================================
;CFLAG:160 = 연령
;CFLAG:161 = 月
;CFLAG:162 = 週
