ELSEIF CFLAG:616 == 15
	PRINTFORM 남편
ELSEIF CFLAG:616 == 16
	PRINTFORM %NAME:MASTER%
ENDIF

IF CFLAG:616 != 4 && CFLAG:616 != 5 && CFLAG:616 != 7 && CFLAG:616 != 11 && CFLAG:616 != 12 && CFLAG:616 != 13 && CFLAG:616 != 8 && CFLAG:616 != 14
	PRINTFORM 에게
ELSEIF CFLAG:616 == 4 || CFLAG:616 == 5
	PRINTFORM 로
;ELSEIF CFLAG:834 >= 3
;	PRINTFORM に
;ELSEIF CFLAG:616 >= 11 || CFLAG:834 == 3
;	PRINTFORM に
;ELSEIF CFLAG:833 == 2 && CFLAG:616 == 8 && TALENT:184 == 1
;	PRINTFORM 
ELSE
	PRINTFORM 에게
ENDIF



IF CFLAG:834 == 0 && CFLAG:616 == 8
	PRINTFORM 
ELSEIF CFLAG:834 == 1
	PRINTFORM  지도중에
ELSEIF CFLAG:834 == 2
	PRINTFORM  촬영중에
ELSEIF CFLAG:834 == 3
	PRINTFORM  몰래 찍히면서
ELSEIF CFLAG:834 == 4
	PRINTFORM  약을 먹여져서 스스로 %CSTR:80%에게 조르며
ELSEIF CFLAG:834 == 5
	PRINTFORM  윤간당하며
ENDIF

PRINTFORML %UNICODE(0x2665)%


ENDIF

