	ELSEIF CFLAG:833 == 14
		PRINTFORM 촬영 스튜디오
	ENDIF
	PRINTFORM 에서
ENDIF


SIF CFLAG:836 == 1
	PRINTFORM 생일기념으로 

IF CFLAG:616 == 0
	PRINTFORM 기억 안나는 사람
ELSEIF CFLAG:616 == 1
	PRINTFORM %CSTR:3%
ELSEIF CFLAG:616 == 2
	PRINTFORM 이름도 모르는 남자손님
ELSEIF CFLAG:616 == 3
	PRINTFORM 이름도 모르는 여자손님
ELSEIF CFLAG:616 == 4
	PRINTFORM 애널바이브
ELSEIF CFLAG:616 == 5
	PRINTFORM 극대애널바이브
ELSEIF CFLAG:616 == 6
	PRINTFORM 이름도 모르는 손님
ELSEIF CFLAG:616 == 7
	PRINTFORM 치한
ELSEIF CFLAG:616 == 8 && CFLAG:837 == 1
	IF CSTR:3 == ""
		PRINTFORM 전 남친
	ELSE
		PRINTFORM %CSTR:3%(전 남친)
	ENDIF
ELSEIF CFLAG:616 == 8 && TALENT:184 == 1
;;;; && CFLAG:833 != 2
	IF CSTR:3 == ""
		PRINTFORM 남친
	ELSE
		PRINTFORM %CSTR:3%(남친)
	ENDIF	
ELSEIF CFLAG:616 == 9
	PRINTFORM 섹프인 %CSTR:47%
ELSEIF CFLAG:616 == 11
	PRINTFORM 불량배
;;;このあたりは対象者を入れる(状況だと, のちのち記述上の問題が生じやすいので)
ELSEIF CFLAG:616 == 12
	PRINTFORM 배게영업 상대
ELSEIF CFLAG:616 == 13
