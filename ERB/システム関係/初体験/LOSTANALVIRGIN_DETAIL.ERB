	PRINTFORM 어는 날
ELSE
	SIF CFLAG:831 <= 9
		PRINTFORM  
	PRINTFORM {CFLAG:831}월
ENDIF

IF ( CFLAG:830 == 0 && CFLAG:831 == 0 ) || CFLAG:835 == 0
ELSE
	SIF CFLAG:835 <= 9
		PRINTFORM  
	PRINTFORM  {CFLAG:835}일
ENDIF

PRINTFORM 에 

