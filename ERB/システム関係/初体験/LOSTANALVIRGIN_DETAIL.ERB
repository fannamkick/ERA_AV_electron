			PRINTFORM 전 남친의 방
		ELSE
			PRINTFORM %CSTR:3%(전 남친)의 방
		ENDIF		
	ELSEIF CFLAG:833 == 2 && CFLAG:616 == 8 && TALENT:184 == 1
		IF CSTR:3 == ""
			PRINTFORM 남친의 방
		ELSE
			PRINTFORM %CSTR:3%(남친)의 방
		ENDIF	
	ELSEIF CFLAG:833 == 3
		PRINTFORM 러브호텔
	ELSEIF CFLAG:833 == 4
		PRINTFORM 바다
	ELSEIF CFLAG:833 == 5
		PRINTFORM 학교
	ELSEIF CFLAG:835 == 6
		PRINTFORM 폐공장
	ELSEIF CFLAG:833 == 7
		PRINTFORM 창관
	ELSEIF CFLAG:833 == 8
		PRINTFORM 전차 안
	ELSEIF CFLAG:833 == 9
