;===========================================================
;처녀상실の状況
;===========================================================
@LOSTANALVIRGIN_DETAIL_CALC

VARSET LOCAL, 0
IF CFLAG:835 == 0
	IF CFLAG:831 == 1 || CFLAG:831 == 2 || CFLAG:831 == 4 || CFLAG:831 == 6 || CFLAG:831 == 7 || CFLAG:831 == 9 || CFLAG:831 == 11 
		IF CFLAG:832 == 1
			CFLAG:835 = RAND:7
				SIF CFLAG:835 == 0
					CFLAG:835 = 1
		ELSEIF CFLAG:832 == 2
			CFLAG:835 = 8 + RAND:7
		ELSEIF CFLAG:832 == 3
			CFLAG:835 = 15 + RAND:8
			SIF CFLAG:835 == 14
				CFLAG:835 = 15
		ELSEIF CFLAG:832 == 4
			CFLAG:835 = 23 + RAND:7
		ENDIF
	ELSE
		IF CFLAG:832 == 1
			CFLAG:835 = RAND:7
				SIF CFLAG:835 == 0
					CFLAG:835 = 1
		ELSEIF CFLAG:832 == 2
			CFLAG:835 = 7 + RAND:7
		ELSEIF CFLAG:832 == 3
			CFLAG:835 = 14 + RAND:7
			SIF CFLAG:835 == 14
				CFLAG:835 = 15
		ELSEIF CFLAG:832 == 4
			CFLAG:835 = 21 + RAND:7
		ELSEIF CFLAG:832 == 5
			CFLAG:835 = 28 + RAND:7
			SIF CFLAG:835 >= 31
				CFLAG:835 = 31
		ENDIF		
	ENDIF
	SIF CFLAG:835 == MAXBASE:12 && CFLAG:831 == MAXBASE:11
		CFLAG:836 = 1
ENDIF

;===========================================================
;CFLAG:830 = 연령
;CFLAG:831 = 月
;CFLAG:832 = 週
;CFLAG:833 = 場所
;CFLAG:834 = 状況
;CFLAG:835 = 日付固定用
;===========================================================
@LOSTANALVIRGIN_DETAIL

CHKFONT "あくびん"
	IF RESULT
		SETFONT "あくびん"
	ENDIF
	SETCOLOR 0xF58F98
	PRINT 　
	CALL HEART_CODE
