		GOTO INPUT_LOOP_2
	ENDIF


;-------------------------------------------------
;途中導入時のCSVデータ読み込み
;SYSTEM_CONFIG.ERBから呼び出される関数
;SYSTEM_IWS.ERBの構文をほぼ丸ごと使わせて頂きました
;-------------------------------------------------
@READ_CSV_BIRTHDAY
	$INPUT_LOOP
	DRAWLINE
	PRINTL CSV 파일로부터 연령, 생일, 혈액형 정보를 불러옵니다.
	PRINTL 불러들일 캐릭터의 종류를 선택해주십시오.
	PRINTL 
	PRINTL  [0] - 미설정 캐릭터만(패치가 되었을 때 사용하는 메뉴)
	PRINTL  [1] - 등록 캐릭터 모두(［고등학생］과 ［중학생］을 고려하지 않습니다)
	PRINTL  [9] - 그만둔다
	INPUT
	IF RESULT == 9
		RETURN 0
	ELSEIF RESULT == 0
		REPEAT CHARANUM
			;実연령が0歳のキャラクター全員
			IF BASE:COUNT:9 == 0
				BASE:COUNT:7 = CSVBASE(NO:COUNT, 7, 0)
				BASE:COUNT:8 = CSVBASE(NO:COUNT, 8, 0)
				BASE:COUNT:9 = CSVBASE(NO:COUNT, 9, 0)
			ENDIF
			;誕生月が不明なキャラクター全員
			IF BASE:COUNT:11 == 0
				BASE:COUNT:11 = CSVBASE(NO:COUNT, 11, 0)
				BASE:COUNT:12 = CSVBASE(NO:COUNT, 12, 0)
				BASE:COUNT:13 = CSVBASE(NO:COUNT, 13, 0)
			ENDIF
		REND
	ELSEIF RESULT == 1	
		REPEAT CHARANUM
			BASE:COUNT:7 = CSVBASE(NO:COUNT, 7, 0)
			BASE:COUNT:8 = CSVBASE(NO:COUNT, 8, 0)
			BASE:COUNT:9 = CSVBASE(NO:COUNT, 9, 0)
			BASE:COUNT:11 = CSVBASE(NO:COUNT, 11, 0)
			BASE:COUNT:12 = CSVBASE(NO:COUNT, 12, 0)
			BASE:COUNT:13 = CSVBASE(NO:COUNT, 13, 0)
		REND
	ELSE
			GOTO INPUT_LOOP
	ENDIF
PRINTW 완료했습니다
;-------------------------------------------------
;途中導入時のCSVデータ読み込み
;SYSTEM_CONFIG.ERBから呼び出される関数
;SYSTEM_IWS.ERBの構文をほぼ丸ごと使わせて頂きました
;-------------------------------------------------
@ADD_CSV_BIRTHDAY
IF DAY:1 == BASE:LOCAL:11
	;3,5,8,10月は5週目がある
	IF DAY:1 == 3 || DAY:1 == 5 || DAY:1 == 8 || DAY:1 == 10
		IF (DAY:2 == 1 && 1 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 7) || (DAY:2 == 2 && 8 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 14) || (DAY:2 == 3 && 15 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 21) || (DAY:2 == 4 && 22 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 28) ||  (DAY:2 == 5 && 29 <= BASE:LOCAL:12)
			SIF !FLAG:74
				BASE:LOCAL:9 += 1
		ENDIF
	ELSE
		IF (DAY:2 == 1 && 1 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 7) || (DAY:2 == 2 && 8 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 14) || (DAY:2 == 3 && 15 <= BASE:LOCAL:12 && BASE:LOCAL:12 <= 21) || (DAY:2 == 4 && 22 <= BASE:LOCAL:12)
			SIF !FLAG:74
				BASE:LOCAL:9 += 1
		ENDIF
	ENDIF
ENDIF