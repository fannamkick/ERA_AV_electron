			SIF LOCAL <= 1
				LOCAL = 1
			EXP:COUNT:71 += LOCAL
			PRINTFORML 가창경험(%CALLNAME:COUNT%)＋{LOCAL}
			CUSTOMDRAWLINE ･･
			WAIT
		ENDIF
	REND
ENDIF

