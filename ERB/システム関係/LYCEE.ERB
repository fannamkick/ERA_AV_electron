	MONEY -= 800000
	FLAG:101 |= 128
	RESTART
ELSEIF RESULT == 999
	RETURN 0
ELSE
	GOTO INPUT_LOOP
ENDIF

;===========================================================
;女子寮イベント
;===========================================================
@LYCEE_EVENT_WEEKEND

IF (FLAG:101 & 1)
	LOCAL = 0
	REPEAT CHARANUM
		IF COUNT == 0
			CONTINUE
		ELSEIF CFLAG:COUNT:140 == 0
			CONTINUE
		ELSEIF CFLAG:COUNT:141 != 1
			CONTINUE
		ELSE
			PRINTFORML %조사처리(NAME:COUNT,"는")% 여자 기숙사의 에스테룸에서 오일마사지를 받고 있다……
			LOCAL = MAXBASE:COUNT:31 * 3
			LOCAL /= 100
			SIF LOCAL <= 1
				LOCAL = 1
			SIF BASE:COUNT:31 + LOCAL >= MAXBASE:COUNT:31
				LOCAL = MAXBASE:COUNT:31 - BASE:COUNT:31
			IF BASE:COUNT:31 >= MAXBASE:COUNT:31
				PRINTFORML 《%CALLNAME:COUNT%에겐 더이상 효과가 없습니다》
			ELSE
				PRINTFORML 《%CALLNAME:COUNT%의 매력치가 {LOCAL} 회복됐다》
				BASE:COUNT:31 += LOCAL
			ENDIF
			CUSTOMDRAWLINE ･･
			WAIT
		ENDIF
	REND
ENDIF

;△同じ組み合わせが二回発生するのはいやなので一回にして双方からの相性が上がるようにしたい
;スキップ機能もほしいかもしれない。長い。
IF (FLAG:101 & 2)
	VARSET LOCAL, 0
	FOR LOCAL, 0, CHARANUM
		IF LOCAL == 0
			CONTINUE
		ELSEIF CFLAG:LOCAL:140 == 0
			CONTINUE
		ELSEIF CFLAG:LOCAL:141 != 2
			CONTINUE
		ELSE
			FOR LOCAL:1, 0, CHARANUM
				IF LOCAL == 0
					CONTINUE
				ELSEIF CFLAG:(LOCAL:1):140 == 0
					CONTINUE
				ELSEIF CFLAG:(LOCAL:1):141 != 2
					CONTINUE
				ELSEIF LOCAL:1 == LOCAL
					CONTINUE
				ELSEIF RELATION:LOCAL:(NO:(LOCAL:1)) >= 1000
					CONTINUE
;△発生率調整用に確保
;				ELSEIF RAND:3 == 0
;					CONTINUE
				ELSE
					IF ABL:LOCAL:22 >= 2 && ABL:(LOCAL:1):22 >= 2 && RELATION:LOCAL:(NO:(LOCAL:1)) >= 250
						LOCAL:2 = 0
						REPEAT CHARANUM
							IF COUNT == 0
								CONTINUE
							ELSEIF CFLAG:COUNT:141 == 2
								LOCAL:2 += 1
							ENDIF
						REND
						PRINTFORM 휴게실에서 닿을 정도로 가깝게 
						SIF LOCAL:2 >= 3						
							PRINTFORM 다른 사람은 신경도 안쓰고 
						PRINTFORM %조사처리(NAME:LOCAL,"과")% %(NAME:(LOCAL:1),"는")% 스킨십을 하며 일상적인 대화를 나누고 있었지만, 
						PRINTFORML 이윽고 스킨십이 과격해지더니 혀를 엮고 타액을 교환하는 키스를 하며 서로의 비부를 애무하기 시작했다……
						PRINTFORM %조사처리(CALLNAME:LOCAL,"과")% %CALLNAME:(LOCAL:1)%의 신음소리가 점점 달콤해지며 
						SIF LOCAL:2 >= 3
							PRINTFORM 다른 사람이 보고 있는 앞에서
						PRINTFORML 거의 동시에 절정했다
						PRINTFORML %조사처리(CALLNAME:LOCAL,"과")% %조사처리(CALLNAME:(LOCAL:1),"는")% 레즈플레이를 통해 서로를 더 깊이 알게됐다……
						RELATION:LOCAL:(NO:(LOCAL:1)) += 10
						IF CFLAG:LOCAL:16 == -1
							PRINTL
							CFLAG:LOCAL:16 = 1
							SETCOLOR 0xF58F98
								PRINTFORM 【첫 키스】
							RESETCOLOR
							PRINTFORML (%CALLNAME:LOCAL%)
							CSTR:LOCAL:1 = %NAME:(LOCAL:1)%
							CFLAG:LOCAL:820 = BASE:LOCAL:9
							CFLAG:LOCAL:821 = DAY:1
							CFLAG:LOCAL:822 = DAY:2
							;△そのうち場所に휴게실とか突っ込んでおくこと
							;ここに限らず日付を合わせる処理はどっかでしないと……
							;どう考えても첫 키스関数作るべきなんですが今回はパス
						ENDIF
						IF CFLAG:(LOCAL:1):16 == -1
							PRINTL
							CFLAG:(LOCAL:1):16 = 1
							SETCOLOR 0xF58F98
								PRINTFORM 【첫 키스】
							RESETCOLOR
							PRINTFORML (%CALLNAME:(LOCAL:1)%) 
							CSTR:(LOCAL:1):1 = %NAME:LOCAL%
							CFLAG:(LOCAL:1):820 = BASE:(LOCAL:1):9
							CFLAG:(LOCAL:1):821 = DAY:1
							CFLAG:(LOCAL:1):822 = DAY:2							
						ENDIF
						PRINTL
						LOCAL:3 = RAND:11 + 1
						SIF LOCAL:3 <= 1
							LOCAL:3 = 1
						SIF TALENT:LOCAL:76 == 1
							LOCAL:3 *= 2
						EXP:LOCAL:40 += LOCAL:3
						EXP:LOCAL:2 += LOCAL:3
						JUEL:LOCAL:0 += LOCAL:3 * 100
						JUEL:LOCAL:5 += LOCAL:3 * 500
						PRINTFORML %EXPNAME:40%(%CALLNAME:LOCAL%)＋{LOCAL}
						PRINTFORML %EXPNAME:2%(%CALLNAME:LOCAL%)＋{LOCAL}
						PRINTFORML %PALAMNAME:0%의 구슬(%CALLNAME:LOCAL%)＋{LOCAL * 100}
						PRINTFORML %PALAMNAME:5%의 구슬(%CALLNAME:LOCAL%)＋{LOCAL * 500}
						PRINTL
					ELSE
						PRINTFORML %조사처리(NAME:LOCAL,"는")% %조사처리(NAME:(LOCAL:1),"와")% 휴게실에서 일상적인 대화를 하며 서로를 더 깊이 알게됐다……
						RELATION:LOCAL:(NO:(LOCAL:1)) += 5
					ENDIF
					SIF RELATION:LOCAL:(NO:(LOCAL:1)) <= 100
						RELATION:LOCAL:(NO:(LOCAL:1)) = 100
					PRINTFORML %조사처리(NAME:LOCAL,"와")% %NAME:(LOCAL:1)%의 상성이 {RELATION:LOCAL:(NO:(LOCAL:1))}％가 됐다
					CUSTOMDRAWLINE ･･
					WAIT
				ENDIF
			NEXT
		ENDIF
	NEXT
ENDIF


IF (FLAG:101 & 32)
	LOCAL = 0
