;総契約女優数に使ってるLOCAL:2とかCHARANUM-2でいいんじゃないのかこれ
;===========================================================
;女子寮
;===========================================================
@LYCEE_MAIN

LOCAL:1 = 0
LOCAL:2 = 0

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF CFLAG:COUNT:140 == 0
		CONTINUE
	ELSE
		LOCAL:1++
	ENDIF
REND

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSE
		LOCAL:2++
	ENDIF
REND
DRAWLINE
PRINTFORML 《여자 기숙사》
PRINTFORML 계약한 여배우를 여자 기숙사에 넣을 수 있습니다
PRINTFORM 현재 입주자수(
SIF LOCAL:1 < 10
	PRINT 0
PRINTFORM {LOCAL:1}명 / 
SIF LOCAL:2 < 10
	PRINT 0
PRINTFORML {LOCAL:2}명)
DRAWLINE
PRINTL  [0] - 입주시킨다
PRINTL  [1] - 불러온다
PRINTL  [2] - 시설을 확장한다
IF FLAG:101
	PRINTL  [3] - 입주중인 배우에게 시설을 이용하게 시킨다
ELSE
	PRINTL  [-] - －－－－－－－
ENDIF

DRAWLINE
PRINTL [999] - 돌아간다
$INPUT_LOOP
INPUT

IF RESULT == 0
	CALL LYCEE_IN
ELSEIF RESULT == 1
	CALL LYCEE_OUT
ELSEIF RESULT == 2
	CALL LYCEE_LABO
ELSEIF RESULT == 3 && FLAG:101
	CALL LYCEE_LABO_USE
ELSEIF RESULT == 999
	RETURN
ELSE
	GOTO INPUT_LOOP
ENDIF

RETURN 0

