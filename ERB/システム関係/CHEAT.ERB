;=====================================================
; 치트 메뉴
; 돈, 시간, 아이템, 캐릭터 에디터, 전체 해금
;=====================================================

@CHEAT_MAIN
$CHEAT_LOOP
DRAWLINE
PRINTL 【치트 메뉴】
PRINTL
PRINTFORML 현재 소지금: {MONEY} 원
PRINTFORML 현재 시간: {DAY+1}주차 \@(TIME == 0) ? "전반" # "후반"\@
PRINTL
PRINTL [1] - 돈 추가
PRINTL [2] - 시간 조작
PRINTL [3] - 아이템 획득
PRINTL [4] - 캐릭터 에디터
PRINTL [5] - 전체 해금
PRINTL
PRINTL [0] - 돌아가기
PRINTL

INPUT
SELECTCASE RESULT
	CASE 1
		CALL CHEAT_MONEY
	CASE 2
		CALL CHEAT_TIME
	CASE 3
		CALL CHEAT_ITEM
	CASE 4
		CALL CHEAT_CHARA_SELECT
	CASE 5
		CALL CHEAT_UNLOCK
	CASE 0
		RETURN 0
ENDSELECT
GOTO CHEAT_LOOP

;=====================================================
; 돈 추가
;=====================================================
@CHEAT_MONEY
DRAWLINE
PRINTL 【돈 추가】
PRINTL
PRINTFORML 현재 소지금: {MONEY} 원
PRINTL
PRINTL [1] - +10,000 원
PRINTL [2] - +100,000 원
PRINTL [3] - +1,000,000 원
PRINTL [4] - +10,000,000 원
PRINTL [5] - 직접 입력
PRINTL
PRINTL [0] - 돌아가기
PRINTL

INPUT
SELECTCASE RESULT
	CASE 1
		MONEY += 10000
		PRINTFORML 10,000 원 추가! 현재: {MONEY} 원
	CASE 2
		MONEY += 100000
		PRINTFORML 100,000 원 추가! 현재: {MONEY} 원
	CASE 3
		MONEY += 1000000
		PRINTFORML 1,000,000 원 추가! 현재: {MONEY} 원
	CASE 4
		MONEY += 10000000
		PRINTFORML 10,000,000 원 추가! 현재: {MONEY} 원
	CASE 5
		PRINTL 추가할 금액을 입력하세요:
		INPUT
		MONEY += RESULT
		PRINTFORML {RESULT} 원 추가! 현재: {MONEY} 원
	CASE 0
		RETURN 0
ENDSELECT
WAIT
RETURN 0

;=====================================================
; 시간 조작
;=====================================================
@CHEAT_TIME
DRAWLINE
PRINTL 【시간 조작】
PRINTL
PRINTFORML 현재 시간: {DAY+1}주차 \@(TIME == 0) ? "전반" # "후반"\@
PRINTL
PRINTL [1] - 전반/후반 전환
PRINTL [2] - 다음 주로
PRINTL [3] - 이전 주로
PRINTL [4] - 주차 직접 설정
PRINTL
PRINTL [0] - 돌아가기
PRINTL

INPUT
SELECTCASE RESULT
	CASE 1
		TIME = (TIME + 1) % 2
		PRINTFORML 시간 변경: \@(TIME == 0) ? "전반" # "후반"\@
	CASE 2
		DAY += 1
		PRINTFORML 시간 변경: {DAY+1}주차
	CASE 3
		DAY -= 1
		SIF DAY < 0
			DAY = 0
		PRINTFORML 시간 변경: {DAY+1}주차
	CASE 4
		PRINTL 주차를 입력하세요 (1~):
		INPUT
		DAY = RESULT - 1
		SIF DAY < 0
			DAY = 0
		PRINTFORML 시간 설정: {DAY+1}주차
	CASE 0
		RETURN 0
ENDSELECT
WAIT
RETURN 0

;=====================================================
; 아이템 획득
;=====================================================
@CHEAT_ITEM
$ITEM_LOOP
DRAWLINE
PRINTL 【아이템 획득】
PRINTL
PRINTL === 소모품 ===
PRINTFORML [24] 콘돔: {ITEM:24}개   [25] 로션: {ITEM:25}개
PRINTFORML [26] 프린세스포이즌: {ITEM:26}개   [27] 이뇨제: {ITEM:27}개
PRINTFORML [30] 영양제: {ITEM:30}개   [40] 배란유발제: {ITEM:40}개
PRINTL
PRINTL === 장비 (미보유만 표시) ===
SIF ITEM:0 == 0
	PRINTL [0] 로터
SIF ITEM:1 == 0
	PRINTL [1] 바이브
SIF ITEM:2 == 0
	PRINTL [2] E마사지기
SIF ITEM:3 == 0
	PRINTL [3] 애널바이브
SIF ITEM:6 == 0
	PRINTL [6] 비디오카메라
SIF ITEM:7 == 0
	PRINTL [7] 클리캡
SIF ITEM:8 == 0
	PRINTL [8] 니플캡
SIF ITEM:10 == 0
	PRINTL [10] 채찍
SIF ITEM:14 == 0
	PRINTL [14] 밧줄
SIF ITEM:17 == 0
	PRINTL [17] 착유기
SIF ITEM:39 == 0
	PRINTL [39] 비밀지식
SIF ITEM:90 == 0
	PRINTL [90] 촉수생물
PRINTL
PRINTL [100] - 소모품 전부 99개
PRINTL [101] - 장비 전부 획득
PRINTL [0] - 돌아가기
PRINTL

INPUT
IF RESULT == 0
	RETURN 0
ELSEIF RESULT == 100
	ITEM:24 = 99
	ITEM:25 = 99
	ITEM:26 = 99
	ITEM:27 = 99
	ITEM:30 = 99
	ITEM:40 = 99
	PRINTL 소모품 전부 99개로 설정!
	WAIT
	GOTO ITEM_LOOP
ELSEIF RESULT == 101
	ITEM:0 = 1
	ITEM:1 = 1
	ITEM:2 = 1
	ITEM:3 = 1
	ITEM:6 = 1
	ITEM:7 = 1
	ITEM:8 = 1
	ITEM:10 = 1
	ITEM:14 = 1
	ITEM:17 = 1
	ITEM:39 = 1
	ITEM:90 = 1
	PRINTL 장비 전부 획득!
	WAIT
	GOTO ITEM_LOOP
ELSEIF RESULT == 24
	PRINTFORML 콘돔 현재: {ITEM:24}개
	PRINTL 설정할 개수:
	INPUT
	ITEM:24 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 25
	PRINTFORML 로션 현재: {ITEM:25}개
	PRINTL 설정할 개수:
	INPUT
	ITEM:25 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 26
	PRINTFORML 프린세스포이즌 현재: {ITEM:26}개
	PRINTL 설정할 개수:
	INPUT
	ITEM:26 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 27
	PRINTFORML 이뇨제 현재: {ITEM:27}개
	PRINTL 설정할 개수:
	INPUT
	ITEM:27 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 30
	PRINTFORML 영양제 현재: {ITEM:30}개
	PRINTL 설정할 개수:
	INPUT
	ITEM:30 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 40
	PRINTFORML 배란유발제 현재: {ITEM:40}개
	PRINTL 설정할 개수:
	INPUT
	ITEM:40 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 1
	ITEM:1 = 1
	PRINTL 바이브 획득!
	WAIT
ELSEIF RESULT == 2
	ITEM:2 = 1
	PRINTL E마사지기 획득!
	WAIT
ELSEIF RESULT == 3
	ITEM:3 = 1
	PRINTL 애널바이브 획득!
	WAIT
ELSEIF RESULT == 6
	ITEM:6 = 1
	PRINTL 비디오카메라 획득!
	WAIT
ELSEIF RESULT == 7
	ITEM:7 = 1
	PRINTL 클리캡 획득!
	WAIT
ELSEIF RESULT == 8
	ITEM:8 = 1
	PRINTL 니플캡 획득!
	WAIT
ELSEIF RESULT == 10
	ITEM:10 = 1
	PRINTL 채찍 획득!
	WAIT
ELSEIF RESULT == 14
	ITEM:14 = 1
	PRINTL 밧줄 획득!
	WAIT
ELSEIF RESULT == 17
	ITEM:17 = 1
	PRINTL 착유기 획득!
	WAIT
ELSEIF RESULT == 39
	ITEM:39 = 1
	PRINTL 비밀지식 획득!
	WAIT
ELSEIF RESULT == 90
	ITEM:90 = 1
	PRINTL 촉수생물 획득!
	WAIT
ENDIF
GOTO ITEM_LOOP

;=====================================================
; 캐릭터 선택
;=====================================================
@CHEAT_CHARA_SELECT
$CHARA_SELECT_LOOP
DRAWLINE
PRINTL 【캐릭터 에디터 - 캐릭터 선택】
PRINTL
LOCAL = 0
REPEAT CHARANUM
	PRINTFORML [{COUNT}] %NAME:COUNT%
REND
PRINTL
PRINTL [999] - 돌아가기
PRINTL

INPUT
IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO CHARA_SELECT_LOOP
ENDIF

TARGET = RESULT
CALL CHEAT_CHARA_EDIT
GOTO CHARA_SELECT_LOOP

;=====================================================
; 캐릭터 에디터 메인
;=====================================================
@CHEAT_CHARA_EDIT
$CHARA_EDIT_LOOP
DRAWLINE
PRINTFORM 【캐릭터 에디터 - %NAME:TARGET%】
PRINTL
PRINTL
PRINTL [1] - 능력(ABL) 수정
PRINTL [2] - 경험(EXP) 수정
PRINTL [3] - 소질(TALENT) 수정
PRINTL [4] - 구슬(JUEL) 수정
PRINTL [5] - 기본 스탯 수정
PRINTL [6] - 상성(RELATION) 수정
PRINTL [7] - 원클릭 세팅
PRINTL
PRINTL [0] - 돌아가기
PRINTL

INPUT
SELECTCASE RESULT
	CASE 1
		CALL CHEAT_ABL
	CASE 2
		CALL CHEAT_EXP
	CASE 3
		CALL CHEAT_TALENT
	CASE 4
		CALL CHEAT_JUEL
	CASE 5
		CALL CHEAT_BASE
	CASE 6
		CALL CHEAT_RELATION
	CASE 7
		CALL CHEAT_ONECLICK
	CASE 0
		RETURN 0
ENDSELECT
GOTO CHARA_EDIT_LOOP

