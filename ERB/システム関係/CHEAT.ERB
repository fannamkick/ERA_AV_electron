;=====================================================
; 소질(TALENT) 수정
;=====================================================
@CHEAT_TALENT
$TALENT_LOOP
DRAWLINE
PRINTFORM 【%NAME:TARGET% - 소질(TALENT) 수정】
PRINTL
PRINTL
PRINTFORM [0] 처녀: \@TALENT:TARGET:0 ? "O" # "X"\@
PRINTFORML     [2] 애널처녀: \@TALENT:TARGET:2 ? "O" # "X"\@
PRINTL
PRINTFORM [76] 음란: \@TALENT:TARGET:76 ? "O" # "X"\@
PRINTFORML     [85] 연심: \@TALENT:TARGET:85 ? "O" # "X"\@
PRINTFORM [90] 섹프: \@TALENT:TARGET:90 ? "O" # "X"\@
PRINTFORML     [440] 절륜: \@TALENT:TARGET:440 ? "O" # "X"\@
PRINTL
PRINTFORM [74] 자위광: \@TALENT:TARGET:74 ? "O" # "X"\@
PRINTFORML   [75] 섹스광: \@TALENT:TARGET:75 ? "O" # "X"\@
PRINTFORM [77] 애널광: \@TALENT:TARGET:77 ? "O" # "X"\@
PRINTFORML   [78] 가슴광: \@TALENT:TARGET:78 ? "O" # "X"\@
PRINTL
PRINTL [999] - 돌아가기
PRINTL
PRINTL 토글할 소질 번호:

INPUT
IF RESULT == 999
	RETURN 0
ELSEIF RESULT == 0
	TALENT:TARGET:0 = 1 - TALENT:TARGET:0
ELSEIF RESULT == 2
	TALENT:TARGET:2 = 1 - TALENT:TARGET:2
ELSEIF RESULT == 74
	TALENT:TARGET:74 = 1 - TALENT:TARGET:74
ELSEIF RESULT == 75
