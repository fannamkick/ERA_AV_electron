ELSEIF RESULT == 76
	TALENT:TARGET:76 = 1 - TALENT:TARGET:76
ELSEIF RESULT == 77
	TALENT:TARGET:77 = 1 - TALENT:TARGET:77
ELSEIF RESULT == 78
	TALENT:TARGET:78 = 1 - TALENT:TARGET:78
ELSEIF RESULT == 85
	TALENT:TARGET:85 = 1 - TALENT:TARGET:85
ELSEIF RESULT == 90
	TALENT:TARGET:90 = 1 - TALENT:TARGET:90
ELSEIF RESULT == 440
	TALENT:TARGET:440 = 1 - TALENT:TARGET:440
ENDIF
PRINTL 토글 완료!
WAIT
GOTO TALENT_LOOP

