;=====================================================
; 기본 스탯 수정
;=====================================================
@CHEAT_BASE
$BASE_LOOP
DRAWLINE
PRINTFORM 【%NAME:TARGET% - 기본 스탯 수정】
PRINTL
PRINTL
PRINTFORML [1] 체력: {BASE:TARGET:0} / {MAXBASE:TARGET:0}
PRINTFORML [2] 기력: {BASE:TARGET:1} / {MAXBASE:TARGET:1}
PRINTFORML [3] 호감도: {CFLAG:TARGET:100}
PRINTL
PRINTFORML [4] 체력 최대치: {MAXBASE:TARGET:0}
PRINTFORML [5] 기력 최대치: {MAXBASE:TARGET:1}
PRINTL
PRINTL [100] - 체력/기력 전회복
PRINTL [101] - 체력 최대치 +100
PRINTL [102] - 기력 최대치 +100
PRINTL [103] - 체력/기력 최대치 +500
PRINTL [0] - 돌아가기
PRINTL

INPUT
IF RESULT == 0
	RETURN 0
ELSEIF RESULT == 100
	BASE:TARGET:0 = MAXBASE:TARGET:0
	BASE:TARGET:1 = MAXBASE:TARGET:1
	PRINTL 체력/기력 전회복!
	WAIT
ELSEIF RESULT == 101
	MAXBASE:TARGET:0 += 100
	BASE:TARGET:0 = MAXBASE:TARGET:0
	PRINTFORML 체력 최대치 +100! 현재: {MAXBASE:TARGET:0}
	WAIT
ELSEIF RESULT == 102
	MAXBASE:TARGET:1 += 100
	BASE:TARGET:1 = MAXBASE:TARGET:1
	PRINTFORML 기력 최대치 +100! 현재: {MAXBASE:TARGET:1}
	WAIT
ELSEIF RESULT == 103
	MAXBASE:TARGET:0 += 500
	MAXBASE:TARGET:1 += 500
	BASE:TARGET:0 = MAXBASE:TARGET:0
	BASE:TARGET:1 = MAXBASE:TARGET:1
	PRINTFORML 체력/기력 최대치 +500! 체력: {MAXBASE:TARGET:0}, 기력: {MAXBASE:TARGET:1}
	WAIT
ELSEIF RESULT == 1
	PRINTFORML 체력 현재값: {BASE:TARGET:0}
	PRINTL 새 값:
	INPUT
	BASE:TARGET:0 = RESULT
	PRINTL 설정 완료!
	WAIT
ELSEIF RESULT == 2
