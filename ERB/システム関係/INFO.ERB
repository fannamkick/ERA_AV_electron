		PRINTFORM %CALLNAME:(LOCAL:1),12,LEFT%＜상성 ??.??배＞　
	LOCAL:3 += 1
	IF LOCAL:3 == 3
		PRINTL
		LOCAL:3 = 0
	ENDIF
	ENDIF
NEXT
SIF LOCAL:3 > 0
	PRINTL
