;-------------------------------------------------
;能力の表示 PRINT_ABLと交換
;-------------------------------------------------
@SHOW_INFO_ABL
U = 0
REPEAT 40
	SIF COUNT >= 4 && COUNT <=9
		CONTINUE
	SIF COUNT >= 18 && COUNT <= 19
		CONTINUE
	SIF COUNT >= 24 && COUNT <= 29
		CONTINUE
	SIF COUNT >= 34 && COUNT <= 36
		CONTINUE
;	SIF COUNT == 38
;		CONTINUE
	;男ならV감각と레즈끼と레즈중독は表示しない
	SIF TALENT:122 && (COUNT == 2 || COUNT == 22 || COUNT == 33)
		CONTINUE
	;女ならホモっ気とホモ中毒は表示しない
	SIF TALENT:122 == 0 && (COUNT == 23 || COUNT == 34)
		CONTINUE
	X = COUNT
	SIF ABL:X == 0 
		CONTINUE
	PRINTFORM   %ABLNAME:X% 
	;文字揃え
	IF X <= 3 || X == 17
		PRINT   
	ELSEIF (X >= 10 && X <= 12) || X == 15 
		PRINT     
	ENDIF	
	PRINTFORM - {ABL:X}LV 
	CALL DECIDE_ABLUP,X
	U += 1
	IF U % 4 == 0
		PRINTL 
	ENDIF
REND 
SIF U % 4 != 0
	PRINTL 
U = 0
REPEAT 3
	X = COUNT + 50
	SIF ABL:X == 0 
		CONTINUE
	PRINTFORM   %ABLNAME:X% 
	IF X == 52
		PRINTFORM     - {ABL:X}LV   
	ELSE
		PRINTFORM - {ABL:X}LV   
	ENDIF
	U += 1
	IF U % 4 == 0
		PRINTL 
	ENDIF
REND

REPEAT 12
	X = COUNT + 70
	SIF ABL:X == 0 
		CONTINUE
	PRINTFORM   %ABLNAME:X% 
	PRINTFORM - {ABL:X}LV   
	U += 1
	IF U % 4 == 0
		PRINTL 
	ENDIF
REND
SIF U % 4 != 0
	PRINTL 

