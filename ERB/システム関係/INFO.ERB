;-------------------------------------------------
;素質の表示 PRINT_TALENTと交換
;-------------------------------------------------
@SHOW_TALENT
U = 0
S = 0

;色を変える素質を追加するにはREPEAT XのXを+1してCOUNT == {X - 1}の処理を追加, COUNT == {X - 1}の処理をCOUNT == Xに修正してください。
;X+1が{6の倍数}になった時はSELECTCASE U内のCASE 0以降を参考に, 処理を追加して下さい。S == {6の倍数}に変えるだけでおkです。
;COUNTの小さい順に素質が表示されます。表示順を変更する場合, COUNT == nの数字を入れ替えて下さい。ただし, BREAKの処理は必ず最後に。
REPEAT 31
	IF S > 0 || (S % 6 == 0)
		SELECTCASE U
			CASE 0
				IF S == 6
					PRINTL 
					U += 1
				ENDIF
			CASE 1
				IF S == 12
					PRINTL 
					U += 1
				ENDIF
			CASE 2;REPEATが19以上の場合の処理
				IF S == 18
					PRINTL 
					U += 1
				ENDIF
			CASE 3;REPEATが19以上の場合の処理
				IF S == 24
					PRINTL 
					U += 1
				ENDIF
			CASE 4;REPEATが19以上の場合の処理
				IF S == 30
					PRINTL 
					U += 1
				ENDIF
			CASE 5;REPEATが19以上の場合の処理
				IF S == 36
					PRINTL 
					U += 1
				ENDIF
		ENDSELECT
	ENDIF

