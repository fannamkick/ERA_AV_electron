;-------------------------------------------------
;購入時に行うキャラの初期設定
;-------------------------------------------------
@CHARA_BUY_SETTING
;難易度EASYで購入したキャラは수명制限が付かない
IF FLAG:5 == 1
	BASE:10 = 0
;難易度NORMALかEXTRAで購入したキャラは수명が2倍
ELSEIF FLAG:5 == 2 || FLAG:5 == 9
	BASE:10 *= 2
ENDIF

;陰毛を生やす設定の場合の処理
IF FLAG:36
	;카나데は毛深いのがコンプレックスです
	IF NO:TARGET == 1
		CFLAG:6 = 14
	;이쿠미はひどいことになっています
	ELSEIF NO:TARGET == 11
		CFLAG:6 = 18
	;外人さんは下の毛の処理は常識です
	ELSEIF NO:TARGET == 9
		CFLAG:6 = 1
	ELSEIF NO:TARGET == 18
		CFLAG:6 = 1
	;미노리は下の毛の発育が悪いのがコンプレックスです
	ELSEIF NO:TARGET == 2
		CFLAG:6 = 7
	;음모 없음なら生えない
	ELSEIF TALENT:125
		CFLAG:6 = -1
	;発育のいい키쿄우以外の15歳以下ならまだ毛が薄い
	ELSEIF BASE:9 <= 15 && NO:TARGET != 5
		CFLAG:6 = 6 
	;それ以外なら12に設定
	ELSE
		CFLAG:6 = 12
	ENDIF
ENDIF

;面接キャラ用
IF NO:TARGET == 51
	CALL INTERVIEW_ADD
	FLAG:90 += 1	;FLAG:90で구인광고の上限回数管理
	IF FLAG:90 < 5	;구인광고は5回まで
		FLAG:1050 = 300
	ENDIF
ENDIF

CALL DEFOLT_GENITALCALL
;着衣設定を採用している場合の処理
SIF FLAG:37
	CALL WEARING_CLOTH_ALL

IF GLOBAL:200 >= 0
	CALL CLEARBONUS_CALL
ELSE
	CALL CALC_BEAUTY	
ENDIF

