;가슴(チェスト)サイズ
;	;基本:身長 * (基礎値:40％ + 脂肪(F):([胸囲加算]体脂肪1%あたり0.2%加算) + 筋肉(M):([M]0%~100%=[胸囲加算]0%~3%)
;	BASE:(LOCAL:4):22 = BASE:(LOCAL:4):20 * (4000 + (F * 2) + (M * 3) ) / 10000
;	;↑としたかったがカップ計算とかの整合のため既存のものに近くなるよう↓
	;基本:身長 * 0.44
	BASE:(LOCAL:4):22 = BASE:(LOCAL:4):20 * 44
	IF TFLAG:400 == 0
		;女(おっぱい) (※ 成熟度(X)で補正 だいたい±1.5cmの範囲)
		X = (X - 60) * 3
		;想定カップサイズはジャストより1cm程度~余裕を持たせておく(大きくなると余裕はより大きめに)
		IF TFLAG:408 == 1		;절벽
			;BT - BU = 3.5cm~7.0cm(AA未満)を想定
			E = 350 + RAND:350 + X
			TFLAG:431 += 100	;절벽はかわいそう補正。기력アップ;
		ELSEIF TFLAG:408 == 2		;빈유
			;BT - BU = 7.0cm~11.5cm(AA~A)を想定
			E = 700 + RAND:450 + X
		ELSEIF TFLAG:408 == 0		;普乳
			;BT - BU = 11.5cm~16.5cm(B~C)を想定
			E = 1150 + RAND:500 + X
		ELSEIF TFLAG:408 == 3		;거유
			;BT - BU = 16.5cm~23.0cm(D~F)を想定
			E = 1650 + RAND:650 + X
		ELSEIF TFLAG:408 == 4		;폭유
			;BT - BU = 23.0cm~31.0cm(G~I)を想定
			E = 2300 + RAND:851 + X
			TFLAG:430 += 100	;폭유は체력アップ
		ELSE				;普乳
			;BT - BU = 7.0cm~11.5cm(B~D)を想定
			E = 700 + RAND:500 + X

		ENDIF
		BASE:(LOCAL:4):21 += E / 1250		;(체중加算)おっぱい重さ(+25cmで+2kgとしてみる)
	ELSEIF TFLAG:400 == 1
		;男:筋肉分を身長*2％加算
		E = M * 2 * BASE:(LOCAL:4):20
		BASE:(LOCAL:4):21 += M / 50		;筋肉重さ加算(M=100あたり2として計算)
	ELSE
		;男の娘:特に補正しない
	ENDIF

	E = E + BASE:(LOCAL:4):22
	BASE:(LOCAL:4):22 = E / 100
	IF E % 100 >= 5
		BASE:(LOCAL:4):22 += 1
	ELSE
		;特になし
	ENDIF



;엉덩이サイズ
	;가슴サイズを基準に身長の数%の補正
	;暫定的に-1.5%~+1.5&とした(胸設定で細身+절벽+乱数最小のとき, さらに-1.5%とかになると変に細くなるかもしれない)
	E = E + BASE:(LOCAL:4):20 * (RAND:16 - RAND:16) / 100
	BASE:(LOCAL:4):24 = E / 100
	IF E % 100 >= 5
		BASE:(LOCAL:4):24 += 1
	ELSE
		;特になし
	ENDIF

