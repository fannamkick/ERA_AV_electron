;=================================================
;キャラの並べ替え
;=================================================
;eraIm@s_ver.0.17βより流用して改造
;;記憶消去薬追加パッチを参考に作成。
;=================================================
@CHARA_SORT
;ローカル変数初期化
K = 0
$INPUT_LOOP_0

PRINTL 여배우 리스트의 정렬순서를 바꿉니다
;PRINTL [0] - 캐릭터 번호 순
PRINTL [1] - 평가액 순
PRINTL [2] - 지도 횟수 순
PRINTL [3] - 성교 경험 순
PRINTL [4] - 애정 경험 순
PRINTL [5] - 매춘 경험 순
PRINTL [6] - 레즈 경험 순
PRINTL [7] - 연령 순
PRINTL [30] - 수동으로 교체한다
PRINTL [999] - 돌아간다

INPUT

IF RESULT == 1
	CALL CHARA_SORT_ESTIMATE
ELSEIF RESULT == 2
	CALL CHARA_SORT_TRAINCOUNT
ELSEIF RESULT == 3
	K = 5
	CALL CHARA_SORT_EXP
ELSEIF RESULT == 4
	K = 23
	CALL CHARA_SORT_EXP
ELSEIF RESULT == 5
	K = 74
	CALL CHARA_SORT_EXP
ELSEIF RESULT == 6
	K = 40
	CALL CHARA_SORT_EXP
ELSEIF RESULT == 7
	CALL CHARA_SORT_OLD
ELSEIF RESULT == 30
	CALL CHARA_SORT_MANUAL
ENDIF

K = 0

SIF RESULT == 999
	RETURN 0

GOTO INPUT_LOOP_0

;-------------------------------------------------
;평가액順ソート
;-------------------------------------------------
@CHARA_SORT_ESTIMATE
PRINTL …정렬 중…

;ローカル変数初期化
F = 0
B = 0
C = 0
D = 0
;@CHARA_SORT_2でのREPEAT用退避変数
G = 0

REPEAT CHARANUM - 1
	F = CHARANUM - COUNT
	CALL CHARA_SORT_ESTIMATE2
	CALL CHARA_SORT_2
	COUNT = CHARANUM - F
REND

PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	;臨死中のキャラは排除
	ELSEIF BASE:COUNT:0 < 1
		CONTINUE
	ELSE
		PRINTFORM [{COUNT}] %NAME:COUNT% 
		TARGET = COUNT
		S = 0
		CALL ESTIMATE_CHARA
		IF S > 0
			PRINTFORM [평가액: {S}포인트]
		ELSE
			PRINTFORM [매각 불가]
		ENDIF
		PRINTL  
	ENDIF
REND
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

PRINTFORML ＜평가액순으로 여배우 리스트를 정렬합니다＞
WAIT

RETURN 999

@CHARA_SORT_ESTIMATE2
B = 1
C = 0
REPEAT F
	SIF COUNT == 0
		CONTINUE
	TARGET = COUNT
	S = 0
	CALL ESTIMATE_CHARA
	IF S > C
		B = COUNT
		C = S
	ENDIF
REND

;-------------------------------------------------
;調教回数順ソート
;-------------------------------------------------
@CHARA_SORT_TRAINCOUNT
PRINTL …정렬 중…

;ローカル変数初期化
F = 0
B = 0
C = 0
D = 0
;@CHARA_SORT_2でのREPEAT用退避変数
G = 0

REPEAT CHARANUM - 1
	F = CHARANUM - COUNT
	CALL CHARA_SORT_TRAINCOUNT2
	CALL CHARA_SORT_2
	COUNT = CHARANUM - F
REND


PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	;臨死中のキャラは排除
	ELSEIF BASE:COUNT:0 < 1
		CONTINUE
	ELSE
		PRINTFORM [{COUNT}] %NAME:COUNT% 
		PRINTFORM [지도 횟수: {CFLAG:COUNT:10}회]
		PRINTL  
	ENDIF
REND
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

PRINTFORML ＜지도 횟수 순으로 여배우 리스트를 정렬합니다＞
WAIT

RETURN 999

@CHARA_SORT_TRAINCOUNT2
B = 1
C = 0
REPEAT F
	SIF COUNT == 0
		CONTINUE
	IF CFLAG:COUNT:10 > C
		B = COUNT
		C = CFLAG:COUNT:10
	ENDIF
REND

;-------------------------------------------------
;経験順ソート
;-------------------------------------------------
@CHARA_SORT_EXP
PRINTL …정렬 중…
;ローカル変数初期化
F = 0
B = 0
C = 0
D = 0
;@CHARA_SORT_2でのREPEAT用退避変数
G = 0
;チェックする経験
;K = 呼び出し元で代入

REPEAT CHARANUM - 1
	F = CHARANUM - COUNT
	CALL CHARA_SORT_EXP2
	CALL CHARA_SORT_2
	COUNT = CHARANUM - F
REND


PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	;臨死中のキャラは排除
	ELSEIF BASE:COUNT:0 < 1
		CONTINUE
	ELSE
		PRINTFORM [{COUNT}] %NAME:COUNT% 
		PRINTFORM [%EXPNAME:K%: {EXP:COUNT:K}회]
		PRINTL  
	ENDIF
REND
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

PRINTFORML ＜%EXPNAME:K% 순으로 여배우 리스트를 정렬합니다＞
WAIT

RETURN 999

@CHARA_SORT_EXP2
B = 1
C = 0
REPEAT F
	SIF COUNT == 0
		CONTINUE
	IF EXP:COUNT:K > C
		B = COUNT
		C = EXP:COUNT:K
	ENDIF
REND

;-------------------------------------------------
;연령順ソート
;-------------------------------------------------
@CHARA_SORT_OLD
PRINTL …정렬 중…
;ローカル変数初期化
F = 0
B = 0
C = 0
D = 0
;@CHARA_SORT_2でのREPEAT用退避変数
G = 0
;チェックする経験
;K = 呼び出し元で代入

REPEAT CHARANUM - 1
	F = CHARANUM - COUNT
	CALL CHARA_SORT_OLD2
	CALL CHARA_SORT_2
	COUNT = CHARANUM - F
REND


PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	;臨死中のキャラは排除
	ELSEIF BASE:COUNT:0 < 1
		CONTINUE
	ELSE
		PRINTFORM [{COUNT}] %NAME:COUNT% 
		PRINT [
			;およその見た目が存在するならそちらで表示, でなければ実연령で表示
			IF BASE:COUNT:8 > 0
				IF BASE:COUNT:7 == 0
					PRINT ?세
				ELSE
					PRINTFORM {BASE:COUNT:7}
					IF BASE:COUNT:8 == 1
						PRINT 대
					ELSEIF BASE:COUNT:8 == 2
						PRINT 대 초반
					ELSEIF BASE:COUNT:8 == 3
						PRINT 대 중반
					ELSEIF BASE:COUNT:8 == 4
						PRINT 대 후반
					ELSEIF BASE:COUNT:8 == 5
						PRINT 세 전후
					ENDIF
				ENDIF
			ELSE
				PRINTFORM {BASE:COUNT:9}세
			ENDIF
		PRINT ]
		PRINTL  
	ENDIF
REND
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

PRINTFORML ＜연령 순으로 여배우 리스트를 정렬합니다＞
WAIT

RETURN 999

@CHARA_SORT_OLD2
B = 1
C = 0
D = 0
REPEAT F
	SIF COUNT == 0
		CONTINUE
	;キャラの연령判定用変数Dを設定(~代など微妙な연령判定用に3倍値を使う)
	D = BASE:COUNT:7 * 3
	IF BASE:COUNT:8 == 1
		D += 28
	ELSEIF BASE:COUNT:8 == 2
		D += 16
	ELSEIF BASE:COUNT:8 == 3
		D += 17
	ELSEIF BASE:COUNT:8 == 4
		D += 29
	ELSEIF BASE:COUNT:8 == 5
		D += 1
	ENDIF
	;외견연령が存在しないなら実연령の3倍値をDに代入
	SIF BASE:COUNT:8 == 0
		D = BASE:COUNT:9 * 3
	IF D > C
		B = COUNT
		C = D
	ENDIF
REND

;-------------------------------------------------
;手動ソート
;-------------------------------------------------
@CHARA_SORT_MANUAL
;ローカル変数初期化
A = 0
B = 0
;@CHARA_SORT_2でのREPEAT用退避変数
G = 0

IF CHARANUM < 1
	PRINTW 배우가 없습니다
	RETURN 0
ENDIF
PRINTL 배우 리스트의 순서를 수동으로 정렬합니다
$INPUT_LOOP_0
PRINTL 누구를 맨 위로 이동시키겠습니까?

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 999
ELSEIF RESULT < 1 || RESULT >= CHARANUM
	PRINTL 잘못된 입력값입니다
	GOTO INPUT_LOOP_0
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	PRINTL 잘못된 입력값입니다
	GOTO INPUT_LOOP_0
ENDIF

PRINTL …정렬 중…

A = RESULT

;Aよりもリスト上位にいるキャラを上から順番に下へ送る
IF A > 1
	C = A - 1
	REPEAT C
		B = 1
		CALL CHARA_SORT_2
	REND
ENDIF
;;※この段階でAは既にリスト先頭に来ている事に注意
;Aよりもリスト下位にいるキャラを上から順番に下へ送る
IF A < CHARANUM - 1
	C = CHARANUM - A - 1
	REPEAT C
		B = 2
		CALL CHARA_SORT_2
	REND
ENDIF

A = 1
PRINTFORML ＜%조사처리(NAME:A,"를")% 맨 위로 이동시켰습니다＞
GOTO INPUT_LOOP_0

;-------------------------------------------------
;登録番号Bのキャラをリストの一番下に移動
;-------------------------------------------------
@CHARA_SORT_2
;現在のCOUNTを退避
G = COUNT

ADDCHARA NO:B
C = CHARANUM-1
;기력・체력コピー
REPEAT 100
	MAXBASE:C:COUNT = MAXBASE:B:COUNT
	BASE:C:COUNT = BASE:B:COUNT
REND
;助手経験コピー
ISASSI:C = ISASSI:B
;素質コピー
REPEAT 999
	TALENT:C:COUNT = TALENT:B:COUNT
REND
;能力コピー
REPEAT 99
	ABL:C:COUNT = ABL:B:COUNT
REND
;経験コピー
REPEAT 999
	EXP:C:COUNT = EXP:B:COUNT
REND
;珠コピー
REPEAT 101
	JUEL:C:COUNT = JUEL:B:COUNT
REND
;刻印コピー
REPEAT 6
	MARK:C:COUNT = MARK:B:COUNT
REND
;CFLAGコピー
REPEAT 999
	CFLAG:C:COUNT = CFLAG:B:COUNT
REND
;相性コピー
REPEAT 999
	RELATION:C:COUNT = RELATION:B:COUNT
REND
;相性コピー
REPEAT 100
	CSTR:C:COUNT = %CSTR:B:COUNT%
REND
	NAME:C = %NAME:B%
	CALLNAME:C = %CALLNAME:B%
	NICKNAME:C = %NICKNAME:B%

;念のため調教対象と助手を空に
TARGET = -1
ASSI = -1

;前回の調教対象・助手フラグを書き換え
IF FLAG:1 == B
	FLAG:1 = C-1
ELSEIF B < FLAG:1
	FLAG:1 -= 1
ENDIF
IF FLAG:2 == B
	FLAG:2 = C-1
ELSEIF B < FLAG:2
	FLAG:2 -= 1
ENDIF

DELCHARA B

;退避していたCOUNTを復帰
COUNT = G

RETURN 0
