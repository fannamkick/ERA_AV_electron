;-------------------------------------------------
;調教時に録画したビデオの売却
;-------------------------------------------------
@SELL_VIDEO

촬영부위C = 0
촬영부위B = 0
촬영부위V = 0
촬영부위A = 0
촬영내용애무 = 0
촬영내용기구 = 0
촬영내용성교 = 0
촬영내용피스트 = 0
촬영내용펠라 = 0
촬영경향봉사 = 0
촬영경향가학 = 0
촬영경향SM = 0
촬영경향자위 = 0
촬영특수로션 = 0
촬영특수약물 = 0
촬영특수긴박 = 0
촬영특수착유 = 0
촬영특수스캇 = 0
촬영특수난교 = 0
촬영특수야외 = 0
촬영특수촉수 = 0
촬영특수레즈 = 0
촬영특수후타나리 = 0
촬영특수거품춤 = 0



X = 0

;録画終了の分のカウントを削る
TFLAG:70 -= 1

;有効なビデオを録画してなければここで終了
SIF TFLAG:70 <= 0
	RETURN 0

DRAWLINE

;ビデオ価格
P = 0
;商売人によるビデオ価格加算
Q = 0

;ビデオ촬영내용分析用フラグ
;行われている調教
T = 0
;助手プレイかどうか
U = 0
;その調教で有利になる能力
;△折角技術系ABLがあるので, E:1など増やすことも視野
E = 0
;加算額
G = 0

;撮影進行時の状況。bit値の立て方は撮影開始時の状況: FLAG:22に準拠
F = FLAG:22

;撮影回数分繰り返します
REPEAT TFLAG:70
	;FLAG:11~21に촬영내용が保存されている。内容はSELECTCOM+(ASSIPLAY*1000)
	LOCAL = COUNT + 11
	T = FLAG:LOCAL % 1000
	U = 0
	SIF FLAG:LOCAL >= 1000
		U = 1

	;着脱系の処理
	;撮影中に코스프레しだしたり脱ぎだしたりしたときの処理が入っていない
	;たぶん信念なのでCOMABLEでできなくしておいてもいいかも
	;야외 플레이
	IF T == 54
		IF F & 1
			F -= 1
		ELSE
			G = 500
			촬영특수야외 += 4
			F |= 1
		ENDIF
	;목욕탕 플레이
	ELSEIF T == 58
		IF F & 2
			F -= 2
		ELSE
			F |= 2
		ENDIF
	;밧줄
	ELSEIF T == 44
		IF F & 8
			F -= 8
		ELSE
			G = 500
			촬영경향SM += 4
			촬영특수긴박 += 4
			F |= 8
		ENDIF
	;바이브
	ELSEIF T == 11
		G = 300
		촬영부위V += 3
		촬영내용기구 += 3
		IF F & 16
			F -= 16
		ELSE
			F |= 16
		ENDIF
	;애널바이브
	ELSEIF T == 13
		G = 700
		촬영부위A += 3
		촬영내용기구 += 3
		IF F & 32
			F -= 32
		ELSE
			F |= 32
		ENDIF
	;관장
	ELSEIF T == 46
		;관장が評価されるのは失禁時のみ
		IF F & 64
			G = 1500
			촬영부위A += 3
			촬영내용기구 += 3
			촬영경향SM += 5
			촬영특수스캇 += 20
			F -= 64
		ELSE
			F |= 64
		ENDIF
	;獣姦
	ELSEIF T == 89
		IF F & 128
			G = 3000
			F -= 128
		ELSE
			F |= 128
		ENDIF
	;촉수생물
	ELSEIF T == 100
		IF F & 256
			G = 5000
			F -= 256
		ELSE
			G = 100
			촬영특수촉수 += 5
			F |= 256
		ENDIF
	;샤워
	ELSEIF T == 18
		IF F & 512
			F -= 512
		ELSE
			F |= 512
			G = 100
		ENDIF
	;삼각목마
	ELSEIF T == 137
		IF F & 8
			F -= 1024
		ELSE
			G = 2000
			촬영경향SM += 4
			촬영경향SM += 4
			촬영특수긴박 += 4
			F |= 1024
		ENDIF
						;****슬라임パッチ追加ここから****
	;슬라임 생성
	ELSEIF T == 150
		IF F & 2056
			G = 3000
			F -= 2056
		ELSE
			G = 300
			촬영특수로션 += 5
			F |= 2056
		ENDIF
						;****슬라임パッチ追加ここまで****
	;通常の調教
	;COM:愛撫を見る
	ELSEIF T == 0
		G = 50
		촬영부위C += 2
		촬영부위B += 2
		촬영내용애무 += 3
	;COM:커닐링구스を見る
	ELSEIF T == 1
		G = 50
		촬영부위C += 3
		촬영내용애무 += 3
	;COM:애널애무を見る
	ELSEIF T == 2
		;애널바이브責めの場合
		IF (F & 32)
			G = 600
			촬영부위A += 3
			촬영내용애무 += 3
			촬영내용기구 += 3
		ELSE
			G = 100
			촬영부위A += 3
			촬영내용애무 += 3
		ENDIF
	;COM:자위を見る
	ELSEIF T == 3
		E = 31
		;両穴자위を見る
		IF (F & 16) && (F & 32)
			G = 1800
			촬영부위V += 2
			촬영부위A += 2
			촬영내용기구 += 3
			촬영경향자위 += 5
		;바이브자위を見る
		ELSEIF (F & 16)
			G = 1200
			촬영부위V += 3
			촬영내용기구 += 3
			촬영경향자위 += 3
		;애널바이브자위を見る
		ELSEIF (F & 32)
			G = 1300
			촬영부위A += 3
			촬영내용기구 += 3
			촬영경향자위 += 3
		;샤워자위を見る
		ELSEIF (F & 512)
			G = 1000
			촬영부위C += 2
			촬영부위B += 2
			촬영내용기구 += 3
			촬영경향자위 += 3
		;通常자위を見る
		ELSE
			G = 500
			촬영부위C += 2
			촬영부위B += 2
			촬영경향자위 += 3
		ENDIF
	;COM:펠라한다を見る
	ELSEIF T == 4
		E = 32
		G = 200
		촬영부위C += 3
		촬영내용애무 += 3
		SIF TALENT:121
			촬영특수후타나리 += 10
	;COM:가슴애무を見る
	ELSEIF T == 5
		G = 100
		촬영부위B += 3
		촬영내용애무 += 3
	;COM:키스한다を見る
	ELSEIF T == 6
		G = 100
		촬영경향봉사 += 3
	;조개벌리기を見る
	ELSEIF T == 7
