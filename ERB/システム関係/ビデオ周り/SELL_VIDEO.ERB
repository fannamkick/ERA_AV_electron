	;COM:후배위애널を見る
	ELSEIF T == 27
		E = 30
		G = 1800
		촬영부위A += 3
		촬영내용성교 += 3
	;COM:대면좌위애널を見る
	ELSEIF T == 28
		E = 30
		G = 1200
		촬영부위A += 3
		촬영내용성교 += 3
	;COM:배면좌위애널を見る
	ELSEIF T == 29
		E = 30
		G = 2000
		촬영부위A += 3
		촬영내용성교 += 3
	;COM:수음を見る
	ELSEIF T == 30
		E = 32
		G = 300
		촬영경향봉사 += 3
	;COM:펠라치오を見る
	ELSEIF T == 31
		E = 32
		G = 500
		촬영경향봉사 += 3
		촬영내용펠라 += 3
	;COM:파이즈리を見る
	ELSEIF T == 32
		E = 32
		G = 650
		촬영부위B += 3
		촬영경향봉사 += 3
	;COM:스마타を見る
	;擬似性交でとってるんだろうけどいったんCO
	ELSEIF T == 33
		E = 32
		G = 770
		촬영부위C += 3
		;촬영내용성교 += 3
		촬영경향봉사 += 3
	;COM:기승위を見る
	ELSEIF T == 34
