	PRINTFORML [18] - 트렁크
	PRINTFORML [19] - 복서 팬티
	PRINTFORML [20] - 부메랑 팬티
ENDIF
DRAWLINE
PRINTFORML [999] - 돌아간다
$INPUT_LOOP
INPUT

X = RESULT

	IF RESULT == X && X != 999 && X <= Y && X != 18 && X != 19 && X != 20
		CFLAG:177 = X
		PRINTFORM 《
		PRINTFORM 팬티 디자인은 
		CALL PRINT_UNDERWEAR_UNDER
		PRINTFORMW  입니다》
		IF CFLAG:177 != 12 && CFLAG:177 != 11 && CFLAG:177 != 14 && CFLAG:177 != 10
			CALL CHOICE_UNDER_COLOR
		ELSE
			CFLAG:176 = 99
		ENDIF
	ELSEIF RESULT >= 18 && X <= Y && X != 999 && TALENT:122 == 1
		CFLAG:177 = X
		PRINTFORM 《
		PRINTFORM 팬티 디자인은 
		CALL PRINT_UNDERWEAR_UNDER
		PRINTFORMW  입니다》
		IF CFLAG:177 != 12 && CFLAG:177 != 11 && CFLAG:177 != 14 && CFLAG:177 != 10
			CALL CHOICE_UNDER_COLOR
		ENDIF
	ELSEIF RESULT == 999
		RETURN 999
	ELSE
		GOTO INPUT_LOOP
	ENDIF

