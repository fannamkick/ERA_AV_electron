@TAILOR_UNDER_MAIN

IF TALENT:116 == 0 && TALENT:135 == 0 && (TALENT:132 == 0 || TALENT:109 == 0)
	CALL CHOICE_TOPS
ELSE
	CALL CHOICE_UNDER
ENDIF

;===========================================================
;トップスの種類
;===========================================================
@CHOICE_TOPS

X = 0
Y = 19

PRINTFORML □브래지어 일람
PRINTFORML 소지금: {MONEY}포인트
DRAWLINE
PRINTFORML [ 0] - 기본 브래지어
PRINTFORML [ 1] - 하프컵 브래지어
PRINTFORML [ 2] - 프릴 브래지어
PRINTFORML [ 3] - 스포츠 브래지어
PRINTFORML [ 4] - 자수 브래지어
PRINTFORML [ 5] - 실크 브래지어
PRINTFORML [ 6] - 마이크로 비키니 브래지어
PRINTFORML [ 7] - 줄무늬 브래지어
PRINTFORML [ 8] - 스팽글 브래지어
PRINTFORML [ 9] - 튜브 탑 브래지어
PRINTFORML [10] - 반창고
PRINTFORML [11] - 니플리스
PRINTFORML [12] - 페더 모티브 브라
PRINTFORML [13] - 가죽 브래지어
PRINTFORML [14] - 붕대
PRINTFORML [15] - 체크무늬 브래지어
PRINTFORML [16] - 오픈 브래지어
PRINTFORML [17] - 시스루 레이스 브래지어
PRINTFORML [18] - 실크 뷔스티에
PRINTFORML [19] - 가죽 뷔스티에
DRAWLINE
PRINTFORML [999] - 돌아간다
$INPUT_LOOP
INPUT

X = RESULT

	IF RESULT == X && X != 999 && X <= Y
		CFLAG:175 = X
		PRINTFORM 《브래지어 디자인은 
		CALL PRINT_UNDERWEAR_TOPS
		PRINTFORMW  입니다》
		IF CFLAG:175 != 12 && CFLAG:175 != 11 && CFLAG:175 != 14 && CFLAG:175 != 10
			CALL CHOICE_TOPS_COLOR
		ELSE
			CFLAG:174 = 99
			CALL CHOICE_UNDER
		ENDIF
	ELSEIF RESULT == 999
		RETURN 999
	ELSE
		GOTO INPUT_LOOP
	ENDIF

