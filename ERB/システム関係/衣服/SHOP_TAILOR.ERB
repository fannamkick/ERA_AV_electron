@HAIRCOLOR
C = 1000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	A = 0
	RETURN 0
ENDIF

$INPUT_LOOP_52

PRINTL □머리색 일람
PRINTFORML 소지금: {MONEY}포인트
DRAWLINE

PRINTL  [ 0] - 검은색
PRINTL  [ 1] - 짙은색
PRINTL  [ 2] - 금빛
PRINTL  [ 3] - 은빛
PRINTL  [ 4] - 붉은색
PRINTL  [ 5] - 푸른색
PRINTL  [ 6] - 녹색
PRINTL  [ 7] - 핑크빛
PRINTL  [ 8] - 보라색
PRINTL  [ 9] - 탈색한다
PRINTL  [10] - 갈색
PRINTL  [99] - 원래 색으로 되돌린다
DRAWLINE
PRINTL  [999] - 돌아간다

INPUT

;今の髪色と同じ場合は染めない(地毛色→染色同色も不可(現実的に意味ないことはしない))
IF RESULT == CFLAG:600
	PRINTFORMW 같은 색으로 바꿀 수 없습니다
	GOTO INPUT_LOOP_52

;999は前の選択肢に戻る
ELSEIF RESULT == 999
	RETURN 1

;不正な値は弾く
ELSEIF RESULT != 99 && RESULT >= 11
	GOTO INPUT_LOOP_52

;地毛の色に戻す以外の選択肢を選んだ場合の処理(肢0－10)
ELSEIF RESULT != 99 && RESULT != CFLAG:600 
	PRINTFORM %타겟은()% 머리를
	IF RESULT == 0
		PRINTFORM 검은색으로 물들였
	ELSEIF RESULT == 1
		PRINTFORM 짙은색으로 물들였
	ELSEIF RESULT == 2
		PRINTFORM 금빛으로 물들였
	ELSEIF RESULT == 3
		PRINTFORM 은빛으로 물들였
	ELSEIF RESULT == 4
		PRINTFORM 븕은색으로 물들였
	ELSEIF RESULT == 5
		PRINTFORM 푸른색으로 물들였
	ELSEIF RESULT == 6
		PRINTFORM 녹색으로 물들였
	ELSEIF RESULT == 7
		PRINTFORM 핑크빛으로 물들였
	ELSEIF RESULT == 8
		PRINTFORM 보라색으로 물들였
	ELSEIF RESULT == 9
		PRINTFORM 탈색했
	ELSEIF RESULT == 10
		PRINTFORM 갈색으로 물들였
	ENDIF
	PRINTFORMW 다
	CFLAG:TARGET:600 = RESULT
	CFLAG:TARGET:601 = 1
	MONEY -= C	

ELSEIF RESULT == 99 && CFLAG:TARGET:601 == 1

	IF MONEY < 1500
		PRINTW 소지금이 부족합니다
		GOTO INPUT_LOOP_52
	ENDIF

	;地毛色の値がある→0でないとき
	;未入力の時はCSVCFLAGを取ってこれる。未指定なら0のはず
	IF CFLAG:TARGET:603 
		PRINTFORMW %타겟은()% 머리를 원래색으로 되돌렸다.
		CFLAG:TARGET:600 = CFLAG:TARGET:603
	;初期設定で髪を染めているキャラは, 地毛を黒髪とみなします。
	;CFLAG:603をCSVで指定することでみなしを免れます
	ELSEIF CSVCFLAG(NO:TARGET,601) == 1
		PRINTFORMW %타겟은()% 머리를 원래색으로 되돌렸다.
		CFLAG:TARGET:600 = 0
	ELSE
		PRINTFORMW %타겟은()% 머리를 원래색으로 되돌렸다.
		CFLAG:TARGET:600 = CSVCFLAG(NO:TARGET,600)
	ENDIF
	;染髪なしにする。
	CFLAG:TARGET:601 = 0
	MONEY -= 1500

ELSEIF RESULT == 99 && CFLAG:TARGET:601 == 0
	PRINTFORMW %타겟은()% 염색을 하지 않았습니다.
	GOTO INPUT_LOOP_52
ELSE	
	GOTO INPUT_LOOP_52
ENDIF
RETURN 1
