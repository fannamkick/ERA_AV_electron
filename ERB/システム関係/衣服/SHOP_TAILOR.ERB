;-------------------------------------------------
;仕立屋用メンバーリスト
;-------------------------------------------------
@LIFE_LIST_TAILOR
REPEAT CHARANUM
	;主人公は排除
	SIF COUNT == 0
		CONTINUE
	;臨死中のキャラは排除
	SIF BASE:COUNT:0 < 1
		CONTINUE
	TARGET = COUNT
	PRINTFORM  [{COUNT}] %NAME:COUNT% 
	IF CFLAG:41 && (CFLAG:45 >= 0 || CFLAG:46 >= 0)
		PRINT / 
		CALL PRINT_CLOTHTYPE_MAIN2
	ELSEIF CFLAG:41 && (CFLAG:43 >= 0 || CFLAG:44 >= 0)
		PRINT / 속옷
	ELSE
		PRINT / 전라
	ENDIF
	IF CFLAG:42 && CFLAG:47 >= 0
		PRINT / 
		CALL PRINT_CLOTHTYPE_SPECIAL
	ENDIF
	PRINTL 
REND
