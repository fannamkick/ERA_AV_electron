;-------------------------------------------------
;채찍
;SM系コマンド
;-------------------------------------------------
@COM41

PRINTL 채찍
SAVESTR:0 = 채찍
CALL TRAIN_MESSAGE_B

;実際には苦痛があるためもっと체력기력をもっていかれる
LOSEBASE:0 += 100
LOSEBASE:1 += 80

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
SOURCE:14 = 1000

;PALAM:苦痛をみる
IF PALAM:9 < PALAMLV:1
	SOURCE:6 = 1000
ELSEIF PALAM:9 < PALAMLV:2
	SOURCE:6 = 1500
ELSEIF PALAM:9 < PALAMLV:3
	SOURCE:6 = 2200
ELSEIF PALAM:9 < PALAMLV:4
	SOURCE:6 = 3000
ELSEIF PALAM:9 >= PALAMLV:4
	SOURCE:6 = 4000
ENDIF

						;****슬라임パッチ追加ここから****
IF ITEM:206 >= 1 && TEQUIP:90 == 0
	TIMES LOSEBASE:0 , 0.80
	TIMES LOSEBASE:1 , 0.80
	TIMES SOURCE:6 , 1.50
	TIMES SOURCE:14 , 0.80
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +2
	EXP:40 += 2
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +2
	EXP:41 += 2
ENDIF

SIF ASSIPLAY == 0 && ABL:21 >= 2
	TFLAG:30 += 1

;애정경험
E = 1
IF CFLAG:2 >= 1000 && (ABL:21 >= 3 || TALENT:88) && ASSIPLAY == 0
	PRINTFORML %EXPNAME:23%+{E}
	EXP:23 += E
ENDIF
E = 0

RETURN 1
