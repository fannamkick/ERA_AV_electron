ELSEIF ABL:17 == 1
	SOURCE:7 += 50
	SOURCE:10 += 50
	TIMES A, 1.20
ELSEIF ABL:17 == 2
	SOURCE:7 += 150
	SOURCE:10 += 150
	TIMES A, 1.40
