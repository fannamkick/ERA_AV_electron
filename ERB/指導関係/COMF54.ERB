;------------------------------------------------------------
;야외 플레이
;奴隷を야외に連れて行く
;------------------------------------------------------------
@COM54

PRINTL 촬영세트 변경
SAVESTR:0 = 촬영세트 변경


;屋外への出入り
;終了時は修正なし
IF TEQUIP:54
	TEQUIP:54 = 0
	RETURN 1
ENDIF

IF ABL:17 <= 4
	LOSEBASE:1 += 50
ELSEIF ABL:17 == 5
	LOSEBASE:1 += 40
ELSEIF ABL:17 == 6
	LOSEBASE:1 += 30
ELSEIF ABL:17 == 7
	LOSEBASE:1 += 20
ELSEIF ABL:17 == 8
	LOSEBASE:1 += 10
ELSEIF ABL:17 >= 9
	LOSEBASE:1 += 0
ENDIF



A = 500
B = 500

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES A , 0.80
ELSEIF PALAM:5 < PALAMLV:2
	TIMES A , 0.90
ELSEIF PALAM:5 < PALAMLV:3
	TIMES A , 1.00
ELSEIF PALAM:5 < PALAMLV:4
	TIMES A , 1.10
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES A , 1.20
ENDIF
;ABL:노출벽をみる
IF ABL:17 == 0
	SOURCE:7 += 0
	SOURCE:10 += 0
	TIMES A, 1.00
ELSEIF ABL:17 == 1
	SOURCE:7 += 50
	SOURCE:10 += 50
	TIMES A, 1.20
ELSEIF ABL:17 == 2
	SOURCE:7 += 150
	SOURCE:10 += 150
	TIMES A, 1.40
ELSEIF ABL:17 == 3
	SOURCE:7 += 400
	SOURCE:10 += 400
	TIMES A, 1.60
ELSEIF ABL:17 == 4
	SOURCE:7 += 750
	SOURCE:10 += 750
	TIMES A, 2.00
ELSE
	SOURCE:7 += 1300
	SOURCE:10 += 1300
	TIMES A, 3.00
ENDIF
;ABL:마조끼をみる
IF ABL:21 == 0
	TIMES A , 0.80
ELSEIF ABL:21 == 1
	TIMES A , 1.00
ELSEIF ABL:21 == 2
	TIMES A , 1.30
ELSEIF ABL:21 == 3
	TIMES A , 1.60
ELSEIF ABL:21 == 4
	TIMES A , 2.00
ELSE
	TIMES A , 3.00
ENDIF

;튀고 싶어함
SIF TALENT:28
	TIMES A , 1.50
;해방
SIF TALENT:33
	TIMES A , 1.50

;겁쟁이
SIF TALENT:10
	TIMES B , 2.00
;수줍음
SIF TALENT:35
	TIMES B , 2.00

;노출광
IF TALENT:89
	TIMES A , 2.00
	TIMES B , 0.50
ENDIF

SOURCE:12 += A
SOURCE:14 += B
SOURCE:16 += A/2

$INPUT_LOOP_00
IF TEQUIP:54 == 0
	PRINTFORML 어디로 갑니까?
	PRINTL  [1] - 야외
	PRINTL  [2] - 교실 세트
	PRINTL  [3] - 수영장
	INPUT
	IF RESULT == 1
		TEQUIP:54 = 1
	ELSEIF RESULT == 2
		TEQUIP:54 = 2
	ELSEIF RESULT == 3
		TEQUIP:54 = 3
	ELSE
		GOTO INPUT_LOOP_00
	ENDIF
ENDIF	

CALL TRAIN_MESSAGE_B

EXP:12 += 1
PRINTFORML 야외노출경험 +1

;야외 플레이が始めての場合
IF TEQUIP:54 && CFLAG:5 == 0
	PRINTFORML 이상경험 +1
	EXP:50 += 1
	CFLAG:5 = 1
ENDIF

RETURN 1

;야외 플레이
@EQUIP_COM54

IF TEQUIP:54 == 1 
	PRINTL ＜야외 플레이중＞
ELSEIF TEQUIP:54 == 2
	IF TIME == 0
		PRINTL ＜교실 플레이중(낮)＞
	ELSE
		PRINTL ＜교실 플레이중(방과후)＞
	ENDIF
ELSEIF TEQUIP:54 == 3
	PRINTL ＜야외 플레이중(수영장)＞
