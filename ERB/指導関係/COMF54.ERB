	SOURCE:10 += 400
	TIMES A, 1.60
ELSEIF ABL:17 == 4
	SOURCE:7 += 750
	SOURCE:10 += 750
	TIMES A, 2.00
ELSE
	SOURCE:7 += 1300
	SOURCE:10 += 1300
	TIMES A, 3.00
ENDIF
;ABL:마조끼をみる
IF ABL:21 == 0
	TIMES A , 0.80
ELSEIF ABL:21 == 1
	TIMES A , 1.00
ELSEIF ABL:21 == 2
	TIMES A , 1.30
ELSEIF ABL:21 == 3
	TIMES A , 1.60
ELSEIF ABL:21 == 4
	TIMES A , 2.00
ELSE
	TIMES A , 3.00
ENDIF

;튀고 싶어함
SIF TALENT:28
	TIMES A , 1.50
;해방
SIF TALENT:33
	TIMES A , 1.50

;겁쟁이
SIF TALENT:10
	TIMES B , 2.00
;수줍음
SIF TALENT:35
	TIMES B , 2.00
;노출광
IF TALENT:89
	TIMES A , 2.00
	TIMES B , 0.50
ENDIF

SOURCE:12 += A
SOURCE:14 += B
SOURCE:16 += A/2

;---------------------------------------------
;レズ・ホモ経験の追加
;---------------------------------------------
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

SIF ASSIPLAY == 0 && ABL:17 >= 3
	TFLAG:30 += 1

RETURN 1
