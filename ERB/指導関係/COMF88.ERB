;-------------------------------------------------
;제모
;過激なコマンド: 調教対象の陰毛を剃り上げる
;-------------------------------------------------
@COM88

PRINTL 제모

;-------------------------------------------------
;実行できるかの判定
;-------------------------------------------------
;밧줄사용중なら自動成功
SIF TEQUIP:44
	GOTO SUCCESS_LOOP

A = 0
S = 0

;すべての命令に共通の要素を考慮
;(従順が高いと命令に従いやすいなど)
CALL COM_ORDER

;ABL:욕망
IF ABL:11
	SIF S
		PRINT  + 
	A += ABL:11 * 3
	PRINTS ABLNAME:11
	PRINTV 'LV,ABL:11,'(,ABL:11 * 3,')
	S = 1
ENDIF
;ABL:노출벽
IF ABL:17
	SIF S
		PRINT  + 
	A += ABL:17 * 4
	PRINTS ABLNAME:17
	PRINTV 'LV,ABL:17,'(,ABL:17 * 4,')
	S = 1
ENDIF
;MARK:쾌락각인
IF MARK:1
	SIF S
		PRINT  + 
	A += MARK:1 * 3
	PRINTS MARKNAME:1
	PRINTV 'LV,MARK:1,'(,MARK:1 * 3,')
	S = 1
ENDIF

;PALAM:욕정
IF PALAM:5 < PALAMLV:1
	L = 0
ELSEIF PALAM:5 < PALAMLV:2
	L = 1
ELSEIF PALAM:5 < PALAMLV:3
	L = 2
ELSEIF PALAM:5 < PALAMLV:4
	L = 3
ELSEIF PALAM:5 < PALAMLV:5
	L = 4
ELSE
	L = 5
ENDIF
IF L
	SIF S
		PRINT  + 
	A += L * 3
	PRINTS PALAMNAME:5
	PRINTV 'LV,L,'(,L * 3,')
	S = 1
ENDIF

;자제심
IF TALENT:20
	PRINT  - 
	A -= 5
	PRINTS TALENTNAME:20
	PRINTV '(,5,')
	S = 1
ENDIF
;수줍음
IF TALENT:35
	PRINT  - 
	A -= 5
	PRINTS TALENTNAME:35
	PRINTV '(,5,')
	S = 1
ENDIF
;부끄럼 없음
IF TALENT:36
	SIF S
		PRINT  + 
	A += 2
	PRINTS TALENTNAME:36
	PRINTV '(,2,')
	S = 1
ENDIF
;노출광
IF TALENT:89
	SIF S
		PRINT  + 
	A += 10
	PRINTS TALENTNAME:89
	PRINTV '(,10,')
	S = 1
ENDIF

;合計を表示(40以上で実行)
PRINT  = 
PRINTV A

;難易度上昇
;공개で+10
V = 36
SIF TEQUIP:53 || TEQUIP:54
	V += 10

SIF A < V
	PRINT  < 
SIF A == V
	PRINT  = 
SIF A > V
	PRINT  > 
PRINT 실행치 
PRINTV V

WAIT

;実行できない
SIF A < V
	RETURN 0

$SUCCESS_LOOP

SAVESTR:0 = 제모
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;実行決定
;-------------------------------------------------
;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 5
LOSEBASE:1 += 100

SOURCE:14 = 1000

;밧줄사용중
SIF TEQUIP:53
	SOURCE:14 += 3000

;비디오 촬영중
IF TEQUIP:53
	SOURCE:10 = 50
	SOURCE:11 = 100
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	SOURCE:12 = 3600
ELSEIF PALAM:5 < PALAMLV:2
	SOURCE:12 = 3900
ELSEIF PALAM:5 < PALAMLV:3
	SOURCE:12 = 4200
ELSEIF PALAM:5 < PALAMLV:4
	SOURCE:12 = 4500
ELSEIF PALAM:5 >= PALAMLV:4
	SOURCE:12 = 5000
ENDIF

;노출벽をみる
;노출벽が高くなるにつれ제모への수줍음が減っていく
IF ABL:17 == 0
	SOURCE:7 = 0
	SOURCE:13 = 7000
ELSEIF ABL:17 == 1
	SOURCE:7 = 60
	SOURCE:13 = 6000
ELSEIF ABL:17 == 2
	SOURCE:7 = 200
	SOURCE:13 = 5000
ELSEIF ABL:17 == 3
	SOURCE:7 = 600
	SOURCE:13 = 4000
ELSEIF ABL:17 == 4
	SOURCE:7 = 1000
	SOURCE:13 = 3000
ELSE
	SOURCE:7 = 2000
	SOURCE:13 = 2000
ENDIF

;ABL:마조끼をみる
IF ABL:21 == 0
	TIMES SOURCE:7 , 0.80
	TIMES SOURCE:12 , 1.00
	SOURCE:10 = 100
	SOURCE:11 = 100
ELSEIF ABL:21 == 1
	TIMES SOURCE:7 , 1.00
	TIMES SOURCE:12 , 1.20
	SOURCE:10 = 200
	SOURCE:11 = 300
ELSEIF ABL:21 == 2
	TIMES SOURCE:7 , 1.30
	TIMES SOURCE:12 , 1.40
	SOURCE:10 = 400
	SOURCE:11 = 700
ELSEIF ABL:21 == 3
	TIMES SOURCE:7 , 1.40
	TIMES SOURCE:12 , 1.50
	SOURCE:10 = 700
	SOURCE:11 = 1200
ELSEIF ABL:21 == 4
	TIMES SOURCE:7 , 1.70
	TIMES SOURCE:12 , 1.70
	SOURCE:10 = 1100
	SOURCE:11 = 1800
ELSE
	TIMES SOURCE:7 , 2.00
	TIMES SOURCE:12 , 2.00
	SOURCE:10 = 1500
	SOURCE:11 = 2500
ENDIF

;場所をみる
;공개
IF TEQUIP:53 || TEQUIP:54
	TIMES SOURCE:12 , 2.50
	TIMES SOURCE:14 , 2.50
;큰거울の前
ELSEIF TEQUIP:57
	TIMES SOURCE:12 , 1.50
	TIMES SOURCE:14 , 1.50
;風呂場
ELSEIF TEQUIP:58
	TIMES SOURCE:12 , 0.50
	TIMES SOURCE:14 , 0.50
ENDIF

A = 100
IF EXP:31 < EXPLV:1
	TIMES A , 3.00
ELSEIF EXP:31 < EXPLV:2
	TIMES A , 2.50
ELSEIF EXP:31 < EXPLV:3
	TIMES A , 2.00
ELSEIF EXP:31 < EXPLV:4
	TIMES A , 1.00
ELSEIF EXP:31 < EXPLV:5
	TIMES A , 0.80
ELSE
	TIMES A , 0.60
ENDIF

;겁쟁이
SIF TALENT:10
	TIMES A , 1.20

;反抗的
SIF TALENT:11
	TIMES A , 2.00

;프라이드 높음
SIF TALENT:15
	TIMES A , 2.00

;프라이드 낮음
SIF TALENT:17
	TIMES A , 0.80

;자제심
SIF TALENT:20
	TIMES A , 1.50

;감정부족
SIF TALENT:22
	TIMES A , 0.60

;튀고 싶어함
SIF TALENT:28
	TIMES A , 0.80

;억압
SIF TALENT:32
	TIMES A , 3.00

;저항
SIF TALENT:34
	TIMES A , 3.00

;수줍음
SIF TALENT:35
	TIMES A , 3.50

;부끄럼 없음
SIF TALENT:36
	TIMES A , 0.50

;노출광
IF TALENT:89
	SOURCE:7 += 500
	TIMES SOURCE:12 , 1.50
ENDIF

SOURCE:14 += A * 5

;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;奴隷のV⇔調教者の指の汚れが移動
STAIN:3 |= STAIN:PLAYER:1
STAIN:PLAYER:1 |= STAIN:3

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
;レズ・ホモ経験
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +2
	EXP:40 += 2
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +2
	EXP:41 += 2
ENDIF

;애정경험
E = 2
IF CFLAG:2 >= 1000 && ASSIPLAY == 0
	PRINTFORML %EXPNAME:23%+{E}
	EXP:23 += E
ENDIF

;-------------------------------------------------
;その他の処理
;-------------------------------------------------
;제모を実行
CFLAG:6 = 1

;굴복각인3に相当
TFLAG:200 = 3

RETURN 1
;
