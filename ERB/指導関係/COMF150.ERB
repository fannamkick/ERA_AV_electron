@COM150
;슬라임 생성

PRINTL 슬라임 생성
SAVESTR:0 = 슬라임 생성
CALL TRAIN_MESSAGE_B

IF TEQUIP:150
	TEQUIP:150 = 0

	;슬라임 질내진입
	TEQUIP:151 = 0
	;슬라임 항문진입
	TEQUIP:152 = 0
	;슬라임 구욕
	TEQUIP:154 = 0
	UP:3 -= 8000
ELSE
	TEQUIP:150 = 1

	LOSEBASE:0 = 10
	LOSEBASE:1 = 70

;ABL:C感覚をみる
IF ABL:0 == 0
	SOURCE:0 = 20
	SOURCE:3 = 25
ELSEIF ABL:0 == 1
	SOURCE:0 = 100
	SOURCE:3 = 50
ELSEIF ABL:0 == 2
	SOURCE:0 = 500
	SOURCE:3 = 80
ELSEIF ABL:0 == 3
	SOURCE:0 = 1200
	SOURCE:3 = 100
ELSEIF ABL:0 == 4
	SOURCE:0 = 2000
	SOURCE:3 = 115
ELSE
	SOURCE:0 = 2800
	SOURCE:3 = 125
ENDIF

;ABL:B感覚をみる
IF ABL:1 == 0
	SOURCE:17 = 15
	SOURCE:3 += 25
ELSEIF ABL:1 == 1
	SOURCE:17 = 50
	SOURCE:3 += 50
ELSEIF ABL:1 == 2
	SOURCE:17 = 300
	SOURCE:3 += 80
ELSEIF ABL:1 == 3
	SOURCE:17 = 700
	SOURCE:3 += 100
ELSEIF ABL:1 == 4
	SOURCE:17 = 1100
	SOURCE:3 += 115
ELSE
	SOURCE:17 = 1600
	SOURCE:3 += 125
ENDIF

	SOURCE:9 = 5000
	SOURCE:14 = 200
	
	;겁쟁이
	SIF TALENT:10
		TIMES SOURCE:14 , 2.00
	;감정부족
	SIF TALENT:22
		TIMES SOURCE:14 , 0.60
ENDIF
T = 0
RETURN 1


@EQUIP_COM150
;슬라임지도중
PRINTL ＜슬라임지도중＞

A = 100
;겁쟁이
SIF TALENT:10
	TIMES A , 2.00

;감정부족
SIF TALENT:22
	TIMES A , 0.60

;음란
SIF TALENT:76
	TIMES A , 0.50

LOSEBASE:0 += 20
LOSEBASE:1 += 80

;ABL:C感覚をみる
IF ABL:0 == 0
	SOURCE:0 += 20
	SOURCE:3 = 25
ELSEIF ABL:0 == 1
	SOURCE:0 += 100
	SOURCE:3 += 50
ELSEIF ABL:0 == 2
	SOURCE:0 += 500
	SOURCE:3 += 80
ELSEIF ABL:0 == 3
	SOURCE:0 += 1200
	SOURCE:3 += 100
ELSEIF ABL:0 == 4
	SOURCE:0 += 2000
	SOURCE:3 += 115
ELSE
	SOURCE:0 += 2800
	SOURCE:3 += 125
ENDIF

;ABL:B感覚をみる
IF ABL:1 == 0
	SOURCE:17 += 15
	SOURCE:3 += 25
ELSEIF ABL:1 == 1
	SOURCE:17 += 50
	SOURCE:3 += 50
ELSEIF ABL:1 == 2
	SOURCE:17 += 300
	SOURCE:3 += 80
ELSEIF ABL:1 == 3
	SOURCE:17 += 700
	SOURCE:3 += 100
ELSEIF ABL:1 == 4
	SOURCE:17 += 1100
	SOURCE:3 += 115
ELSE
	SOURCE:17 += 1600
	SOURCE:3 += 125
ENDIF

UP:10 += A * 20
SOURCE:8 += A * 10
SOURCE:14 += A * 5

SOURCE:9 += 2000

TIMES SOURCE:13 , 1.80

;-------------------------------------------------
;사정チェック
;-------------------------------------------------
IF MAXBASE:PLAYER:4 != 0

	B = 0
	;ABL:기교をみる
	IF ABL:12 == 0
		B = 500
	ELSEIF ABL:12 == 1
		B = 600
	ELSEIF ABL:12 == 2
		B = 800
	ELSEIF ABL:12 == 3
		B = 1000
	ELSEIF ABL:12 == 4
		B = 1400
	ELSE
		B = 2000
	ENDIF

	;ABL:従順をみる
	IF ABL:10 == 0
		TIMES B , 0.80
	ELSEIF ABL:10 == 1
		TIMES B , 0.90
	ELSEIF ABL:10 == 2
		TIMES B , 1.00
	ELSEIF ABL:10 == 3
		TIMES B , 1.10
	ELSEIF ABL:10 == 4
		TIMES B , 1.20
	ELSE
		TIMES B , 1.30
	ENDIF

	;PALAM:욕정をみる
	IF PALAM:5 < PALAMLV:1
		TIMES B , 1.00
	ELSEIF PALAM:5 < PALAMLV:2
		TIMES B , 1.10
	ELSEIF PALAM:5 < PALAMLV:3
		TIMES B , 1.20
	ELSEIF PALAM:5 < PALAMLV:4
		TIMES B , 1.30
	ELSEIF PALAM:5 < PALAMLV:5
		TIMES B , 1.40
	ELSE
		TIMES B , 1.50
	ENDIF
	
	;슬라임 질내진입
	SIF TEQUIP:151
		TIMES B , 1.50
	;슬라임 항문진입
	SIF TEQUIP:152
		TIMES B , 1.50
	;슬라임 구욕
	SIF TEQUIP:154
		TIMES B , 1.50

	BASE:PLAYER:4 += B

	;슬라임の快感が高いとキャラの快感のソースも増える
	SOURCE:0 = SOURCE:0 * (BASE:PLAYER:4 + 20000) / 20000
	SOURCE:1 = SOURCE:1 * (BASE:PLAYER:4 + 20000) / 20000
	SOURCE:2 = SOURCE:2 * (BASE:PLAYER:4 + 20000) / 20000
	SOURCE:17 = SOURCE:17 * (BASE:PLAYER:4 + 20000) / 20000

	S = BASE:PLAYER:4
	EJAC = MAXBASE:PLAYER:4

	IF  S > EJAC * 2
		E = 2
	ELSEIF S > EJAC
		E = 1
	ELSE
		E = 0
	ENDIF


	;강절정
	IF E == 2
		SIF TEQUIP:151
			CFLAG:112 += 3
		PRINTL 슬라임강절정

		BASE:PLAYER:4 -= EJAC*2
		SIF BASE:PLAYER:4 >= EJAC
			BASE:PLAYER:4 = EJAC-1
		
		TIMES SOURCE:0 , 2.00
		TIMES SOURCE:1 , 2.00
		TIMES SOURCE:2 , 2.00
		TIMES SOURCE:17 , 2.00
	;通常の절정
	ELSEIF E == 1
		SIF TEQUIP:151
			CFLAG:112 += 1
		PRINTL 슬라임절정

		BASE:PLAYER:4 -= EJAC
		SIF BASE:PLAYER:4 >= EJAC
			BASE:PLAYER:4 = EJAC-1
			
		TIMES SOURCE:0 , 1.50
		TIMES SOURCE:1 , 1.50
		TIMES SOURCE:2 , 1.50
		TIMES SOURCE:17 , 1.50
	ENDIF


ENDIF

RETURN 1


@COM153
;슬라임자위
JUMP COM3
RETURN 1

@COM154
;슬라임 구욕
PRINTL 슬라임 구욕
SAVESTR:0 = 슬라임 구욕
CALL TRAIN_MESSAGE_B

LOSEBASE:0 += 60
LOSEBASE:1 += 80

;첫 키스
IF CFLAG:16 == -1
	CFLAG:16 = 1
	SETCOLOR 0xDDBBCC
	PRINTFORML 첫 키스
	RESETCOLOR
	CSTR:1 = 슬라임
	TFLAG:135 = 1	
ENDIF

;ABL:봉사정신をみる
IF ABL:16 == 0
	SOURCE:4 += 200
	 A = 100
ELSEIF ABL:16 == 1
	SOURCE:4 += 300
	A = 200
ELSEIF ABL:16 == 2
	SOURCE:4 += 400
	A = 400
ELSEIF ABL:16 == 3
	SOURCE:4 += 500
	A = 600
ELSEIF ABL:16 == 4
	SOURCE:4 += 600
	A = 800
ELSE
	SOURCE:4 += 800
	A = 1100
ENDIF

;ABL:기교をみる
IF ABL:12 == 0
	TIMES SOURCE:4 , 0.50
ELSEIF ABL:12 == 1
	TIMES SOURCE:4 , 0.80
ELSEIF ABL:12 == 2
	TIMES SOURCE:4 , 1.00
ELSEIF ABL:12 == 3
	TIMES SOURCE:4 , 1.20
ELSEIF ABL:12 == 4
	TIMES SOURCE:4 , 1.50
ELSE
	TIMES SOURCE:4 , 2.00
ENDIF

SOURCE:13 += A
SOURCE:16 += A

;촉수の抜き挿し
IF TEQUIP:154
	TEQUIP:154 = 0
ELSE
	TEQUIP:154 = 1
ENDIF
T = 0

EXP:22 += 1
PRINTL 펠라경험 +1
RETURN 1


