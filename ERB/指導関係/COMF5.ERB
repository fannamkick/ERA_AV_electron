;-------------------------------------------------
;가슴애무
;애무系コマンド: 調教者が調教対象の乳房を手と口で刺激
;-------------------------------------------------
@COM5

;前回と今回の調教者が同じ
IF (ASSIPLAY && TFLAG:50) || (ASSIPLAY == 0 && TFLAG:50 == 0)
	;前回の調教が정상위, 정상위キス, 정상위SPだと정상위・가슴애무に
	IF PREVCOM == 20 || PREVCOM == 128 || PREVCOM == 130
		CALL COM_ABLE129
		SIF RESULT == 1
			JUMP COM129
	ENDIF
ENDIF

;前回と今回の調教者が同じ
IF (ASSIPLAY && TFLAG:50) || (ASSIPLAY == 0 && TFLAG:50 == 0)
	;前回の調教が후배위, 후배위・스팽킹, 서서삽입, 후배위SPだと후배위・가슴애무に
	IF PREVCOM == 21 || PREVCOM == 132 || PREVCOM == 133 || PREVCOM == 134
		CALL COM_ABLE131
		SIF RESULT == 1
			JUMP COM131
	ENDIF
ENDIF

PRINTL 가슴애무
SAVESTR:0 = 가슴애무
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 5
LOSEBASE:1 += 50

SOURCE:4 = 60
SOURCE:8 = 20
SOURCE:12 = 100

;ABL:B感覚をみる
IF ABL:1 == 0
	SOURCE:17 = 20
	SOURCE:3 = 50
ELSEIF ABL:1 == 1
	SOURCE:17 = 100
	SOURCE:3 = 100
ELSEIF ABL:1 == 2
	SOURCE:17 = 500
	SOURCE:3 = 160
ELSEIF ABL:1 == 3
	SOURCE:17 = 1200
	SOURCE:3 = 200
ELSEIF ABL:1 == 4
	SOURCE:17 = 2000
	SOURCE:3 = 230
ELSE
	SOURCE:17 = 2800
	SOURCE:3 = 250
ENDIF

;獣姦の場合はここで終了
SIF TEQUIP:89
	RETURN 1

;調教者が［유아퇴행］
IF TALENT:PLAYER:131 && TEQUIP:89 == 0
	TIMES SOURCE:17 , 1.20
	TIMES SOURCE:3 , 1.20
ENDIF

;調教者が［유치］
IF TALENT:PLAYER:132 && TEQUIP:89 == 0
	TIMES SOURCE:17 , 1.20
	TIMES SOURCE:3 , 1.20
ENDIF

;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
IF TEQUIP:90
	;奴隷のBに촉수の汚れがつく
	STAIN:5 |= 2
	STAIN:5 |= 4
ELSE
	;奴隷の胸の汚れがなければ口をつかう(愛液と모유よごれはOK, 불결무시か助手調教時は問題なし)
	IF STAIN:5 < 2 || STAIN:5 == 16 || STAIN:5 == 17 || ASSIPLAY == 1 || TALENT:MASTER:64 == 1
		;調教者のTALENT:혀놀림をみる
		IF TALENT:PLAYER:52
			TIMES SOURCE:17 , 1.40
			SOURCE:16 += SOURCE:17/20
		ENDIF

		;奴隷のB⇔調教者の口の汚れが移動
		STAIN:5 |= STAIN:PLAYER:0
		STAIN:PLAYER:0 |= STAIN:5
	ENDIF

	;奴隷のB⇔調教者の指の汚れが移動
	STAIN:5 |= STAIN:PLAYER:1
	STAIN:PLAYER:1 |= STAIN:5
ENDIF

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
;レズ・ホモ経験
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +5
	EXP:40 += 5
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +5
	EXP:41 += 5
ENDIF
PRINTFORML %EXPNAME:14%+2
	EXP:14 += 2
;애정경험
E = 1
IF CFLAG:2 >= 1000 && ASSIPLAY == 0
	PRINTFORML %EXPNAME:23%+{E}
	EXP:23 += E
ENDIF
E = 0

CALL EVENT_JUNYU

RETURN 1

;-------------------------------------------------
;-------------------------------------------------
;모유체질への変化
;-------------------------------------------------
@EVENT_JUNYU
A = NO:PLAYER
;【모유체질】無しかつ【작은체형】で無し【빈유】無しかつ【남성】でない
SIF TALENT:130  || TALENT:100 || TALENT:109 || TALENT:122
	RETURN 0
;更に［B感度］5以上かつ【거유】か【폭유】で촉수調教や獣姦でなく
SIF ABL:1 <= 4 || (TALENT:110 == 0 && TALENT:114 == 0) || TEQUIP:90 || TEQUIP:89
	RETURN 0
;調教者が【유치】か【유아퇴행】か【미숙함】
SIF TALENT:PLAYER:132 == 0 && TALENT:PLAYER:131 == 0 && TALENT:PLAYER:135 == 0
	RETURN 0
;「調教対象」から「調教者」への関係が150以上か主人プレイで愛
SIF RELATION:TARGET:A < 150 && (ASSIPLAY || TALENT:85 == 0)
	RETURN 0
PRINTFORML %NAME:PLAYER%에게 유방을 빨리는 사이에, %타겟은(1)% 모유가 나오게 됐다…
TALENT:130 = 1

RETURN 1
