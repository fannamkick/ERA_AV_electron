@COM135
;안면기승 플레이

PRINTL 안면기승 플레이
SAVESTR:0 = 안면기승 플레이
CALL TRAIN_MESSAGE_B


;終了時は修正なし
IF TEQUIP:55
	TEQUIP:55 = 0
	RETURN 1
ENDIF

;체력は消費なし
LOSEBASE:0 += 0
;기력は200消費
LOSEBASE:1 += 200


A = 500
B = 500

;EXP:가학쾌락경험をみる
IF EXP:33 < EXPLV:1
	TIMES A , 1.00
ELSEIF EXP:33 < EXPLV:2
	TIMES A , 1.10
ELSEIF EXP:33 < EXPLV:3
	TIMES A , 1.20
ELSEIF EXP:33 < EXPLV:4
	TIMES A , 1.30
ELSEIF EXP:33 < EXPLV:4
	TIMES A , 1.40
ENDIF

;ABL:노출벽をみる
IF ABL:17 == 0
	SOURCE:7 += 0
	SOURCE:10 += 0
	SOURCE:13 += 600
	SOURCE:14 += 1000
	SOURCE:15 += 1000
	TIMES A, 0.60
ELSEIF ABL:17 == 1
	SOURCE:7 += 150
	SOURCE:10 += 150
	SOURCE:13 += 500
	TIMES A, 1.00
ELSEIF ABL:17 == 2
	SOURCE:7 += 300
	SOURCE:10 += 300
	SOURCE:13 += 400
	TIMES A, 1.60
ELSEIF ABL:17 == 3
	SOURCE:7 += 600
	SOURCE:10 += 600
	SOURCE:13 += 300
	TIMES A, 2.00
ELSEIF ABL:17 == 4
	SOURCE:7 += 1000
	SOURCE:10 += 1000
	SOURCE:13 += 200
	TIMES A, 2.60
ELSE
	SOURCE:7 += 1800
	SOURCE:10 += 1800
	SOURCE:13 += 100
	TIMES A, 3.80
ENDIF
;ABL:새드끼をみる
IF ABL:20 == 0
	TIMES A , 1.00
ELSEIF ABL:20 == 1
	TIMES A , 1.20
ELSEIF ABL:20 == 2
	TIMES A , 1.40
ELSEIF ABL:20 == 3
	TIMES A , 1.60
ELSEIF ABL:20 == 4
	TIMES A , 1.80
ELSE
	TIMES A , 2.00
ENDIF

;무관심
SIF TALENT:21
	TIMES A , 0.80
;감정부족
SIF TALENT:22
	TIMES A , 0.80
;호기심
SIF TALENT:23
	TIMES A , 2.50
;해방
SIF TALENT:33
	TIMES A , 1.50

;겁쟁이
SIF TALENT:10
	TIMES B , 1.50
;수줍음
SIF TALENT:35
	TIMES B , 3.00

;도착적
SIF TALENT:80
	TIMES A , 1.50
	TIMES B , 1.20
;매력
SIF TALENT:113
	SOURCE:13 += 500
	SOURCE:14 += 500
	TIMES A , 1.50
	TIMES B , 1.20

SOURCE:12 += A
SOURCE:14 += B
SOURCE:16 += A/2

TEQUIP:55 = 1


RETURN 1


