;-------------------------------------------------
;유두로터
;道具使用コマンド: 調教対象の클리토리스を로터で刺激
;追加されるソース: 쾌B,露出,逸脱
;-------------------------------------------------
@COM92

PRINTL 유두로터
SAVESTR:0 = 유두로터
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 10
LOSEBASE:1 += 80

SOURCE:12 = 120
SOURCE:14 = 70

;ABL:B感覚をみる
IF ABL:1 == 0
	SOURCE:17 = 150
ELSEIF ABL:1 == 1
	SOURCE:17 = 300
ELSEIF ABL:1 == 2
	SOURCE:17 = 675
ELSEIF ABL:1 == 3
	SOURCE:17 = 1200
ELSEIF ABL:1 == 4
	SOURCE:17 = 1800
ELSE
	SOURCE:17 = 2250
ENDIF

						;****슬라임パッチ追加ここから****
IF ITEM:200 >= 1
	TIMES LOSEBASE:0 , 0.80
	TIMES LOSEBASE:1 , 0.80
	TIMES SOURCE:12 , 1.20
	TIMES SOURCE:14 , 0.80
	TIMES SOURCE:17 , 1.20
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
;レズ・ホモ経験
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

PRINTFORML %EXPNAME:14%+1
EXP:14 += 1

RETURN 1
