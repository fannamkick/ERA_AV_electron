;=================================================
;역강간
;セックス系コマンド: 調教者의 %CSTR:81%の中へ調教対象의 %CSTR:80%を挿入させる
;=================================================
@COM25

PRINTL 역애널강간
SAVESTR:0 = 역애널강간

;-------------------------------------------------
;調教時メッセージ
;-------------------------------------------------
IF (FLAG:6 & 1) == 0
	PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥ 

	;前回と今回の調教者が同じで, 前回の調教が역강간であり, 抜かないフラグがある場合
	IF TFLAG:60 && PREVCOM == 25 && ((ASSIPLAY && TFLAG:50) || (ASSIPLAY == 0 && TFLAG:50 == 0))
		PRINTFORML %CALLNAME:PLAYER%は%CALLNAME:TARGET%の肉棒をきつく食い締めたまま, 執拗に腰を振りたてた…
	ELSE
		PRINTFORM %CALLNAME:PLAYER%は
		SIF TEQUIP:44
			PRINT 縛り上げられた
		PRINTFORM %CALLNAME:TARGET%の体にのしかかり, 勃起した肉棒を強引に
		SIF EXP:PLAYER:2 == 0
			PRINT 男を知らない
		PRINTFORML アヌスの奥へと咥えこんだ…
	ENDIF

	WAIT
ENDIF

;調教者の처녀を与えるどうかの確認
$INPUT_LOOP_01
IF TALENT:PLAYER:2
	PRINTFORML %CALLNAME:PLAYER%の애널처녀を%CALLNAME:TARGET%に与えますか?
	PRINTL  [0] - 네
	PRINTL  [1] - 아니오
	INPUT
	IF RESULT == 1
		RETURN 0
	ELSEIF RESULT != 0
		GOTO INPUT_LOOP_01
	ENDIF
ENDIF

;-------------------------------------------------
;調教者の사정게이지チェック(후타나리の場合)
;-------------------------------------------------
B = 0

;ABL:기교をみる
IF ABL:12 == 0
	B = 50
ELSEIF ABL:12 == 1
	B = 300
ELSEIF ABL:12 == 2
	B = 800
ELSEIF ABL:12 == 3
	B = 1500
ELSEIF ABL:12 == 4
	B = 2000
ELSE
	B = 3200
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES B , 0.80
ELSEIF ABL:10 == 1
	TIMES B , 0.90
ELSEIF ABL:10 == 2
	TIMES B , 1.00
ELSEIF ABL:10 == 3
	TIMES B , 1.10
ELSEIF ABL:10 == 4
	TIMES B , 1.20
ELSE
	TIMES B , 1.30
ENDIF

;ABL:봉사정신をみる
IF ABL:16 == 0
	TIMES B , 0.50
ELSEIF ABL:16 == 1
	TIMES B , 0.80
ELSEIF ABL:16 == 2
	TIMES B , 1.20
ELSEIF ABL:16 == 3
	TIMES B , 1.50
ELSEIF ABL:16 == 4
	TIMES B , 1.80
ELSE
	TIMES B , 2.40
ENDIF

;調教者のABL:V감각をみる
IF ABL:PLAYER:2 == 0
	TIMES B , 0.50
ELSEIF ABL:PLAYER:2 == 1
	TIMES B , 0.80
ELSEIF ABL:PLAYER:2 == 2
	TIMES B , 1.00
ELSEIF ABL:PLAYER:2 == 3
	TIMES B , 1.20
ELSEIF ABL:PLAYER:2 == 4
	TIMES B , 1.50
ELSE
	TIMES B , 2.00
ENDIF

;調教者のEXP:V경험をみる
IF EXP:PLAYER:0 < EXPLV:1
	TIMES B , 0.20
ELSEIF EXP:PLAYER:0 < EXPLV:2
	TIMES B , 0.50
ELSEIF EXP:PLAYER:0 < EXPLV:3
	TIMES B , 0.80
ELSEIF EXP:PLAYER:0 < EXPLV:4
	TIMES B , 1.00
ELSEIF EXP:PLAYER:0 < EXPLV:5
	TIMES B , 1.20
ELSE
	TIMES B , 1.40
ENDIF

;ABL:C感覚をみる
IF ABL:0 == 0
	TIMES B , 1.00
ELSEIF ABL:0 == 1
	TIMES B , 1.50
ELSEIF ABL:0 == 2
	TIMES B , 2.00
ELSEIF ABL:0 == 3
	TIMES B , 2.50
ELSEIF ABL:0 == 4
	TIMES B , 3.50
ELSE
	TIMES B , 5.00
ENDIF

SIF TALENT:PLAYER:121 || TALENT:PLAYER:122
	BASE:PLAYER:2 += B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 40
LOSEBASE:1 += 75

SOURCE:3 = 550
SOURCE:13 = 1000
SOURCE:14 = 800

;ABL:C感覚をみる
IF ABL:0 == 0
	SOURCE:0 = 800
	TIMES SOURCE:14 , 3.00
ELSEIF ABL:0 == 1
	SOURCE:0 = 1400
	TIMES SOURCE:14 , 2.00
ELSEIF ABL:0 == 2
	SOURCE:0 = 2000
	TIMES SOURCE:14 , 1.50
ELSEIF ABL:0 == 3
	SOURCE:0 = 2500
	TIMES SOURCE:14 , 1.00
ELSEIF ABL:0 == 4
	SOURCE:0 = 2900
	TIMES SOURCE:14 , 0.80
ELSE
	SOURCE:0 = 3200
	TIMES SOURCE:14 , 0.60
ENDIF

;調教者のABL:기교をみる
IF ABL:PLAYER:12 == 0
	TIMES SOURCE:0 , 0.50
	SOURCE:4 = 1600
ELSEIF ABL:PLAYER:12 == 1
	TIMES SOURCE:0 , 0.80
	SOURCE:4 = 1900
ELSEIF ABL:PLAYER:12 == 2
	TIMES SOURCE:0 , 1.00
	SOURCE:4 = 2300
ELSEIF ABL:PLAYER:12 == 3
	TIMES SOURCE:0 , 1.50
	SOURCE:4 = 2700
ELSEIF ABL:PLAYER:12 == 4
	TIMES SOURCE:0 , 2.50
	SOURCE:4 = 3100
ELSEIF ABL:PLAYER:12 == 5
	TIMES SOURCE:0 , 3.00
	SOURCE:4 = 3500
ELSE
	TIMES SOURCE:0 , 4.00
	SOURCE:4 = 4000
ENDIF

;調教者のABL:V감각をみる
IF ABL:PLAYER:4 == 0
	TIMES SOURCE:0 , 0.50
ELSEIF ABL:PLAYER:4 == 1
	TIMES SOURCE:0 , 0.80
ELSEIF ABL:PLAYER:4 == 2
	TIMES SOURCE:0 , 1.00
ELSEIF ABL:PLAYER:4 == 3
	TIMES SOURCE:0 , 1.20
ELSEIF ABL:PLAYER:4 == 4
	TIMES SOURCE:0 , 1.50
ELSEIF ABL:PLAYER:4 == 5
	TIMES SOURCE:0 , 2.00
ELSE
	TIMES SOURCE:0 , 3.00
ENDIF

;調教対象がオトコではない
IF TALENT:122 == 0
	SOURCE:12 = 1200
	TIMES SOURCE:14 , 6.00
ENDIF


;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;奴隷のP⇔調教者のAの汚れが移動
STAIN:2 |= STAIN:PLAYER:4
STAIN:PLAYER:4 |= STAIN:2

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
;レズ・ホモ経験
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +4
	EXP:40 += 4
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +4
	EXP:41 += 4
ENDIF

EXP:5 += 1
PRINTL 성교경험 +1


S = 0
;V감각が高いほどV경험が入る
IF ABL:PLAYER:3 <= 1
	S += 2
ELSEIF ABL:PLAYER:3 <= 4
	S += 3
ELSEIF ABL:PLAYER:3 <= 7
	S += 4
ELSE
	S += 5
ENDIF
EXP:PLAYER:1 += S
PRINTFORML A경험 +{S}(%CALLNAME:PLAYER%)
S = 0

EXP:PLAYER:5 += 1
PRINTFORML 성교경험 +1(%CALLNAME:PLAYER%)

CALL EVENT_SEITSU_REVARAPE

;이상경험
Z = 0
TFLAG:14 = 0
CALL INCEST

IF Z
	EXP:50 += Z
	PRINTFORML %EXPNAME:50% +{Z}
ENDIF

Z = 0
;역강간で처녀상실の場合, 調教者の이상경험に＋1
SIF TALENT:PLAYER:2
	Z += 1
IF Z
	EXP:PLAYER:50 += Z
	PRINTFORML %EXPNAME:50% +{Z}(%CALLNAME:PLAYER%)
ENDIF

TFLAG:14 = 0

;애정경험
;調教者が처녀で調教対象が동정
IF TALENT:PLAYER:2
	E = 100
ENDIF
IF CFLAG:2 >= 1000 && ASSIPLAY == 0
	PRINTFORML %EXPNAME:23%+{E}
	EXP:23 += E
ENDIF
E = 0

;親族関係の判定
TFLAG:14 = 0
CALL INCEST

;調教者が애널처녀なら처녀상실
IF TALENT:PLAYER:2
	CSTR:PLAYER:3 = %NAME:TARGET%
	TALENT:PLAYER:2 = 0
	SETCOLOR 0xF58F98
	PRINTFORML 【애널처녀상실】(%CALLNAME:PLAYER%)
	RESETCOLOR
	CFLAG:PLAYER:830 = BASE:9
	CFLAG:PLAYER:831 = DAY:1
	CFLAG:PLAYER:832 = DAY:2
	CFLAG:PLAYER:833 = 14
	CFLAG:PLAYER:834 = 1
	CFLAG:PLAYER:616 = 1
ENDIF

TFLAG:14 = 0

RETURN 1
;
;-------------------------------------------------
;=================================================
;精通
;=================================================
@EVENT_SEITSU_REVARAPE
A = NO:PLAYER
;【남성】か【후타나리】であり【미숙함】
SIF (TALENT:121 == 0 && TALENT:122 == 0) || TALENT:135 == 0
	RETURN 0
;更に［C感度］5以上で촉수調教や獣姦でなく
SIF ABL:0 <= 4 || TEQUIP:90 || TEQUIP:89
	RETURN 0
;「調教対象」から「調教者」への関係が150以上
SIF RELATION:TARGET:A < 150
	RETURN 0
PRINTFORML %NAME:PLAYER%のアヌスで페니스を刺激されて, %NAME:TARGET%は精通を迎えた…
TALENT:135 = 0

RETURN 1
