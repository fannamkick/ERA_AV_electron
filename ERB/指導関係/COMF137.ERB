;-------------------------------------------------
;삼각목마
;道具使用コマンド: 삼각목마に乗せて클리토리스を刺激
;-------------------------------------------------
@COM137

PRINTL 삼각목마
SAVESTR:0 = 삼각목마
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 0
LOSEBASE:1 += 20
SOURCE:14 = 1000

;ABL:C感覚をみる
IF ABL:0 == 0
	SOURCE:0 = 400
ELSEIF ABL:0 == 1
	SOURCE:0 = 800
ELSEIF ABL:0 == 2
	SOURCE:0 = 1800
ELSEIF ABL:0 == 3
	SOURCE:0 = 3200
ELSEIF ABL:0 == 4
	SOURCE:0 = 4800
ELSE
	SOURCE:0 = 6000
ENDIF

;PALAM:苦痛をみる
IF PALAM:9 < PALAMLV:1
	SOURCE:6 = 3000
ELSEIF PALAM:9 < PALAMLV:2
	SOURCE:6 = 3300
ELSEIF PALAM:9 < PALAMLV:3
	SOURCE:6 = 3600
ELSEIF PALAM:9 < PALAMLV:4
	SOURCE:6 = 4000
ELSEIF PALAM:9 >= PALAMLV:4
	SOURCE:6 = 4500
ENDIF

;大きいと重いので食い込みが強くなる
;큰체구
IF TALENT:99
	TIMES SOURCE:0 , 1.80
	TIMES SOURCE:6 , 1.80
ENDIF
;작은체형
IF TALENT:100
	TIMES SOURCE:0 , 0.80
	TIMES SOURCE:6 , 0.80
ENDIF

						;****슬라임パッチ追加ここから****
IF ITEM:213 >= 1
	TIMES SOURCE:0 , 1.20
	TIMES SOURCE:6 , 1.50
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +2
	EXP:40 += 2
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +2
	EXP:41 += 2
ENDIF

SIF ASSIPLAY == 0 && ABL:21 >= 3
	TFLAG:30 += 1

;애정경험
E = 0


;-------------------------------------------------
;삼각목마の乗降
;-------------------------------------------------
IF TEQUIP:70 >= 1
	TEQUIP:70 = 0
ELSE
	TEQUIP:70 = 1
ENDIF
RETURN 1
;-------------------------------------------------
;-------------------------------------------------
;삼각목마 기승 중
;-------------------------------------------------
@EQUIP_COM137

PRINTL ＜삼각목마 기승 중＞

LOSEBASE:0 += 10
LOSEBASE:1 += 20

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
;ABL:C感覚をみる
IF ABL:0 == 0
	A = 40 + 10 * TEQUIP:70
ELSEIF ABL:0 == 1
	A = 80 + 20 * TEQUIP:70
ELSEIF ABL:0 == 2
	A = 180 + 30 * TEQUIP:70
ELSEIF ABL:0 == 3
	A = 320 + 40 * TEQUIP:70
ELSEIF ABL:0 == 4
	A = 480 + 50 * TEQUIP:70
ELSE
	A = 600 + 100 * TEQUIP:70
ENDIF

SOURCE:14 = 100

;PALAM:苦痛をみる
IF PALAM:9 < PALAMLV:1
	B = 290 + 10 * TEQUIP:70
ELSEIF PALAM:9 < PALAMLV:2
	B = 320 + 10 * TEQUIP:70
ELSEIF PALAM:9 < PALAMLV:3
	B = 350 + 10 * TEQUIP:70
ELSEIF PALAM:9 < PALAMLV:4
	B = 390 + 10 * TEQUIP:70
ELSEIF PALAM:9 >= PALAMLV:4
	B = 440 + 10 * TEQUIP:70
ENDIF

;大きいと重いので食い込みが強くなる
;큰체구
IF TALENT:99
	TIMES A , 1.80
	TIMES B , 1.80
ENDIF
;작은체형
IF TALENT:100
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF

SOURCE:0 += A
SOURCE:6 += B

						;****슬라임パッチ追加ここから****
IF ITEM:213 >= 1
	TIMES SOURCE:0 , 1.20
	TIMES SOURCE:6 , 1.50
	TIMES SOURCE:11 , 1.50
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

SIF ASSIPLAY == 0 && ABL:21 >= 3
	TFLAG:30 += 1

;-------------------------------------------------
;その他の処理
;-------------------------------------------------
;放置すると食い込んで効果が高くなる
TEQUIP:70 += 1

RETURN 1
