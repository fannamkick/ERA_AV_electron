;-------------------------------------------------
;손가락삽입
;애무系コマンド: 調教者が調教対象의 %CSTR:81%を手で刺激
;-------------------------------------------------
@COM8

;前回の調教が손가락삽입かつプレイヤの기교3以上だとG스팟자극に
SIF PREVCOM == 8 && ABL:PLAYER:12 >= 3
	JUMP COM84
;前回の調教がGスポットならさらにG스팟자극に
SIF PREVCOM == 84
	JUMP COM84

PRINTL 손가락삽입
SAVESTR:0 = 손가락삽입
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 30
LOSEBASE:1 += 80

SOURCE:12 = 300
SOURCE:14 = 200

;ABL:V감각をみる
IF ABL:2 == 0
	SOURCE:1 = 10
	SOURCE:13 = 150
ELSEIF ABL:2 == 1
	SOURCE:1 = 50
	SOURCE:13 = 250
ELSEIF ABL:2 == 2
	SOURCE:1 = 250
	SOURCE:13 = 400
ELSEIF ABL:2 == 3
	SOURCE:1 = 600
	SOURCE:13 = 700
ELSEIF ABL:2 == 4
	SOURCE:1 = 1200
	SOURCE:13 = 1300
ELSE
	SOURCE:1 = 1800
	SOURCE:13 = 2000
ENDIF

;EXP:V경험をみる
IF EXP:0 < EXPLV:1
	TIMES SOURCE:1 , 0.20
	TIMES SOURCE:13, 0.20
	SOURCE:6 = 300
ELSEIF EXP:0 < EXPLV:2
	TIMES SOURCE:1 , 0.50
	TIMES SOURCE:13, 0.50
	SOURCE:6 = 180
ELSEIF EXP:0 < EXPLV:3
	TIMES SOURCE:1 , 1.00
	TIMES SOURCE:13, 0.80
	SOURCE:6 = 80
ELSEIF EXP:0 < EXPLV:4
	TIMES SOURCE:1 , 1.20
	TIMES SOURCE:13, 1.00
	SOURCE:6 = 30
ELSEIF EXP:0 < EXPLV:5
	TIMES SOURCE:1 , 1.60
	TIMES SOURCE:13, 1.20
	SOURCE:6 = 0
ELSE
	TIMES SOURCE:2 , 1.80
	TIMES SOURCE:13, 1.50
	SOURCE:6 = 0
ENDIF

;PALAM:윤활をみる
IF PALAM:3 < PALAMLV:1
	TIMES SOURCE:1 , 0.10
	SOURCE:6 += 700
	TIMES SOURCE:6 , 3.00
ELSEIF PALAM:3 < PALAMLV:2
	TIMES SOURCE:1 , 0.20
	SOURCE:6 += 200
	TIMES SOURCE:6 , 1.00
ELSEIF PALAM:3 < PALAMLV:3
	TIMES SOURCE:1 , 0.60
	TIMES SOURCE:6 , 0.80
ELSEIF PALAM:3 < PALAMLV:4
	TIMES SOURCE:1 , 1.00
	TIMES SOURCE:6 , 0.50
ELSEIF PALAM:3 >= PALAMLV:4
	TIMES SOURCE:1 , 2.00
	TIMES SOURCE:6 , 0.10
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES SOURCE:1 , 0.50
ELSEIF PALAM:5 < PALAMLV:2
	TIMES SOURCE:1 , 0.80
ELSEIF PALAM:5 < PALAMLV:3
	TIMES SOURCE:1 , 1.20
ELSEIF PALAM:5 < PALAMLV:4
	TIMES SOURCE:1 , 1.50
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES SOURCE:1 , 1.80
ENDIF


;V민감, 鈍感をみる
;쾌V自体のチェックは後でまとめてやる
IF TALENT:103
	TIMES SOURCE:6 , 1.50
	TIMES SOURCE:13 , 1.50
	TIMES SOURCE:14 , 1.50
ELSEIF TALENT:104
	TIMES SOURCE:6 , 0.60
	TIMES SOURCE:13 , 0.60
	TIMES SOURCE:14 , 0.60
ENDIF

;처녀で정조관념
SIF EXP:0 == 0 && TALENT:30
	TIMES SOURCE:13 , 2.00
;미숙함
SIF TALENT:135
	TIMES SOURCE:6 , 2.00

;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
IF TEQUIP:90
	;奴隷のVに촉수の汚れがつく
	STAIN:3 |= 2
	STAIN:3 |= 4
ELSE
	;奴隷のV⇔調教者の指の汚れが移動
	STAIN:3 |= STAIN:PLAYER:1
	STAIN:PLAYER:1 |= STAIN:3
ENDIF

;-------------------------------------------------
;経験上昇
;-------------------------------------------------

;레즈경험
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +4
	EXP:40 += 4
ENDIF

IF TALENT:0 == 0
	PRINTS EXPNAME:0
	PRINTL +1
	EXP:0 += 1
ENDIF

;애정경험
E = 1
IF CFLAG:2 >= 1000 && ASSIPLAY == 0
	PRINTFORML %EXPNAME:23%+{E}
	EXP:23 += E
ENDIF
E = 0

;-------------------------------------------------
;その他の処理
;-------------------------------------------------

RETURN 1
