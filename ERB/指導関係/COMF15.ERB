;-------------------------------------------------
;니플캡
;道具使用コマンド: 調教対象の乳房を니플캡で刺激
;-------------------------------------------------
@COM15

IF TEQUIP:90
	PRINTL 촉수 유두자극
	SAVESTR:0 = 촉수 유두자극
ELSE
	PRINTL 니플캡
	SAVESTR:0 = 니플캡
ENDIF
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 20
LOSEBASE:1 += 70

SOURCE:12 = 120
SOURCE:14 = 70

;ABL:B感覚をみる
IF ABL:1 == 0
	A = 100
ELSEIF ABL:1 == 1
	A = 300
ELSEIF ABL:1== 2
	A = 800
ELSEIF ABL:1 == 3
	A = 1500
ELSEIF ABL:1 == 4
	A = 2300
ELSE
	A = 2900
ENDIF

;助手が유아퇴행
SIF TALENT:PLAYER:131
	TIMES SOURCE:17 , 1.20

;助手が유치
SIF TALENT:PLAYER:132
	TIMES SOURCE:17 , 1.20

IF TALENT:110
	TIMES A , 1.50
ENDIF
IF TALENT:108
	TIMES A , 1.50
ELSEIF TALENT:107
	TIMES A , 0.60
ENDIF

SOURCE:17 += A

IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

						;****슬라임パッチ追加ここから****
IF ITEM:205 >= 1 && TEQUIP:90 == 0
	TIMES LOSEBASE:0 , 0.80
	TIMES LOSEBASE:1 , 0.80
	TIMES SOURCE:12 , 1.20
	TIMES SOURCE:14 , 0.80
	TIMES SOURCE:17 , 1.20
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;니플캡の着脱
;-------------------------------------------------
TEQUIP:15 = 1 - TEQUIP:15
SIF TEQUIP:90
	T = 0

;-------------------------------------------------
;汚れ(촉수)
;-------------------------------------------------
IF TEQUIP:90 && TEQUIP:15
	STAIN:5 |= 2
	STAIN:5 |= 4
ENDIF

RETURN 1

;-------------------------------------------------
;-------------------------------------------------
;니플캡장착중
;-------------------------------------------------
@EQUIP_COM15
IF TEQUIP:90
	PRINTL ＜촉수 유두자극중＞
ELSE
	PRINTL ＜니플캡 장착중＞
ENDIF

LOSEBASE:0 += 5
LOSEBASE:1 += 20

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
;ABL:B感覚をみる
IF ABL:1 == 0
	A = 40
ELSEIF ABL:1 == 1
	A = 120
ELSEIF ABL:1 == 2
	A = 250
ELSEIF ABL:1 == 3
	A = 450
ELSEIF ABL:1 == 4
	A = 600
ELSE
	A = 750
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES A , 0.80
ELSEIF PALAM:5 < PALAMLV:2
	TIMES A , 0.90
ELSEIF PALAM:5 < PALAMLV:3
	TIMES A , 1.00
ELSEIF PALAM:5 < PALAMLV:4
	TIMES A , 1.10
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES A , 1.20
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES A , 0.80
ELSEIF ABL:10 == 1
	TIMES A , 0.90
ELSEIF ABL:10 == 2
	TIMES A , 1.00
ELSEIF ABL:10 == 3
	TIMES A , 1.10
ELSEIF ABL:10 == 4
	TIMES A , 1.20
ELSE
	TIMES A , 1.30
ENDIF

SOURCE:17 += A
SOURCE:11 += 50
SOURCE:12 += 50

						;****슬라임パッチ追加ここから****
IF ITEM:205 >= 1 && TEQUIP:90 == 0
	LOSEBASE:0 -= 1
	LOSEBASE:1 -= 4
	TIMES SOURCE:11 , 1.20
	TIMES SOURCE:12 , 1.20
	TIMES SOURCE:17 , 1.20
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

IF TEQUIP:15
	PRINTFORML %EXPNAME:14%+1
	EXP:14 += 1
ENDIF

IF TEQUIP:90
	T += 1
ENDIF

RETURN 1
;
