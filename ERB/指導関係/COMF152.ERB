;-------------------------------------------------
;슬라임 항문진입
;道具使用コマンド: 調教対象のアナルを애널바이브で刺激
;-------------------------------------------------
@COM152

	PRINTL 슬라임 항문진입
	SAVESTR:0 = 슬라임 항문진입
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 30
LOSEBASE:1 += 90

SOURCE:14 = 300

;ABL:A감각をみる
IF ABL:3 == 0
	SOURCE:2 = 40
	SOURCE:13 = 150
ELSEIF ABL:3 == 1
	SOURCE:2 = 125
	SOURCE:13 = 400
ELSEIF ABL:3 == 2
	SOURCE:2 = 300
	SOURCE:13 = 700
ELSEIF ABL:3 == 3
	SOURCE:2 = 500
	SOURCE:13 = 900
ELSEIF ABL:3 == 4
	SOURCE:2 = 650
	SOURCE:13 = 1050
ELSE
	SOURCE:2 = 850
	SOURCE:13 = 1200
ENDIF

;EXP:A경험をみる
IF EXP:1 < EXPLV:1
	TIMES SOURCE:2 , 0.50
	SOURCE:6 = 1000
	SOURCE:14 += 200
ELSEIF EXP:1 < EXPLV:2
	TIMES SOURCE:2 , 1.00
	SOURCE:6 = 150
	SOURCE:14 += 100
ELSEIF EXP:1 < EXPLV:3
	TIMES SOURCE:2 , 1.10
	SOURCE:6 = 25
	SOURCE:14 += 50
ELSEIF EXP:1 < EXPLV:4
	TIMES SOURCE:2 , 1.20
	SOURCE:6 = 5
ELSEIF EXP:1 < EXPLV:5
	TIMES SOURCE:2 , 1.40
	SOURCE:6 = 0
ELSE
	TIMES SOURCE:2 , 1.60
	SOURCE:6 = 0
ENDIF

;PALAM:윤활をみる
IF PALAM:3 < PALAMLV:1
	TIMES SOURCE:2 , 0.40
	SOURCE:6 += 400
ELSEIF PALAM:3 < PALAMLV:2
	TIMES SOURCE:2 , 0.80
	SOURCE:6 += 250
ELSEIF PALAM:3 < PALAMLV:3
	TIMES SOURCE:2 , 1.00
	SOURCE:6 += 150
ELSEIF PALAM:3 < PALAMLV:4
	TIMES SOURCE:2 , 1.40
	SOURCE:6 += 60
ELSEIF PALAM:3 >= PALAMLV:4
	TIMES SOURCE:2 , 1.80
	SOURCE:6 += 50
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES SOURCE:2 , 0.80
ELSEIF PALAM:5 < PALAMLV:2
	TIMES SOURCE:2 , 0.90
ELSEIF PALAM:5 < PALAMLV:3
	TIMES SOURCE:2 , 1.00
ELSEIF PALAM:5 < PALAMLV:4
	TIMES SOURCE:2 , 1.10
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES SOURCE:2 , 1.20
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES SOURCE:2 , 0.80
	TIMES SOURCE:14 , 2.00
ELSEIF ABL:10 == 1
	TIMES SOURCE:2 , 0.90
	TIMES SOURCE:14 , 1.50
ELSEIF ABL:10 == 2
	TIMES SOURCE:14 , 1.00
ELSEIF ABL:10 == 3
	TIMES SOURCE:14 , 0.80
ELSEIF ABL:10 == 4
	TIMES SOURCE:14 , 0.60
ELSE
	TIMES SOURCE:14 , 0.30
ENDIF

;큰체구
SIF TALENT:99
	TIMES SOURCE:6 , 0.80
;작은체형
SIF TALENT:100
	TIMES SOURCE:6 , 2.00
;미숙함
SIF TALENT:135
	TIMES SOURCE:6 , 2.00

;A민감, 鈍感をみる
;快A自体のチェックは後でまとめてやる
IF TALENT:105
	TIMES SOURCE:6 , 1.50
	TIMES SOURCE:13 , 1.50
	TIMES SOURCE:14 , 1.50
ELSEIF TALENT:106
	TIMES SOURCE:6 , 0.60
	TIMES SOURCE:13 , 0.60
	TIMES SOURCE:14 , 0.60
ENDIF

IF EXP:0 == 0 && TALENT:30
	SOURCE:13 /= 3
ENDIF

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
S = 0
;A감각が高いほどA경험が入る
IF ABL:3 <= 1
	S = 1
ELSEIF ABL:3 <= 4
	S = 2
ELSEIF ABL:3 <= 7
	S = 3
ELSE
	S = 4
ENDIF
EXP:1 += S
PRINTFORML A경험 +{S}

;レズ・ホモ経験
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

;-------------------------------------------------
;애널바이브の着脱
;-------------------------------------------------
TEQUIP:152 = 1 - TEQUIP:152

RETURN 1

;-------------------------------------------------
;-------------------------------------------------
;애널바이브 삽입중
;-------------------------------------------------
@EQUIP_COM152

	PRINTL ＜슬라임 항문 진입중＞

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 15
LOSEBASE:1 += 40

SOURCE:14 = 100

;ABL:A감각をみる
IF ABL:3 == 0
	A = 20
	B = 150
ELSEIF ABL:3 == 1
	A = 60
	B = 400
ELSEIF ABL:3 == 2
	A = 150
	B = 700
ELSEIF ABL:3 == 3
	A = 250
	B = 900
ELSEIF ABL:3 == 4
	A = 325
	B = 1050
ELSE
	A = 425
	B = 1200
ENDIF

;EXP:A경험をみる
IF EXP:1 < EXPLV:1
	TIMES A , 0.50
	C = 1000
ELSEIF EXP:1 < EXPLV:2
	TIMES A , 1.00
	C = 150
ELSEIF EXP:1 < EXPLV:3
	TIMES A , 1.10
	C = 25
ELSEIF EXP:1 < EXPLV:4
	TIMES A , 1.20
	C = 5
ELSEIF EXP:1 < EXPLV:5
	TIMES A , 1.40
	C = 0
ELSE
	TIMES A , 1.60
	C = 0
ENDIF

;PALAM:윤활をみる
IF PALAM:3 < PALAMLV:1
	TIMES A , 0.40
	C += 400
ELSEIF PALAM:3 < PALAMLV:2
	TIMES A , 0.80
	C += 250
ELSEIF PALAM:3 < PALAMLV:3
	TIMES A , 1.00
	C += 150
ELSEIF PALAM:3 < PALAMLV:4
	TIMES A , 1.40
	C += 60
ELSEIF PALAM:3 >= PALAMLV:4
	TIMES A , 1.80
	C += 50
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES A , 0.80
ELSEIF PALAM:5 < PALAMLV:2
	TIMES A , 0.90
ELSEIF PALAM:5 < PALAMLV:3
	TIMES A , 1.00
ELSEIF PALAM:5 < PALAMLV:4
	TIMES A , 1.10
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES A , 1.20
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES A , 0.80
	TIMES SOURCE:14 , 2.00
ELSEIF ABL:10 == 1
	TIMES A , 0.90
	TIMES SOURCE:14 , 1.50
ELSEIF ABL:10 == 2
	TIMES SOURCE:14 , 1.00
ELSEIF ABL:10 == 3
	TIMES SOURCE:14 , 0.80
ELSEIF ABL:10 == 4
	TIMES SOURCE:14 , 0.60
ELSE
	TIMES SOURCE:14 , 0.30
ENDIF

;큰체구
SIF TALENT:99
	TIMES C , 0.80
;작은체형
SIF TALENT:100
	TIMES C , 2.00
;미숙함
SIF TALENT:135
	TIMES SOURCE:6 , 2.00

;A민감, 鈍感をみる
;快A自体のチェックは後でまとめてやる
IF TALENT:105
	TIMES SOURCE:6 , 1.50
	TIMES SOURCE:13 , 1.50
	TIMES SOURCE:14 , 1.50
ELSEIF TALENT:106
	TIMES SOURCE:6 , 0.60
	TIMES SOURCE:13 , 0.60
	TIMES SOURCE:14 , 0.60
ENDIF

SOURCE:2 += A
SOURCE:13 += B
SOURCE:6 += C

;처녀で정조관념
IF TALENT:0 && TALENT:30
	TIMES SOURCE:13 , 0.80
	TIMES SOURCE:14 , 0.50
ENDIF

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
S = 0
;자위実行時は経験 +1
SIF SELECTCOM == 3
	S = 1
;A감각が高いほどA경험が入る
IF ABL:3 <= 1
	S += 1
ELSEIF ABL:3 <= 4
	S += 2
ELSEIF ABL:3 <= 7
	S += 3
ELSE
	S += 4
ENDIF
EXP:1 += S
PRINTFORML A경험 +{S}

S = 0
RETURN 1
;
