;0-9 愛撫系コマンド
;-------------------------------------------------
;-------------------------------------------------
;애무実行判定
;-------------------------------------------------
@COM_ABLE0
RETURN 1
;-------------------------------------------------
;커닐링구스実行判定
;-------------------------------------------------
@COM_ABLE1
;対象がオトコだとダメ
SIF TALENT:122
	RETURN 0
;촉수 지도중はダメ
SIF TEQUIP:90
	RETURN 0
						;****슬라임パッチ追加ここから****
;슬라임지도중はダメ
SIF TEQUIP:150
	RETURN 0
						;****슬라임パッチ追加ここまで****
;삼각목마 기승 중はダメ
SIF TEQUIP:70
	RETURN 0
;パンツか上着下・ズボンタイプを着てるとダメ
SIF (CFLAG:40 & 17)
	RETURN 0
;黒ストッキングだとダメ
SIF CFLAG:170 == 6 && CFLAG:173 == 0
	RETURN 0
;기저귀をはいているとダメ
SIF CFLAG:42 == 69 && (CFLAG:40 & 64)
	RETURN 0
;즈코 인형を着てるとダメ
SIF CFLAG:42 == 11 && (CFLAG:40 & 64)
	RETURN 0
;性器が精液, アナル, 尿で汚れており, 악취민감で従順3以下のASSIの場合커닐링구스はできない(調教者が불결무시ならOK)
IF (STAIN:2 & 4 || STAIN:2 & 8 || STAIN:2 & 32) && ASSIPLAY
	SIF ABL:ASSI:0 <= 3 && TALENT:ASSI:62 && TALENT:ASSI:64 == 0
		RETURN 0
ENDIF
RETURN 1

;-------------------------------------------------
;애널애무実行判定
;-------------------------------------------------
@COM_ABLE2
