	RETURN 0
;黒ストッキングだとダメ
SIF CFLAG:170 == 6 && CFLAG:173 == 0
	RETURN 0
;기저귀をはいているとダメ
SIF CFLAG:42 == 69 && (CFLAG:40 & 64)
	RETURN 0
;즈코 인형を着てるとダメ
SIF CFLAG:42 == 11 && (CFLAG:40 & 64)
	RETURN 0
;主人プレイなら自動成功
IF ASSIPLAY == 0
	RETURN 1
;助手プレイの場合
ELSE
	;윤활 부족の場合はダメ
	IF  PALAM:3 < PALAMLV:2
		;助手が새드ならOK
		IF TALENT:ASSI:83
			RETURN 1
		;助手が従順4以上かつ레즈끼4以上の場合はOK
		ELSEIF ABL:ASSI:10 <= 3 && ABL:ASSI:22 <= 3
			RETURN 1
		ENDIF
		RETURN 0
	ENDIF
ENDIF
RETURN 1

