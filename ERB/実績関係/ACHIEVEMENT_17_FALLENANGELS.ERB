;===========================================================
;実績・FALLEN ANGELS
;===========================================================

; 実績のタイトル
@ACHIEVEMENT_TITLE_17
RESULTS = FALLEN ANGELS

; 実績の達成条件
@ACHIEVEMENT_CALC_17
; 条件を満たす人数の計算
LOCAL = 0
FOR COUNT, 0, CHARANUM
	SIF COUNT == MASTER
		CONTINUE
	SIF (NO:COUNT == 15 || NO:COUNT == 85 || NO:COUNT == 94) && TALENT:COUNT:0 == 0 && TALENT:COUNT:2 == 0 && TALENT:COUNT:440 == 1 && PBAND:135 == 3 && PBAND:144 == 3 			
		LOCAL++
NEXT
; 条件を達成している場合は실적번호のグローバルを1にする
SIF GLOBAL:17 == 0 && DIFFICULTY_CHECK() && LOCAL == 3
	GLOBAL:17 = 1
RETURN GLOBAL:17

; 実績の説明および諸々の処理
@ACHIEVEMENT_MAIN_17
; 解説文
PRINTFORML 야마토 나데시코인 히나미 하루노, 더러움을 모르는 천사 히나미 마유, 인공적으로 천사를 만드는 계획으로 천사가 된 하세카와 미코토……
PRINTFORML 그러나 그녀들의 깨끗했던 모습은 자취를 감추고, 지금은 양구멍으로 음탕하게 쾌락을 갈구하게 되어버렸습니다
PRINTFORML 만약 %플레이어와()% 만나지 않았더라도, 그녀들은 언젠가『진짜 자신』을 알게 됐을지도 모르죠
PRINTFORML 반대로, 음욕에 빠진 그녀들의 유일한 희망은 이제 %플레이어와()% 만났다는 걸지도 모릅니다
PRINTFORMW ……오늘도 그녀들은 정욕에 몸을 태우며 %플레이어가()% 주는 쾌락을 기다리고 있습니다
IF FLAG:563 == 0
	IF GETCHARA(86, 0) >= 0
		PRINTFORML 《실적 해금 보너스로서 유니스・파라디수스의 연구실에【사상개변: 타천사화】가 추가됐습니다》
		FLAG:563 = 1
	ENDIF
ENDIF