;===========================================================
;実績・ONLY ONE EMPRESS
;===========================================================

; 実績のタイトル
@ACHIEVEMENT_TITLE_19
RESULTS = ONLY ONE EMPRESS

; 実績の達成条件
@ACHIEVEMENT_CALC_19
; 条件を満たす人数の計算
LOCAL = 0
FOR COUNT, 0, CHARANUM
	SIF COUNT == MASTER
		CONTINUE
	IF TALENT:COUNT:553
		IF TALENT:COUNT:181 == 1
			LOCAL++
		ENDIF
	ENDIF
NEXT
; 条件を達成している場合は실적번호のグローバルを1にする
SIF GLOBAL:19 == 0 && DIFFICULTY_CHECK() && LOCAL == 1
	GLOBAL:19 = 1
RETURN GLOBAL:19

; 実績の説明および諸々の処理
@ACHIEVEMENT_MAIN_19
; 解説文
PRINTFORML 얌전하고 청순가련한 우등생이었던 미야마 카나데……
PRINTFORML 그러나 그녀에겐 검고 음흉한 소질이 잠들어 있었습니다
PRINTFORM 그리고 거듭되는 지도로 소질이 개화한 카나데는 겉으로는 평소대로 행동하면서도
PRINTFORML 다른 누구보다도 남자들을 철저하게 괴롭히게 됐습니다
PRINTFORMW 그녀가 일하는 창관에선 오늘도 그녀를「카나데님」이라 부르는 수많은 마조남들이 다녀갑니다

IF GETCHARA(1, 0) >= 1
	LOCAL = GETCHARA(1)
	IF TALENT:LOCAL:553 == 0 && PBAND:51 == 0
		PRINTFORML 《미야마 카나데를【ONLY ONE EMPRESS】로 각성시키시겠습니까?》
		PRINTL [0] - 네
		PRINTL [1] - 아니오
		$INPUTLOOP
		INPUT
		
		IF RESULT == 0
			PRINTFORMW 《미야마 카나데가【ONLY ONE EMPRESS】로 각성했습니다》
			TALENT:LOCAL:76 = 1
			TALENT:LOCAL:33 = 1
			TALENT:LOCAL:83 = 1
			TALENT:LOCAL:87 = 1
			TALENT:LOCAL:93 = 1
			TALENT:LOCAL:211 = 1
			TALENT:LOCAL:24 = 0
			TALENT:LOCAL:35 = 0
			TALENT:LOCAL:30 = 0
			TALENT:LOCAL:423 = 0
			TALENT:LOCAL:553 = 1
			MAXBASE:LOCAL:31 += 30
			BASE:LOCAL:31 += 30
			MAXBASE:LOCAL:1 += 500
			BASE:LOCAL:1 += 500
			PBAND:51 = 3
		ELSEIF RESULT == 1
			PRINTFORMW 《미야마 카나데의 소질을 그대로 둡니다》
		ELSE
			GOTO INPUTLOOP
		ENDIF
	ENDIF
ENDIF