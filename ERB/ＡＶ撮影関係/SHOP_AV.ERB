ENDIF

RETURN 0
;-----------------------------------------------------------
;通常営業の営業内容を決定します
;-----------------------------------------------------------
@CHARA_SELECT_AV

$INPUT_LOOP_0

DRAWLINE
PRINTL 누구를 촬영합니까?
CALL LIFE_LIST_NEW,6
IF RESULT == 999
	RETURN 1
;	CALL AV_TOP
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP_0
ENDIF

;以下営業させられる条件
;主人だと不可
IF RESULT == MASTER
	PRINTFORML %플레이어는()% 감독입니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF

;체력が500未満だと不可
IF BASE:RESULT:0 < 500
	PRINTL 촬영하기엔 체력이 부족합니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF
;반발각인2以上が付いていると不可
IF MARK:RESULT:3 >= 2
	PRINTL 반발각인이 높아 촬영할 수 없습니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF
;従順と욕망の合計値が6以下だと不可
B = ABL:RESULT:10
B += ABL:RESULT:11
IF B < 3
	PRINTL 능력이 부족합니다. 추가적인 지도가 필요합니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF
;산월だと不可
IF CFLAG:RESULT:110 - 2 <= DAY && TALENT:RESULT:153
	PRINTL 배가 너무 무거워 촬영할 수 없습니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF
IF TALENT:RESULT:154
	PRINTL 육아 중에는 촬영할 수 없습니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF
;素質【남성】が付いていると不可
IF TALENT:RESULT:122
	PRINTL 호모는 취급하지 않습니다!
	WAIT
	GOTO INPUT_LOOP_0
ENDIF
IF TIME == 1 && CFLAG:RESULT:12 != 0
	PRINTL 영업이 끝날때까지 촬영할 수 없습니다
	WAIT
	GOTO INPUT_LOOP_0
ENDIF

TARGET = RESULT

;まだデビュー前の場合, ここで예명を決定する
IF TALENT:400 == 0
	PRINTL
	$INPUTLOOP_DECIDENAME
	PRINTFORML 《%CALLNAME:TARGET%의 예명을 정해주세요》

	INPUTS
		SIF RESULTS == ""
			RESULTS = %NICKNAME%
	PRINTFORML %CALLNAME:TARGET%의 예명을 %조사처리(RESULTS,"로")% 합니까?
	PRINTL [0] - 네
	PRINTL [1] - 아니오
	$INPUTLOOP_DECIDE
	INPUT
		IF RESULT == 0
				NICKNAME:TARGET = %RESULTS%
				PRINTFORML 본인과 상담한 결과, %조사처리(NICKNAME:TARGET,"로")% 정해졌다
		ELSEIF RESULT == 1
			PRINTFORML 예명을 다시 입력해 주세요
			GOTO INPUTLOOP_DECIDENAME
		ELSE
			GOTO INPUTLOOP_DECIDE
		ENDIF
	PRINTL
ENDIF

CALL AV_LIST

