		CALL CHARA_SELECT_AV
		;
		SIF RESULT == 1
			GOTO DRAW
	ELSE
		PRINTL 촬영에 필요한 기재가 없습니다
		RETURN
	ENDIF
;ELSEIF RESULT == 1
;	CALL AV_LABO
ELSEIF RESULT == 999
	RETURN
ELSE
