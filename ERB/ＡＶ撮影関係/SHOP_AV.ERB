REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF ABL:COUNT:10 >= 3 
		T += 1
	ENDIF
REND

PRINTFORML 소지금: {MONEY}포인트
PRINTFORM 이번달 유행: 
CALL VIDEOSALE_PRINT
PRINTL

$INPUT_LOOP

DRAWLINE
IF T >= 1
	PRINTL  [0] - 촬영 시작
ELSE
	PRINTL  [-] - －－－－－－－
ENDIF
;PRINTL  [1] - 남배우와 계약한다
DRAWLINE
PRINTFORML  [999] - 돌아간다

INPUT

IF RESULT == 0
;	IF ITEM:6 == 1 && ITEM:28 > 0 && T >= 1
