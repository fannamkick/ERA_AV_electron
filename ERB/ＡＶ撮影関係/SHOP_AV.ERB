;===========================================================
;男優の決定
;===========================================================
@AV_LIST
; 変数の定義と初期化
; LOCAL		一時変数(要素数2)
; LIST		存在する미션番号を格納する変数(要素数250)
; PAGE		現在の表示ページ番号を格納する変数 (要素数1)
; PAGE_END	ページ番号の最大値を格納する変数 (要素数1)
#LOCALSIZE 50
#DIM LIST, 250
#DIM PAGE
#DIM PAGE_END
VARSET LIST, -1
PAGE = 0
VARSET LOCAL, 0
VARSET TCVAR, 0
; 미션の存在判定
K = 0
FOR LOCAL, 0, 50
	; 미션の存在チェック
	; 存在する미션タイトルを戻す関数の番号をリスト変数に格納し, 
	; リストの要素番号を格納するカウンタ変数LOCAL:1をインクリメントする
	; 存在しない場合は次のループへ移る
	TRYCCALLFORM SCENE_TITLE_{LOCAL}
		DEBUGPRINTFORML 리스트번호 {LOCAL:1}에 미션번호 {LOCAL} %조사처리(RESULTS,"를")% 등록합니다
		LIST:(LOCAL:1) = LOCAL
		LOCAL:1++
	CATCH
		CONTINUE
	ENDCATCH
NEXT
; ページ終端の計算
PAGE_END = (LOCAL:1 - 1 < 0 ? 0 # LOCAL:1 - 1) / 10
; ここからリスト表示処理
$SCENE_LIST
PRINTFORML 《%NICKNAME:TARGET%의 촬영씬을 정해주세요》
PRINTFORML 남은 씬: {BASE:MASTER:60} / {MAXBASE:MASTER:60}
DRAWLINE
; リストヘッダーの表示
; リスト本体の表示
FOR LOCAL, PAGE * 10, PAGE * 10 + 10
	; リスト終端ならループ終了
	SIF LIST:LOCAL < 0
		BREAK
	; リスト描画
	CALLFORM SCENE_VISIBLE_{LIST:LOCAL}
	IF  RESULT == 1
		; 미션タイトルの取得
		CALLFORM SCENE_TITLE_{LIST:LOCAL}
		PRINTFORML [{LOCAL, 3}] - %RESULTS%
	ELSE
		PRINTFORML [ - ] - －－－－－
	ENDIF
NEXT
DRAWLINE
; リストフッターの表示
IF PAGE > 0
	PRINT [997] - 이전 페이지　　
ELSE
	; PRINTPLAINでボタン化を防止
	PRINTPLAIN [ - ] - －－－－－　　
ENDIF
IF TFLAG:700 == 0
	PRINT [998] - 돌아간다
ELSE
	PRINT [998] - 촬영 시작
ENDIF
IF PAGE < PAGE_END
	PRINT 　　[999] - 다음 페이지
ELSE
	; PRINTPLAINでボタン化を防止
	PRINTPLAIN 　　[ - ] - －－－－－
ENDIF
; ここから入力処理
$INPUT_LOOP
INPUT
; 既に미션を請け負っていて, 
; なおかつ請け負っている미션ではない場合は弾く
IF RESULT >= 0 && RESULT < 250 && P:1 < MAXBASE:MASTER:60
	LOCAL = (LIST:RESULT)
	CALLFORM SCENE_INFO_{LOCAL}
	CALLFORM SCENE_FEE_{LOCAL}
	BASE:MASTER:60 -= P:1
	IF (BASE:MASTER:60 < 0)
		CLEARLINE 1
		PRINTFORML 더 이상 촬영할 수 없습니다
			BASE:MASTER:60 += P:1
			P:1 = 0
			GOTO SCENE_LIST
	ELSE
		$INPUT_LOOP_RECEIVE
		PRINTFORML 이 씬을 촬영합니까?
		PRINT [  1] - 네
		PRINTL 　　[  0] - 아니오
		INPUT
		IF RESULT == 1
			PRINTFORML 이 씬을 촬영합니다
			TFLAG:(500 + K) = LOCAL
			TFLAG:700 += 1
			K++
			P:1 = 0
			GOTO SCENE_LIST
		ELSE
			BASE:MASTER:60 += P:1
			P:1 = 0
			GOTO SCENE_LIST
		ENDIF
	ENDIF
ELSEIF RESULT >= 0 && RESULT < 250 && P:1 >= MAXBASE:MASTER:60

ELSEIF RESULT == 997 && PAGE > 0
	PAGE--
	GOTO SCENE_LIST
ELSEIF RESULT == 998 && TFLAG:700 == 0
	RETURN
ELSEIF RESULT == 998
	CALL AV_CHOOSE
ELSEIF RESULT == 999 && PAGE < PAGE_END
	PAGE++
	GOTO SCENE_LIST
ELSE
	CLEARLINE 1
	REUSELASTLINE 잘못된 입력값입니다
	GOTO INPUT_LOOP
ENDIF

