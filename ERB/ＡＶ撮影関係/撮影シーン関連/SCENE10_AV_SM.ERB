;=================================================
; シーンタイトル
;--------------------------------------------
; RESULTS = の後にシーンのタイトルを記述する
;=================================================
@SCENE_TITLE_10
RESULTS = SM

;=================================================
; シーン可視条件
;--------------------------------------------
; 特定のキャラクターの存在や, 他のシーン結果などを, 
; このシーンの表示条件に使用したい時に編集する
;=================================================
@SCENE_VISIBLE_10
; 不可視なら0, 可視なら1を戻す
IF ABL:PLAYER:12 == 3 && ABL:21 >= 3 && ITEM:14 == 0
	RETURN 0
ELSE
	RETURN 1
ENDIF
;=================================================
; シーン報酬
;--------------------------------------------
; シーンの報酬を記述する
; P:1 消費行動포인트
; P:2 基本消費체력
; P:3 基本消費체력
;=================================================
@SCENE_FEE_10
P:1 = 5
P:2 += 200
P:3 += 400

;=================================================
; シーン解説文
;--------------------------------------------
; シーンの解説文を記述する
;=================================================
@SCENE_INFO_10
CUSTOMDRAWLINE ‥
PRINTL 《SM》
PRINTL 카메라 앞에서 SM플레이를 합니다
CUSTOMDRAWLINE ‥

;=================================================
; シーン成功判定
;--------------------------------------------
; シーンの成功判定を行います
;=================================================
@SCENE_CALC_10

LOCAL:1 = 0

LOCAL:1 += ABL:10
LOCAL:1 += ABL:11
LOCAL:1 += ABL:17
LOCAL:1 += ABL:21
LOCAL:1 += ABL:70

;아이마스크
SIF ITEM:5
	LOCAL:1 += 5
;ギャグ
SIF ITEM:9
	LOCAL:1 += 5
;채찍
SIF ITEM:10
	LOCAL:1 += 5
;바늘
SIF ITEM:11
	LOCAL:1 += 5
;관장
SIF ITEM:15
	LOCAL:1 += 10
;電極
SIF ITEM:21
	LOCAL:1 += 10
;木馬
SIF ITEM:24
	LOCAL:1 += 10

SIF TALENT:14
	LOCAL:1 += 5
SIF TALENT:17
	LOCAL:1 += 5
SIF TALENT:41
	LOCAL:1 += 10
SIF TALENT:80
	LOCAL:1 += 10
SIF TALENT:88
	LOCAL:1 += 10
SIF TALENT:110
	LOCAL:1 += 5
SIF TALENT:114
	LOCAL:1 += 5
SIF TALENT:440
	LOCAL:1 += 20


SIF TALENT:15
	LOCAL:1 -= 5
SIF TALENT:34
	LOCAL:1 -= 20
SIF TALENT:40
	LOCAL:1 -= 10

IF LOCAL:1 >= 30
	IF LOCAL:1 >= 80
		RETURN 2
	ELSE
		RETURN 1
	ENDIF
ELSE
	RETURN 0
ENDIF


;=================================================
; シーン撮影開始
;--------------------------------------------
; シーン撮影開始時の地の文を表示します
; 処理の都合上, ここで以下の項目を加算
; P:4 獲得メダル
; P:10 基本獲得포인트
;=================================================
@SCENE_RESULT_START_10

P:4 = 6
P:10 = 3000
PRINTFORML %NICKNAME:TARGET%, %NAME:TARGET%의 SM조교를 촬영했다……
PRINTW

;=================================================
; シーン結果・大成功
;--------------------------------------------
; シーン成功判定で2を返した場合の処理を行います
;=================================================
@SCENE_RESULT_PERFECT_10

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 카메라를 의식하며, 
PRINTFORML 교성을 흘리고 밧줄에 묶인 몸을 경련하며, 성기를 애액으로 질척질척하게 적셨다……
PRINTL

TIMES (P:10) , 1.25
P:4 *= 2

;=================================================
; シーン結果・成功
;--------------------------------------------
; シーン成功判定で1を返した場合の処理を行います
;=================================================
@SCENE_RESULT_SUCCESS_10

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 카메라를 신경쓰면서, 
SIF TALENT:35
	PRINTFORM 새빨간 얼굴로 
PRINTFORML 밧줄에 묶인 몸을 쾌락에 떨며, 성기를 적셨다……
PRINTL

;=================================================
; シーン結果・失敗
;--------------------------------------------
; シーン成功判定で0を返した場合の処理を行います
;=================================================
@SCENE_RESULT_FAILED_10

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 
IF TALENT:35
	PRINTFORM 새빨간 얼굴로 
ENDIF
PRINTFORML 밧줄이 조이는 고통을 참고 있다……
PRINTL

TIMES (P:10), 0.8
P:4 = 0


;=================================================
; シーン経験増加処理
;--------------------------------------------
; シーンの経験増加処理を行います
;=================================================
@SCENE_EXP_10

VARSET LOCAL, 0

LOCAL = (1 + RAND:5)
LOCAL += ABL:21
SIF TALENT:76
	TIMES LOCAL , 1.25

TCVAR:51 += LOCAL

IF P:4 != 0 && ABL:21 != 0
	LOCAL:1 += ABL:21
	SIF TALENT:76
		TIMES LOCAL , 1.50
	SIF ABL:0 >= LOCAL
		LOCAL:1 = LOCAL
	TCVAR:30 += LOCAL:1
ENDIF