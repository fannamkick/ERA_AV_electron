;=================================================
; シーン経験増加処理
;--------------------------------------------
; シーンの経験増加処理を行います
;=================================================
@SCENE_EXP_5

VARSET LOCAL, 0

LOCAL = (1 + RAND:5)
LOCAL += ABL:30
SIF TALENT:77
	TIMES LOCAL , 1.25

TCVAR:1 += LOCAL
TCVAR:5 += LOCAL
TCVAR:22 += LOCAL


IF P:4 != 0 && ABL:3 != 0
	LOCAL:1 += ABL:3
	SIF TALENT:77
		TIMES LOCAL , 1.50
	SIF ABL:0 >= LOCAL
		LOCAL:1 = LOCAL
	TCVAR:2 += LOCAL:1
ENDIF
