;=================================================
; シーンタイトル
;--------------------------------------------
; RESULTS = の後にシーンのタイトルを記述する
;=================================================
@SCENE_TITLE_5
RESULTS = 하드 애널섹스

;=================================================
; シーン可視条件
;--------------------------------------------
; 特定のキャラクターの存在や, 他のシーン結果などを, 
; このシーンの表示条件に使用したい時に編集する
;=================================================
@SCENE_VISIBLE_5
; 不可視なら0, 可視なら1を戻す
;男優処理がないので暫定
IF TALENT:PLAYER:121 == 0 && TALENT:PLAYER:122 == 0 && ABL:PLAYER:12 == 0 && ITEM:4 == 0 
	RETURN 0
ELSE
	RETURN 1
ENDIF
;=================================================
; シーン報酬
;--------------------------------------------
; シーンの報酬を記述する
; P:1 消費行動포인트
; P:2 基本消費체력
; P:3 基本消費체력
;=================================================
@SCENE_FEE_5
P:1 = 3
P:2 += 150
P:3 += 200

;=================================================
; シーン解説文
;--------------------------------------------
; シーンの解説文を記述する
;=================================================
@SCENE_INFO_5
CUSTOMDRAWLINE ‥
PRINTL 《하드 애널섹스》
PRINTL 카메라 앞에서 애널섹스를 보여줍니다
CUSTOMDRAWLINE ‥

;=================================================
; シーン成功判定
;--------------------------------------------
; シーンの成功判定を行います
;=================================================
@SCENE_CALC_5

LOCAL:1 = 0

LOCAL:1 += ABL:3
LOCAL:1 += ABL:10
LOCAL:1 += ABL:11
LOCAL:1 += ABL:14
LOCAL:1 += ABL:30
LOCAL:1 += ABL:70

SIF TALENT:2
	LOCAL:1 += 10
SIF TALENT:31
	LOCAL:1 += 5
SIF TALENT:33
	LOCAL:1 += 5
SIF TALENT:36
	LOCAL:1 += 5
SIF TALENT:70
	LOCAL:1 += 5
SIF TALENT:76
	LOCAL:1 += 5
SIF TALENT:77
	LOCAL:1 += 10
SIF TALENT:88
	LOCAL:1 += 10
SIF TALENT:106
	LOCAL:1 += 10
SIF TALENT:440
	LOCAL:1 += 20

SIF TALENT:30
	LOCAL:1 -= 5
SIF TALENT:34
	LOCAL:1 -= 20
SIF TALENT:35
	LOCAL:1 -= 5
SIF TALENT:105
	LOCAL:1 -= 5
SIF TALENT:153
	LOCAL:1 -= 5

IF LOCAL:1 >= 10
	IF LOCAL:1 >= 50
		RETURN 2
	ELSE
		RETURN 1
	ENDIF
ELSE
	RETURN 0
ENDIF


;=================================================
; シーン撮影開始
;--------------------------------------------
; シーン撮影開始時の地の文を表示します
; 処理の都合上, ここで以下の項目を加算
; P:4 獲得メダル
; P:10 基本獲得포인트
;=================================================
@SCENE_RESULT_START_5

P:4 = 3
P:10 = 1500
PRINTFORML %NICKNAME:TARGET%, %NAME:TARGET%의 애널섹스씬을 촬영했다……
PRINTW

;=================================================
; シーン結果・大成功
;--------------------------------------------
; シーン成功判定で2を返した場合の処理を行います
;=================================================
@SCENE_RESULT_PERFECT_5
CSTR:20 = %CALLNAME:PLAYER%
PRINTFORMW %CSTR:20%

PRINTFORML 최음효과가 있는 향을 피운 러브호텔의 한 방에서, %타겟은()% %CALLNAME:PLAYER%에게 교성을 흘리고 전신을 경련시키며, 
PRINT 애널이 안 닫히게 될때까지 몇번이고 
IF TALENT:PLAYER:121 == 1 || TALENT:PLAYER:122 == 1
	PRINT 육봉으
ELSE
	PRINT 페니스밴드
ENDIF
PRINTL 로 찔렸다…… 
PRINTL
IF TALENT:2 == 1
	SETCOLOR 0xF58F98
	PRINTL 【애널처녀상실】
	RESETCOLOR
	TALENT:2 = 0
	CSTR:3 = %CSTR:20%
ENDIF
IF CFLAG:16 == -1
	CSTR:20 = %CALLNAME:PLAYER%
	CFLAG:16 = 1
	SETCOLOR 0xDDBBCC
	PRINTFORML 첫 키스
	RESETCOLOR
	CFLAG:16 = 1
	IF TALENT:122 == 0 && TALENT:422 == 0 && TALENT:76 == 0
		CSTR:1 = %CSTR:20%의 고○
	ELSEIF TALENT:122 == 0 && TALENT:422 == 0 && TALENT:76 == 1
		CSTR:1 = %CSTR:20%의 자○
	ELSEIF TALENT:122 == 0 && TALENT:422 == 1
		CSTR:1 = %CSTR:20%의 자지
	ENDIF
ENDIF

TIMES (P:10) , 1.25
P:4 *= 2

