;=================================================
; シーンタイトル
;--------------------------------------------
; RESULTS = の後にシーンのタイトルを記述する
;=================================================
@SCENE_TITLE_3
RESULTS = 펠라치오

;=================================================
; シーン可視条件
;--------------------------------------------
; 特定のキャラクターの存在や, 他のシーン結果などを, 
; このシーンの表示条件に使用したい時に編集する
;=================================================
@SCENE_VISIBLE_3
;男優処理がないので暫定
IF TALENT:PLAYER:121 == 0 && TALENT:PLAYER:122 == 0 && ITEM:4 == 0 
	RETURN 0
ELSE
	RETURN 1
ENDIF

;=================================================
; シーン報酬
;--------------------------------------------
; シーンの報酬を記述する
; P:1 消費行動포인트
; P:2 基本消費체력
; P:3 基本消費체력
;=================================================
@SCENE_FEE_3
P:1 = 2
P:2 += 80
P:3 += 50

;=================================================
; シーン解説文
;--------------------------------------------
; シーンの解説文を記述する
;=================================================
@SCENE_INFO_3
CUSTOMDRAWLINE ‥
PRINTL 《펠라치오》
PRINTL 카메라 앞에서 펠라치오를 보여줍니다
CUSTOMDRAWLINE ‥

;=================================================
; シーン成功判定
;--------------------------------------------
; シーンの成功判定を行います
;=================================================
@SCENE_CALC_3

LOCAL:1 = 0

LOCAL:1 += ABL:10
LOCAL:1 += ABL:11
LOCAL:1 += ABL:12
LOCAL:1 += ABL:13
LOCAL:1 += ABL:16
LOCAL:1 += ABL:17
LOCAL:1 += ABL:70

SIF TALENT:47
	LOCAL:1 += 20
SIF TALENT:52
	LOCAL:1 += 15
SIF TALENT:62
	LOCAL:1 += 5
SIF TALENT:63
	LOCAL:1 += 5
SIF TALENT:64
	LOCAL:1 += 10
SIF TALENT:76
	LOCAL:1 += 5
SIF TALENT:88
	LOCAL:1 += 10
SIF TALENT:89
	LOCAL:1 += 10
SIF TALENT:440
	LOCAL:1 += 20

SIF TALENT:15
	LOCAL:1 -= 5
SIF TALENT:34
	LOCAL:1 -= 20
SIF TALENT:35
	LOCAL:1 -= 5
SIF TALENT:61
	LOCAL:1 -= 10


IF LOCAL:1 >= 10
	IF LOCAL:1 >= 50
		RETURN 2
	ELSE
		RETURN 1
	ENDIF
ELSE
	RETURN 0
ENDIF


;=================================================
; シーン撮影開始
;--------------------------------------------
; シーン撮影開始時の地の文を表示します
; 処理の都合上, ここで以下の項目を加算
; P:4 獲得メダル
; P:10 基本獲得포인트
;=================================================
@SCENE_RESULT_START_3
P:4 = 1
P:10 = 1000
PRINTFORML %NICKNAME:TARGET%, %NAME:TARGET%의 펠라치오를 촬영했다……
PRINTW

;=================================================
; シーン結果・大成功
;--------------------------------------------
; シーン成功判定で2を返した場合の処理を行います
;=================================================
@SCENE_RESULT_PERFECT_3

;男優処理がないので暫定

PRINTFORML %조사처리(NICKNAME:TARGET,"은")% 황홀한 표정으로 %CALLNAME:PLAYER%의 육봉을 물었다……
PRINTL

TIMES (P:10) , 1.25
P:4 *= 2

;=================================================
; シーン結果・成功
;--------------------------------------------
; シーン成功判定で1を返した場合の処理を行います
;=================================================
@SCENE_RESULT_SUCCESS_3

PRINTFORML %조사처리(NICKNAME:TARGET,"은")% %CALLNAME:PLAYER%의 육봉에 봉사했다……
PRINTL

;=================================================
; シーン結果・失敗
;--------------------------------------------
; シーン成功判定で0を返した場合の処理を行います
;=================================================
@SCENE_RESULT_FAILED_3

PRINTFORML %조사처리(NICKNAME:TARGET,"은")% 떨면서도 육봉을 입에 물었지만, 이내 몸이 굳어버렸다……
PRINTL

TIMES (P:10), 0.8
P:4 = 0


;=================================================
; シーン経験増加処理
;--------------------------------------------
; シーンの経験増加処理を行います
;=================================================
@SCENE_EXP_3

VARSET LOCAL, 0

LOCAL = (1 + RAND:5)
LOCAL += ABL:13
SIF TALENT:76
	TIMES LOCAL , 1.25

TCVAR:10 += LOCAL
TCVAR:11 += LOCAL


IF P:4 != 0 && ABL:16 != 0
	LOCAL:1 += ABL:16
	SIF TALENT:76
		TIMES LOCAL , 1.50
	SIF ABL:0 >= LOCAL
		LOCAL:1 = LOCAL
	TCVAR:2 += LOCAL:1
ENDIF