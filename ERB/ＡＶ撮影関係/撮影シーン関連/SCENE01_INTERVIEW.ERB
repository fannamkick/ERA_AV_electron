;=================================================
; シーンタイトル
;--------------------------------------------
; RESULTS = の後にシーンのタイトルを記述する
;=================================================
@SCENE_TITLE_1
RESULTS = 인터뷰

;=================================================
; シーン可視条件
;--------------------------------------------
; 特定のキャラクターの存在や, 他のシーン結果などを, 
; このシーンの表示条件に使用したい時に編集する
;=================================================
@SCENE_VISIBLE_1
; 不可視なら0, 可視なら1を戻す
RETURN 1

;=================================================
; シーン報酬
;--------------------------------------------
; シーンの報酬を記述する
; P:1 消費行動포인트
; P:2 基本消費체력
; P:3 基本消費체력
;=================================================
@SCENE_FEE_1
P:1 += 1
P:2 += 10
P:3 += 50

;=================================================
; シーン解説文
;--------------------------------------------
; シーンの解説文を記述する
;=================================================
@SCENE_INFO_1
CUSTOMDRAWLINE ‥
PRINTL 《인터뷰》
PRINTL 여배우의 성경험과 연령등을 질문합니다
CUSTOMDRAWLINE ‥

;=================================================
; シーン成功判定
;--------------------------------------------
; シーンの成功判定を行います
;=================================================
@SCENE_CALC_1

LOCAL:1 = 0

LOCAL:1 += ABL:10
LOCAL:1 += ABL:15
LOCAL:1 += ABL:17
LOCAL:1 += ABL:70


SIF TALENT:28
	LOCAL:1 += 10
SIF TALENT:74
	LOCAL:1 += 10
SIF TALENT:182
	LOCAL:1 += 10
SIF TALENT:36
	LOCAL:1 += 5
SIF TALENT:17
	LOCAL:1 += 5

SIF TALENT:34
	LOCAL:1 -= 20
SIF TALENT:35
	LOCAL:1 -= 5

IF LOCAL:1 >= 10
	IF LOCAL:1 >= 40
		RETURN 2
	ELSE
		RETURN 1
	ENDIF
ELSE
	RETURN 0
ENDIF

;=================================================
; シーン撮影開始
;--------------------------------------------
; シーン撮影開始時の地の文を表示します
; 処理の都合上, ここで以下の項目を加算
; P:4 獲得メダル
; P:10 基本獲得포인트
;=================================================
@SCENE_RESULT_START_1

P:4 = 1
P:10 = 500

PRINTFORML %NICKNAME:TARGET%, %NAME:TARGET%의 인터뷰를 촬영했다……
PRINTW


;=================================================
; シーン結果・大成功
;--------------------------------------------
; シーン成功判定で2を返した場合の処理を行います
;=================================================
@SCENE_RESULT_PERFECT_1

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 침착하고 자연스럽게 
IF TALENT:35
	PRINTFORM 새빨간 얼굴로 
ELSEIF TALENT:36
	PRINTFORM 거리낌없이 
ENDIF
PRINTFORML 상당히 아슬아슬한 수위의 질문에도 제대로 대답하고 있다……
PRINTL
TIMES P:10, 1.25
P:4 *= 2

;=================================================
; シーン結果・成功
;--------------------------------------------
; シーン成功判定で1を返した場合の処理を行います
;=================================================
@SCENE_RESULT_SUCCESS_1

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 살짝 긴장하면서 
IF TALENT:35
	PRINTFORM 새빨간 얼굴로 
ELSEIF TALENT:36
	PRINTFORM 거리낌없이 
ENDIF
PRINTFORML 상당히 아슬아슬한 수위의 질문에 당황해 하면서도 대답하고 있다……
PRINTL

TIMES P:10, 1.00
P:4 *= 1

;=================================================
; シーン結果・失敗
;--------------------------------------------
; シーン成功判定で0を返した場合の処理を行います
;=================================================
@SCENE_RESULT_FAILED_1

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 많이 긴장했는지, 
IF TALENT:35
	PRINTFORM 새빨간 얼굴로 
ENDIF
PRINTFORML 동문서답을 하더니, 이내 입을 닫아버렸다……
PRINTL
TIMES P:10, 0.80
P:4 = 0

;=================================================
; シーン経験増加処理
;--------------------------------------------
; シーンの経験増加処理を行います
;=================================================
@SCENE_EXP_1

TCVAR:73 += ABL:15 + RAND:6
	SIF TALENT:182
		TCVAR:73 += RAND:6