;=================================================
; シーンタイトル
;--------------------------------------------
; RESULTS = の後にシーンのタイトルを記述する
;=================================================
@SCENE_TITLE_2
RESULTS = 자위

;=================================================
; シーン可視条件
;--------------------------------------------
; 特定のキャラクターの存在や, 他のシーン結果などを, 
; このシーンの表示条件に使用したい時に編集する
;=================================================
@SCENE_VISIBLE_2
; 不可視なら0, 可視なら1を戻す
RETURN 1

;=================================================
; シーン報酬
;--------------------------------------------
; シーンの報酬を記述する
; P:1 消費行動포인트
; P:2 基本消費체력
; P:3 基本消費체력
;=================================================
@SCENE_FEE_2
P:1 = 2
P:2 += 80
P:3 += 50

;=================================================
; シーン解説文
;--------------------------------------------
; シーンの解説文を記述する
;=================================================
@SCENE_INFO_2
CUSTOMDRAWLINE ‥
PRINTL 《자위》
PRINTL 카메라 앞에서 자위를 보여줍니다
CUSTOMDRAWLINE ‥

;=================================================
; シーン成功判定
;--------------------------------------------
; シーンの成功判定を行います
;=================================================
@SCENE_CALC_2

LOCAL:1 = 0

LOCAL:1 += ABL:0
LOCAL:1 += ABL:10
LOCAL:1 += ABL:11
LOCAL:1 += ABL:17
LOCAL:1 += ABL:31
LOCAL:1 += ABL:70


SIF TALENT:440
	LOCAL:1 += 20
SIF TALENT:89
	LOCAL:1 += 10
SIF TALENT:74
	LOCAL:1 += 10
SIF TALENT:88
	LOCAL:1 += 10
SIF TALENT:76
	LOCAL:1 += 5
SIF TALENT:36
	LOCAL:1 += 5
SIF TALENT:60
	LOCAL:1 += 5
SIF TALENT:17
	LOCAL:1 += 5


SIF TALENT:34
	LOCAL:1 -= 20
SIF TALENT:203
	LOCAL:1 -= 10
SIF TALENT:35
	LOCAL:1 -= 5
SIF TALENT:15
	LOCAL:1 -= 5


IF LOCAL:1 >= 10
	IF LOCAL:1 >= 50
		RETURN 2
	ELSE
		RETURN 1
	ENDIF
ELSE
	RETURN 0
ENDIF


;=================================================
; シーン撮影開始
;--------------------------------------------
; シーン撮影開始時の地の文を表示します
; 処理の都合上, ここで以下の項目を加算
; P:4 獲得メダル
; P:10 基本獲得포인트
;=================================================
@SCENE_RESULT_START_2

P:4 = 1
P:10 = 1000
PRINTFORML %NICKNAME:TARGET%, %타겟이(1)% 자위하는 모습을 촬영했다……
PRINTW

;=================================================
; シーン結果・大成功
;--------------------------------------------
; シーン成功判定で2を返した場合の処理を行います
;=================================================
@SCENE_RESULT_PERFECT_2

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 카메라를 의식하며, 비음섞인 달콤한 교성을 내뱉고 
PRINTFORML 전신을 경련하며 애액으로 질척질척한 성기를 만지고 있다……
PRINTL

TIMES (P:10) , 1.25
P:4 *= 2

;=================================================
; シーン結果・成功
;--------------------------------------------
; シーン成功判定で1を返した場合の処理を行います
;=================================================
@SCENE_RESULT_SUCCESS_2

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 카메라를 신경쓰면서, 
SIF TALENT:35
	PRINTFORM 새빨간 얼굴로 
PRINTFORML 쾌락에 몸을 떨며 성기를 만지고 있다……
PRINTL

;=================================================
; シーン結果・失敗
;--------------------------------------------
; シーン成功判定で0を返した場合の処理を行います
;=================================================
@SCENE_RESULT_FAILED_2

PRINTFORM %조사처리(NICKNAME:TARGET,"은")% 
IF TALENT:35
	PRINTFORM 새빨간 얼굴로 
ENDIF
PRINTFORML 어색하게 성기를 만지고 있었지만, 이내 몸이 굳어버렸다……
PRINTL

TIMES (P:10), 0.8
P:4 = 0


;=================================================
; シーン経験増加処理
;--------------------------------------------
; シーンの経験増加処理を行います
;=================================================
@SCENE_EXP_2

VARSET LOCAL, 0

LOCAL = (1 + RAND:5)
LOCAL += ABL:31
SIF TALENT:74
	TIMES LOCAL , 1.25

TCVAR:10 += LOCAL
TCVAR:11 += LOCAL


IF P:4 != 0 && ABL:0 != 0
	LOCAL:1 += ABL:0
	SIF TALENT:74
		TIMES LOCAL , 1.50
	SIF ABL:0 >= LOCAL
		LOCAL:1 = LOCAL
	TCVAR:2 += LOCAL:1
ENDIF