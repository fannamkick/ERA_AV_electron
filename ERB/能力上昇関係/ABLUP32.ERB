;정액중독のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;정액중독のLvUP
;-------------------------------------------------
@ABLUP32
DRAWLINE
;PRINTL 노예의 정액에 대한 집착도가 올라갑니다
;PRINTL 정액중독이 높아지면, 정액을 뿌려지거나 마시는 것에 대한 만족감이 깊어져,
;PRINTL 자주 정액 냄새를 맡지 못하면 마음이 진정되지 않게 됩니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;정액중독はLv5が上限
;[음란][習得早い][악취둔감][불결무시][정애미각]が付いている場合はLv10まで해방
IF ABL:32 >= 5 && (TALENT:76 == 0 && TALENT:50 == 0 && TALENT:61 == 0 && TALENT:64 == 0 && TALENT:47 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:32 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
;정액중독＋레즈중독は11以上にならない
;そんなファンタジー。例外多々あり, ABLUP33のコメント参照
ELSEIF ABL:32 + ABL:33 + ABL:40 >= 10 && TALENT:47 == 0 && TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 && TALENT:140 == 0 && TALENT:136 == 0
	PRINTFORMW 정액중독({ABL:32})＋레즈중독({ABL:33})＋수간중독({ABL:40})의 상한은 10입니다
	RETURN 0
ENDIF

;必要な욕정의 구슬
A = 0
;必要な屈服의 구슬
B = 0
;必要な정액경험
C = 0
;必要な이상경험回数
D = 0

;条件別にOKかダメかを記録する
;정액경험多いバージョンの可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0
;정액경험少ないバージョンの可否(J=0:可, J&1:珠不足, J&2:経験不足, J&4:能力不足)
J = 0

CALL DECIDE_ABLUP32

;LV2から3, LV3から4, 4から5に上げるときは이상경험必要(素質: [악취둔감][중독되기쉬움]なら無視できる)
SIF D > 0
	PRINTFORML %EXPNAME:50%{D}이상 (현재{EXP:50}) 그리고

;봉사정신が정액중독＋1レベルでないといけない([음란]がない場合)
IF TALENT:76 == 0
	PRINTFORML %ABLNAME:16%{ABL:32 + 1}LV이상 (현재{ABL:16}LV) 그리고
ELSEIF TALENT:76 == 1
;욕망が정액중독＋1レベルでないといけない([음란]がある場合)
	PRINTFORML %ABLNAME:11%{ABL:32 + 1}LV이상 (현재{ABL:11}LV) 그리고
ENDIF

;정액경험多いバージョン
PRINTFORM [0] - %PALAMNAME:5%의 구슬×{JUEL:5}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTFORML 　　　%PALAMNAME:6%의 구슬×{JUEL:6}/{B}
PRINTFORML 　　　%EXPNAME:20%　{EXP:20}/{C}

;정액경험少ないバージョン
PRINTFORM [1] - %PALAMNAME:5%의 구슬×{JUEL:5}/{A*3} ……
IF J == 0
	PRINT OK
ELSE
	SIF J & 1
		PRINT 구슬부족 
	SIF J & 2
		PRINT 경험부족 
	SIF J & 4
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTFORML 　　　%PALAMNAME:6%의 구슬×{JUEL:6}/{B*3}
PRINTFORML 　　　%EXPNAME:20%　{EXP:20}/{C/2}

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 1) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF J != 0 && RESULT == 1
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:32 += 1

IF RESULT == 0
	JUEL:5 -= A
	JUEL:6 -= B
ELSEIF RESULT == 1
	JUEL:5 -= A*3
	JUEL:6 -= B*3
ENDIF

PRINTFORML %ABLNAME:32%의 레벨이 %조사처리(ABL:32,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;정액중독のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP32
;정액중독はLv5が上限
;[음란][習得早い][악취둔감][불결무시][정애미각]が付いている場合はLv10まで해방
SIF ABL:32 >= 10
	RETURN 0
SIF ABL:32 >= 5 && (TALENT:76 == 0 && TALENT:50 == 0 && TALENT:61 == 0 && TALENT:64 == 0 && TALENT:47 == 0)
	RETURN 0
;정액중독＋레즈중독＋수간중독は11以上にならない
SIF ABL:32 + ABL:33 + ABL:40 >= 10 && TALENT:47 == 0 && TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 && TALENT:140 == 0 && TALENT:136 == 0
	RETURN 0

;判定変数を空に
I = 0
J = 0

A = 0
B = 0
C = 0
D = 0

IF ABL:32 == 0
	A = 3000
	B = 10000
	C = 10
ELSEIF ABL:32 == 1
	A = 8000
	B = 20000
	C = 25
ELSEIF ABL:32 == 2
	A = 15000
	B = 35000
	C = 40
ELSEIF ABL:32 == 3
	A = 30000
	B = 60000
	C = 80
ELSEIF ABL:32 == 4
	A = 50000
	B = 130000
	C = 200
ELSEIF ABL:32 == 5
	A = 65000
	B = 190000
	C = 500
ELSEIF ABL:32 == 6
	A = 90000
	B = 300000
	C = 800
ELSEIF ABL:32 == 7
	A = 120000
	B = 500000
	C = 1200
ELSEIF ABL:32 == 8
	A = 200000
	B = 800000
	C = 1500
ELSEIF ABL:32 == 9
	A = 500000
	B = 1500000
	C = 2000
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:32 == 3
		TIMES A , 1.50
		TIMES B , 1.50
		TIMES C , 1.50
	ELSEIF ABL:32 == 4
		TIMES A , 2.00
		TIMES B , 2.00
		TIMES C , 2.00
	ELSEIF ABL:32 == 5
		TIMES A , 2.50
		TIMES B , 2.50
		TIMES C , 2.50
	ELSEIF ABL:32 >= 6
		TIMES A , 3.00
		TIMES B , 3.00
		TIMES C , 3.00
	ENDIF
ENDIF

;LV2以上に上げるときは이상경험必要(素質: [악취둔감][중독되기쉬움][도착적][광기][정애미각]なら無視できる)
SIF ABL:32 >= 2 && (TALENT:61 == 0 && TALENT:72 == 0 && TALENT:80 == 0 && TALENT:123 == 0 && TALENT:47 == 0)
	D = ABL:32 - 1

;反抗的
IF TALENT:11
	TIMES A , 1.50
	TIMES B , 1.50
	TIMES C , 1.50
ENDIF
;감정부족
IF TALENT:22
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF
;보수적
IF TALENT:24
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES C , 1.20
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES C , 1.20
;해방
ELSEIF TALENT:33
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
ENDIF

;저항
IF TALENT:34
	TIMES A , 2.00
	TIMES B , 2.00
	TIMES C , 2.00
ENDIF

;정애미각
IF TALENT:47
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF

;혀놀림
IF TALENT:52
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF

;악취둔감
IF TALENT:61
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
;악취민감
ELSEIF TALENT:62
	TIMES A , 2.00
	TIMES B , 2.00
	TIMES C , 2.00
ENDIF
;불결무시
IF TALENT:64
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF

;중독되기쉬움
IF TALENT:72
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;즉각함락
IF TALENT:73
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;음란
IF TALENT:76
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF
;색정광
IF TALENT:440
	TIMES A , 0.40
	TIMES B , 0.40
	TIMES C , 0.40
ENDIF
;도착적
IF TALENT:80
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
ENDIF
;소악마
IF TALENT:87
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF
;광기
IF TALENT:123
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF
;붕괴
IF TALENT:9
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF

IF TALENT:505
	TIMES A , 0.01
	TIMES B , 0.01
	TIMES C , 0.01
ENDIF

;最低でも1個か1回は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1
SIF C < 1
	C = 1

IF D > EXP:50
	;이상경험が不足
	I |= 2
	J |= 2
ENDIF

;봉사정신が정액중독＋1レベルでないといけない([음란]がない場合)
IF TALENT:76 == 0
	IF ABL:16 < ABL:32 + 1
		I |= 4
		J |= 4
	ENDIF
ELSEIF TALENT:76 == 1
;욕망が정액중독＋1レベルでないといけない([음란]がある場合)
	IF ABL:11 < ABL:32 + 1
		I |= 4
		J |= 4
	ENDIF
ENDIF

;정액경험多いバージョン
;욕정의 구슬が不足
SIF JUEL:5 < A
	I |= 1
;屈服의 구슬が不足
SIF JUEL:6 < B
	I |= 1
;정액경험が不足
SIF EXP:20 < C
	I |= 2

;정액경험少ないバージョン
;욕정의 구슬が不足
SIF JUEL:5 < A*3
	J |= 1
;屈服의 구슬が不足
SIF JUEL:6 < B*3
	J |= 1
;정액경험が不足
SIF EXP:20 < C/2
	J |= 2

IF I == 0 || J == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
