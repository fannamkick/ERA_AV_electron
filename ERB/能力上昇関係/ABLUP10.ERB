;従順のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;従順のLvUP
;-------------------------------------------------
@ABLUP10
DRAWLINE
;PRINTL 노예의 복종도를 높입니다
;PRINTL 복종도가 높아지면 명령에 따르기 쉬워집니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;従順はLv5が上限
;[愛][망신]が付いている場合は10まで上昇可能
;[섹프]で7まで上げられます。ようわからんけど。
IF ABL:10 >= 5 && (TALENT:85 == 0 && TALENT:86 == 0 && TALENT:90 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:10 >= 7 && (TALENT:85 == 0 && TALENT:86 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:10 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要な恐怖의 구슬
A = 0
;必要な온순의 구슬
B = 0
;必要な욕정의 구슬
C = 0
;必要な屈服의 구슬
D = 0
;必要な이상경험回数
E = 0

;条件別にOKかダメかを記録する
;恐怖의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足)
I = 0
;온순의 구슬による可否(J=0:可, J&1:珠不足, J&2:経験不足)
J = 0
;욕정의 구슬による可否(K=0:可, K&1:珠不足, K&2:経験不足, K=256:そのレベルでは自動不可)
K = 0
;屈服의 구슬による可否(L=0:可, L&1:珠不足, L&2:経験不足, L=256:そのレベルでは自動不可)
L = 0

CALL DECIDE_ABLUP10

;이상경험が必要か
SIF E > 0
	PRINTFORML %EXPNAME:50%{E}이상 (현재{EXP:50}) 그리고

IF A > 0
	;恐怖의 구슬で上げる
	PRINTFORM [0] - %PALAMNAME:10%의 구슬×{JUEL:10}/{A} ……
	IF I == 0
		PRINT OK
	ELSE
		SIF I & 1
			PRINT 구슬부족 
		SIF I & 2
			PRINT 경험부족 
	ENDIF
	PRINTL 
ENDIF

;온순의 구슬で上げる
PRINTFORM [1] - %PALAMNAME:4%의 구슬×{JUEL:4}/{B} ……
IF J == 0
	PRINT OK
ELSE
	SIF J & 1
		PRINT 구슬부족 
	SIF J & 2
		PRINT 경험부족 
ENDIF
PRINTL 

IF C > 0
	;욕정의 구슬で上げる
	PRINTFORM [2] - %PALAMNAME:5%의 구슬×{JUEL:5}/{C} ……
	IF K == 0
		PRINT OK
	ELSE
		SIF K & 1
			PRINT 구슬부족 
		SIF K & 2
			PRINT 경험부족 
	ENDIF
	PRINTL 
ENDIF

IF D > 0
	;屈服의 구슬で上げる
	PRINTFORM [3] - %PALAMNAME:6%의 구슬×{JUEL:6}/{D} ……
	IF L == 0
		PRINT OK
	ELSE
		SIF L & 1
			PRINT 구슬부족 
		SIF L & 2
			PRINT 경험부족 
	ENDIF
	PRINTL 
ENDIF

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 3) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF J != 0 && RESULT == 1
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF K == 256 && RESULT == 2
	RESTART
ELSEIF K != 0 && RESULT == 2
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF L == 256 && RESULT == 3
	RESTART
ELSEIF L != 0 && RESULT == 3
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:10 += 1

IF RESULT == 0
	JUEL:10 -= A
ELSEIF RESULT == 1
	JUEL:4 -= B
ELSEIF RESULT == 2
	JUEL:5 -= C
ELSEIF RESULT == 3
	JUEL:6 -= D
ENDIF

PRINTFORML %ABLNAME:10%의 레벨이 %조사처리(ABL:10,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;従順のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP10
;従順はLv5が上限, [愛][망신]が付いている場合はLv10まで해방
SIF ABL:10 >= 5 && (TALENT:85 == 0 && TALENT:86 == 0 && TALENT:90 == 0)
	RETURN 0
SIF ABL:10 >= 7 && (TALENT:85 == 0 && TALENT:86 == 0)
	RETURN 0
SIF ABL:10 >= 10
	RETURN 0

;判定変数を空に
I = 0
J = 0
K = 0
L = 0

A = 0
B = 0
C = 0
D = 0
E = 0

;不可は-10に変更(TIMESの関係)
IF ABL:10 == 0
	A = 10
	B = 10
	C = 300
	D = 200
ELSEIF ABL:10 == 1
	A = 150
	B = 100
	C = 1000
	D = 1200
ELSEIF ABL:10 == 2
	A = 1000
	B = 800
	C = 2000
	D = 3000
ELSEIF ABL:10 == 3
	A = 3000
	B = 3000
	C = -10
	D = 12000
ELSEIF ABL:10 == 4
	A = 8000
	B = 5000
	C = -10
	D = -10
ELSEIF ABL:10 == 5
	A = 12000
	B = 10000
	C = -10
	D = -10
ELSEIF ABL:10 == 6
	A = 25000
	B = 20000
	C = -10
	D = -10
ELSEIF ABL:10 == 7
	A = -10
	B = 40000
	C = -10
	D = -10
ELSEIF ABL:10 == 8
	A = -10
	B = 80000
	C = -10
	D = -10
ELSEIF ABL:10 == 9
	A = -10
	B = 150000
	C = -10
	D = -10
ENDIF

;LV4から5に上げるときは이상경험必要
;(素質: [겁쟁이][솔직함][즉각함락][음란][愛][망신]なら無視できる)
IF ABL:10 == 4 && (TALENT:10 == 0 && TALENT:13 == 0 && TALENT:76 == 0 && TALENT:73 == 0 && TALENT:85 == 0 && TALENT:86 == 0)
	E = 1
;LV7から8に上げるときは이상경험が2以上必要
;(素質: [겁쟁이][솔직함][즉각함락][음란][愛][망신]なら無視できる)
ELSEIF ABL:10 == 7 && (TALENT:10 == 0 && TALENT:13 == 0 && TALENT:76 == 0 && TALENT:73 == 0 && TALENT:85 == 0 && TALENT:86 == 0)
	E = 2
ENDIF

;겁쟁이
IF TALENT:10
	TIMES A , 0.50
	TIMES B , 0.90
	TIMES D , 0.90
ENDIF
;反抗的
IF TALENT:11
	TIMES A , 2.00
	TIMES B , 1.50
	TIMES C , 1.20
	TIMES D , 1.50
ENDIF
;다부짐
IF TALENT:12
	TIMES A , 3.00
	TIMES B , 1.50
	TIMES C , 1.20
	TIMES D , 1.50
ENDIF
;솔직함
IF TALENT:13
	TIMES B , 0.80
	TIMES D , 0.90
ENDIF
;건방짐
IF TALENT:16
	TIMES A , 1.20
	TIMES B , 1.50
	TIMES D , 1.20
ENDIF
;프라이드 높음
IF TALENT:15
	TIMES A , 1.20
	TIMES B , 1.50
	TIMES D , 2.00
;프라이드 낮음
ELSEIF TALENT:17
	TIMES B , 0.80
	TIMES D , 0.80
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES C , 2.00
	TIMES D , 1.20
;해방
ELSEIF TALENT:33
	TIMES C , 0.50
ENDIF

;저항
IF TALENT:34
	TIMES A , 1.50
	TIMES B , 1.50
	TIMES C , 2.00
	TIMES D , 2.00
ENDIF

;음란
SIF TALENT:76
	TIMES C , 0.50
;愛
SIF TALENT:85
	TIMES B , 0.75
;여동생
SIF TALENT:320
	TIMES B , 0.80
;소꿉친구
SIF TALENT:319
	TIMES B , 0.80
;언니
SIF TALENT:324
	TIMES B , 0.80
;야마토 나데시코
SIF TALENT:209
	TIMES B , 0.90
;망신
SIF TALENT:86
	TIMES B , 0.20
;영원한 사랑
SIF TALENT:430
	TIMES B , 0.20
;메이드
SIF TALENT:504
	TIMES B , 0.20

;女神
SIF TALENT:511
	TIMES B , 0.10
;흑갸루
SIF TALENT:511
	TIMES B , 1.20

;질투
IF TALENT:84
	TIMES B , 5.00
	TIMES C , 0.80
	TIMES D , 2.00
ENDIF

;最低でも1個は必要
SIF B < 1
	B = 1

;恐怖의 구슬は必要か?
IF A > 0
	;恐怖의 구슬は足りている?
	SIF JUEL:10 < A
	I |= 1
ELSE
	I = 256
ENDIF

;온순의 구슬は足りている?
SIF JUEL:4 < B
	J |= 1

;욕정의 구슬は必要か?
IF C > 0
	;욕정의 구슬は足りている?
	SIF JUEL:5 < C
		K |= 1
ELSE
	K = 256
ENDIF

;屈服의 구슬は足りている?
IF D > 0
	;屈服의 구슬で上げる
	SIF JUEL:6 < D
		L |= 1
ELSE
	L = 256
ENDIF

;이상경험は足りている?
IF E > EXP:50
	I |= 2
	J |= 2
	K |= 2
	L |= 2
ENDIF

IF I == 0 || J == 0 || K == 0 || L ==0
	RETURN 1,I,J,K,L
ELSE
	RETURN 0
ENDIF
