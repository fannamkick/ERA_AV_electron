;성교기술のLvUP処理とその可否判定
;eraIm@s_ver.0.17βdのスクリプトをベースに処理を簡略化

;-------------------------------------------------
;성교기술のLvUP
;-------------------------------------------------
@ABLUP14
DRAWLINE
;PRINTL 노예의 성행위 기술을 UP시킵니다
;PRINTL 성교기술이 높아지면, 성행위할 때 상대를 절정시키기 쉬워집니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;성교기술の上限は10
IF (ABL:12 >= 5 && ABL:12 < 5) || ABL:14 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要な습득의 구슬
A = 0
;必要な성교경험
B = 0

;条件別にOKかダメかを記録する
;습득의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足)
I = 0

CALL DECIDE_ABLUP14

;Lv5までは기교が성교기술+1Lvでないといけない
SIF ABL:14 < 5
	PRINTFORML %ABLNAME:12%{ABL:14 + 1}LV이상 (현재{ABL:12}LV) 그리고

PRINTFORM [0] - %PALAMNAME:7%의 구슬×{JUEL:7}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족
ENDIF
PRINTL 
PRINTFORML       %EXPNAME:5%　{EXP:5}/{B}

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 0) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:14 += 1
SIF RESULT == 0
	JUEL:7 -= A

PRINTFORML %ABLNAME:14%의 레벨이 %조사처리(ABL:14,"가")% 되었습니다

RETURN 0

;--------------------------------------------------
;성교기술のLvUP可否判定
;--------------------------------------------------
@DECIDE_ABLUP14
IF (ABL:12 >= 5 && ABL:12 < 5) || ABL:14 >= 10
	RETURN 0
ENDIF
;判定変数を空に
A = 0
B = 0
I = 0

IF ABL:14 == 0
	A = 1
	B = 3
ELSEIF ABL:14 == 1
	A = 10
	B = 10
ELSEIF ABL:14 == 2
	A = 100
	B = 30
ELSEIF ABL:14 == 3
	A = 1500
	B = 80
ELSEIF ABL:14 == 4
	A = 4000
	B = 100
ELSEIF ABL:14 == 5
	A = 5000
	B = 130
ELSEIF ABL:14 == 6
	A = 6500
	B = 160
ELSEIF ABL:14 == 7
	A = 8000
	B = 200
ELSEIF ABL:14 == 8
	A = 10000
	B = 250
ELSEIF ABL:14 == 9
	A = 15000
	B = 300
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:14 == 3
		TIMES A , 1.50
		TIMES B , 1.50
	ELSEIF ABL:14 == 4
		TIMES A , 2.00
		TIMES B , 2.00
	ELSEIF ABL:14 == 5
		TIMES A , 2.50
		TIMES B , 2.50
	ELSEIF ABL:14 >= 6
		TIMES A , 3.00
		TIMES B , 3.00
	ENDIF
ENDIF

;솔직함
IF TALENT:13
	TIMES A , 0.90
	TIMES B , 0.95
ENDIF
;무관심
IF TALENT:21
	TIMES A , 1.10
	TIMES B , 1.05
ENDIF
;감정부족
IF TALENT:22
	TIMES A , 1.10
	TIMES B , 1.05
ENDIF
;호기심
IF TALENT:23
	TIMES A , 0.95
	TIMES B , 0.95
ENDIF
;보수적
IF TALENT:24
	TIMES A , 1.20
	TIMES B , 1.10
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.10
	TIMES B , 1.05
;해방
ELSEIF TALENT:33
	TIMES A , 0.90
	TIMES B , 0.95
ENDIF

;저항
IF TALENT:34
	TIMES A , 1.20
	TIMES B , 1.10
ENDIF

;색정광
IF TALENT:440
	TIMES A , 0.40
	TIMES B , 0.40
ENDIF

;수줍음
IF TALENT:35
	TIMES A , 1.10
	TIMES B , 1.05
;부끄럼 없음
ELSEIF TALENT:36
	TIMES A , 0.95
	TIMES B , 0.95
ENDIF

;習得早い
IF TALENT:50
	TIMES A , 0.80
	TIMES B , 0.80
;습득느림
ELSEIF TALENT:51
	TIMES A , 1.50
	TIMES B , 1.20
ENDIF

;헌신적
IF TALENT:63
	TIMES A , 0.95
	TIMES B , 0.95
ENDIF
;불결무시
IF TALENT:64
	TIMES A , 0.95
	TIMES B , 0.95
ENDIF

;성교중독
IF ABL:30 < 3
	TIMES A , 1.00
	TIMES B , 1.00
ELSEIF ABL:30 < 6
	TIMES A , 0.95
	TIMES B , 0.95
ELSEIF ABL:30 < 8
	TIMES A , 0.90
	TIMES B , 0.90
ELSEIF ABL:30 < 10
	TIMES A , 0.85
	TIMES B , 0.85
ELSE
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF

IF TALENT:505
	TIMES A , 0.01
	TIMES B , 0.10
ENDIF

;最低でも1回・1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1

;습득의 구슬は足りている?
SIF JUEL:7 < A
	I |= 1
;성교경험が必要
SIF EXP:5 < B
	I |= 2
;Lv4までは기교が必要
SIF ABL:12 < 5 && ABL:12 < ABL:14 + 1
	I |= 4

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
