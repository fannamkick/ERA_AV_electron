;-------------------------------------------------
;체력増強
;-------------------------------------------------
@BASEHP_UP
C = 300000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

$INPUT_LOOP

PRINTL 「원하는 분의 체력을 강화하는 약이옵니까?　네, 만들 수 있습니다――만,」
PRINTL 그리고 레이첼이 보여준 재료는 간단하게 모을 수 있는 건 아니었지만, 
PRINTL 돈만 있다면 어떻게든 얻을 수 있는 것들이었다
PRINTL 그러나 필요한 금액이 눈의 의심하게 되는 단위라, 자주 부탁하지는 못할 것 같다……
PRINTL 
PRINTL 어떻게든 자금을 확보해 모은 재료를 레이첼에게 건내주니,
PRINTL 그녀는 잠시 공방에 틀어박혔다
PRINTL 공방 앞을 지나가니 코를 찌르는 냄새와 함께 수상한 목소리가 들려온다……
PRINTW  
PRINTL 「네, 다 됐습니다」
PRINTL 얼마 후, 레이첼이 보라빛 액체가 가득담긴 작은 병을 가지고 왔다
PRINTL 「주의 사항이 있습니다 ……인간이 아닌 분,
PRINTL 　예를들면 안드로이드나 음마 같은 분들에겐 효과가 없습니다.
PRINTL 　또, 부작용으로 체질이 변화할수도 있으니 조심해 주세요」
PRINTL 그럼, 누구에게 먹일까……
PRINTW

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
;안드로이드は排除
ELSEIF TALENT:RESULT:504
	PRINTFORMW 【%TALENTNAME:504%】에겐 효과가 없습니다
	RETURN 0
ELSEIF TALENT:RESULT:330
	PRINTFORMW 【%TALENTNAME:330%】대상에겐 먹일 수 없습니다
	RETURN 0
;안드로이드は排除
ELSEIF TALENT:RESULT:505
	PRINTFORMW 【%TALENTNAME:505%】에겐 효과가 없습니다
	RETURN 0
ENDIF

T = RESULT

$INPUT_LOOP_ADD_PHYSICAL
PRINTFORM %NAME:T%에게 체력 강화제를 먹입니까?
PRINTL  [0] - 네
PRINTL  [1] - 그만둔다
PRINTL  [2] - 여러병 먹인다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0
	PRINTFORMW %NAME:T%의 최대 체력이 100 늘었다
	MAXBASE:T:0 += 100
	CFLAG:T:700 += 1
	MONEY -= C
		IF CFLAG:T:700 == 5 && TALENT:T:112
			PRINTFORMW %CALLNAME:T%의 신진대사가 개선돼, %조사처리(CALLNAME:T,"는")%【%TALENTNAME:112%】이 아니게 됐다
			TALENT:T:112 = 0
		ELSEIF CFLAG:T:700 == 10 && TALENT:T:111 == 0 && TALENT:T:419 == 0
			IF TALENT:T:501 == 0
				IF TALENT:T:511 == 0
					PRINTFORMW %CALLNAME:T%의 신진대사가 개선돼, %조사처리(CALLNAME:T,"는")%【%TALENTNAME:111%】이 됐다
					TALENT:T:111 = 1
				ENDIF
			ENDIF
		ELSEIF CFLAG:T:700 == 15 && TALENT:T:419 == 0
			PRINTFORML %CALLNAME:T%의 신진대사가 개선돼, %조사처리(CALLNAME:T,"는")%【%TALENTNAME:419%】이 됐다
			PRINTFORMW %EXPNAME:50%+1
			TALENT:T:111 = 0
			TALENT:T:419 = 1
			EXP:T:50 += 1
		ENDIF
		
		IF CFLAG:T:700 + CFLAG:T:701 >= 21 && TALENT:T:9 == 0
			PRINTFORMW %CALLNAME:T%의 모습이 이상하다……
			PRINTFORML 과도한 투여에 의해 %CALLNAME:T%의 정신이 붕괴돼 버렸다……
			CALL ADD_CATASTROPH_LABO
		ENDIF	
ELSEIF RESULT == 2
	$INPUT_LOOP_BASE1
	PRINTFORML %NAME:T%에게 체력 강화제를 몇병이나 먹입니까?
	INPUT
	IF RESULT == 0
		RETURN 1
	ELSEIF MONEY < 300000 * RESULT
		PRINTFORMW 포인트가 부족합니다
		GOTO INPUT_LOOP_BASE1
	ELSE
		PRINTFORMW %CALLNAME:T%에게 {RESULT}회 먹입니다 (필요포인트: {300000 * RESULT})
		PRINTFORMW %CALLNAME:T%의 최대 체력이 {100 * RESULT} 늘었다
		MAXBASE:T:0 += 100 * RESULT
		CFLAG:T:700 += 1 * RESULT
		MONEY -= C * RESULT
			IF CFLAG:T:700 >= 5 && CFLAG:T:700 < 10 && TALENT:T:112
				PRINTFORMW %CALLNAME:T%의 신진대사가 개선돼, %조사처리(CALLNAME:T,"는")%【%TALENTNAME:112%】이 아니게 됐다
				TALENT:T:112 = 0
			ELSEIF CFLAG:T:700 >= 10 && CFLAG:T:700 < 15 && TALENT:T:111 == 0 && TALENT:T:419 == 0
				IF TALENT:T:501 == 0
					IF TALENT:T:511 == 0
						PRINTFORMW %CALLNAME:T%의 신진대사가 개선돼, %조사처리(CALLNAME:T,"는")%【%TALENTNAME:111%】이 됐다
						TALENT:T:111 = 1
						TALENT:T:112 = 0
					ENDIF
				ENDIF
			ELSEIF CFLAG:T:700 >= 15 && TALENT:T:419 == 0
				PRINTFORML %CALLNAME:T%의 신진대사가 개선돼, %조사처리(CALLNAME:T,"는")%【%TALENTNAME:419%】이 됐다
				PRINTFORMW %EXPNAME:50%+1
				TALENT:T:111 = 0
				TALENT:T:112 = 0
				TALENT:T:419 = 1
				EXP:T:50 += 1
			ENDIF

			IF CFLAG:T:700 + CFLAG:T:701 >= 21 && TALENT:T:9 == 0
				PRINTFORMW %CALLNAME:T%의 모습이 이상하다……
				PRINTFORML 과도한 투여에 의해 %CALLNAME:T%의 정신이 붕괴돼 버렸다……
				CALL ADD_CATASTROPH_LABO
			ENDIF
			
	ENDIF		
ELSE 
	GOTO INPUT_LOOP_ADD_PHYSICAL
ENDIF

RETURN 1
;

