;===========================================================
;実績の計算
;===========================================================
@IKUMI_LABO_CALC
A = 0
B = 0
C = 0
D = 0
X = 0

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF TALENT:COUNT:500 == 1 && CFLAG:COUNT:1 == 2
		A = 1
	ELSEIF TALENT:COUNT:505 == 1 && CFLAG:COUNT:1 == 2 && TALENT:COUNT:501 == 0
		B = 1
	ELSEIF TALENT:COUNT:501 == 1 && CFLAG:COUNT:1 == 2
		C = 1
	ENDIF
	SIF NO:COUNT == 92
		D = -1
REND

IF A == 1 && B == 1 && C == 1
	CFLAG:MASTER:720 = 1
ENDIF

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 17
		IF CFLAG:COUNT:1 == 2
			D += 1
		ENDIF
	ENDIF
REND

