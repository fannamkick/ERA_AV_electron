$INPUT_LOOP

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
;안드로이드は排除
ELSEIF TALENT:RESULT:504
	PRINTFORMW 【%TALENTNAME:504%】는 임신하지 않습니다
	RETURN 0
;서큐버스は排除
ELSEIF TALENT:RESULT:505
	PRINTFORMW 【%TALENTNAME:505%】는 피임마법을 사용해 임신하지 않습니다
	RETURN 0
;레이첼は排除
ELSEIF TALENT:RESULT:500
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 피임마법을 사용해 임신하지 않습니다
	RETURN 0
ELSEIF TALENT:RESULT:330
	PRINTFORMW 【%TALENTNAME:330%】대상자는 불임수술할 수 없습니다
	RETURN 0
;임신중は排除
ELSEIF TALENT:RESULT:153
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 임신중이므로 모체에 악영향을 미칠 가능성이 있습니다
	RETURN 0
;虚弱な女の子は排除
ELSEIF MAXBASE:RESULT:0 <= 1000
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 체력이 적어 악영향을 미칠 가능성이 있습니다
	RETURN 0
ENDIF

T = RESULT

$INPUT_LOOP_2

PRINTFORML %조사처리(NAME:T,"로")% 합니까?
PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0
	IF TALENT:T:420 == 0
		PRINTFORMW %조사처리(NAME:T,"를")% 이쿠미의 연구소에 데려갔다……
		PRINTFORML 불임수술을 받아달라고 하니 %조사처리(CALLNAME:T,"는")% 망설이면서도 고개를 끄덕였다……
		PRINTFORMW %조사처리(CALLNAME:T,"는")%【%TALENTNAME:420%】이 됐다
		TALENT:T:420 = 1
		MAXBASE:T:0 -= 500
		BASE:T:0 -= 500
	ELSEIF TALENT:T:420 == 1
		PRINTFORMW %조사처리(NAME:T,"를")% 이쿠미의 연구소에 데려갔다……
		PRINTFORML 피임치료를 받아달라고 하니 %조사처리(CALLNAME:T,"는")% 망설이면서도 고개를 끄덕였다……
		PRINTFORMW %조사처리(CALLNAME:T,"는")%【%TALENTNAME:420%】이 아니게 됐다
		TALENT:T:420 = 0
		MAXBASE:T:0 += 500
		BASE:T:0 += 500
	ENDIF
ELSE
	GOTO INPUT_LOOP_2
ENDIF
PRINTW

MONEY -= C

RETURN 1
