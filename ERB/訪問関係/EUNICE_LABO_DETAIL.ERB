;=================================================
;프라이드 높음
;=================================================
@BREAK_PRIDE_HIGH
C = 2000000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

CHKFONT "あくびん"
	IF RESULT
		SETFONT "あくびん"
	ENDIF
SETCOLOR 0xDDBBCC
PRINTL 「그래, 이 아이의 프라이드가 높아지도록 조정하면 되는거지?」
RESETCOLOR
SETFONT ""
$INPUT_LOOP
DRAWLINE

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
;미션は排除
ELSEIF TALENT:RESULT:330
	PRINTFORMW  유니스는【%TALENTNAME:330%】대상에겐 흥미가 없어 보입니다
	GOTO INPUT_LOOP
;유니스は排除
ELSEIF NO:RESULT == 86
	PRINTFORMW  %CALLNAME:RESULT%에겐 효과가 없습니다
	GOTO INPUT_LOOP
;프라이드 높음・低いは排除
ELSEIF TALENT:RESULT:15 || TALENT:RESULT:17
	PRINTFORMW  %CALLNAME:RESULT%에겐 효과가 없습니다
	GOTO INPUT_LOOP
ENDIF

TARGET = RESULT

$INPUT_LOOP_2
PRINTFORML  %타겟을()% 유니스에게 데려오겠습니까?
PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0
	PRINTFORML  유니스는 끌려온 %CALLNAME:TARGET%에게 귓속말로, 말 그대로 악마의 유혹을 속삭였다……
	PRINTFORML  그 말에 영혼이 침식당한 %타겟은()% 텅 빈 눈으로 특정한 말을 읇조리고 있다
	PRINTFORML 《유니스의 광기에 침식당한 %타겟은()%【%TALENTNAME:15%】이 됐다》
	PRINTFORML
	PRINTFORMW  %EXPNAME:50% +1
	EXP:50 += 1
	TALENT:15 = 1
ELSE
	GOTO INPUT_LOOP_2
ENDIF

MONEY -= C

RETURN 1
