PRINTFORML %CALLNAME:TARGET%에게【영원한 사랑】을 습득시킵니까?
PRINTL [0] - 네
PRINTL [1] - 아니오
$INPUT_LOOP
INPUT

IF RESULT == 1
	RETURN
ELSEIF RESULT == 0
	PRINTFORMW 《%타겟이()%【영원한 사랑】을 습득한 상태로 시작합니다》
	CFLAG:1 = 2
	TALENT:27 = 0
	TALENT:85 = 1
	TALENT:430 = 1
	CFLAG:2 = 5000
	ABL:10 = 7
	ABL:16 = 7
	MARK:2 = 3
	LOADGLOBAL
		GLOBAL:200 -= 500
	SAVEGLOBAL
	X += 500
	EXP:23 = 500
	RETURN
ELSE
	GOTO INPUT_LOOP
ENDIF

RETURN

