import { useState, useMemo } from 'react';
import { useGameStore } from '../stores/gameStore';
import { gameData } from '../data/loaderJSON';
import './SlaveMarketScreen.css';

interface SlaveMarketScreenProps {
  onBack: () => void;
}

const CHARS_PER_PAGE = 60;

function SlaveMarketScreen({ onBack }: SlaveMarketScreenProps) {
  const { availableCharacters, ownedCharacters, money, flags, addCharacter, addMoney } = useGameStore();
  const [currentPage, setCurrentPage] = useState(0);
  const [selectedChar, setSelectedChar] = useState<number | null>(null);

  // 사무소 규모 (FLAG:23, 기본 10명, 키류 조직 요청으로 증가)
  const maxCharacters = flags[23] || 10;

  // 현재 페이지의 캐릭터들
  const currentPageChars = useMemo(() => {
    const start = currentPage * CHARS_PER_PAGE;
    const end = start + CHARS_PER_PAGE;
    return availableCharacters
      .filter(char => char.id > 0) // ID 0은 플레이어 자신
      .slice(start, end);
  }, [availableCharacters, currentPage]);

  // 총 페이지 수
  const totalPages = Math.ceil(availableCharacters.filter(c => c.id > 0).length / CHARS_PER_PAGE);

  const handlePurchase = (char: any) => {
    // 계약 수 제한 체크
    if (ownedCharacters.length >= maxCharacters) {
      alert(`이 이상 계약하려면 다른 배우를 은퇴시켜야 합니다 (최대: ${maxCharacters}명)`);
      return;
    }

    // 가격 확인 (Character 객체 또는 CharacterData에서 가져오기)
    let price = char.price?.[1001]; // 랜덤 캐릭터는 price 필드 있음
    if (!price) {
      // 스페셜 캐릭터는 gameData에서 가져오기
      const charData = gameData.getCharacter(char.id);
      price = charData?.price?.[1001] || 50000; // 기본 가격 50000
    }

    // 소지금 확인
    if (money < price) {
      alert('소지금이 부족합니다');
      return;
    }

    // 이미 소유 확인
    if (ownedCharacters.some(c => c.id === char.id)) {
      alert('이미 계약한 배우입니다');
      return;
    }

    // 구매 확인
    if (!confirm(`${char.name}을(를) ¥${price.toLocaleString()}에 계약하시겠습니까?`)) {
      return;
    }

    // 소지금 차감
    addMoney(-price);

    // 캐릭터 추가 (ADDCHARA)
    addCharacter(char);

    alert(`${char.name}을(를) 계약했습니다!`);
    setSelectedChar(null);
  };

  const handleShowDetail = (charId: number) => {
    setSelectedChar(selectedChar === charId ? null : charId);
  };

  return (
    <div className="slave-market-screen">
      <div className="info-bar">
        <h2>배우 모집 ({ownedCharacters.length}/{maxCharacters}명)</h2>
        <div className="money-display">
          <span className="label">소지금:</span>
          <span className="value">¥{money.toLocaleString()}</span>
        </div>
      </div>

      {/* 페이지네이션 */}
      <div className="pagination">
        <button
          onClick={() => setCurrentPage(p => Math.max(0, p - 1))}
          disabled={currentPage === 0}
        >
          ◀ 이전
        </button>
        <span>페이지 {currentPage + 1} / {totalPages}</span>
        <button
          onClick={() => setCurrentPage(p => Math.min(totalPages - 1, p + 1))}
          disabled={currentPage >= totalPages - 1}
        >
          다음 ▶
        </button>
      </div>

      <div className="market-grid-container">
        <div className="market-grid">
          {currentPageChars.map((char) => {
            const isOwned = ownedCharacters.some(c => c.id === char.id);

            // 가격 확인 (랜덤 캐릭터는 char.price, 스페셜은 gameData)
            let price = char.price?.[1001];
            if (!price) {
              const charData = gameData.getCharacter(char.id);
              price = charData?.price?.[1001] || 50000;
            }

            const charData = gameData.getCharacter(char.id);
            const isExpanded = selectedChar === char.id;

            return (
              <div key={char.id} className={`market-card ${isOwned ? 'owned' : ''} ${isExpanded ? 'expanded' : ''}`}>
                <div className="char-header" onClick={() => handleShowDetail(char.id)}>
                  <div className="char-avatar">{char.name[0]}</div>
                  <div className="char-details">
                    <div className="char-name">{char.name}</div>
                    {char.callName && (
                      <div className="char-callname">{char.callName}</div>
                    )}
                    <div className="char-price">¥{price.toLocaleString()}</div>
                  </div>
                  <div className="expand-icon">{isExpanded ? '▼' : '▶'}</div>
                </div>

                {isExpanded && charData && (
                  <div className="char-expanded-info">
                    <div className="char-stats">
                      <h4>능력치</h4>
                      <div className="stats-grid">
                        {Object.entries(charData.abilities || {}).slice(0, 5).map(([ablId, value]) => {
                          const ablDef = gameData.getAbility(Number(ablId));
                          return (
                            <div key={ablId} className="stat-item">
                              <span className="stat-name">{ablDef?.name || `ABL${ablId}`}:</span>
                              <span className="stat-value">{value}</span>
                            </div>
                          );
                        })}
                      </div>
                    </div>

                    <div className="char-talents">
                      <h4>소질 ({charData.talents?.length || 0}개)</h4>
                      <div className="talents-list">
                        {charData.talents?.slice(0, 5).map((talentId) => {
                          const talentDef = gameData.getTalent(talentId);
                          return (
                            <span key={talentId} className="talent-tag">
                              {talentDef?.name || `T${talentId}`}
                            </span>
                          );
                        })}
                        {(charData.talents?.length || 0) > 5 && (
                          <span className="talent-tag">외 {charData.talents!.length - 5}개...</span>
                        )}
                      </div>
                    </div>

                    <button
                      className="purchase-button-detail"
                      onClick={(e) => {
                        e.stopPropagation();
                        handlePurchase(char);
                      }}
                      disabled={isOwned || money < price || ownedCharacters.length >= maxCharacters}
                    >
                      {isOwned ? '보유중' : money < price ? '소지금 부족' : ownedCharacters.length >= maxCharacters ? '계약 한도 초과' : `¥${price.toLocaleString()} 계약`}
                    </button>
                  </div>
                )}

                {!isExpanded && (
                  <button
                    className="purchase-button"
                    onClick={(e) => {
                      e.stopPropagation();
                      handlePurchase(char);
                    }}
                    disabled={isOwned || money < price || ownedCharacters.length >= maxCharacters}
                  >
                    {isOwned ? '보유중' : '계약'}
                  </button>
                )}
              </div>
            );
          })}
        </div>

        {/* 돌아가기 버튼을 그리드 하단에 배치 */}
        <div className="market-bottom-actions">
          <button className="back-button" onClick={onBack}>돌아가기</button>
        </div>
      </div>
    </div>
  );
}

export default SlaveMarketScreen;
