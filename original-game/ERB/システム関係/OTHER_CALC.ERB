;===========================================================
;AVパートの計算
;===========================================================
@AV_CALC
A = 0
B = 0
C = 0
D = 0
E = 0
F = 0
G = 0

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 1 && TALENT:COUNT:422 == 1 && CFLAG:COUNT:1 == 2 && TALENT:COUNT:400 == 1
		A = 1
			IF FLAG:506 == 1 && TALENT:COUNT:121 == 1
				E = 1
			ENDIF
	ELSEIF NO:COUNT == 5 && CFLAG:COUNT:1 == 2 && TALENT:COUNT:400 == 1
		B = 1
			IF FLAG:505 == 1 && TALENT:COUNT:121 == 1
				F = 1
			ENDIF
	ELSEIF TALENT:COUNT:507 == 1
		C = 1
	ELSEIF NO:COUNT == 13 && CFLAG:COUNT:1 == 2
		D = 1
	ELSEIF TALENT:COUNT:422 == 1
		G = 1
	ENDIF
REND