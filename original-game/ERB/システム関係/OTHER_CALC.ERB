;===========================================================
;위험일算出
;===========================================================
@OVULATION_CALC
REPEAT CHARANUM
	IF TALENT:COUNT:122 == 1
		CONTINUE
	ELSEIF TALENT:COUNT:504
		CONTINUE
		IF CFLAG:COUNT:30 > 5
			CFLAG:COUNT:18 = 0
		ELSEIF DAY:2 == 1 && CFLAG:COUNT:30 == 1
			CFLAG:COUNT:20 = 1
		ELSEIF DAY:2 == 2 && CFLAG:COUNT:30 == 2
			CFLAG:COUNT:20 = 1
		ELSEIF DAY:2 == 3 && CFLAG:COUNT:30 == 3
			CFLAG:COUNT:20 = 1
		ELSEIF DAY:2 == 4 && CFLAG:COUNT:30 == 4
			CFLAG:COUNT:20 = 1
		ELSEIF DAY:2 == 5 && CFLAG:COUNT:30 == 5
			CFLAG:COUNT:20 = 1
		ELSEIF DAY:2 == 5 && CFLAG:COUNT:30 == 0
			CFLAG:COUNT:20 = 1
		ELSEIF DAY:2 == 1 && CFLAG:COUNT:30 == 3
			CFLAG:COUNT:20 = 2
		ELSEIF DAY:2 == 2 && CFLAG:COUNT:30 == 4
			CFLAG:COUNT:20 = 2
		ELSEIF DAY:2 == 3 && CFLAG:COUNT:30 == 5
			CFLAG:COUNT:20 = 2
		ELSEIF DAY:2 == 3 && CFLAG:COUNT:30 == 0
			CFLAG:COUNT:20 = 2
		ELSEIF DAY:2 == 3 && CFLAG:COUNT:30 == 1
			CFLAG:COUNT:20 = 2
		ELSEIF DAY:2 == 4 && CFLAG:COUNT:30 == 2
			CFLAG:COUNT:20 = 2
		ENDIF
	ENDIF
REND
