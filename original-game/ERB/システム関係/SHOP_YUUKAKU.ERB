@YUUKAKU_LABO

$INPUT_LOOP

A = 0
B = 0

DRAWLINE
PRINTL 어떤 시설을 확장시키겠습니까?
PRINTFORML 《운영자금 {MONEY}포인트》(현재 공헌도: {EXP:MASTER:90})
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
SIF (FLAG:48 & 1) == 0
	PRINTL  [0] - 개인실　　　　　(3000포인트)
SIF (FLAG:48 & 2) == 0 && EXP:MASTER:90 >= 10
	PRINTL  [1] - SM용품　　　　(1500포인트)
SIF (FLAG:48 & 4) == 0 && EXP:MASTER:90 >= 30
	PRINTL  [2] - 호위　　　　　　(10000포인트)
SIF (FLAG:48 & 1) != 0 && (FLAG:48 & 32) == 0 && EXP:MASTER:90 >= 50
	PRINTL  [3] - 목욕실　　　　　(30000포인트)
SIF (FLAG:48 & 128) == 0 && EXP:MASTER:90 >= 60
	PRINTL  [4] - 포장마차　　　　(80000포인트)
SIF (FLAG:48 & 8) == 0 && EXP:MASTER:90 >= 80
	PRINTL  [5] - 다목적홀　　　　(100000포인트)
SIF (FLAG:48 & 8) != 0 && (FLAG:48 & 16) == 0 && EXP:MASTER:90 >= 100
	PRINTL  [6] - 음향설비　　　　(50000포인트)
SIF (FLAG:48 & 8) != 0 && FLAG:40 < 10 && EXP:MASTER:90 >= 120
	PRINTL  [7] - 경비원　　　　　(50000포인트)
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
PRINTL  [99] - 확장 여부 확인
DRAWLINE
PRINTL  [999] - 돌아간다

INPUT
IF RESULT == 999
	RETURN 999
ELSEIF RESULT == 99
	CALL FACILITIES_CHECK
	GOTO INPUT_LOOP
ELSEIF RESULT == 0 && (FLAG:48 & 1) == 0
	A = 3000
	B = 1
ELSEIF RESULT == 1 && (FLAG:48 & 2) == 0
	A = 1500
	B = 2
ELSEIF RESULT == 2 && (FLAG:48 & 4) == 0 && EXP:MASTER:90 >= 30
	A = 10000
	B = 4
ELSEIF RESULT == 3 && (FLAG:48 & 1) != 0 && (FLAG:48 & 32) == 0 && EXP:MASTER:90 >= 50
	A = 30000
	B = 32
ELSEIF RESULT == 4 && (FLAG:48 & 128) == 0 && EXP:MASTER:90 >= 60
	A = 80000
	B = 128
ELSEIF RESULT == 5 && (FLAG:48 & 8) == 0 && EXP:MASTER:90 >= 80
	A = 100000
	B = 8
ELSEIF RESULT == 6 && (FLAG:48 & 8) != 0 && (FLAG:48 & 16) == 0 && EXP:MASTER:90 >= 100
	A = 50000
	B = 16
ELSEIF RESULT == 7 && (FLAG:48 & 8) != 0 && FLAG:40 < 10 && EXP:MASTER:90 >= 120
	A = 50000
	;ビットでまとめてチェックすることを想定し, 一応これにもビットを割りあてておく
	B = 64
ELSE
	GOTO INPUT_LOOP
ENDIF

R = RESULT

;助手の中の商売人をチェック
M = 0
REPEAT CHARANUM
	IF TALENT:COUNT:211 && ISASSI:COUNT && ABL:COUNT:15
		SIF ABL:COUNT:15 > ABL:M:15
			M = COUNT
	ENDIF
REND

IF M
	A *= 100 - (ABL:M:15 * 5)
	A /= 100
	PRINTFORML %NAME:M%의 협상을 통해 가격을 {A}포인트로 흥정했다.
	WAIT
ENDIF

IF MONEY < A
	PRINTL 필요한 포인트가 부족합니다.
	WAIT
	GOTO INPUT_LOOP
ENDIF

MONEY -= A
FLAG:48 |= B

IF R == 0
	PRINTL 방음 시설을 갖춘 독방을 추가했습니다.
	PRINTL 이제 A영업과 V영업이 가능합니다.
	WAIT
ELSEIF R == 1
	PRINTL 각종 SM상품을 입하했습니다.
	PRINTL 이제 SM영업이 가능합니다.
	WAIT
ELSEIF R == 2
	PRINTL 운전사 겸 호위를 고용했습니다.
	PRINTL 이제 출장 영업이 가능합니다.
	WAIT
ELSEIF R == 3
	PRINTL 각 별실에 목욕실을 설치했습니다.
	PRINTL 이제 소프 플레이가 가능합니다.
	WAIT
ELSEIF R == 4
	PRINTFORML 손님에게 식사를 주기 위한 포장마차를 구비했습니다.
	PRINTL 이제 요리를 판매할 수 있습니다.
	WAIT
ELSEIF R == 5
	PRINTL 다목적 홀을 지었습니다.
	PRINTL 이제 특별한 영업이 가능합니다.
	WAIT
ELSEIF R == 6
	PRINTL 음향 시설을 갖추었습니다.
	PRINTL 이제 다양한 쇼가 가능합니다.
	WAIT
ELSEIF R == 7
	FLAG:40 += 1
	PRINTFORML 전속 경비원을 고용했습니다.(총 {FLAG:40}인)
	PRINTL 쇼를 할 때 직원의 안전성이 높아집니다.
	WAIT
ENDIF

GOTO INPUT_LOOP

