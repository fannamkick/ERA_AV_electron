;-------------------------------------------------
;모유売却
;-------------------------------------------------
@SELL_MILK

A = TFLAG:35 * 100
O = A * 5
IF A > 0
	DRAWLINE

	IF EXP:54 <= EXPLV:3
		TIMES O , 1.00
	ELSEIF EXP:54 <= EXPLV:4
		TIMES O , 1.20
	ELSEIF EXP:54 <= EXPLV:5
		TIMES O , 1.50
	ELSE
		TIMES O , 2.00
	ENDIF

	;처녀なら売却額三倍
	SIF TALENT:0
		O = O * 3
	;가슴광なら売却額ニ倍
	SIF TALENT:78
		O = O * 2

	PRINTFORML 착유기를 사용해 %CALLNAME:TARGET%에게서 모유를 {A}cc 짜냈습니다.
	IF ASSI > 0
		IF TALENT:ASSI:211 && ABL:ASSI:15
			PRINTFORML %CALLNAME:ASSI%의 뛰어난 가공 덕분에 %CALLNAME:TARGET%의 모유는 평소보다 비싸게 팔렸다.
			O *= 100 + ABL:ASSI:15 * 5
			O /= 100
		ENDIF
	ENDIF
	PRINTFORML %NAME:TARGET%의 모유는 {O}포인트로 팔렸다
	MONEY += O
	PRINTFORML 소지금 {O}포인트 증가
	WAIT
ENDIF

RETURN 0
