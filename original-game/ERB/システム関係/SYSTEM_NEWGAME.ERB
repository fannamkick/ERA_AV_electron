;-------------------------------------------------
;強くてニューゲーム引継ぎキャラ選択
;-------------------------------------------------
@NEWGAME_SUCCEEDED
;大幅改変
#DIM 인수
;ここまで要らなかったと思うけどこのぐらい持っておく
#DIM 후보리스트,500
#DIM CNUM
#DIM LINENUM

;リストを構築する
;変数のリセット
VARSET 후보리스트
인수 = 0

;候補抽出
REPEAT CHARANUM
	;主人公は排除
	SIF COUNT == 0
		CONTINUE
	;臨死中のキャラは排除
	SIF BASE:COUNT:0 < 1
		CONTINUE
	;【연심】【음란】持ちでないキャラは排除
	SIF TALENT:COUNT:85 == 0 && TALENT:COUNT:76 == 0
		CONTINUE
	후보리스트:인수 = COUNT
	인수++
REND

;描画

PRINTFORML 인계할 배우를 선택해주세요
DRAWLINE
;セーブ포인트
$REFRESH_POINT
;行数を覚えておく
LINENUM = LINECOUNT

FOR CNUM,0,인수
	PRINTFORM [{후보리스트:CNUM}]  %NAME:(후보리스트:CNUM)%
	SIF CFLAG:(후보리스트:CNUM):130 == 1
	PRINT  (선택됨)
	PRINTL 
NEXT
PRINTFORML  [999] - 선택완료 / [1000] - 전원 선택/선택 해제

INPUT

IF RESULT == 999
	RETURN 1
ELSEIF RESULT == 1000
	J = 0
	;最初の一人を見てそれに合わせる
	IF CFLAG:(후보리스트:0):130 == 0
		FOR CNUM,0,인수
			CFLAG:(후보리스트:CNUM):130 = 1
			J++
		NEXT
	ELSE
		FOR CNUM,0,인수
			CFLAG:(후보리스트:CNUM):130 = 0
		NEXT
	ENDIF
	GOTO RESET_POINT
ELSEIF RESULT == 0
	PRINTW 잘못된 입력값입니다
	GOTO RESET_POINT
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	PRINTW 잘못된 입력값입니다
	GOTO RESET_POINT
;【연심】【음란】持ちでないキャラは排除
ELSEIF TALENT:RESULT:85 == 0 && TALENT:RESULT:76 == 0
	PRINTW 잘못된 입력값입니다
	GOTO RESET_POINT
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	PRINTW 잘못된 입력값입니다
	GOTO RESET_POINT
ENDIF

IF CFLAG:RESULT:130 == 0
	CFLAG:RESULT:130 = 1
	J += 1
ELSEIF CFLAG:RESULT:130 == 1
	CFLAG:RESULT:130 = 0
	J -= 1
ENDIF

$RESET_POINT
;これで元のリストが消えてちょうどよく表示される予定
CLEARLINE LINECOUNT-LINENUM
GOTO REFRESH_POINT