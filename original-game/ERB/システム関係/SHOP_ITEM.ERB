;-------------------------------------------------
;複数個所持可能な아이템の処理
;-------------------------------------------------
@BUY_PLURAL
;현재 구매가능 수량, B는 소지 가능 최대수(현재100개), C는 소지금によるもの
;A는 아이템의 단가, D는 B와 C중 작은쪽, E는 B<=C라면 0, B>C라면 1
;콘돔
SIF BOUGHT == 24
	A = 10
;로션
SIF BOUGHT == 25
	A = 200
;프린세스포이즌
SIF BOUGHT == 26
	A = 2000
;싸인펜
SIF BOUGHT == 29
	A = 100
;이뇨제
SIF BOUGHT == 27
	A = 1000
;=====================
;;비디오테이프 - 없음
;SIF BOUGHT == 28
;	A = 500
;=====================
;피어스링
SIF BOUGHT == 34
	A = 5000
B = 100-ITEM:BOUGHT
C = MONEY/A+1
IF B <= C
	D = B
	E = 0
ELSE
	D = C
	E = 1
ENDIF
