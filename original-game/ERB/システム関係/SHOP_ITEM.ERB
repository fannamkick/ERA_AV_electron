	PRINTFORML 《%플레이어는(1)%【%TALENTNAME:91%】을 몸에 익혔다》
	TALENT:MASTER:91 = 1
	ITEM:BOUGHT = 0
ENDIF
;素質아이템【비밀지식】
IF BOUGHT == 39
	TALENT:MASTER:325 = 1
	ITEM:BOUGHT = 0
ENDIF
;素質아이템【조합지식】
IF BOUGHT == 42
	TALENT:MASTER:55 = 1
	ITEM:BOUGHT = 0
ENDIF
;素質아이템【기교LV】
IF BOUGHT == 52
	;EASYなら1つで1Lv上がる
	IF FLAG:5 == 1
		CALL TECHNIQUE_OF_MASTER_UP
	;NORMAL/EXTRAならLv3までは1つで1Lv上がり, それ以降は기교Lv-1分必要になる
	ELSEIF FLAG:5 == 2 || FLAG:5 == 9
		IF ABL:MASTER:12 >= 3
			F = ABL:MASTER:12 - 1
			CALL TECHNIQUE_OF_MASTER
		ELSE
			CALL TECHNIQUE_OF_MASTER_UP
		ENDIF
	;HARDならLv2までは1つで1Lv上がり, それ以降は기교Lv*2分必要になる
	ELSEIF FLAG:5 == 3
		IF ABL:MASTER:12 >= 2
			F = ABL:MASTER:12
			F *= 2
			CALL TECHNIQUE_OF_MASTER
		ELSE
			CALL TECHNIQUE_OF_MASTER_UP
		ENDIF
	;POWERFULならLv1までは1つで1Lv上がり, それ以降は기교Lv*5分必要になる
	ELSEIF FLAG:5 == 4
		IF ABL:MASTER:12 >= 1
			F = ABL:MASTER:12
			F *= 5
			CALL TECHNIQUE_OF_MASTER
		ELSE
			CALL TECHNIQUE_OF_MASTER_UP
		ENDIF
	;PHANTASM以上なら기교Lv*100分必要になる
	ELSE
		F = ABL:MASTER:12
		F *= 100
		CALL TECHNIQUE_OF_MASTER
	ENDIF
	;撮影可能シーン数らしいよ
	MAXBASE:MASTER:60 += 4
ENDIF

WAIT

RETURN 1
