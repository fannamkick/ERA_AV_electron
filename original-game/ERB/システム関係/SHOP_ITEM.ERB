						;****使用아이템連続購入改造ここまで****
	RETURN 0
ELSEIF RESULT < 0
	GOTO INPUT_LOOP
ELSEIF RESULT > D
	IF RESULT > D && E == 0
		PRINTL 그렇게 많이 가질 수 없습니다
	ELSEIF RESULT > D && E == 1
		PRINTL 소지금이 부족합니다
	ENDIF
	GOTO INPUT_LOOP
ELSEIF RESULT == 1
	PRINTFORML 《%조사처리(ITEMNAME:BOUGHT,"를")% 구입했습니다》
	WAIT
	RETURN 0
ELSE
	PRINTFORML 《%조사처리(ITEMNAME:BOUGHT,"를")% {RESULT}개 구입했습니다》
	WAIT
	ITEM:BOUGHT += RESULT-1
	MONEY -= A*(RESULT-1)
	RETURN 0
ENDIF

