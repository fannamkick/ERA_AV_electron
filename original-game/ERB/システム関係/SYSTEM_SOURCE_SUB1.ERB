;-------------------------------------------------
;첫 키스のチェック
;-------------------------------------------------
@FIRSTKISS_TARGET_CHECK
;キス経験済か唇を使うコマンドフラグが立ってなければそのまま終了
SIF CFLAG:16 != -1 || TFLAG:621 == 0
	RETURN 0

SETCOLOR 0xF58F98
PRINTL 【첫 키스】
RESETCOLOR
CFLAG:16 = 1

CFLAG:820 = BASE:9
CFLAG:821 = DAY:1
CFLAG:822 = DAY:2

;CFLAG:16=16にするとこの辺の特殊処理をガン無視することになるんだなあと頭を抱えるなど
IF (TFLAG:621 & 2)
	IF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 0 && ASSIPLAY == 0
		CSTR:1 = 오빠
		CFLAG:16 = 16
	ELSEIF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 1 && ASSIPLAY == 0
		CSTR:1 = 오라비
		CFLAG:16 = 16
	ELSE
		CSTR:1 = %NAME:PLAYER%
		SIF NO:PLAYER == MASTER
			CFLAG:16 = 16
	ENDIF
	CFLAG:824 = 1
ELSEIF (TFLAG:621 & 4)
	IF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 0 && ASSIPLAY == 0
		CSTR:1 = 오빠
		CFLAG:16 = 16
	ELSEIF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 1 && ASSIPLAY == 0
		CSTR:1 = 오라비
		CFLAG:16 = 16
	ELSE
		CSTR:1 = %NAME:PLAYER%
		SIF NO:PLAYER == MASTER
			CFLAG:16 = 16
	ENDIF
	CFLAG:824 = 2
ELSEIF (TFLAG:621 & 8) 
	IF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 0 && ASSIPLAY == 0
		CSTR:1 = 오빠
		CFLAG:16 = 16
	ELSEIF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 1 && ASSIPLAY == 0
		CSTR:1 = 오라비
		CFLAG:16 = 16
	ELSE
		CSTR:1 = %NAME:PLAYER%
	ENDIF
	CFLAG:824 = 3
ELSE
	IF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 0 && ASSIPLAY == 0
		CSTR:1 = 오빠
		CFLAG:16 = 16
	ELSEIF NO:TARGET == 1 && NO:MASTER == 0 && TALENT:432 == 1 && ASSIPLAY == 0
		CSTR:1 = 오라비
		CFLAG:16 = 16
	ELSE
		CSTR:1 = %NAME:PLAYER%
		SIF NO:PLAYER == MASTER
			CFLAG:16 = 16
	ENDIF
ENDIF


