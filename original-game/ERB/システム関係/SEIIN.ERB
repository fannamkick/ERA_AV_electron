;----------------------------------------------------------------
;精飲절정関連の処理の始動
;----------------------------------------------------------------
@SEIIN_START
;システムを適応していないと処理しない
SIF FLAG:72 == 1
RETURN 0

;口で사정させていないor失神中だと処理しない
IF TFLAG:0 == 0 || TFLAG:899 > 0
	RETURN 0
;정애미각を持っている場合は精飲절정処理へ直行
ELSEIF TALENT:47 && TFLAG:0 > 0
	CALL SEIIN_ORGASM
;정애미각を持たず, 절정を迎えている場合(箇所は問わない), 強制精飲절정の回数(通称: パブロフカウンター)をチェックする
ELSEIF TFLAG:0 > 0 && TFLAG:29 > 0
	CALL SEIIN_CHECK
ENDIF

;----------------------------------------------------------------
;強制精飲절정の回数(パブロフカウンター)チェック
;----------------------------------------------------------------
@SEIIN_CHECK

;規定の回数
P = 50

;奴隷の素質により規定回数を増減する
;다부짐
SIF TALENT:12 == 1
	P += 4
;보수적
SIF TALENT:24 == 1
	P += 4
;포지티브(ポジティブ)
SIF TALENT:25 == 1
	P -= 2
;悲観的(ネガティブ)
SIF TALENT:26 == 1
	P += 2
;일선을 넘지않음
SIF TALENT:27 == 1
	P += 5
;억압
SIF TALENT:32 == 1
	P += 4
;해방
SIF TALENT:33 == 1
	P -= 2
;악취둔감
SIF TALENT:61 == 1
	P -= 2
;악취민감
SIF TALENT:62 == 1
	P += 2
;쾌감에 솔직
SIF TALENT:70 == 1
	P -= 2
;쾌감을 부정
SIF TALENT:71 == 1
	P += 4
;중독되기쉬움
SIF TALENT:72 == 1
	P -= 5
;도착적
SIF TALENT:80 == 1
	P -= 2
;음란
SIF TALENT:76 == 1
	P -= 20

;強制精飲절정の処理へ
CALL SEIIN_COMPULSION_ORGASM

;----------------------------------------------------------------
;精飲절정の処理
;----------------------------------------------------------------
@SEIIN_ORGASM

;精飲절정경험の回数追加
EX:13 += 1
EXP:8 += 1

;精飲절정경험の処理
;経験の回数によって処理が変化
IF TFLAG:0 == 2
	PRINTFORML %CALLNAME:TARGET% 정음 절정
	PRINTFORML 정음절정경험 +1
	PRINTL 대량의 정액이 목에 흘러드는 것에 의해 스위치가 켜져버린 것인지, 
	PRINTFORML %타겟은()% 우물거리는 소리를 내며, 동시에 움찔 하고 크게 어깨를 떨며 절정에 도달했다…
ELSE
	PRINTFORML %CALLNAME:TARGET% 정음 절정
	PRINTFORML 정음절정경험 +1
	PRINTFORML 페니스를 입에 물고 있던 %타겟은()% 우물거리는 소리를 내며, 
	PRINTL 움찔 하고 어깨를 작게 떨며 절정에 도달했다…
ENDIF

;パラメーター増減
;基本ソース
SOURCE:10 = 2000
SOURCE:11 = 5000
SOURCE:13 = 10000

IF EXP:8 == 1
	TIMES SOURCE:13 , 3.00
ELSEIF ABL:32 == 3
	TIMES SOURCE:13 , 2.00
ELSEIF ABL:32 == 4
	TIMES SOURCE:10 , 1.50
	TIMES SOURCE:11 , 1.50
	TIMES SOURCE:13 , 1.50
ELSEIF ABL:32 == 5
	TIMES SOURCE:10 , 2.00
	TIMES SOURCE:11 , 2.00
ENDIF


;----------------------------------------------------------------
;強制精飲절정の処理
;強制精飲절정の経験回数をCFLAG:580に格納
;----------------------------------------------------------------
@SEIIN_COMPULSION_ORGASM
;△二本Fのときのことを考えると誰が放ったかちゃんと分かるようにして代入すべきなんだけど
;とりあえず暫定でダブル系の場合地の文と実態に齟齬が出るとこだけ修正

CFLAG:580 += 1

;정애미각獲得フラグ成立メッセージ
IF CFLAG:580 >= P
	PRINTFORML 강제 정음 절정
	PRINTFORML %타겟은()% 완전히 
	PRINTFORMW 정액의 맛을 각인해버린 것 같다…
	TFLAG:110 = 1
;強制精飲절정初回
ELSEIF CFLAG:580 == 1
	PRINTFORML 강제 정음 절정
	PRINTFORML %타겟은()% %플레이어가()% 쏟아낸 정액을 마시며
	PRINTFORML 지속적으로 주어지는 자극에 의해 
	PRINTFORMW 강제로 가버렸다…
	PRINTFORML 이상경험 +1
	EXP:50 += 1
;以降メッセージは出るがウェイトはかからない
ELSE
	PRINTFORML 강제 정음 절정
	PRINTFORML %타겟은()% %플레이어가()% 쏟아낸 정액을 마시며
	PRINTFORML 지속적으로 주어지는 자극에 의해 
	PRINTFORML 강제로 가버렸다…
ENDIF

;정애미각獲得フラグ成立時
IF CFLAG:580 >= P
	;정액중독がLV3に上がる
	IF ABL:32 < 3
		PRINTFORMW %CALLNAME:TARGET%의 정액중독이 LV3이 되었다
		ABL:32 = 3
	ENDIF
ENDIF

;パラメーター増減
;基本ソース
SOURCE:13 = 1000

IF CFLAG:580 == 1
	TIMES SOURCE:13 , 1.50
ELSEIF CFLAG:580 == P
	SOURCE:5 = 1000
ENDIF
