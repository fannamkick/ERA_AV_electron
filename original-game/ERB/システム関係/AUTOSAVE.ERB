@SYSTEM_AUTOSAVE
GETTIME
SELECTCASE FLAG:5
	CASE 1
		RESULTS:0 += " EASY/"
	CASE 2
		RESULTS:0 += " NORMAL/"
	CASE 3
		RESULTS:0 += " HARD/"
	CASE 4
		RESULTS:0 += " POWERFUL/"
	CASE 9
		RESULTS:0 += " EXTRA/"
ENDSELECT

IF TIME == 0
	RESULTS:0 += @"{DAY+1}주차・전반"
ELSE
	RESULTS:0 += @"{DAY+1}주차・후반"
ENDIF

SIF FLAG:1 >= 0
	TARGET = FLAG:1
SIF FLAG:2 >= 0
	ASSI = FLAG:2

SIF TARGET >= 1
	RESULTS:0 += @" 전회: %NAME:TARGET%지도"

SAVEDATA 99,RESULTS:0
IF !LOCAL
	SAVEDATA 991,RESULTS:0
	LOCAL = 1
ELSE
	SAVEDATA 992,RESULTS:0
	LOCAL = 0
ENDIF