@ADD_EXABL

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF CFLAG:COUNT:680 == 1
						;****追加ここから****
		IF EXP:COUNT:120 <= 5 && ABL:COUNT:50 == 1
			EXP:COUNT:120 = 5
