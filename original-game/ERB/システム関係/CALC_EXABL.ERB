		ELSEIF EXP:COUNT:120 <= 40 && ABL:COUNT:50 == 7 && (TALENT:COUNT:402 || TALENT:COUNT:203)
			EXP:COUNT:120 = 40
		ELSEIF EXP:COUNT:120 <= 50 && ABL:COUNT:50 == 8 && (TALENT:COUNT:402 || TALENT:COUNT:203)
			EXP:COUNT:120 = 50
		ELSEIF EXP:COUNT:120 <= 60 && ABL:COUNT:50 == 9 && (TALENT:COUNT:509 || TALENT:COUNT:515 || TALENT:COUNT:518 || TALENT:COUNT:519 || TALENT:COUNT:522)
			EXP:COUNT:120 = 60
		ELSEIF EXP:COUNT:120 <= 70 && ABL:COUNT:50 == 10 && (TALENT:COUNT:509 || TALENT:COUNT:515 || TALENT:COUNT:518 || TALENT:COUNT:519 || TALENT:COUNT:522 || TALENT:COUNT:523)
			EXP:COUNT:120 = 70
		ENDIF
						;****追加ここまで****
		EXP:COUNT:120 += 1
		SIF TALENT:COUNT:402 || TALENT:COUNT:50
			EXP:COUNT:120 += 1
		SIF TALENT:COUNT:432
