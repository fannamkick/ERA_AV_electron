;-------------------------------------------------
;着用可能な衣装の全装着
;-------------------------------------------------
@WEARING_CLOTH_ABLE

CALL WEARING_CLOTH_ALL

SIF CFLAG:43 != 0
	CFLAG:40 -= (CFLAG:40 & 1)
SIF CFLAG:44 != 0
	CFLAG:40 -= (CFLAG:40 & 2)
SIF CFLAG:45 != 0
	CFLAG:40 -= (CFLAG:40 & 4)
SIF CFLAG:46 != 0
	CFLAG:40 -= (CFLAG:40 & 8)
SIF CFLAG:46 != 0
	CFLAG:40 -= (CFLAG:40 & 16)
SIF CFLAG:47 != 0
	CFLAG:40 -= (CFLAG:40 & 64)

;靴下を履く
SIF CFLAG:170 != 0
	CFLAG:173 = 0

;-------------------------------------------------
;着衣フラグの初期化
;-------------------------------------------------
@WEARING_CLOTH_ALL
;標準衣装が設定されてない場合は戻る
SIF CFLAG:41 == 0 && CFLAG:42 == 0
	RETURN 0

;一旦全裸に
CFLAG:40 = 0

;全裸以外の場合の標準コス処理
IF CFLAG:41 != 0

	;下着着衣フラグの初期化
	CALL WEARING_UNDERWARE_ALL

	;上着着衣フラグの初期化
	CALL WEARING_OUTERWARE_ALL

ENDIF

;特別コスの装着
SIF CFLAG:42
	CFLAG:40 |= 64

RETURN 1

;-------------------------------------------------
;下着着衣フラグの初期化
;-------------------------------------------------
@WEARING_UNDERWARE_ALL

;パンツ装着
CFLAG:40 |= 1

;절벽, 미숙함, 유치＋빈유の場合を除きブラ装着
SIF TALENT:116 == 0 && TALENT:135 == 0 && (TALENT:132 == 0 || TALENT:109 == 0)
	CFLAG:40 |= 2
;기모노・버니걸用ノーブラ化処理
SIF CFLAG:41 == 202 || CFLAG:41 == 254
	CFLAG:40 -= CFLAG:40 & 2
;全裸の上にまとうタイプ(191~200or241~250or291~300)ならノーブラ・ノーパン化
SIF CFLAG:41 >= 191 && CFLAG:41 <= 200
	CFLAG:40 -= CFLAG:40 & 3
SIF CFLAG:41 >= 241 && CFLAG:41 <= 250
	CFLAG:40 -= CFLAG:40 & 3
SIF CFLAG:41 >= 291 && CFLAG:41 <= 300
	CFLAG:40 -= CFLAG:40 & 3
;島の娘の服用ノーブラ・ノーパン処理
SIF CFLAG:41 == 29
	CFLAG:40 -= CFLAG:40 & 3
;기저귀着用時のノーパン処理
SIF CFLAG:42 == 69
	CFLAG:40 -= CFLAG:40 & 1

;-------------------------------------------------
;上着着衣フラグの初期化
;-------------------------------------------------
@WEARING_OUTERWARE_ALL

;下がスカートタイプのツーピース
IF CFLAG:41 >= 1 && CFLAG:41 <= 100
	CFLAG:40 |= 4
	CFLAG:40 |= 8
;下がズボンタイプのツーピース
ELSEIF CFLAG:41 >= 101 && CFLAG:41 <= 200
	CFLAG:40 |= 4
	CFLAG:40 |= 16
;下がスカートタイプの全身衣装
ELSEIF CFLAG:41 >= 201 && CFLAG:41 <= 250
	CFLAG:40 |= 4
	CFLAG:40 |= 8
;下がズボンタイプの全身衣装
ELSEIF CFLAG:41 >= 251 && CFLAG:41 <= 300
	CFLAG:40 |= 4
	CFLAG:40 |= 16
ENDIF

;ふんどし
SIF CFLAG:41 == 192
	CFLAG:40 = 16

;-------------------------------------------------
;調教後の衣類の処理
;-------------------------------------------------
@AFTERTRAIN_CLOTH
;더러운 옷가지의 처리
S = 0
;特別コス
IF CFLAG:42 && (TFLAG:49 & 64)
	PRINTFORM (%NAME:TARGET%의 
	CALL PRINT_CLOTHTYPE_SPECIAL
	IF RESULT == 0
		PRINTL 를 폐기처분 했습니다)
	ELSE
		PRINTL 을 폐기처분 했습니다)
	ENDIF
	CFLAG:42 = 0
	TFLAG:49 = 0
	S = 1
	SIF CFLAG:40 & 64
		CFLAG:40 -= 64
ELSEIF CFLAG:42 == 69 && (TFLAG:49 & 3) && CFLAG:47 == 0 && MONEY >= 50
	;기저귀の場合の特殊処理
	$INPUT_LOOP_01
	PRINTFORML 50 드라크마로 %CALLNAME:TARGET%의 기저귀를 교환합니까?
	PRINTL  [0] - 네
	PRINTL  [1] - 아니오
	INPUT
	IF RESULT == 0
		PRINTFORM (%CALLNAME:TARGET%에게 새 기저귀를 채웠습니다)
		MONEY -= 50
		CFLAG:47 = 0
		TFLAG:49 = 0
		IF TALENT:135 == 0
			PRINTL 
			PRINTFORM %PALAMNAME:8%의 구슬 +500
			JUEL:8 += 500
		ENDIF
		WAIT
		S = 1
	ELSEIF RESULT == 1
		PRINTFORMW (%NAME:TARGET%의 기저귀를 세탁하러 보냈습니다)
		CFLAG:47 = 2
		TFLAG:49 = 0
		S = 1
		SIF CFLAG:40 & 64
			CFLAG:40 -= 64
	ELSE
		GOTO INPUT_LOOP_01
	ENDIF
ELSEIF CFLAG:42 && (TFLAG:49 & 3) && CFLAG:47 == 0
	PRINTFORM (%NAME:TARGET%の
	CALL PRINT_CLOTHTYPE_SPECIAL
	IF RESULT == 0
		PRINTW 를 세탁하러 보냈습니다)
	ELSE
		PRINTW 을 세탁하러 보냈습니다)
	ENDIF
	CFLAG:47 = 5
	;기저귀の場合は洗濯速度は下着並
	SIF CFLAG:42 == 69
		CFLAG:47 = 2
	TFLAG:49 = 0
	S = 1
	SIF CFLAG:40 & 64
		CFLAG:40 -= 64
ENDIF
;상의 하의
IF CFLAG:41 && (TFLAG:48 & 64)
	PRINTFORM (%타겟이()% 입었던
	CALL PRINT_CLOTHTYPE_MAIN_BOTTOM
	IF RESULT == 0
		PRINTW 는 폐기처분됐습니다)
	ELSE
		PRINTW 은 폐기처분됐습니다)
	ENDIF
	IF CFLAG:41 >= 201
		CFLAG:41 = 0
		SIF CFLAG:40 & 4
			CFLAG:40 -= 4
		SIF CFLAG:40 & 8
			CFLAG:40 -= 8
		SIF CFLAG:40 & 16
			CFLAG:40 -= 16
	ELSE
		CFLAG:46 = -2
		SIF CFLAG:40 & 8
			CFLAG:40 -= 8
		SIF CFLAG:40 & 16
			CFLAG:40 -= 16
	ENDIF
	TFLAG:48 = 0
	S = 1
ELSEIF CFLAG:41 && (TFLAG:48 & 3) && CFLAG:46 == 0
	PRINTFORM (%타겟이()% 입었던
	CALL PRINT_CLOTHTYPE_MAIN_BOTTOM
	IF RESULT == 0
		PRINTW 를 세탁하러 보냈습니다)
	ELSE
		PRINTW 을 세탁하러 보냈습니다)
	ENDIF
	IF CFLAG:41 >= 201
		CFLAG:45 = 3
		CFLAG:46 = 3
		SIF CFLAG:40 & 4
			CFLAG:40 -= 4
		SIF CFLAG:40 & 8
			CFLAG:40 -= 8
		SIF CFLAG:40 & 16
			CFLAG:40 -= 16
	ELSE
		CFLAG:46 = 3
		SIF CFLAG:40 & 8
			CFLAG:40 -= 8
		SIF CFLAG:40 & 16
			CFLAG:40 -= 16
	ENDIF
	TFLAG:48 = 0
	S = 1
ENDIF
;パンツ
IF (TFLAG:45 & 64)
	PRINTFORMW (%NAME:TARGET%의 속옷은 폐기처분됐습니다)
	CFLAG:43 = -2
	SIF CFLAG:40 & 1
		CFLAG:40 -= 1
	TFLAG:45 = 0
	S = 1
ELSEIF (TFLAG:45 & 3) && CFLAG:43 == 0
	PRINTFORMW (%NAME:TARGET%의 속옷을 세탁하러 보냈습니다)
	CFLAG:43 = 2
	SIF CFLAG:40 & 1
		CFLAG:40 -= 1
	TFLAG:45 = 0
	S = 1
ENDIF

;상하 모두 망가진 의상은 삭제
IF CFLAG:41
	SIF CFLAG:45 < 0 && CFLAG:46 < 0
		CFLAG:41 = 0
	;ふんどし用処理
	SIF CFLAG:41 == 192 && CFLAG:46 < 0
		CFLAG:41 = 0
ENDIF
;고장난 특별코스는 삭제
IF CFLAG:42
	SIF CFLAG:47 < 0
		CFLAG:42 = 0
ENDIF

RETURN 1

;-------------------------------------------------
;衣類の再着衣
;-------------------------------------------------
@RE_CLOTHED
#DIM DYNAMIC T0
#DIM DYNAMIC T1
#DIM DYNAMIC T2
#DIM DYNAMIC T4

CALL COM110_ABLE0T
T0 = RESULT
CALL COM110_ABLE1T
T1 = RESULT
CALL COM110_ABLE2T
T2 = RESULT
;CALL COM110_ABLE4T
;T4 = RESULT

