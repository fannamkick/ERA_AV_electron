			IF TALENT:122 == 0 && TALENT:116 == 0 && (TALENT:109 == 0 || TALENT:132 == 0)
				PRINT 가슴이 튀어나온
			ELSE
				PRINT 상반신 알몸
			ENDIF
		ENDIF
		RETURN 1
