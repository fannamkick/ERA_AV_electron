ENDIF
;通常の衣服
IF (CFLAG:40 & 28)
	IF (CFLAG:40 & 4) && (CFLAG:40 & 24) == 0
		CALL PRINT_CLOTHTYPE_MAIN2
		PRINT  상의에 
