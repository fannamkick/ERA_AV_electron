;=================================================
;衣装関連の関数群
;=================================================
;-------------------------------------------------
;使用一時フラグ
;TFLAG:45 = パンツの状態(&1:尿まみれ &2:精液まみれ &64:調教後に処分)
;TFLAG:46 = ブラジャーの状態(&1:尿まみれ &2:精液まみれ &64:調教後に処分)
;TFLAG:47 = 上着上の状態(&1:尿まみれ &2:精液まみれ &64:調教後に処分)
;TFLAG:48 = 上着下の状態(&1:尿まみれ &2:精液まみれ &64:調教後に処分)
;TFLAG:49 = 特別コスの状態(&1:尿まみれ &2:精液まみれ &64:調教後に処分)
;-------------------------------------------------
;使用キャラフラグ
;CFLAG;40 = 着衣状態(&1:パンツ &2:ブラジャー &4:上着上 &8:上着下・スカートタイプ &:16上着下・ズボンタイプ &64:特別コス)
;CFLAG:41 = 上着のタイプ
;CFLAG:42 = 特別コスチュームのタイプ
;CFLAG:43 = パンツの状態(-2:廃棄 -1:没収 0:通常 1以上:洗濯中)
;CFLAG:44 = ブラジャーの状態(-2:廃棄 -1:没収 0:通常 1以上:洗濯中)
;CFLAG:45 = 上着上の状態(-2:廃棄 -1:没収 0:通常 1以上:洗濯中)
;CFLAG:46 = 上着下の状態(-2:廃棄 -1:没収 0:通常 1以上:洗濯中)
;CFLAG:47 = 特別コスチュームの状態(-1:没収 0:通常 1以上:洗濯中)
;-------------------------------------------------
;よく参照するシチュ早見表
;CFLAG:40 & 3  == False;:何も下着を着けていない True:何か下着を付けている
;CFLAG:40 & 6  == False:상반신 알몸 True:上半身に何か着ている
;CFLAG:40 & 17 == False:性器を直に触れる状態 True:性器を触れない状態
;CFLAG:40 & 24 == False:上着の下部分を付けていない True:上着の下部分を付けている
;CFLAG:40 & 25 == False:하반신 알몸 True:下半身に何か着ている
;CFLAG:40 & 28 == False:上着を上も下も一切着ていない True:何か上着を着ている
;=================================================
;-------------------------------------------------
;사용중の着衣表示
;-------------------------------------------------
@PRINT_CLOTHTYPE
;着衣設定を使ってない場合
IF (CFLAG:41 == 0 && CFLAG:42 == 0) || FLAG:37 == 0
	IF CFLAG:40 == 0
		PRINT 전라
		RETURN 2
	ELSE
		PRINT 속옷
		RETURN 2
	ENDIF
ENDIF

;特別コス: 즈코 인형の場合の処理
IF CFLAG:42 == 11 && (CFLAG:40 & 64)
	PRINT 즈코 인형
	RETURN 1
ENDIF

;基本コスチューム処理
CALL PRINT_CLOTHTYPE_MAIN
LOCAL:1 = RESULT

