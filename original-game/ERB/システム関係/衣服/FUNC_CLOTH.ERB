			PRINTFORM 팬티 한장
		ELSEIF (CFLAG:40 & 1) && TALENT:76 == 0 && TALENT:121 == 1
			PRINTFORM 팬티 한장
		ELSEIF (CFLAG:40 & 1) && TALENT:76 == 1 && TALENT:121 == 0
			PRINTFORM 팬티 한장
		ELSEIF (CFLAG:40 & 1) && TALENT:76 == 1 && TALENT:121 == 1
			PRINTFORM 팬티 한장
		ELSEIF (CFLAG:40 & 1) && TALENT:76 == 1 && TALENT:121 == 1
