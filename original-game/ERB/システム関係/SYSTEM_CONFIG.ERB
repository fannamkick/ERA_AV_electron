;---------------------------------------------------------
;キャラに陰毛を生やす FLAG:36使用
;---------------------------------------------------------
@CONFIG_PUBLICHAIR
IF FLAG:36
	FLAG:36 = 0
ELSE
	FLAG:36 = 1

	;初期状態のキャラがいたら陰毛を設定する
	REPEAT CHARANUM
		;既に生えてるならそのまま
		SIF CFLAG:COUNT:6 != 0
			CONTINUE
		

		;음모 없음なら-1に設定
		IF TALENT:COUNT:125
			CFLAG:COUNT:6 = -1
		;유치・미숙함なら7に設定
		ELSEIF TALENT:COUNT:132 || TALENT:COUNT:135
			CFLAG:COUNT:6 = 7
		;중학생なら7に設定
		ELSEIF TALENT:COUNT:221
			CFLAG:COUNT:6 = 7
		;고등학생なら9に設定
		ELSEIF TALENT:COUNT:220
			CFLAG:COUNT:6 = 9
		;それ以外なら12に設定
		ELSE
			CFLAG:COUNT:6 = 12
		ENDIF
	REND
ENDIF

RETURN 0

;---------------------------------------------------------
;着衣システムの使用 FLAG:37使用
;---------------------------------------------------------
@CONFIG_CLOTHING
IF FLAG:37 == 0
	FLAG:37 = 1
ELSE
	$INPUT_LOOP
	DRAWLINE
	PRINTFORML 착의 시스템을 OFF로 하면 모든 캐릭터의 착의 플래그가 사라집니다
	PRINTFORML 사라진 착의 플래그는 착의 시스템을 다시 ON으로 하더라도 복구되지 않습니다.
	PRINTL 
	PRINTFORML 착의 시스템을 OFF로 합니까?
	PRINTL  [0] - 네
	PRINTL  [1] - 아니오
	INPUT
	IF RESULT == 1
		RETURN 0
	ELSEIF RESULT != 0
		GOTO INPUT_LOOP
	ENDIF

	;着衣フラグ初期化
	REPEAT CHARANUM
		CFLAG:COUNT:40 = 0
		CFLAG:COUNT:41 = 0
		CFLAG:COUNT:42 = 0
		CFLAG:COUNT:43 = 0
		CFLAG:COUNT:44 = 0
		CFLAG:COUNT:45 = 0
		CFLAG:COUNT:46 = 0
		CFLAG:COUNT:47 = 0
	REND
	
	FLAG:37 = 0

	DRAWLINE
	PRINTL 모든 캐릭터의 착의 플래그를 소거했습니다
	DRAWLINE

ENDIF

RETURN 0

