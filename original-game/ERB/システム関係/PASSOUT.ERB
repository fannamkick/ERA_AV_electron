		TFLAG:880 = (-1)
	;シチュエーション(特殊コマンド)系の실행중判定
	SIF (TEQUIP:53 && TFLAG:881 != 53)  || (TEQUIP:54 && TFLAG:881 != 54) || (TEQUIP:58 && TFLAG:881 != 58)
		TFLAG:881 = (-1)
