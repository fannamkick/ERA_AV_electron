;===========================================================
;첫 키스の状況
;===========================================================
@FIRSTKISS_DETAIL_CALC

VARSET LOCAL, 0
IF CFLAG:825 == 0
	IF CFLAG:821 == 1 || CFLAG:821 == 2 || CFLAG:821 == 4 || CFLAG:821 == 6 || CFLAG:821 == 7 || CFLAG:821 == 9 || CFLAG:821 == 11 
		IF CFLAG:822 == 1
			CFLAG:825 = RAND:7
				SIF CFLAG:825 == 0
					CFLAG:825 = 1
		ELSEIF CFLAG:822 == 2
			CFLAG:825 = 8 + RAND:7
		ELSEIF CFLAG:822 == 3
			CFLAG:825 = 15 + RAND:8
			SIF CFLAG:825 == 14
				CFLAG:825 = 15
		ELSEIF CFLAG:822 == 4
			CFLAG:825 = 23 + RAND:7
		ENDIF
	ELSE
		IF CFLAG:822 == 1
			CFLAG:825 = RAND:7
				SIF CFLAG:825 == 0
					CFLAG:825 = 1
		ELSEIF CFLAG:822 == 2
			CFLAG:825 = 7 + RAND:7
		ELSEIF CFLAG:822 == 3
			CFLAG:825 = 14 + RAND:7
			SIF CFLAG:825 == 14
				CFLAG:825 = 15
		ELSEIF CFLAG:822 == 4
			CFLAG:825 = 21 + RAND:7
		ELSEIF CFLAG:822 == 5
			CFLAG:825 = 28 + RAND:7
			SIF CFLAG:825 >= 31
				CFLAG:825 = 31
		ENDIF		
	ENDIF
	SIF CFLAG:825 == MAXBASE:12 && CFLAG:821 == MAXBASE:11
		CFLAG:826 = 1
ENDIF

;===========================================================
;CFLAG:820 = 연령
;CFLAG:821 = 月
;CFLAG:822 = 週
;CFLAG:823 = 場所
;CFLAG:824 = 状況
;CFLAG:825 = 日付固定用
;===========================================================
@FIRSTKISS_DETAIL

CHKFONT "あくびん"
	IF RESULT
		SETFONT "あくびん"
	ENDIF
	SETCOLOR 0xF58F98 
	PRINT 　
	CALL HEART_CODE
	PRINT 첫 키스: 

IF ABL:10 < 3 && NO:TARGET != 0
	PRINTL 경험함

ELSE



CALL FIRSTKISS_DETAIL_CALC

IF CFLAG:820 == 0
	PRINTFORM 몇년 전 
ELSE
	PRINTFORM  {CFLAG:820}살 
ENDIF

IF CFLAG:821 == 0
	PRINTFORM 어느 날
ELSE
	SIF CFLAG:821 <= 9
		PRINTFORM  
	PRINTFORM {CFLAG:821}월
ENDIF

IF ( CFLAG:820 == 0 && CFLAG:821 == 0 ) || CFLAG:825 == 0
ELSE
	SIF CFLAG:825 <= 9
		PRINTFORM  
	PRINTFORM  {CFLAG:825}일
ENDIF

PRINTFORM 에 

IF CFLAG:823 == 0 || CFLAG:823 >= 15
ELSE
	IF CFLAG:823 == 1
		PRINTFORM  %CALLNAME:TARGET%의 방
	ELSEIF CFLAG:823 == 2 && CFLAG:16 == 8 && TALENT:184 == 0 && EXP:101 >= 1
		IF CSTR:1 == ""
			PRINTFORM 전 남친의 방
		ELSE
			PRINTFORM %CSTR:1%(전 남친)의 방
		ENDIF		
	ELSEIF CFLAG:823 == 2 && CFLAG:16 == 8 && TALENT:184 == 1
		IF CSTR:1 == ""
			PRINTFORM 남친의 방
		ELSE
			PRINTFORM %CSTR:1%(남친)의 방
		ENDIF				
	ELSEIF CFLAG:823 == 3
		PRINTFORM 러브호텔
	ELSEIF CFLAG:823 == 4
		PRINTFORM 바다
	ELSEIF CFLAG:823 == 5
		PRINTFORM 학교
	ELSEIF CFLAG:823 == 6
		PRINTFORM 폐공장
	ELSEIF CFLAG:823 == 7
		PRINTFORM 창관
	ELSEIF CFLAG:823 == 8
		PRINTFORM 전차 안
	ELSEIF CFLAG:823 == 9
		PRINTFORM 버스 안
	ELSEIF CFLAG:823 == 10
		PRINTFORM 야외
	ELSEIF CFLAG:823 == 11
		PRINTFORM 수영장
	ELSEIF CFLAG:823 == 12
		PRINTFORM 비밀 지하실
	ELSEIF CFLAG:823 == 13
		PRINTFORM 회원제 비밀클럽
	ELSEIF CFLAG:823 == 14
		PRINTFORM 촬영 스튜디오
	ENDIF
	PRINTFORM 에서, 
ENDIF

SIF CFLAG:826 == 1
	PRINTFORM 생일기념으로 

IF CFLAG:16 == 0
	PRINTFORM 기억 안나는 사람
ELSEIF CFLAG:16 == 1
	PRINTFORM %CSTR:1%
ELSEIF CFLAG:16 == 2
	PRINTFORM 이름도 모르는 남자손님
ELSEIF CFLAG:16 == 3
	PRINTFORM 이름도 모르는 여자손님
ELSEIF CFLAG:16 == 4
	PRINTFORM 바이브
ELSEIF CFLAG:16 == 5
	PRINTFORM 극대바이브
ELSEIF CFLAG:16 == 6
	PRINTFORM 이름도 모르는 손님
ELSEIF CFLAG:16 == 7
	PRINTFORM 치한
ELSEIF CFLAG:16 == 8 && CFLAG:827 == 1
	IF CSTR:1 == ""
		PRINTFORM 전 남친
	ELSE
		PRINTFORM %CSTR:1%(전 남친)
	ENDIF	
ELSEIF CFLAG:16 == 8 && TALENT:184 == 1
	IF CSTR:1 == ""
		PRINTFORM 남친
	ELSE
		PRINTFORM %CSTR:1%(남친)
	ENDIF	
ELSEIF CFLAG:16 == 9
	PRINTFORM 섹프인 %CSTR:47%
ELSEIF CFLAG:16 == 11
	PRINTFORM 불량배
;;;このあたりは対象者を入れる(状況だと, のちのち記述上の問題が生じやすいので)
ELSEIF CFLAG:16 == 12
	PRINTFORM 배게영업 상대
ELSEIF CFLAG:16 == 13
	PRINTFORM 『접대』손님
ELSEIF CFLAG:16 == 14
	PRINTFORM 촉수생물
ELSEIF CFLAG:16 == 15
	PRINTFORM 남편
ELSEIF CFLAG:16 == 16
	PRINTFORM %CALLNAME:MASTER%
ENDIF

IF CFLAG:16 == 10
	;空分岐。STAFFNTR用。
ELSEIF CFLAG:824 != 0
	PRINTFORM 의 
ELSEIF CFLAG:16 == 1 && CSTR:1 == ""
	;名前が設定されていない経験済キャラクターのための
ELSE
	PRINTFORM 에게
ENDIF

IF CFLAG:824 == 1
	PRINTFORM %CSTR:80%에게
ELSEIF CFLAG:824 == 2
	PRINTFORM %CSTR:82%에게
ELSEIF CFLAG:824 == 3
	PRINTFORM %CSTR:81%에게
ENDIF

PRINTFORML %UNICODE(0x2665)%


ENDIF

SETFONT ""
RESETCOLOR