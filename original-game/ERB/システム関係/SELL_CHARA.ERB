;-------------------------------------------------
;売却と助手化のチェック
;-------------------------------------------------
@CHECK_SELLASSIABLE

;【매각 불가】を持っておらず
SIF TALENT:199 == 1
	RETURN 0
;従順+욕망が6LV以上であるか
SIF ABL:10+ABL:11 < 6
	RETURN 0
;C感覚・V감각・A감각・B感覚のいずれかが最低3LVであり
SIF ABL:0 < 3 && ABL:1 < 3 && ABL:2 < 3 && ABL:3 < 3
	RETURN 0
;【反抗的】か【다부짐】を持っているなら従順が4LV以上になっており
SIF ABL:10 < 4 && (TALENT:11 || TALENT:12)
	RETURN 0
;【자제심】【억압】【저항】を持っているなら욕망が4LV以上になっており
SIF ABL:11 < 4 && (TALENT:20 || TALENT:32 || TALENT:34)
	RETURN 0
;「〈기교〉3LV以上で〈봉사정신〉3LV以上」か「〈노출벽〉3LV以上で〈자위중독〉2LV以上」か「C・V・A・B感覚の合計が13LV以上」か「従順か욕망がLV5」に達しているか
IF ((ABL:12 >= 3 && ABL:16 >= 3) || (ABL:17 >= 3 && ABL:31 >= 2) || ABL:21 >= 3 || (ABL:0+ABL:1+ABL:2+ABL:3 >= 13) || ABL:10 >= 5 || ABL:11 >= 5) && TALENT:400 == 1
	IF CFLAG:1 <= 0
		PRINTFORMW %타겟이(1)% 은퇴할 수 있게 됐습니다
		CFLAG:1 = 1
	ENDIF
ELSE
	RETURN 0
ENDIF

;「〈従順〉〈욕망〉〈기교〉〈C感覚〉〈레즈끼〉がすべて3LV以上」か「〈従順〉が5LV以上かつ〈욕망〉が4LV以上」か
IF ((ABL:10 >= 3 && ABL:11 >= 3 && ABL:12 >= 3 && ABL:0 >= 3 && (ABL:22 >= 3 || ABL:23 >= 3)) || (ABL:10 >= 5 && ABL:11 >= 4)) && TALENT:400 == 1 && EXP:76 >= 3
	IF CFLAG:1 <= 1
		PRINTFORMW 이제 %타겟을(1)% 조수로 쓸 수 있습니다
		CFLAG:1 = 2
	ENDIF
ENDIF
