@CHARA_SALE
DRAWLINE
PRINTV DAY+1
PRINT 주차
IF TIME == 0
	PRINTL  전반
ELSE
	PRINTL  후반
ENDIF

PRINTFORML 소지금: ${MONEY}포인트
DRAWLINE

$INPUT_LOOP

PRINTL 누구를 은퇴시키겠습니까?
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	;매각 불가のキャラは排除
	ELSEIF TALENT:COUNT:199
		CONTINUE
	;売れないキャラは排除
	ELSEIF CFLAG:COUNT:1 < 1
		CONTINUE
	;臨死中のキャラは排除
	ELSEIF  BASE:COUNT:0 < 1
		CONTINUE
	ELSEIF CFLAG:COUNT:1 >= 1
		PRINTFORM [{COUNT}] %NAME:COUNT% 
		TARGET = COUNT
		S = 0
		CALL ESTIMATE_CHARA
		IF S > 0
			PRINTFORM [평가액: {S}포인트]
		ELSE
			PRINTFORM [매각 불가]
		ENDIF
		IF ISASSI:COUNT == 1
			PRINT (전 조수)
		ELSEIF CFLAG:COUNT:1 == 2
			PRINT (조수 가능)
		ENDIF
		PRINTL  
	ENDIF
REND
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
PRINTFORML [999] - 돌아간다

INPUT

IF RESULT == 999
	RETURN 999
ELSEIF RESULT <= 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
ELSEIF TALENT:RESULT:199
	GOTO INPUT_LOOP
ELSEIF CFLAG:RESULT:1 < 1
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
;営業中のキャラは排除
ELSEIF  CFLAG:RESULT:12 && TIME == 1
	PRINTL 이번주 영업이 끝날때까지 은퇴시킬 수 없습니다
	WAIT
	GOTO INPUT_LOOP
ENDIF

;現在の調教対象の情報を取得
SIF TARGET > 0
	T = NO:TARGET

TARGET = RESULT

;売却処理
S = 0
CALL SALE_CHARA

;売却した場合はキャラを削除
IF S > 0
	SIF CFLAG:684 == 1
		FLAG:557 -= 1
	SIF CFLAG:671 == 1
		FLAG:556 = 0
	SIF CFLAG:60 == 1
		CFLAG:MASTER:65 = 0
	T = -1
	CALL KILL_TARGET
	EXP:MASTER:107 += 1
ENDIF

;対象を戻す
TARGET = -1
REPEAT CHARANUM
	SIF NO:COUNT == T
		TARGET = COUNT
REND

RESTART
