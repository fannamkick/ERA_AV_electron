@LONG_GOOD_BYE
A = NO:TARGET

REPEAT CHARANUM
	SIF COUNT == 0
		CONTINUE
	;キャラのストレス値
	U = 0
	SIF A == (CFLAG:COUNT:21 % 100) && (CFLAG:COUNT:21 / 100) < 2
		U += 40
	SIF A == (CFLAG:COUNT:21 % 100)
		U += 80
	SIF A == (CFLAG:COUNT:22 % 100) && (CFLAG:COUNT:22 / 100) < 2
		U += 40
	SIF A == (CFLAG:COUNT:22 % 100)
		U += 80
	SIF A == (CFLAG:COUNT:23 % 100) && (CFLAG:COUNT:23 / 100) < 2
		U += 40
	SIF A == (CFLAG:COUNT:23 % 100)
		U += 80
	SIF A == (CFLAG:COUNT:24 % 100) && (CFLAG:COUNT:24 / 100) < 2
		U += 40
	SIF A == (CFLAG:COUNT:24 % 100)
		U += 80
	SIF A == (CFLAG:COUNT:25 % 100) && (CFLAG:COUNT:25 / 100) < 2
		U += 40
	SIF A == (CFLAG:COUNT:25 % 100)
		U += 80
	SIF RELATION:COUNT:A > 100
		U += RELATION:COUNT:A - 100
	IF U > 50
		DRAWLINE
		PRINTL 
		PRINTFORML 그 날, %조사처리(NAME:COUNT,"는")% 팔려나가는 %타겟이(1)% 탄 차를 
		SIF TALENT:COUNT:45 == 0 && TALENT:COUNT:310 == 0 
			PRINT 눈물로 흐려진 
		PRINTFORML 시야에서 안보이게 될때까지, 
		PRINTFORML 그리고 안보이게 된 뒤에도 계속 바라보고 있었다.
		WAIT
		;연심
		SIF TALENT:COUNT:85
			U -= 120
		;음란
		SIF TALENT:COUNT:76
			U -= 60
		;다부짐
		SIF TALENT:COUNT:12
			U -= 20
		;감정부족
		SIF TALENT:COUNT:22
			U -= 20
		;유리멘탈
		SIF TALENT:COUNT:134
			U += 20
		;ヒーロー
		SIF TALENT:COUNT:311
			U -= 100
		;従順
		U -= ABL:COUNT:10 * 10
		;반발각인
		U += MARK:COUNT:3 * 30

		;ストレス値の累積が100を超えた場合
		IF U >= 100 && TALENT:COUNT:9 == 0
		DRAWLINE
			PRINTFORML %조사처리(CALLNAME:COUNT,"는")% 알맹이가 빠져나간 것처럼 멍하니 서있다
			PRINTFORML %CALLNAME:COUNT%의 안에서 뭔가가 부서진것 같다……
			PRINTFORML %CALLNAME:COUNT%의 정신이【%TALENTNAME:9%】돼 버렸다
			WAIT
			IF TALENT:COUNT:85
				PRINTFORML %조사처리(CALLNAME:COUNT,"는")%【%TALENTNAME:85%】을 잃었다
				TALENT:COUNT:85 = 0
			ENDIF
			IF TALENT:COUNT:76
				PRINTFORML %조사처리(CALLNAME:COUNT,"는")%【%TALENTNAME:76%】을 잃었다
				TALENT:COUNT:76 = 0
			ENDIF
			TALENT:COUNT:9 = 1
			WAIT
		ENDIF
	ENDIF
REND
