;---------------------------------------------------------
;営業内容によって得た経験や素質の変化を計算
;---------------------------------------------------------
@WORK_EXP2
;特殊営業の参加人数(FLAG:42)が多いと, 一人あたりの娼館人気上昇は下がる
IF FLAG:42 >= 3 && I >= 1
	IF A >= 5
		I = 1
	ELSE 
		I = 0
	ENDIF
ELSEIF FLAG:42 == 2 && I >= 1
	IF A >= 4
		I = 1
	ELSE 
		I = 0
	ENDIF
ENDIF

;人気の上限は100
SIF EXP:91 + J >= 100
	J = 100 - EXP:91
SIF EXP:MASTER:91 + I >= 100
	I = 100 - EXP:MASTER:91

;人気の下限は0
SIF EXP:91 + J <= 0
	J = 0 - EXP:91
SIF EXP:MASTER:91 + I <= 0
	I = 0 - EXP:MASTER:91

;人気・娼館人気変化の表示
IF (FLAG:6 & 2) == 0 || CFLAG:12 == 0
	PRINT  인기　　　　:
	N = EXP:91
	CALL FIGURE_INDENT
	PRINTV EXP:91
	IF J >= 0
		PRINT  + 
		N = J
		CALL FIGURE_INDENT
		PRINTV J
	ELSE
		PRINT  - 
		;eraBASICはマイナス演算子を扱えないのでわざとこうしています
		J = 0 - J
		N = J
		CALL FIGURE_INDENT
		PRINTV J
		J = 0 - J
	ENDIF
	PRINT  = 
	N = EXP:91 + J
	CALL FIGURE_INDENT
	PRINTVL EXP:91 + J

	PRINT  창관인기　　:
	N = EXP:MASTER:91
	CALL FIGURE_INDENT
	PRINTV EXP:MASTER:91
	IF I >= 0
		PRINT  + 
		N = I
		CALL FIGURE_INDENT
		PRINTV I
	ELSE
		PRINT  - 
		;eraBASICはマイナス演算子を扱えないのでわざとこうしています
		I = 0 - I
		N = I
		CALL FIGURE_INDENT
		PRINTV I
		I = 0 - I
	ENDIF
	PRINT  = 
	N = EXP:MASTER:91 + I
	CALL FIGURE_INDENT
	PRINTVL EXP:MASTER:91 + I
ELSE
	PRINTFORML (인기:{EXP:91 + J})
ENDIF

EXP:91 += J
EXP:MASTER:91 += I

;満足度最高の場合단골손님が付くことあり
IF A >= 4
	IF TALENT:183 == 0 && (C == 0 || CFLAG:12 == 3 || CFLAG:12 == 4 || CFLAG:12 == 5) && TALENT:27 == 0
		PRINTFORML 손님 중 한 사람은 %타겟을()% 굉장히 마음에 들어한 듯 하다…
		PRINTFORMW %CALLNAME:TARGET%에게【%TALENTNAME:183%】이 붙었다
		TALENT:183 = 1
	ENDIF
ENDIF

SIF (FLAG:6 & 2) == 0 || CFLAG:12 == 0
	PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

;V경험増加量=客に질내사정された回数と解釈して임신フラグを加算
SIF T:0 && CFLAG:13 == 0 
	CFLAG:105 += T:0

;『T:X』のXの値に応じて経験が上昇します
REPEAT 76
	IF T:COUNT
		IF (FLAG:6 & 2) == 0 || CFLAG:12 == 0
			PRINTFORM  %EXPNAME:COUNT%
			IF COUNT == 0 || COUNT == 1
				PRINT 　　　
			ELSEIF COUNT == 11 || COUNT == 21 || COUNT == 30 || COUNT == 33 || COUNT == 73 || COUNT == 75
				PRINT 
			ELSEIF COUNT == 22 || COUNT == 32 || COUNT == 52 || COUNT == 53
				PRINT 　
			ELSE
				PRINT 　　
			ENDIF
			PRINT :
			N = EXP:COUNT
			CALL FIGURE_INDENT
			PRINTV EXP:COUNT
			PRINTFORM  + 
			N = T:COUNT
			CALL FIGURE_INDENT
			PRINTV T:COUNT
			PRINTFORM  = 
			N = EXP:COUNT + T:COUNT
			CALL FIGURE_INDENT
			PRINTVL EXP:COUNT + T:COUNT
		ENDIF
		EXP:COUNT += T:COUNT
		T:COUNT = 0
	ENDIF
REND

SIF CFLAG:12 == 0
	PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

;『U:X』のXの値に応じて珠を獲得します
REPEAT 101
	IF U:COUNT
		IF (FLAG:6 & 2) == 0 || CFLAG:12 == 0
			PRINTFORM  %PALAMNAME:COUNT%의 구슬　　
			PRINT :
			N = JUEL:COUNT
			CALL FIGURE_INDENT
			PRINTV JUEL:COUNT
			PRINTFORM  + 
			N = U:COUNT
			CALL FIGURE_INDENT
			PRINTV U:COUNT
			PRINTFORM  = 
			N = JUEL:COUNT + U:COUNT
			CALL FIGURE_INDENT
			PRINTVL JUEL:COUNT + U:COUNT
		ENDIF
		JUEL:COUNT += U:COUNT
		U:COUNT = 0
	ENDIF
REND
