;===========================================================
;淫語の処理
;===========================================================
@GENITAL_SLANG

;コンフィグで切れます
;口上で機能殺したい場合には先にCFLAG:8に1を入れておくとよい
;ってこれもフラグまとめに書いてないし
SIF FLAG:160 == 1
	RETURN

PRINTL
IF EXP:112 == 0
	PRINTFORM %CALLNAME:TARGET%에게도 꽤나 신뢰받게 되어, 
	PRINTFORML 지도의 성과인지 이제 %타겟은()% 성행위에 대한 수치심도 옅어진 것 같다……
	PRINTFORM 그리하여 %플레이어는()% 다음 스텝을 위해 %CALLNAME:TARGET%에게 
	PRINTFORML AV에서 수요가 있는 요소――음어를 가르쳐주기로 했다
	PRINTL
ENDIF

PRINTFORML 《%NAME:TARGET%에게 음어를 가르쳐 주겠습니까?》
PRINTL [0] - 네
PRINTL [1] - 아니오
$INPUT_LOOP1

INPUT

IF RESULT == 1
	RETURN
ELSEIF RESULT == 0
	CALL DECIDE_GENITAL_SLANG
ELSE
	GOTO INPUT_LOOP1
ENDIF

;===========================================================
;淫語の設定
;===========================================================
@DECIDE_GENITAL_SLANG

$INPUT_LOOP00
PRINTFORML 현재 %타겟은()% 남성기를 %CSTR:80%, 여성기를 %CSTR:81%, 항문을 %조사처리(CSTR:82,"라")%고 부르고 있습니다

PRINTFORML 남성기를――
PRINTL [0] - 그대로 부르게 한다
PRINTL [1] - 랜덤하게 설정한다
PRINTL [2] - 스스로 생각한다

$INPUT_LOOP01
INPUT

IF RESULT == 0
	CSTR:83 = %CSTR:80%
ELSEIF RESULT == 1
	CALL GENERATE_CALLPENIS
ELSEIF RESULT == 2
	PRINTL 《입력해주세요(입력하지 않을 경우 바꾸지 않습니다)》
	$INPUTLOOP_CALLPENIS
	INPUTS
	
	IF RESULTS == ""
		RESULTS = %CSTR:80%
		CSTR:83 = %RESULTS%
	ELSE
		CSTR:83 = %RESULTS%
		PRINTFORML 남성기를『%CSTR:83%』%조사만처리(CSTR:83,"라")%고 부르게 합니까?
		PRINTL [0] - 네
		PRINTL [1] - 아니오
		$INPUT_LOOP02
		INPUT
		
		IF RESULT == 0
			PRINTL
		ELSEIF RESULT == 1
			PRINTFORML 《재입력해주세요(입력하지 않을 경우 바꾸지 않습니다)》
			GOTO INPUTLOOP_CALLPENIS
		ELSE
			GOTO INPUT_LOOP02
		ENDIF
	ENDIF
ELSE
	GOTO INPUT_LOOP01
ENDIF

PRINTFORML 남성기를《%CSTR:83%》, 여성기를――
PRINTL [0] - 그대로 부르게 한다
PRINTL [1] - 랜덤하게 설정한다
PRINTL [2] - 스스로 생각한다

$INPUT_LOOP03
INPUT

IF RESULT == 0
	CSTR:84 = %CSTR:81%
ELSEIF RESULT == 1
	CALL GENERATE_CALLVAGINA
ELSEIF RESULT == 2
	PRINTL 《입력해주세요(입력하지 않을 경우 바꾸지 않습니다)》
	$INPUTLOOP_CALLVAGINA
	INPUTS
	
	IF RESULTS == ""
		RESULTS = %CSTR:81%
		CSTR:84 = %RESULTS%
	ELSE
		CSTR:84 = %RESULTS%
		PRINTFORML 여성기를『%CSTR:84%』%조사만처리(CSTR:84,"라")%고 부르게 합니까?
		PRINTL [0] - 네
		PRINTL [1] - 아니오
		$INPUT_LOOP04
		INPUT
		
		IF RESULT == 0
			PRINTL
		ELSEIF RESULT == 1
			PRINTFORML 《재입력해주세요(입력하지 않을 경우 바꾸지 않습니다)》
			GOTO INPUTLOOP_CALLVAGINA
		ELSE
			GOTO INPUT_LOOP04
		ENDIF
	ENDIF
ELSE
	GOTO INPUT_LOOP03
ENDIF

PRINTFORML 남성기를《%CSTR:83%》, 여성기를《%CSTR:84%》, 항문을――
PRINTL [0] - 그대로 부르게 한다
PRINTL [1] - 랜덤하게 설정한다
PRINTL [2] - 스스로 생각한다

$INPUT_LOOP05
INPUT

IF RESULT == 0
	CSTR:85= %CSTR:82%
ELSEIF RESULT == 1
	CALL GENERATE_CALLANAL
ELSEIF RESULT == 2
	PRINTL 《입력해주세요(입력하지 않을 경우 바꾸지 않습니다)》
	$INPUTLOOP_CALLANAL
	INPUTS
	
	IF RESULTS == ""
		RESULTS = %CSTR:82%
		CSTR:85 = %RESULTS%
	ELSE
		CSTR:85 = %RESULTS%
		PRINTFORML 항문을『%CSTR:85%』%조사만처리(CSTR:85,"라")%고 부르게 합니까?
		PRINTL [0] - 네
		PRINTL [1] - 아니오
		$INPUT_LOOP06
		INPUT
		
		IF RESULT == 0
			PRINTL
		ELSEIF RESULT == 1
			PRINTFORML 《재입력해주세요(입력하지 않을 경우 바꾸지 않습니다)》
			GOTO INPUTLOOP_CALLANAL
		ELSE
			GOTO INPUT_LOOP06
		ENDIF
	ENDIF
ELSE
	GOTO INPUT_LOOP05
ENDIF

PRINTFORML %CALLNAME:TARGET%에게 남성기를《%CSTR:83%》, 여성기를《%CSTR:84%》, 항문을《%CSTR:85%》%조사만처리(CSTR:85,"라")%고 부르게 합니다
PRINTFORML 실행하시겠습니까?
PRINTL [0] - 네
PRINTL [1] - 아니오
$INPUT_LOOP07
INPUT

IF RESULT == 0
	PRINTFORM %타겟은()% 남성기를《%CSTR:83%》, 여성기를《%CSTR:84%》, 
	PRINTFORML 항문을《%CSTR:85%》%조사만처리(CSTR:85,"라")%고 부르게 했습니다
	CSTR:80 = %CSTR:83%
	CSTR:81 = %CSTR:84%
	CSTR:82 = %CSTR:85%
	
	PRINTFORML 다음「대화한다」선택시 단어지도를 안하도록 설정하겠습니까?
	PRINTL [0] - 네
	PRINTL [1] - 아니오
	$INPUT_LOOP08
	INPUT

	IF RESULT == 0
		PRINTFORML 《앞으로 단어지도를 하지 않습니다》
		CFLAG:8 = 1
	ELSEIF RESULT == 1
		PRINTFORML 《앞으로도 단어지도를 계속합니다》
		PRINTFORML (단어지도를 하기 위해선 다시「대화한다」를 선택해 주세요)
	ELSE
		GOTO INPUT_LOOP08
	ENDIF
ELSEIF RESULT == 1
	PRINTFORML 《재입력해주세요》
	GOTO INPUT_LOOP00
ELSE
	GOTO INPUT_LOOP07
ENDIF

EXP:112 += 1


