;===========================================================
;여배우명부
;===========================================================
@ACTRESS_CB_LIST

#DIM LIST, 250
#DIM PAGE
#DIM MAXPAGE
#DIM SHOWNUM
#DIM SHOWCOLUMN
#DIM SHOWLENGTH

LOADGLOBAL
Y = 0

;1ページあたりの表示人数の定義
SHOWNUM = 30
;1ページあたりの列数の定義
SHOWCOLUMN = 3
;1行あたりの長さの定義
SHOWLENGTH = 108
;------------------------------------------------------------
;リスト作成
;------------------------------------------------------------
VARSET LIST, -1
LOCAL:1 = 0
FOR LOCAL, 0, 250
	;CSVが存在しない場合ははじく
	SIF !EXISTCSV(LOCAL, 0)
		CONTINUE
	SIF LOCAL == MASTER
		CONTINUE
	;条件満たした番号をリストに登録
	LIST:(LOCAL:1) = LOCAL
	LOCAL:1++
NEXT
MAXPAGE = LOCAL:1 / SHOWNUM

$INPUT_LOOP35
DRAWLINE
PRINTFORML 여배우명부 page[{PAGE}/{MAXPAGE}]
PRINTFORML %"‥" * (SHOWLENGTH / 2)%
LOCAL:1 = 0
FOR LOCAL, PAGE * SHOWNUM, (PAGE + 1) * SHOWNUM
	SIF LOCAL >= 250
		CONTINUE
	IF LIST:LOCAL < 0
		PRINTFORM %"", SHOWLENGTH / 3, LEFT%
	;契約済み
	ELSEIF GLOBAL:(200 + LIST:LOCAL)
		PRINTFORM %@"[{LIST:LOCAL, 3}] - %CSVNAME(LIST:LOCAL, 0)%", SHOWLENGTH / 3, LEFT%
	ELSE
		PRINTFORM %"[ - ] - ----------", SHOWLENGTH / 3, LEFT%
	ENDIF
	SIF LOCAL:1 % SHOWCOLUMN == SHOWCOLUMN - 1
		PRINTL 
	LOCAL:1++
NEXT
SIF !LINEISEMPTY()
	PRINTL 
;こっちのほうがいいかもしれない
;CUSTOMDRAWLINE ‥
PRINTFORML %"‥" * (SHOWLENGTH / 2)%
PRINTFORM %"[998] - 이전 페이지", SHOWLENGTH / 3, LEFT%
;適当にボタンの間隔は変更してください
PRINTFORM %"[999] - 돌아간다", SHOWLENGTH / 3, LEFT%
PRINTFORM %"[1000] - 다음 페이지", SHOWLENGTH / 3, LEFT%
PRINTL 

INPUT

IF RESULT == 999
	RETURN 0
ELSEIF RESULT == 998 && PAGE > 0
	PAGE -= 1
ELSEIF RESULT == 1000 && PAGE < MAXPAGE
	PAGE += 1
ELSEIF RESULT >= 0 && RESULT < 250 && MATCH(LIST, RESULT) && GLOBAL:(200 + RESULT) > 0
	Y = RESULT
	ADDCHARA Y
	SIF GETCHARA(Y, 0) != -1
		TARGET = GETCHARA(Y)
	PRINTFORML %타겟과(1)% 계약한 상태로 시작하겠습니까?
	PRINTFORML [0] - 네
	PRINTFORML [1] - 아니오
	$INPUT_LOOP_ACTRESS
	INPUT
	IF RESULT == 0
		PRINTFORMW %타겟과(1)% 계약했습니다
		FLAG:(999 + (NO:TARGET)) = -1
		LOADGLOBAL
			GLOBAL:(200 + (NO:TARGET)) += 1
		SAVEGLOBAL
		CALL DEFOLT_GENITALCALL
		CALL CLEARBONUS_CALL_CHARA
		SIF TALENT:330 == 1
			TALENT:330 = 0
		RETURN 1
	ELSEIF RESULT
		PRINTFORMW %타겟과(1)% 계약하지 않았습니다
		CALL キャラ削除, TARGET
	ELSE
		GOTO INPUT_LOOP_ACTRESS
	ENDIF
ENDIF

