; 実績の表示
@PRINT_ACHIEVEMENT
; 変数の定義と初期化
; LOCAL			カウンタなどの完全な一時変数 (要素数2)
; LIST			存在する실적번호を格納する変数 (要素数50)
; ACHIEVEMENT	達成条件の判定結果を格納する変数 (要素数50)
; PAGE			現在の表示ページ番号を格納する変数 (要素数1)
; PAGE_END		ページ番号の最大値を格納する変数 (要素数1)
#LOCALSIZE 2
#DIM LIST, 50
#DIM ACHIEVEMENT, 50
#DIM PAGE
#DIM PAGE_END
VARSET LIST, -1
VARSET ACHIEVEMENT, 0
; グローバル読み込み
LOADGLOBAL
; 関数の存在判定
LOCAL:1 = 0
FOR LOCAL, 0, 50
	; 関数の存在チェック
	; 存在する実績タイトルを戻す関数の番号をリスト変数に格納し, 
	; リストの要素番号を格納するカウンタ変数をインクリメントする
	; 存在しない場合は次のループへ移る
	TRYCCALLFORM ACHIEVEMENT_TITLE_{LOCAL}
		LIST:(LOCAL:1) = LOCAL
		; タイトルが存在するなら引き続き実績の達成条件を判定
		CALLFORM ACHIEVEMENT_CALC_{LOCAL}
		SIF RESULT
			ACHIEVEMENT:(LOCAL) = 1
		LOCAL:1++
	CATCH
		CONTINUE
	ENDCATCH
NEXT
; ページ終端を計算
PAGE_END = LOCAL:1 / 10
; グローバルのセーブ
SAVEGLOBAL
; ここからリスト表示処理
$ACHIEVE_LIST
; リストヘッダーの表示
DRAWLINE
PRINTFORML %CALLNAME:MASTER%의 지금까지의 활동실적 page[{PAGE + 1}/{PAGE_END + 1}]
DRAWLINE
; リスト本体の表示
FOR LOCAL, PAGE * 10, PAGE * 10 + 10
	; リスト終端ならループ終了
	SIF LIST:LOCAL < 0
		BREAK
	; 達成条件判定とリスト描画処理
	IF ACHIEVEMENT:(LIST:LOCAL)
		CALLFORM ACHIEVEMENT_TITLE_{LIST:LOCAL}
		PRINTFORML  [{LOCAL, 2}] - %RESULTS%
	ELSE
		PRINTL  [ -] - －－－－
	ENDIF
NEXT
PRINTL 
; リストフッターの表示
IF PAGE > 0
	PRINT [997] - 이전 페이지　　
ELSE
	; PRINTPLAINでボタン化を防止
	PRINTPLAIN [ - ] - －－－－－　　
ENDIF
PRINT [998] - 확인 종료
IF PAGE < PAGE_END
	PRINT 　　[999] - 다음 페이지
ELSE
	; PRINTPLAINでボタン化を防止
	PRINTPLAIN 　　[ - ] - －－－－－
ENDIF
PRINTL 
; ここから入力処理
$INPUT_LOOP
INPUT
IF RESULT < 100 && ACHIEVEMENT:(LIST:RESULT)
	CALLFORM ACHIEVEMENT_MAIN_{LIST:RESULT}
	PRINTL 
	GOTO ACHIEVE_LIST
ELSEIF RESULT == 997 && PAGE > 0
	PAGE--
	GOTO ACHIEVE_LIST
ELSEIF RESULT == 998
	RETURN
ELSEIF RESULT == 999 && PAGE < PAGE_END
	PAGE++
	GOTO ACHIEVE_LIST
ELSE
	CLEARLINE 1
	REUSELASTLINE 잘못된 입력값입니다
	GOTO INPUT_LOOP
ENDIF

; 難易度チェック式中関数
@DIFFICULTY_CHECK
#FUNCTION
RETURNF FLAG:5 != 1 && FLAG:24 != 1

;毎ターン勝手に実績達成がチェックされるようにする
;知らない間に逃していた, は嫌なので
@CHECK_ACHIEVEMENT
SIF !DIFFICULTY_CHECK()
	RETURN
FOR LOCAL, 0, 50
	TRYCALLFORM ACHIEVEMENT_CALC_{LOCAL}
NEXT
