;===========================================================
;実績・BLACK IMPACT
;===========================================================

; 実績のタイトル
@ACHIEVEMENT_TITLE_7
RESULTS = BLACK IMPACT

; 実績の達成条件
@ACHIEVEMENT_CALC_7
; 条件を満たす人数の計算
LOCAL = 0
FOR COUNT, 0, CHARANUM
	SIF COUNT == MASTER
		CONTINUE
	SIF TALENT:COUNT:422 == 1 && TALENT:COUNT:432 == 1
		LOCAL++
NEXT
; 条件を達成している場合は실적번호のグローバルを1にする
SIF GLOBAL:7 == 0 && DIFFICULTY_CHECK() && LOCAL >= 4
	GLOBAL:7 = 1
RETURN GLOBAL:7

; 実績の説明および諸々の処理
@ACHIEVEMENT_MAIN_7
; 解説文
PRINTFORML 수많은 흑갸루걸레들과 꺄꺄우후후 했던 %CALLNAME:MASTER%에게 딱맞는 실적이군요
PRINTFORMW 앞으로도 음란한 일에 탐욕적인 그녀들과 자아낼『충격』을 기대해 주세요
; ボーナスなどの処理はここ以降に記述する
PRINTFORML 그런 %CALLNAME:MASTER%에게 보너스를 내리겠습니다
PRINTFORMW 아래의 보너스 중에서 좋아하는 것을 선택해 주세요 
$INPUT_LOOP_3
CUSTOMDRAWLINE ･･
PRINTFORML  [0] - 여자아이들을 빼앗을 남친을 흑갸루를 좋아하는【바람둥이】로 고정하고, 미팅을 하면 반드시 남친이 생기게 한다
PRINTFORML  [1] - 여자아이들을 빼앗을 남친을 원래대로 랜덤으로 한다
PRINTFORML  [2] - 흑갸루들의 사적인 행동을 억제한다
PRINTFORML  [3] - 흑갸루들의 사적인 행동을 종래대로 랜덤으로 한다
PRINTFORML  [4] - 사랑을 맹세한 흑갸루의 놀이를 허락한다
PRINTFORML  [5] - 사랑을 맹세한 흑갸루의 놀이를 허락하지 않는다
CUSTOMDRAWLINE ･･
PRINTL [999] - 돌아간다
INPUT
IF RESULT == 0 && FLAG:541 == 0
	PRINTFORMW  남친을【바람둥이】로 고정하고 미팅을 하면 반드시 남친이 생깁니다
	FLAG:541 = 1
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 0 && FLAG:541 == 1
	PRINTFORMW 이미 남친이【바람둥이】로 고정되어 있습니다
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 1 && FLAG:541 == 1
	PRINTFORMW 원래대로 랜덤으로 남친이 결정됩니다
	FLAG:541 = 0
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 1 && FLAG:541 == 0
	PRINTFORMW 남친이 랜덤으로 결정되게 되어있습니다
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 2 && FLAG:542 == 0
	PRINTFORMW 흑갸루들의 사적인 행동을 억제했습니다
	FLAG:542 = 1
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 2 && FLAG:541 == 1
	PRINTFORMW 흑갸루들의 사적인 행동은 억제되어 있습니다
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 3 && FLAG:542 == 1
	PRINTFORMW 원래대로 랜덤으로 흑갸루들의 사적인 행동이 결정되도록 합니다
	FLAG:542 = 0
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 3 && FLAG:542 == 0
	PRINTFORMW 흑갸루들의 사적인 행동은 랜덤으로 결정되게 되어 있습니다
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 4 && FLAG:545 == 0
	PRINTFORMW 사랑을 맹세한 흑갸루의 놀이를 허락한다(단, 남친은 생기지 않습니다)
	FLAG:545 = 1
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 4 && FLAG:545 == 1
	PRINTFORMW 현재, 사랑을 맹세한 흑갸루의 놀이를 허락하지 않고 있습니다
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 5 && FLAG:545 == 1
	PRINTFORMW 사랑을 맹세한 흑갸루의 놀이를 허락하지 않습니다
	FLAG:545 = 0
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 5 && FLAG:545 == 0
	PRINTFORMW 현재, 사랑을 맹세한 흑갸루의 놀이를 허락하고 있습니다(단, 남친은 생기지 않습니다)
	GOTO INPUT_LOOP_3
ELSEIF RESULT == 999
	RETURN 0
ELSE
	GOTO INPUT_LOOP_3
ENDIF
