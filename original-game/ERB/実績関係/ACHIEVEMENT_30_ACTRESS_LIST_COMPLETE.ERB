;===========================================================
;実績・ACTRESS LIST COMPLETED!!
;===========================================================

; 実績のタイトル
@ACHIEVEMENT_TITLE_30
RESULTS = ACTRESS LIST COMPLETED!!

; 実績の達成条件
@ACHIEVEMENT_CALC_30
; 条件を満たす人数の計算
VARSET LOCAL, 0
FOR LOCAL, 0, 250
	;CSVが存在しない場合ははじく
	SIF !EXISTCSV(LOCAL, 0)
		CONTINUE
	SIF LOCAL == MASTER
		CONTINUE
	;条件満たした番号をリストに登録
	LOCAL:1++
	SIF GLOBAL:(200 + LOCAL:1)
		LOCAL:2++
NEXT


; 条件を達成している場合は실적번호のグローバルを1にする
SIF LOCAL:2 == LOCAL:1
	GLOBAL:30 = 1
RETURN GLOBAL:30

; 実績の説明および諸々の処理
@ACHIEVEMENT_MAIN_30
; 解説文
PRINTFORML 이 세계를 몇번이나 반복하며, 끝내 모든 여배우후보를 알게 된 %CALLNAME:MASTER%
PRINTFORML 그 중에는 만나는 것조차 어려운 사람도 있었지만, %플레이어는()% 어떤 고난도 해쳐나올 수 있었습니다
PRINTFORM 세계를 반복하는 사이에, 만난 적이 없는 사람의 프로필까지 기록돼있는
PRINTFORML 이상한『여배우명부』
PRINTFORML 이게 있으면 앞으로의 지도가 편해질지도 모릅니다
PRINTW
