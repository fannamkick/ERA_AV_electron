@SHOW_ABLUP_SELECT
#DIM LCOUNT

U = 0
REPEAT 42
	SIF COUNT >= 4 && COUNT <=9
		CONTINUE
	SIF COUNT >= 18 && COUNT <= 19
		CONTINUE
	SIF COUNT >= 24 && COUNT <= 29
		CONTINUE
	SIF COUNT >= 34 && COUNT <= 36
		CONTINUE

	;男だとV감각と레즈끼と레즈중독は上げられない
	SIF TALENT:122 && (COUNT == 2 || COUNT == 22 || COUNT == 33)
		CONTINUE
	;女だとBLっ気とBL中毒は上げられない
	SIF TALENT:122 == 0 && (COUNT == 23 || COUNT == 34)
		CONTINUE
	;男か후타나리でないと사정中毒は上げられない
	SIF (TALENT:122 == 0 && TALENT:121 == 0) && COUNT == 38
		CONTINUE
	X = COUNT
	PRINTFORM  [{X}]
	;文字揃え
	IF X < 10
		PRINT  
	ENDIF	
	PRINTFORM %ABLNAME:X%
	;文字揃えその2
	IF X <= 3
		PRINT    
	ELSEIF X >= 17 && X <= 23
		PRINT   
	ELSEIF (X >= 10 && X <= 12) || X == 15
		PRINT     
	ENDIF	
	PRINTFORM -{ABL:X}LV
	CALL DECIDE_ABLUP,X
	U += 1
	IF U % 4 == 0
		PRINTL 
	ENDIF
REND 
SIF U % 4 != 0
	PRINTL 

FOR LCOUNT,70,74
	PRINTFORM  [{LCOUNT}]%ABLNAME:LCOUNT%-{ABL:LCOUNT}LV
	CALL DECIDE_ABLUP,LCOUNT
NEXT
PRINTL

PRINTFORM  [99]%MARKNAME:3%-{MARK:3}LV
