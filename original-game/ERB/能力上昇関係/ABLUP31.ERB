;자위중독のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化
;eraIm@s_ver.0.17βdのスクリプトを参考に修正

;-------------------------------------------------
;자위중독のLvUP
;-------------------------------------------------
@ABLUP31
DRAWLINE
;PRINTL 노예의 자위에 대한 집착도가 높아집니다
;PRINTL 자위중독이 높아지면, 자위행위에 대한 만족감이 깊어져, 
;PRINTL 자주 자위를 하지 않으면 마음이 진정되지 않게 됩니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;자위중독はLv5が上限
;[愛][음란][자위하기쉬움][쾌감에 솔직][자위광][가슴광]が付いている場合はLv10まで해방
IF ABL:31 >= 5 && (TALENT:85 == 0 && TALENT:76 == 0 && TALENT:60 == 0 && TALENT:70 == 0 && TALENT:74 == 0 && TALENT:78 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:31 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
;성교중독＋자위중독は11以上にならない
ELSEIF ABL:30 + ABL:31 >= 15 && TALENT:505 == 0 && TALENT:511 == 0
	PRINTFORMW 성교중독({ABL:30})＋자위중독({ABL:31})의 상한은 15입니다
	RETURN 0
ENDIF

;必要な욕정의 구슬
A = 0
;必要な快C의 구슬
B = 0
;必要な습득의 구슬
C = 0
;必要な자위경험回数
D = 0
;必要な지도자위경험回数
E = 0
;必要な이상경험回数
F = 0

;条件別にOKかダメかを記録する
;자위경험で上げる場合の可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0
;지도자위경험で上げる場合の可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
J = 0

CALL DECIDE_ABLUP31

;LV2から3, LV3から4, 4から5に上げるときは이상경험必要(素質: [해방][자위하기쉬움][중독되기쉬움][음란化]なら無視できる)
SIF F > 0
	PRINTFORML %EXPNAME:50%{F}이상 (현재{EXP:50}) 그리고

;노출벽が必要
PRINTFORML %ABLNAME:17%{ABL:31 + 1}LV이상 (현재{ABL:17}LV) 그리고

;C感覚が必要
PRINTFORML %ABLNAME:0%{ABL:31 + 1}LV이상 (현재{ABL:0}LV) 그리고

;자위경험で上げる場合
PRINTFORM [0] - %PALAMNAME:5%의 구슬×{JUEL:5}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTFORML 　　　%PALAMNAME:0%의 구슬×{JUEL:0}/{B}
PRINTFORML 　　　%PALAMNAME:8%의 구슬×{JUEL:8}/{C}
PRINTFORML 　　　%EXPNAME:10%　{EXP:10}/{D}

;지도자위경험で上げる場合
PRINTFORM [1] - %PALAMNAME:5%의 구슬×{JUEL:5}/{A} ……
IF J == 0
	PRINT OK
ELSE
	SIF J & 1
		PRINT 구슬부족 
	SIF J & 2
		PRINT 경험부족 
	SIF J & 4
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTFORML 　　　%PALAMNAME:0%의 구슬×{JUEL:0}/{B}
PRINTFORML 　　　%PALAMNAME:8%의 구슬×{JUEL:8}/{C}
PRINTFORML 　　　%EXPNAME:11%　{EXP:11}/{E}

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 1) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF J != 0 && RESULT == 1
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:31 += 1

IF RESULT == 0 || RESULT == 1
	JUEL:5 -= A
	JUEL:0 -= B
	JUEL:8 -= C
ENDIF

PRINTFORML %ABLNAME:31%의 레벨이 %조사처리(ABL:31,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;자위중독のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP31
;자위중독はLv5が上限
;[愛][음란][자위하기쉬움][쾌감에 솔직][자위광][음유]が付いている場合はLv10まで해방
SIF ABL:31 >= 10
	RETURN 0
SIF ABL:31 >= 5 && (TALENT:85 == 0 && TALENT:76 == 0 && TALENT:60 == 0 && TALENT:70 == 0 && TALENT:74 == 0 && TALENT:78 == 0)
	RETURN 0
;성교중독LV＋자위중독LVは10が上限
SIF ABL:30 + ABL:31 >= 15 && TALENT:505 == 0 && TALENT:511 == 0
	RETURN 0

;判定変数を空に
I = 0
J = 0

A = 0
B = 0
C = 0
D = 0
E = 0
F = 0

IF ABL:31 == 0
	A = 3000
	B = 10000
	C = 1000
	D = 100
	E = 20
ELSEIF ABL:31 == 1
	A = 6000
	B = 25000
	C = 3000
	D = 250
	E = 40
ELSEIF ABL:31 == 2
	A = 12000
	B = 50000
	C = 6000
	D = 500
	E = 60
ELSEIF ABL:31 == 3
	A = 20000
	B = 100000
	C = 15000
	D = 1000
	E = 100
ELSEIF ABL:31 == 4
	A = 32000
	B = 200000
	C = 30000
	D = 1500
	E = 150
ELSEIF ABL:31 == 5
	A = 50000
	B = 250000
	C = 40000
	D = 2000
	E = 200
ELSEIF ABL:31 == 6
	A = 70000
	B = 320000
	C = 50000
	D = 3000
	E = 320
ELSEIF ABL:31 == 7
	A = 100000
	B = 500000
	C = 70000
	D = 4000
	E = 500
ELSEIF ABL:31 == 8
	A = 150000
	B = 800000
	C = 100000
	D = 6000
	E = 800
ELSEIF ABL:31 == 9
	A = 200000
	B = 1000000
	C = 150000
	D = 8000
	E = 1000
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:31 == 3
		TIMES A , 1.50
		TIMES B , 1.50
		TIMES C , 1.50
		TIMES D , 1.50
		TIMES E , 1.50
	ELSEIF ABL:31 == 4
		TIMES A , 2.00
		TIMES B , 2.00
		TIMES C , 2.00
		TIMES D , 2.00
		TIMES E , 2.00
	ELSEIF ABL:31 == 5
		TIMES A , 2.50
		TIMES B , 2.50
		TIMES C , 2.50
		TIMES D , 2.50
		TIMES E , 2.50
	ELSEIF ABL:31 >= 6
		TIMES A , 3.00
		TIMES B , 3.00
		TIMES C , 3.00
		TIMES D , 3.00
		TIMES E , 3.00
	ENDIF
ENDIF

;LV2から3, LV3から4, 4から5に上げるときは이상경험必要(素質: [해방][자위하기쉬움][음란][중독되기쉬움][광기]なら無視できる)
IF ABL:31 == 2 && (TALENT:33 == 0 && TALENT:60 == 0 && TALENT:72 == 0 && TALENT:76 == 0 && TALENT:123 == 0)
	F = ABL:31 - 1
	IF EXP:50 < F
		;이상경험が不足
		I |= 2
		J |= 2
	ENDIF
ENDIF

;자위하기쉬움
IF TALENT:60
	TIMES A , 0.25
	TIMES B , 0.25
	TIMES C , 0.25
	TIMES D , 0.25
	TIMES E , 0.25
ENDIF

;중독되기쉬움
IF TALENT:72
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
	TIMES D , 0.50
	TIMES E , 0.50
ENDIF

;도착적
IF TALENT:80
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
	TIMES D , 0.75
	TIMES E , 0.75
ENDIF

;음란化
IF TALENT:76
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
	TIMES D , 0.50
	TIMES E , 0.50
ENDIF

IF TALENT:440
	TIMES A , 0.10
	TIMES B , 0.10
	TIMES C , 0.10
	TIMES D , 0.10
	TIMES E , 0.10
ENDIF

IF TALENT:505
	TIMES A , 0.01
	TIMES B , 0.01
	TIMES C , 0.01
	TIMES D , 0.01
	TIMES E , 0.01
ENDIF

;이상경험が不足
IF F > EXP:50
	I |= 2
	J |= 2
ENDIF

;노출벽が자위중독＋1レベルでないと能力不足
IF ABL:17 < ABL:31 + 1
	I |= 4
	J |= 4
ENDIF

;C感覚が자위중독＋1レベルでないと能力不足
IF ABL:0 < ABL:31 + 1
	I |= 4
	J |= 4
ENDIF

;最低でも1回・1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1
SIF C < 1
	C = 1
SIF D < 1
	D = 1
SIF E < 1
	E = 1

;자위경험で上げる場合
;욕정의 구슬が不足
SIF JUEL:5 < A
	I |= 1
;快C의 구슬が不足
SIF JUEL:0 < B
	I |= 1
;습득의 구슬が不足
SIF JUEL:8 < C
	I |= 1
;자위경험が不足
SIF EXP:10 < D
	I |= 2

;지도자위경험で上げる場合
;욕정의 구슬で上げる
SIF JUEL:5 < A
	J |= 1
;快C의 구슬で上げる
SIF JUEL:0 < B
	J |= 1
;습득의 구슬で上げる
SIF JUEL:8 < C
	J |= 1
;지도자위경험が必要
SIF EXP:11 < E
	J |= 2

IF I == 0 || J == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
;
;
;