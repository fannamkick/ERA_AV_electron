;화술のLvUP処理とその可否判定
;eraIm@s_ver.0.17βdのスクリプトをベースに処理を簡略化

;-------------------------------------------------
;화술のLvUP
;-------------------------------------------------
@ABLUP15
DRAWLINE
;PRINTL 노예의 화술을 향상시킵니다
;PRINTL 화술이 올라가면, 창관에서의 영업과 접대 성공율이 높아집니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;화술はLv10が上限
IF ABL:15 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
;기교＋화술は16以上にならない
;ただし[협상에 능숙함]を除く
ELSEIF ABL:12 + ABL:15 >= 15 && TALENT:211 == 0
	PRINTFORMW 기교({ABL:12})＋화술({ABL:15})의 상한은 15입니다
	RETURN 0
ENDIF


;条件別にOKかダメかを記録する
;必要な습득의 구슬
A = 0
;必要な調教회화경험
B = 0
;必要な매춘경험
C = 0

;条件別にOKかダメかを記録する
;습득의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足)
I = 0

CALL DECIDE_ABLUP15

PRINTFORM [0] - %PALAMNAME:7%의 구슬×{JUEL:7}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
ENDIF
PRINTL 
PRINTFORML       %EXPNAME:73%　{EXP:73}/{B} or
PRINTFORML       %EXPNAME:74%　{EXP:74}/{C}

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 0) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:15 += 1

IF RESULT == 0
	JUEL:7 -= A
ENDIF

PRINTFORML %ABLNAME:15%의 레벨이 %조사처리(ABL:15,"가")% 되었습니다

RETURN 0

;--------------------------------------------------
;レベルアップに必要な珠計算, レベルアップ予告処理
;--------------------------------------------------
@DECIDE_ABLUP15
;화술はLv10が上限
SIF ABL:15 >= 10
	RETURN 0
SIF ABL:12 + ABL:15 >= 15 && TALENT:211 == 0
	RETURN 0

;条件別にOKかダメかを記録する
A = 0
B = 0
C = 0
I = 0

IF ABL:15 == 0
	A = 1
	B = 1
	C = 5
ELSEIF ABL:15 == 1
	A = 10
	B = 5
	C = 20
ELSEIF ABL:15 == 2
	A = 100
	B = 15
	C = 50
ELSEIF ABL:15 == 3
	A = 1500
	B = 40
	C = 100
ELSEIF ABL:15 == 4
	A = 3000
	B = 80
	C = 150
ELSEIF ABL:15 == 5
	A = 4000
	B = 120
	C = 180
ELSEIF ABL:15 == 6
	A = 5200
	B = 150
	C = 250
ELSEIF ABL:15 == 7
	A = 7500
	B = 180
	C = 320
ELSEIF ABL:15 == 8
	A = 9000
	B = 220
	C = 350
ELSEIF ABL:15 == 9
	A = 13000
	B = 250
	C = 400
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:15 == 3
		TIMES A , 1.50
		TIMES C , 1.25
	ELSEIF ABL:15 == 4
		TIMES A , 2.00
		TIMES C , 1.50
	ELSEIF ABL:15 == 5
		TIMES A , 2.50
		TIMES C , 1.75
	ELSEIF ABL:15 >= 6
		TIMES A , 3.00
		TIMES C , 2.00
	ENDIF
ENDIF

;反抗的
IF TALENT:11
	TIMES A , 1.50
	TIMES B , 1.20
	TIMES C , 1.20
ENDIF
;솔직함
IF TALENT:13
	TIMES A , 0.90
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF
;건방짐
IF TALENT:16
	TIMES A , 1.25
	TIMES B , 1.15
	TIMES C , 1.15
ENDIF
;프라이드 높음
IF TALENT:15
	TIMES A , 1.20
	TIMES B , 1.10
	TIMES C , 1.10
ENDIF
;무관심
IF TALENT:21
	TIMES A , 1.50
	TIMES B , 1.20
	TIMES C , 1.20
ENDIF
;감정부족
IF TALENT:22
	TIMES A , 1.50
	TIMES B , 1.20
	TIMES C , 1.20
ENDIF
;호기심
IF TALENT:23
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF

;포지티브
IF TALENT:25
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
;悲観的
ELSEIF TALENT:26
	TIMES A , 1.20
	TIMES B , 1.10
	TIMES C , 1.10
ENDIF

;튀고 싶어함
IF TALENT:28
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.20
	TIMES B , 1.10
	TIMES C , 1.10
;해방
ELSEIF TALENT:33
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF

;저항
IF TALENT:34
	TIMES A , 1.20
	TIMES B , 1.10
	TIMES C , 1.10
ENDIF

;수줍음
IF TALENT:35
	TIMES A , 1.20
	TIMES B , 1.10
	TIMES C , 1.10
;부끄럼 없음
ELSEIF TALENT:36
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF

;習得早い
IF TALENT:50
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
;습득느림
ELSEIF TALENT:51
	TIMES A , 1.20
	TIMES B , 1.10
	TIMES C , 1.10
ENDIF

;수수께끼의 매력
IF TALENT:92
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF
;소악마
IF TALENT:87
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF
;요설스러움
IF TALENT:182
	TIMES A , 0.60
	TIMES B , 0.60
	TIMES C , 0.80
ENDIF

;튀고 싶어함
IF TALENT:224
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
ENDIF

;最低でも1回・1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1
SIF C < 1
	C = 1

;습득의 구슬は足りている?
SIF JUEL:7 < A
	I |= 1
;調教회화경험か매춘경험は足りている?
SIF EXP:73 < B && EXP:74 < C
	I |= 2

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
