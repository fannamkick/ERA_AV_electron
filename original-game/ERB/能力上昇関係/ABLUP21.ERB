ENDIF

IF TALENT:505
	TIMES A , 0.10
	TIMES B , 0.10
	TIMES C , 0.10
	TIMES D , 0.10
	TIMES E , 0.10
ENDIF

;本性はドSな카나데
IF NO:TARGET == 1
	TIMES A , 2.20
	TIMES B , 2.20
	TIMES C , 2.20
	TIMES D , 2.20
	TIMES E , 2.20
ENDIF
;本性はドMなカナ
IF NO:TARGET == 91
	TIMES A , 0.40
	TIMES B , 0.40
	TIMES C , 0.40
	TIMES D , 0.40
	TIMES E , 0.40
ENDIF

SIF D <= 0
	D = 1
SIF E <= 0
	E = 1
SIF G <= 0
	G = 1

;욕망が마조끼＋1レベルでないといけない
IF ABL:11 < ABL:21+1
	;욕망が不足
	I |= 4
	J |= 4
ENDIF

;이상경험が不足
IF EXP:50 < F
	I |= 2
	J |= 2
ENDIF

;욕정＋苦痛의 구슬で上げる場合
IF B > 0
	;고통의 구슬が不足
	SIF JUEL:9 < A
		I |= 1
	;욕정의 구슬が不足
	SIF JUEL:5 < B
		I |= 1
	;피학쾌락경험が不足
	SIF EXP:30 < C
		I |= 2
ELSE
	I = 256
ENDIF

;고통＋屈服의 구슬で上げる
IF D > 0
	;고통의 구슬が不足
	SIF JUEL:9 < D
		J |= 1
	;屈服의 구슬が不足
	SIF JUEL:6 < E
		J |= 1
	;피학쾌락경험が不足
	SIF EXP:30 < C
		J |= 2
	;절정경험が不足
	SIF EXP:2 < G
		J |= 2
ELSE
	J = 256
ENDIF

IF I == 0 || J == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF

