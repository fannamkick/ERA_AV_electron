;마조ッ気のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;마조ッ気のLvUP
;-------------------------------------------------
@ABLUP21
DRAWLINE
;PRINTL 노예의 마조끼를 올립니다
;PRINTL 마조끼가 높아지면, 고통이나 굴욕적인 행위로부터 쾌락을 얻을 수 있게 됩니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;마조ッ気はLv5が上限
;[새드]が付いている場合はLv3が上限
;음마は両方こなせるらしい
;[겁쟁이][얌전함][약점][마조]が付いている場合はLv10まで해방
IF ABL:21 >= 3 && TALENT:83 == 1 && TALENT:505 == 0
	PRINTFORMW 소질 【%TALENTNAME:83%】가 있으므로 이 이상 올릴 수 없습니다
	RETURN 0
ELSEIF ABL:21 >= 5 && (TALENT:10 == 0 && TALENT:14 == 0 && TALENT:37 == 0 && TALENT:88 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
;새드끼＋마조끼は11以上にならない
;ここも음마除く
ELSEIF ABL:20 + ABL:21 >= 10 && TALENT:505 == 0
	PRINTFORMW 새드끼({ABL:20})＋마조끼({ABL:21})의 상한은 10입니다
	RETURN 0
ELSEIF ABL:21 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;고통＋欲情で上げる場合に必要な苦痛의 구슬
A = 0
;必要な욕정의 구슬
B = 0
;必要な피학쾌락경험回数
C = 0
;고통＋屈服で上げる場合に必要な苦痛의 구슬
D = 0
;必要な屈服의 구슬
E = 0
;必要な이상경험回数
F = 0
;必要な절정경험回数
G = 0

;条件別にOKかダメかを記録する
;고통＋욕정의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0
;고통＋屈服의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
J = 0

CALL DECIDE_ABLUP21

;욕망が마조끼＋1レベルでないといけない
PRINTFORML %ABLNAME:11%{ABL:21+1}LV이상 (현재{ABL:11}LV) 그리고

;LV3から4, 4から5に上げるときは이상경험必要(素質: [해방]なら無視できる)
SIF F > 0
	PRINTFORML %EXPNAME:50%{F}이상 (현재{EXP:50}) 그리고

IF B > 0
	PRINTFORM [0] - %PALAMNAME:9%의 구슬×{JUEL:9}/{A} ……
	IF I == 0
		PRINT OK
	ELSE
		SIF I & 1
			PRINT 구슬부족 
		SIF I & 2
			PRINT 경험부족 
		SIF I & 4
			PRINT 능력부족 
	ENDIF
	PRINTL 
	;욕정의 구슬
	PRINTFORML 　　　%PALAMNAME:5%의 구슬×{JUEL:5}/{B}
	;피학쾌락경험
	SIF C > 0
		PRINTFORML 　　　%EXPNAME:30%　{EXP:30}/{C}
ENDIF

IF D > 0
	PRINTFORM [1] - %PALAMNAME:9%의 구슬×{JUEL:9}/{D} ……
	IF J == 0
		PRINT OK
	ELSE
		SIF J & 1
			PRINT 구슬부족 
		SIF J & 2
			PRINT 경험부족 
		SIF J & 4
			PRINT 능력부족 
	ENDIF
	PRINTL 
	;屈服의 구슬
	PRINTFORML 　　　%PALAMNAME:6%의 구슬×{JUEL:6}/{E}
	;피학쾌락경험
	SIF C > 0
		PRINTFORML 　　　%EXPNAME:30%　{EXP:30}/{C}
	;절정경험
	SIF G > 0
		PRINTFORML 　　　%EXPNAME:2%　{EXP:2}/{G}
ENDIF

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 1) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF J == 256 && RESULT == 1
	RESTART
ELSEIF J != 0 && RESULT == 1
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:21 += 1

IF RESULT == 0
	JUEL:9 -= A
	JUEL:5 -= B
ELSEIF RESULT == 1
	JUEL:9 -= D
	JUEL:6 -= E
ENDIF

PRINTFORML %ABLNAME:21%의 레벨이 %조사처리(ABL:21,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;마조끼のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP21
;마조ッ気はLv10が上限
SIF ABL:21 >= 5 && (TALENT:10 == 0 && TALENT:14 == 0 && TALENT:37 == 0 && TALENT:88 == 0)
	RETURN 0
SIF ABL:21 >= 10
	RETURN 0
SIF ABL:21 >= 3 && TALENT:83 == 1 && TALENT:505 == 0
	RETURN 0
SIF ABL:20 + ABL:21 >= 10 && TALENT:505 == 0
	RETURN 0

;고통＋欲情で上げる場合に必要な苦痛의 구슬
A = 0
;必要な욕정의 구슬
B = 0
;必要な피학쾌락경험回数
C = 0
;고통＋屈服で上げる場合に必要な苦痛의 구슬
D = 0
;必要な屈服의 구슬
E = 0
;必要な이상경험回数
F = 0

;条件別にOKかダメかを記録する
;고통＋욕정의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0
;고통＋屈服의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
J = 0

IF ABL:21 == 0
	A = 100
	B = 100
	C = 0
	D = 100
	E = 100
ELSEIF ABL:21 == 1
	A = 500
	B = 500
	C = 0
	D = 500
	E = 300
ELSEIF ABL:21 == 2
	A = 1200
	B = 1000
	C = 0
	D = 1500
	E = 1000
ELSEIF ABL:21 == 3
	A = 0
	B = 0
	C = 30
	D = 2800
	E = 6000
ELSEIF ABL:21 == 4
	A = 0
	B = 0
	C = 80
	D = 4300
	E = 12000
ELSEIF ABL:21 == 5
	A = 0
	B = 0
	C = 150
	D = 6000
	E = 24000
ELSEIF ABL:21 == 6
	A = 0
	B = 0
	C = 200
	D = 8000
	E = 38000
ELSEIF ABL:21 == 7
	A = 0
	B = 0
	C = 300
	D = 11000
	E = 56000
ELSEIF ABL:21 == 8
	A = 0
	B = 0
	C = 450
	D = 15000
	E = 86000
ELSEIF ABL:21 == 9
	A = 0
	B = 0
	C = 600
	D = 20000
	E = 120000
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:21 == 3
		TIMES C , 1.50
		TIMES D , 1.50
		TIMES E , 1.50
	ELSEIF ABL:21 == 4
		TIMES C , 2.00
		TIMES D , 2.00
		TIMES E , 2.00
	ELSEIF ABL:21 == 5
		TIMES C , 2.50
		TIMES D , 2.50
		TIMES E , 2.50
	ELSEIF ABL:21 >= 6
		TIMES C , 3.00
		TIMES D , 3.00
		TIMES E , 3.00
	ENDIF
ENDIF

;LV3から4, 4から5, 7から8に上げるときは이상경험必要(素質: [해방][도착적][마조]なら無視できる)
SIF (ABL:21 == 3 || ABL:21 == 4 || ABL:21 == 7) && TALENT:33 == 0 && TALENT:80 == 0 && TALENT:88 == 0
	F = ABL:21 - 2

;必要な절정경험数は全レベル1
G = 1

;겁쟁이
IF TALENT:10
	TIMES A , 1.10
	TIMES B , 1.10
	TIMES C , 1.10
	TIMES D , 1.10
	TIMES E , 1.10
ENDIF
;反抗的
IF TALENT:11
