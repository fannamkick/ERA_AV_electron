;새드ッ気のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;새드ッ気のLvUP
;-------------------------------------------------
@ABLUP20
DRAWLINE
;PRINTL 노예의 새드끼를 올립니다
;PRINTL 새드끼가 올라가면, 누군가에게 고통을 주는 것에 욕정하기 쉬워집니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;새드ッ気はLv5が上限
;[마조]が付いている場合はLv3が上限
;음마は両方こなせる由
;[도착적][새드][역습]が付いている場合はLv10まで해방
IF ABL:20 >= 3 && TALENT:88 == 1 && TALENT:505 == 0
	PRINTFORMW 소질【%TALENTNAME:88%】가 있으므로 이 이상 올릴 수 없습니다
	RETURN 0
ELSEIF ABL:20 >= 5 && (TALENT:80 == 0 && TALENT:83 == 0 && TALENT:127 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
;새드끼＋마조끼は11以上にならない
ELSEIF ABL:20 + ABL:21 >= 10 && TALENT:505 == 0
	PRINTFORMW 새드끼({ABL:20})＋마조끼({ABL:21})의 상한은 10입니다
	RETURN 0
ELSEIF ABL:20 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要な욕정의 구슬
A = 0
;必要な가학쾌락경험回数
B = 0
;必要な이상경험回数
C = 0

;条件別にOKかダメかを記録する
;욕정의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0

CALL DECIDE_ABLUP20

;욕망が새드끼＋1レベルでないといけない
PRINTFORML %ABLNAME:11%{ABL:20+1}LV이상 (현재{ABL:11}LV) 그리고

;LV3から4, 4から5に上げるときは이상경험必要(素質: [도착적][새드][질투][소악마]なら無視できる)
SIF C > 0
	PRINTFORML %EXPNAME:50%{C} 이상(현재{EXP:50})그리고 

PRINTFORM [0] - %PALAMNAME:5%의 구슬×{JUEL:5}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족 
ENDIF
PRINTL 
;가학쾌락경험
SIF B > 0
	PRINTFORML 　　　%EXPNAME:33%　{EXP:33}/{B}

PRINTL [100] - 그만둔다

INPUT
IF RESULT != 0 && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:20 += 1

JUEL:5 -= A

PRINTFORML %ABLNAME:20%의 레벨이 %조사처리(ABL:20,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;마조끼のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP20
;새드ッ気はLv10が上限
SIF ABL:20 >= 5 && (TALENT:80 == 0 && TALENT:83 == 0 && TALENT:127 == 0)
	RETURN 0
SIF ABL:20 >= 10
	RETURN 0
SIF ABL:20 >= 3 && TALENT:88 == 1 && TALENT:505 == 0
	RETURN 0
SIF ABL:20 + ABL:21 >= 10 && TALENT:505 == 0
	RETURN 0

;必要な욕정의 구슬
A = 0
;必要な가학쾌락경험回数
B = 0
;必要な이상경험回数
C = 0

;条件別にOKかダメかを記録する
;욕정의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0

IF ABL:20 == 0
	A = 100
	B = 5
ELSEIF ABL:20 == 1
	A = 500
	B = 20
ELSEIF ABL:20 == 2
	A = 1500
	B = 50
ELSEIF ABL:20 == 3
	A = 3000
	B = 120
ELSEIF ABL:20 == 4
	A = 5000
	B = 300
ELSEIF ABL:20 == 5
	A = 8000
	B = 600
ELSEIF ABL:20 == 6
	A = 12000
	B = 1500
ELSEIF ABL:20 == 7
	A = 15000
	B = 3000
ELSEIF ABL:20 == 8
	A = 25000
	B = 5000
ELSEIF ABL:20 == 9
	A = 30000
	B = 8000
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:20 == 3
		TIMES C , 1.50
		TIMES D , 1.50
		TIMES E , 1.50
	ELSEIF ABL:20 == 4
		TIMES C , 2.00
		TIMES D , 2.00
		TIMES E , 2.00
	ELSEIF ABL:20 == 5
		TIMES C , 2.50
		TIMES D , 2.50
		TIMES E , 2.50
	ELSEIF ABL:20 >= 6
		TIMES C , 3.00
		TIMES D , 3.00
		TIMES E , 3.00
	ENDIF
ENDIF
IF TALENT:505
	TIMES A , 0.10
	TIMES B , 0.10
	TIMES C , 0.10
	TIMES D , 0.10
	TIMES E , 0.10
ENDIF

;LV3から4, 4から5, 7から8に上げるときは이상경험必要(素質: [도착적][새드][질투][소악마]なら無視できる)
SIF (ABL:20 == 3 || ABL:20 == 4 || ABL:20 == 7) && TALENT:80 == 0 && TALENT:83 == 0 && TALENT:84 == 0 && TALENT:87 == 0
	C = ABL:20 - 2

;必要な절정경험数は全レベル1
G = 1

;겁쟁이
IF TALENT:10
	TIMES A , 1.50
ENDIF
;反抗的
IF TALENT:11
	TIMES A , 0.90
	TIMES B , 0.90
ENDIF
;다부짐
SIF TALENT:12
	TIMES A , 0.90
;얌전함
SIF TALENT:14
	TIMES A , 1.20
;건방짐
IF TALENT:16
	TIMES A , 0.90
	TIMES B , 0.90
ENDIF

;프라이드 높음
IF TALENT:15
	TIMES A , 0.90
	TIMES B , 0.90
;프라이드 낮음
ELSEIF TALENT:17
	TIMES A , 1.10
	TIMES B , 1.10
ENDIF

;자제심
IF TALENT:20
	TIMES A , 1.20
	TIMES B , 1.20
ENDIF
;무관심
IF TALENT:21
	TIMES A , 1.20
	TIMES B , 1.20
ENDIF
;감정부족
IF TALENT:22
	TIMES A , 1.50
	TIMES B , 1.20
ENDIF
;호기심
IF TALENT:23
	TIMES A , 0.90
	TIMES B , 0.90
ENDIF
;悲観的
SIF TALENT:26
	TIMES A , 1.10
;튀고 싶어함
IF TALENT:28
	TIMES A , 0.90
	TIMES B , 0.90
ENDIF
;정조관념
IF TALENT:30
	TIMES A , 1.10
	TIMES B , 1.10
;정조무관심
ELSEIF TALENT:31
	TIMES A , 0.95
	TIMES B , 0.95
ENDIF

;억압
IF TALENT:32
	TIMES A , 0.95
	TIMES B , 0.95
;해방
ELSEIF TALENT:33
	TIMES A , 0.90
	TIMES B , 0.90
ENDIF

;남성혐오or女嫌い
IF TALENT:79 || TALENT:82
	TIMES A , 0.95
	TIMES B , 0.95
ENDIF

;아픔에 약함
IF TALENT:40
	TIMES A , 1.20
	TIMES B , 1.20
;아픔에 강함
ELSEIF TALENT:41
	TIMES A , 0.90
	TIMES B , 0.90
ENDIF

;음란
IF TALENT:76
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
	TIMES D , 0.80
	TIMES E , 0.80
ENDIF
;음란
IF TALENT:553
	TIMES A , 0.60
	TIMES B , 0.60
	TIMES C , 0.60
	TIMES D , 0.60
	TIMES E , 0.60
ENDIF
;색정광
IF TALENT:440
	TIMES A , 0.40
	TIMES B , 0.40
	TIMES C , 0.40
	TIMES D , 0.40
	TIMES E , 0.40
ENDIF
;도착적
IF TALENT:80
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF
;새드
IF TALENT:83
	TIMES A , 0.50
	TIMES B , 0.50
ENDIF
;마조
IF TALENT:88
	TIMES A , 1.20
	TIMES B , 1.20
ENDIF
;질투
IF TALENT:84
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF
;소악마
IF TALENT:87
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF
;광기
IF TALENT:123
	TIMES A , 0.50
	TIMES B , 0.50
ENDIF
;붕괴
IF TALENT:9
	TIMES A , 2.00
	TIMES B , 2.00
ENDIF
;소악마
IF TALENT:407
	TIMES A , 0.75
	TIMES B , 0.75
ENDIF
;本性はドSな카나데
IF NO:TARGET == 1
	TIMES A , 0.40
	TIMES B , 0.40
	TIMES C , 0.40
	TIMES D , 0.40
	TIMES E , 0.40
ENDIF
;本性はドMなカナ
IF NO:TARGET == 91
	TIMES A , 2.20
	TIMES B , 2.20
	TIMES C , 2.20
	TIMES D , 2.20
	TIMES E , 2.20
ENDIF

;욕정의 구슬が不足
SIF JUEL:5 < A
	I |= 1

;가학쾌락경험が不足
SIF EXP:33 < B
	I |= 2

;이상경험が不足
SIF EXP:50 < C
	I |= 2

;욕망が새드끼＋1レベルでないといけない
SIF ABL:11 < ABL:20 + 1
	I |= 4

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF

