;봉사정신のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;봉사정신のLvUP
;-------------------------------------------------
@ABLUP16
DRAWLINE
;PRINTL 노예의 봉사정신을 올립니다
;PRINTL 봉사정신이 올라가면, 성적인 봉사에 기쁨을 느끼게 됩니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;봉사정신はLv5が上限
;[愛][망신][헌신적]が付いている場合はLv10まで해방
;[섹프]で7まで해방。
IF ABL:16 >= 5 && (TALENT:63 == 0 && TALENT:85 == 0 && TALENT:86 == 0 && TALENT:90 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:16 >= 7 && (TALENT:63 == 0 && TALENT:85 == 0 && TALENT:86 == 0)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:16 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要な屈服의 구슬
A = 0
;必要な온순의 구슬
B = 0
;必要な습득의 구슬
C = 0
;必要な봉사쾌락경험回数
D = 0
;必要な절정경험＆정액경험回数
E = 0
;必要な이상경험回数
F = 0

;条件別にOKかダメかを記録する
;屈服의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足, I&4:能力不足)
I = 0
;온순의 구슬による可否(J=0:可, J&1:珠不足, J&2:経験不足, J&4:能力不足, J=256:そのレベルでは自動不可)
J = 0
;습득의 구슬による可否(K=0:可, K&1:珠不足, K&2:経験不足, K&4:能力不足, K=256:そのレベルでは自動不可)
K = 0

CALL DECIDE_ABLUP16

;従順が봉사정신＋1レベルでないといけない
PRINTFORML %ABLNAME:10%{ABL:16+1}LV이상 (현재{ABL:10}LV) 그리고

;LV3から4, 4から5に上げるときは이상경험必要(素質: [망신]なら無視できる)
SIF F > 0
	PRINTFORML %EXPNAME:50%{F}이상 (현재{EXP:50}) 그리고

;屈服의 구슬で上げる
PRINTFORM [0] - %PALAMNAME:6%의 구슬×{JUEL:6}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족 
ENDIF
PRINTL 
IF E > 0
	PRINTFORML 　　　%EXPNAME:2%　{EXP:2}/{E}
	PRINTFORML 　　　%EXPNAME:20%　{EXP:20}/{E}
ENDIF

IF B > 0
	;온순의 구슬で上げる
	PRINTFORM [1] - %PALAMNAME:4%의 구슬×{JUEL:4}/{B} ……
	IF J == 0
		PRINT OK
	ELSE
		SIF J & 1
			PRINT 구슬부족 
		SIF J & 2
			PRINT 경험부족 
		SIF J & 4
			PRINT 능력부족 
	ENDIF
	PRINTL 
	SIF D > 0
		PRINTFORML 　　　%EXPNAME:21%　{EXP:21}/{D}
ENDIF

IF C > 0
	;습득의 구슬で上げる
	PRINTFORM [2] - %PALAMNAME:7%의 구슬×{JUEL:7}/{C} ……
	IF K == 0
		PRINT OK
	ELSE
		SIF K & 1
			PRINT 구슬부족 
		SIF K & 2
			PRINT 경험부족 
		SIF K & 4
			PRINT 능력부족 
	ENDIF
	PRINTL 
	PRINTFORML 　　　%EXPNAME:2%　{EXP:2}/1
ENDIF

PRINTL [100] - 그만둔다

$INPUT_LOOP
INPUT
IF (RESULT < 0 || RESULT > 2) && RESULT != 100
	GOTO INPUT_LOOP
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	GOTO INPUT_LOOP
ELSEIF J == 256 && RESULT == 1
	GOTO INPUT_LOOP
ELSEIF J != 0 && RESULT == 1
	PRINTL 조건을 만족하지 않았습니다
	GOTO INPUT_LOOP
ELSEIF K == 256 && RESULT == 2
	GOTO INPUT_LOOP
ELSEIF K != 0 && RESULT == 2
	PRINTL 조건을 만족하지 않았습니다
	GOTO INPUT_LOOP
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:16 += 1

IF RESULT == 0
	JUEL:6 -= A
ELSEIF RESULT == 1
	JUEL:4 -= B
ELSEIF RESULT == 2
	JUEL:7 -= C
ENDIF

PRINTFORML %ABLNAME:16%의 레벨이 %조사처리(ABL:16,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;봉사정신のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP16
SIF ABL:16 >= 10
	RETURN 0
SIF ABL:16 >= 5 && (TALENT:63 == 0 && TALENT:85 == 0 && TALENT:86 == 0 && TALENT:90 == 0)
	RETURN 0
SIF ABL:16 >= 7 && (TALENT:63 == 0 && TALENT:85 == 0 && TALENT:86 == 0)
	RETURN 0

;判定変数を空に
I = 0
J = 0
K = 0

A = 0
B = 0
C = 0
D = 0
E = 0
F = 0



IF ABL:16 == 0
	A = 100
	B = 20
	C = 100
	D = 1
	E = 1
ELSEIF ABL:16 == 1
	A = 1200
	B = 400
	C = 2000
	D = 1
	E = 3
ELSEIF ABL:16 == 2
	A = 5000
	B = 2000
	C = 10000
	D = 20
	E = 6
ELSEIF ABL:16 == 3
	A = 10000
	B = 3000
	C = 0
	D = 20
	E = 10
ELSEIF ABL:16 == 4
	A = 30000
	B = 10000
	C = 0
	D = 100
	E = 20
ELSEIF ABL:16 == 5
	A = 50000
	B = 20000
	C = 0
	D = 200
	E = 80
ELSEIF ABL:16 == 6
	A = 70000
	B = 30000
	C = 0
	D = 350
	E = 150
ELSEIF ABL:16 == 7
	A = 100000
	B = 50000
	C = 0
	D = 500
	E = 200
ELSEIF ABL:16 == 8
	A = 150000
	B = 80000
	C = 0
	D = 700
	E = 400
ELSEIF ABL:16 == 9
	A = 200000
	B = 150000
	C = 0
	D = 1000
	E = 800
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:16 == 3
		TIMES A , 1.50
		TIMES B , 1.50
		TIMES D , 1.50
		TIMES E , 1.50
	ELSEIF ABL:16 == 4
		TIMES A , 2.00
		TIMES B , 2.00
		TIMES D , 2.00
		TIMES E , 2.00
	ELSEIF ABL:16 == 5
		TIMES A , 2.50
		TIMES B , 2.50
		TIMES D , 2.50
		TIMES E , 2.50
	ELSEIF ABL:16 >= 6
		TIMES A , 3.00
		TIMES B , 3.00
		TIMES D , 3.00
		TIMES E , 3.00
	ENDIF
ENDIF

;LV3以上に上げるときは이상경험必要(素質: [헌신적][愛][망신]なら無視できる)
IF ABL:16 >= 3 && (TALENT:63 == 0 && TALENT:85 == 0 && TALENT:86 == 0)
	F = ABL:16 - 2
ENDIF

;反抗的
IF TALENT:11
	TIMES A , 1.20
	TIMES B , 1.40
	TIMES D , 1.20
	TIMES E , 1.20
ENDIF

;다부짐
IF TALENT:12
	TIMES A , 1.20
	TIMES D , 1.20
ENDIF

;솔직함
IF TALENT:13
	TIMES A , 0.90
	TIMES B , 0.80
	TIMES C , 0.80
	TIMES D , 0.70
ENDIF

;건방짐
IF TALENT:16
	TIMES A , 1.10
	TIMES B , 1.10
ENDIF

;프라이드 높음
IF TALENT:15
	TIMES A , 1.40
	TIMES B , 1.30
	TIMES D , 1.20
	TIMES E , 1.20
;프라이드 낮음
ELSEIF TALENT:17
	TIMES A , 0.90
	TIMES B , 0.80
	TIMES D , 0.80
	TIMES E , 0.80
ENDIF

;영원한 사랑
IF TALENT:430
	TIMES A , 0.20
	TIMES B , 0.20
	TIMES D , 0.20
	TIMES E , 0.20
ENDIF
;女神
IF TALENT:511
	TIMES B , 0.10
	TIMES D , 0.10
ENDIF
;자제심
IF TALENT:20
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES D , 1.20
	TIMES E , 1.20
ENDIF

;무관심
IF TALENT:21
	TIMES A , 1.10
	TIMES B , 1.10
	TIMES D , 1.20
	TIMES E , 1.10
ENDIF

;감정부족
IF TALENT:22
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES D , 1.40
	TIMES E , 1.20
ENDIF

;보수적
IF TALENT:24
	TIMES A , 1.30
	TIMES B , 1.30
	TIMES C , 1.30
	TIMES D , 1.20
	TIMES E , 1.20
ENDIF

;포지티브
IF TALENT:25
	TIMES A , 0.90
	TIMES B , 0.80
	TIMES D , 0.70
	TIMES E , 0.75
;悲観的
ELSEIF TALENT:26
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES D , 0.80
	TIMES E , 0.80
ENDIF

;튀고 싶어함
IF TALENT:28
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
	TIMES D , 0.90
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.10
	TIMES B , 1.10
	TIMES D , 2.50
	TIMES E , 3.00
;해방
ELSEIF TALENT:33
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES D , 0.70
	TIMES E , 0.60
ENDIF

;저항
IF TALENT:34
	TIMES A , 1.50
	TIMES B , 1.50
	TIMES C , 1.50
	TIMES D , 2.00
	TIMES E , 2.00
ENDIF

;약점
IF TALENT:37
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
	TIMES D , 0.50
	TIMES E , 0.50
ENDIF

;習得早い
SIF TALENT:50
	TIMES C , 0.80

;습득느림
SIF TALENT:51
	TIMES C , 1.60

;혀놀림
SIF TALENT:52
	TIMES C , 0.80

;헌신적
IF TALENT:63
	TIMES A , 0.80
	TIMES B , 0.70
	TIMES D , 0.60
	TIMES E , 0.80
ENDIF

;쾌감에 솔직
IF TALENT:70
	TIMES E , 0.70
;쾌감을 부정
ELSEIF TALENT:71
	TIMES E , 3.00
ENDIF

;즉각함락
IF TALENT:73
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES D , 0.50
	TIMES E , 0.50
ENDIF

;도착적
IF TALENT:80
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
	TIMES D , 0.75
	TIMES E , 0.75
ENDIF

;새드
IF TALENT:83
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES D , 1.50
ENDIF

;愛
IF TALENT:85
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
	TIMES D , 0.75
ENDIF
;여동생
IF TALENT:320
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
	TIMES D , 0.80
ENDIF
;소꿉친구
IF TALENT:319
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
	TIMES D , 0.80
ENDIF
;언니
IF TALENT:324
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
	TIMES D , 0.80
ENDIF
;야마토 나데시코
IF TALENT:209
	TIMES A , 0.60
	TIMES B , 0.60
	TIMES C , 0.60
	TIMES D , 0.60
ENDIF
;망신
IF TALENT:86
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
	TIMES D , 0.50
	TIMES E , 0.50
ENDIF

;소악마
IF TALENT:87
	TIMES A , 1.10
	TIMES B , 1.10
	TIMES D , 1.20
	TIMES E , 0.80
ENDIF

;광기
IF TALENT:123
	TIMES A , 2.50
	TIMES B , 3.00
	TIMES C , 1.50
	TIMES D , 0.80
	TIMES E , 0.50
ENDIF

;붕괴
IF TALENT:9
	TIMES A , 2.50
	TIMES B , 2.50
	TIMES C , 2.50
	TIMES D , 0.50
	TIMES E , 0.50
ENDIF

;매니저
IF TALENT:202
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES D , 0.80
	TIMES E , 0.80
ENDIF

;最低でも1回・1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1
SIF D < 1
	D = 1
SIF E < 1
	E = 1

;屈服의 구슬は足りている?
SIF JUEL:6 < A
	I |= 1

;온순의 구슬は足りている?
IF B > 0
	SIF JUEL:4 < B
		J |= 1
	;この場合봉사쾌락경험が必要なことあり
	SIF EXP:21 < D
		J |= 2
ELSE
	J = 256
ENDIF

;습득의 구슬は足りている?
IF C > 0
	SIF JUEL:7 < C
		K |= 1
	;この場合절정경험が1以上必要
	SIF EXP:2 < 1
		K |= 2
ELSE
	K = 256
ENDIF

;절정경험が必要な場合
SIF EXP:2 < E
	I |= 2
;정액경험が必要な場合
SIF EXP:20 < E
	I |= 2

;従順が봉사정신＋1レベルでないと能力不足
IF ABL:10 < ABL:16 + 1
	I |= 4
	J |= 4
	K |= 4
ENDIF

;이상경험が不足
IF F > EXP:50
	I |= 2
	J |= 2
	K |= 2
ENDIF

IF I == 0 || J == 0 || K == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
