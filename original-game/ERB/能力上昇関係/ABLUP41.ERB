;촉수中毒のLvUP処理とその可否判定
;eraIm@s_ver.0.17βdのスクリプトをベースに処理を簡略化

;-------------------------------------------------
;촉수中毒のLvUP
;-------------------------------------------------
@ABLUP41
DRAWLINE
;PRINTL 奴隷の촉수への執着心を高めます
;PRINTL 촉수中毒が高くなると, 촉수とのセックスや奉仕行為への満足感が深まり, 
;PRINTL 頻繁に촉수相手に性行為をしていないと心が落ち着かなくなります
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;;촉수中毒はLv5が上限
;;[묘판]が付いている場合はLv10まで해방
IF ABL:41 >= 5 && TALENT:137 == 0
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:41 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要な욕정의 구슬
A = 0
;必要な屈服의 구슬
B = 0
;必要な촉수경험
C = 0
;必要な이상경험回数
F = 0

CALL DECIDE_ABLUP41

;上げるときは이상경험必要(素質: [음란][중독되기쉬움][묘판]なら無視できる)
SIF F > 0
	PRINTFORML %EXPNAME:50%{F}이상(현재{EXP:50})그리고 

;욕망が必要。묘판の場合は신뢰
IF TALENT:137
	PRINTFORML %ABLNAME:10%{ABL:41 + 1}LV이상(현재{ABL:10}LV) 그리고 
ELSE
	PRINTFORML %ABLNAME:11%{ABL:41 + 1}LV이상(현재{ABL:11}LV) 그리고 
ENDIF
PRINTFORM [0] - %PALAMNAME:5%의 구슬×{JUEL:5}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTFORML 　　　%PALAMNAME:6%의 구슬×{JUEL:6}/{B}
PRINTFORML 　　　%EXPNAME:55%　{EXP:55}/{C}
PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 0) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:41 += 1
IF RESULT == 0
	JUEL:5 -= A
	JUEL:6 -= B
ENDIF

PRINTFORML %ABLNAME:41%의 레벨이 %조사처리(ABL:41,"가")% 되었습니다

RETURN 0

;--------------------------------------------------
;レベルアップに必要な珠計算, レベルアップ予告処理
;--------------------------------------------------
@DECIDE_ABLUP41
;촉수中毒はLv5が上限
;[묘판]が付いている場合はLv10まで해방
SIF ABL:41 == 10
	RETURN 0
SIF ABL:41 >= 5 && TALENT:137 == 0
	RETURN 0

;条件別にOKかダメかを記録する
I = 0

IF ABL:41 == 0
	A = 2000
	B = 2000
	C = 30
ELSEIF ABL:41 == 1
	A = 5000
	B = 5000
	C = 100
ELSEIF ABL:41 == 2
	A = 10000
	B = 10000
	C = 220
ELSEIF ABL:41 == 3
	A = 20000
	B = 20000
	C = 400
ELSEIF ABL:41 == 4
	A = 30000
	B = 30000
	C = 800
ELSEIF ABL:41 == 5
	A = 45000
	B = 45000
	C = 1600
ELSEIF ABL:41 == 6
	A = 75000
	B = 75000
	C = 2000
ELSEIF ABL:41 == 7
	A = 100000
	B = 100000
	C = 2800
ELSEIF ABL:41 == 8
	A = 200000
	B = 200000
	C = 4000
ELSEIF ABL:41 == 9
	A = 300000
	B = 300000
	C = 6000
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:37 == 3
		TIMES A , 2.00
		TIMES B , 2.00
		TIMES C , 2.00
	ELSEIF ABL:37 == 4
		TIMES A , 2.50
		TIMES B , 2.50
		TIMES C , 2.50
	ELSEIF ABL:37 >= 5
		TIMES A , 3.00
		TIMES B , 3.00
		TIMES C , 3.00
	ENDIF
ENDIF

F = 0
;2以上に上げるときは이상경험必要(素質: [중독되기쉬움][음란][묘판]なら無視できる)
SIF ABL:41 >= 2 && (TALENT:72 == 0 && TALENT:76 == 0 && TALENT:137 == 0)
		F = ABL:41 + 1

;자제심
IF TALENT:20
	TIMES A , 2.50
	TIMES B , 2.50
	TIMES C , 1.50
ENDIF
;쾌감에 솔직
IF TALENT:70
	TIMES A , 0.75
	TIMES B , 0.75
;쾌감을 부정
ELSEIF TALENT:71
	TIMES A , 1.75
	TIMES B , 1.75
ENDIF
;중독되기쉬움
IF TALENT:72
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;도착적
IF TALENT:80
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
ENDIF
;광기
IF TALENT:123
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;동물귀
IF TALENT:124
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
ENDIF
;묘판
IF TALENT:137
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF

;最低でも1回・1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1
SIF C < 1
	C = 1

;묘판の場合は신뢰で判定
IF TALENT:137
	;신뢰が必要
	SIF ABL:10 < ABL:41 + 1
		I |= 4
	;욕정의 구슬は足りている?
	SIF JUEL:5 < A
		I |= 1
	;屈服의 구슬は足りている?
	SIF JUEL:6 < B
		I |= 1
ELSE
	;욕망が必要
	SIF ABL:11 < ABL:41 + 1
		I |= 4
	;욕정의 구슬は足りている?
	SIF JUEL:5 < A
		I |= 1
	;屈服의 구슬は足りている?
	SIF JUEL:6 < B
		I |= 1
ENDIF
;촉수경험は足りている?
SIF EXP:55 < C
	I |= 2
;이상경험は足りている?
SIF EXP:50 < F
	I |= 2

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF

