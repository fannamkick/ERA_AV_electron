;레즈중독のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;레즈중독のLvUP
;-------------------------------------------------
@ABLUP33
;オトコだとダメ
SIF TALENT:122
	RETURN 0
DRAWLINE
;PRINTL 노예의 레즈행위에 대한 집착도를 올립니다
;PRINTL 레즈중독이 높아지면, 여성끼리의 섹스행위나 봉사행위에 대한 만족감이 깊어져,
;PRINTL 자주 동성의 몸과 맞닿지 않으면 마음이 진정되지 않게 됩니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;레즈중독はLv5が上限
;[음란][바이][도착적][남성혐오]が付いている場合はLv10まで해방
;카나데, 카나, [음마][공주님]も해방
;いつから仕込んであったんだこれ。
IF ABL:33 >= 5 && (TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 && TALENT:505 == 0 && TALENT:407 == 0 && NO:TARGET != 1 && NO:TARGET != 91)
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:33 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
;정액중독＋레즈중독は11以上にならない
;と見せかけて例外がこんなに。[정애미각][도착적][바이][남성불신][암캐][동물좋아함]
ELSEIF ABL:32 + ABL:33 + ABL:40 >= 10 && TALENT:47 == 0 && TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 && TALENT:140 == 0 && TALENT:136 == 0
	PRINTFORMW 정액중독({ABL:32})＋레즈중독({ABL:33})＋수간중독({ABL:40})의 상한은 10입니다
	RETURN 0
ENDIF

;必要な欲情・屈服의 구슬
A = 0
;必要な快C의 구슬
B = 0
;必要な레즈경험回数
C = 0
;必要な이상경험回数
D = 0

;条件別にOKかダメかを記録する
I = 0

CALL DECIDE_ABLUP33

;LV2以上に上げるときは이상경험必要(素質: [도착적][바이][남성혐오][중독되기쉬움][광기]なら無視できる)
SIF D > 0
	PRINTFORML %EXPNAME:50%{D}이상 (현재{EXP:50}) 그리고

;레즈끼が레즈중독＋1レベルでないといけない
PRINTFORML %ABLNAME:22%{ABL:33 + 1}LV이상 (현재{ABL:22}LV) 그리고

PRINTFORM [0] - %PALAMNAME:0%의 구슬×{JUEL:0}/{B} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
	SIF I & 4
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTFORML 　　　%PALAMNAME:5%의 구슬×{JUEL:5}/{A}
PRINTFORML 　　　%PALAMNAME:6%의 구슬×{JUEL:6}/{A}
PRINTFORML 　　　%EXPNAME:40%　{EXP:40}/{C}

PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 0) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:33 += 1

IF RESULT == 0
	JUEL:0 -= B
	JUEL:5 -= A
	JUEL:6 -= A
ENDIF

PRINTFORML %ABLNAME:33%의 레벨이 %조사처리(ABL:33,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;레즈중독のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP33
;オトコだとダメ
SIF TALENT:122
	RETURN 0
;레즈중독はLv5が上限
;[음란][바이][도착적][남성혐오]が付いている場合はLv10まで해방
SIF ABL:33 >= 10
	RETURN 0
SIF ABL:33 >= 5 && (TALENT:76 == 0 && TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 && TALENT:505 == 0 && TALENT:505 == 0 && NO:TARGET != 1 && NO:TARGET != 91)
	RETURN 0
;정액중독＋레즈중독＋수간중독は11以上にならない
SIF ABL:32 + ABL:33 + ABL:40 >= 10 && TALENT:47 == 0 && TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 && TALENT:140 == 0 && TALENT:136 == 0
	RETURN 0

;判定変数を空に
I = 0

A = 0
B = 0
C = 0
D = 0

IF ABL:33 == 0
	A = 1200
	B = 5000
	C = 300
ELSEIF ABL:33 == 1
	A = 3900
	B = 15000
	C = 600
ELSEIF ABL:33 == 2
	A = 6000
	B = 23000
	C = 1000
ELSEIF ABL:33 == 3
	A = 18000
	B = 50000
	C = 1400
ELSEIF ABL:33 == 4
	A = 30000
	B = 70000
	C = 2100
ELSEIF ABL:33 == 5
	A = 55000
	B = 120000
	C = 3000
ELSEIF ABL:33 == 6
	A = 70000
	B = 200000
	C = 4000
ELSEIF ABL:33 == 7
	A = 100000
	B = 350000
	C = 5200
ELSEIF ABL:33 == 8
	A = 150000
	B = 500000
	C = 6500
ELSEIF ABL:33 == 9
	A = 300000
	B = 800000
	C = 8000
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:33 == 3
		TIMES A , 1.50
		TIMES B , 1.50
		TIMES C , 1.50
	ELSEIF ABL:33 == 4
		TIMES A , 2.00
		TIMES B , 2.00
		TIMES C , 2.00
	ELSEIF ABL:33 == 5
		TIMES A , 2.50
		TIMES B , 2.50
		TIMES C , 2.50
	ELSEIF ABL:33 >= 6
		TIMES A , 3.00
		TIMES B , 3.00
		TIMES C , 3.00
	ENDIF
ENDIF

;LV2以上に上げるときは이상경험必要(素質: [중독되기쉬움][도착적][남성혐오][바이][광기]なら無視できる)
SIF ABL:33 >= 2 && ( TALENT:72 == 0 && TALENT:80 == 0 && TALENT:81 == 0 && TALENT:82 == 0 &&TALENT:123 == 0 && TALENT:505 == 0 && TALENT:407 == 0 && NO:TARGET != 1 && NO:TARGET != 91)
	D = ABL:33 - 1

;反抗的
IF TALENT:11
	TIMES A , 1.50
	TIMES B , 1.50
	TIMES C , 1.50
ENDIF
;자제심
IF TALENT:20
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES C , 1.20
ENDIF
;무관심
IF TALENT:21
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES C , 1.20
ENDIF
;보수적
IF TALENT:24
	TIMES A , 1.50
	TIMES B , 1.50
	TIMES C , 1.50
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.20
	TIMES B , 1.20
	TIMES C , 1.20
;해방
ELSEIF TALENT:33
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
ENDIF

;저항
IF TALENT:34
	TIMES A , 2.00
	TIMES B , 2.00
	TIMES C , 2.00
ENDIF
;혀놀림
IF TALENT:52
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF
;악취둔감
IF TALENT:61
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF
;헌신적
IF TALENT:63
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF
;불결무시
IF TALENT:64
	TIMES A , 0.95
	TIMES B , 0.95
	TIMES C , 0.95
ENDIF

;쾌감에 솔직
IF TALENT:70
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
;쾌감을 부정
ELSEIF TALENT:71
	TIMES A , 1.10
	TIMES B , 1.10
	TIMES C , 1.10
ENDIF
;중독되기쉬움
IF TALENT:72
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;즉각함락
IF TALENT:73
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;음란
IF TALENT:76
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
ENDIF

;女嫌い
IF TALENT:79
	TIMES A , 2.00
	TIMES B , 2.00
	TIMES C , 2.00
ENDIF

;도착적
IF TALENT:80
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
ENDIF
;바이
IF TALENT:81
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;남성혐오
IF TALENT:82
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF
;소악마
IF TALENT:87
	TIMES A , 0.90
	TIMES B , 0.90
	TIMES C , 0.90
ENDIF
;광기
IF TALENT:123
	TIMES A , 0.50
	TIMES B , 0.50
	TIMES C , 0.50
ENDIF

;공주님
IF TALENT:407
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.75
ENDIF

;공주님
IF TALENT:76
	TIMES A , 0.70
	TIMES B , 0.70
	TIMES C , 0.70
ENDIF

;색정광
IF TALENT:440
	TIMES A , 0.20
	TIMES B , 0.20
	TIMES C , 0.20
ENDIF

IF NO:TARGET == 1 || NO:TARGET == 91
	TIMES A , 0.75
	TIMES B , 0.75
	TIMES C , 0.50
ENDIF 
;붕괴
IF TALENT:9
	TIMES A , 0.80
	TIMES B , 0.80
	TIMES C , 0.80
ENDIF

IF TALENT:505
	TIMES A , 0.10
	TIMES B , 0.10
	TIMES C , 0.10
	TIMES D , 0.10
ENDIF
;最低でも1回・1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1
SIF C < 1
	C = 1

;이상경험が不足
IF D > EXP:50
		I |= 2
		J |= 2
ENDIF

;레즈끼が레즈중독＋1レベルでないと能力不足
IF ABL:22 < ABL:33 + 1
	I |= 4
	J |= 4
ENDIF

;快C의 구슬が不足
SIF JUEL:0 < B
	I |= 1
;욕정의 구슬が不足
SIF JUEL:5 < A
	I |= 1
;屈服의 구슬が不足
SIF JUEL:6 < A
	I |= 1
;레즈경험が不足
SIF EXP:40 < C
	I |= 2

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
