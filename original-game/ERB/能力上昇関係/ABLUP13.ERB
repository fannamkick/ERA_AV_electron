;봉사기술のLvUP処理とその可否判定
;eraIm@s_ver.0.17βdのスクリプトをベースに処理を簡略化

;-------------------------------------------------
;봉사기술のLvUP
;-------------------------------------------------
@ABLUP13
DRAWLINE
;PRINTL 노예의 봉사기술을 UP시킵니다
;PRINTL 봉사기술이 높아지면, 봉사할 때 상대를 절정시키기 쉬워집니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;봉사정신がLv5以上ある場合はLv10まで해방
IF (ABL:13 >= 5 && ABL:16 < 5) || ABL:13 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要な습득의 구슬
A = 0

;条件別にOKかダメかを記録する
;습득의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足)
I = 0

CALL DECIDE_ABLUP13

;Lv5までは기교が봉사기술+1Lvでないといけない
SIF ABL:13 < 5
	PRINTFORML %ABLNAME:12%{ABL:13 + 1}LV이상 (현재{ABL:12}LV) 그리고
;Lv5からは봉사정신が봉사기술+1Lvでないといけない
SIF ABL:13 >= 5
	PRINTFORML %ABLNAME:16%{ABL:13 + 1}LV이상 (현재{ABL:16}LV) 그리고

PRINTFORM [0] - %PALAMNAME:7%의 구슬×{JUEL:7}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 능력부족 
ENDIF
PRINTL 
PRINTL [100] - 그만둔다

INPUT
IF (RESULT < 0 || RESULT > 0) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:13 += 1
SIF RESULT == 0
	JUEL:7 -= A

PRINTFORML %ABLNAME:13%의 레벨이 %조사처리(ABL:13,"가")% 되었습니다

RETURN 0

;--------------------------------------------------
;봉사기술のLvUP可否判定
;--------------------------------------------------
@DECIDE_ABLUP13
;봉사정신Lv5以上ある場合はLv10まで해방
IF ABL:13 >= 5 && ABL:16 < 5
	RETURN 0
ENDIF

;判定変数を空に
A = 0
I = 0

IF ABL:13 == 0
	A = 5
ELSEIF ABL:13 == 1
	A = 400
ELSEIF ABL:13 == 2
	A = 1000
ELSEIF ABL:13 == 3
	A = 3000
ELSEIF ABL:13 == 4
	A = 6000
ELSEIF ABL:13 == 5
	A = 9000
ELSEIF ABL:13 == 6
	A = 12000
ELSEIF ABL:13 == 7
	A = 16000
ELSEIF ABL:13 == 8
	A = 20000
ELSEIF ABL:13 == 9
	A = 25000
ENDIF

;일선을 넘지않음
IF TALENT:27
	SIF ABL:13 == 3
		TIMES A , 1.50
	SIF ABL:13 == 4
		TIMES A , 2.00
	SIF ABL:13 == 5
		TIMES A , 2.50
	SIF ABL:13 >= 6
		TIMES A , 3.00
ENDIF

;反抗的
IF TALENT:11
	TIMES A , 1.20
ENDIF
;솔직함
IF TALENT:13
	TIMES A , 0.95
ENDIF
;건방짐
IF TALENT:16
	TIMES A , 1.20
ENDIF

;프라이드 높음
IF TALENT:15
	TIMES A , 1.20
;프라이드 낮음
ELSEIF TALENT:17
	TIMES A , 0.95
ENDIF

;무관심
IF TALENT:21
	TIMES A , 1.05
ENDIF
;감정부족
IF TALENT:22
	TIMES A , 1.05
ENDIF
;호기심
IF TALENT:23
	TIMES A , 0.95
ENDIF
;보수적
IF TALENT:24
	TIMES A , 1.10
ENDIF

;억압
IF TALENT:32
	TIMES A , 1.10
;해방
ELSEIF TALENT:33
	TIMES A , 0.90
ENDIF

;저항
IF TALENT:34
	TIMES A , 1.20
ENDIF

;수줍음
IF TALENT:35
	TIMES A , 1.05
;부끄럼 없음
ELSEIF TALENT:36
	TIMES A , 0.95
ENDIF

;약점
IF TALENT:37
	TIMES A , 0.90
ENDIF

;習得早い
IF TALENT:50
	TIMES A , 0.80
;습득느림
ELSEIF TALENT:51
	TIMES A , 1.50
ENDIF

;혀놀림
IF TALENT:52
	TIMES A , 0.90
ENDIF
;헌신적
IF TALENT:63
	TIMES A , 0.90
ENDIF
;영원한 사랑
IF TALENT:430
	TIMES A , 0.40
ENDIF
;불결무시
IF TALENT:64
	TIMES A , 0.90
ENDIF
;즉각함락
IF TALENT:73
	TIMES A , 0.90
ENDIF

;야마토 나데시코
SIF TALENT:209
	TIMES B , 0.90
SIF TALENT:504
	TIMES B , 0.10
;도착적
IF TALENT:80
	TIMES A , 0.95
ENDIF
;새드
IF TALENT:83
	TIMES A , 1.10
ENDIF

;봉사정신
IF ABL:16 < 3
	TIMES A , 1.00
ELSEIF ABL:16 < 6
	TIMES A , 0.95
ELSEIF ABL:16 < 8
	TIMES A , 0.90
ELSEIF ABL:16 < 10
	TIMES A , 0.85
ELSE
	TIMES A , 0.80
ENDIF

IF TALENT:505
	TIMES A , 2.00
ENDIF

;最低でも1個は必要
SIF A < 1
	A = 1

;습득의 구슬は足りている?
SIF JUEL:7 < A
	I |= 1

;Lv5までは기교が봉사기술+1Lvでないといけない
SIF ABL:13 < 5 && ABL:12 < ABL:13 + 1
	I |= 2
;Lv5からは봉사정신が봉사기술+1Lvでないといけない
SIF ABL:13 >= 5 && ABL:16 < ABL:13 + 1
	I |= 2

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF
