;A감각のLvUP処理とその可否判定
;eratohoA ver1,204のスクリプトをベースに処理を簡略化

;-------------------------------------------------
;A감각のLvUP
;-------------------------------------------------
@ABLUP3
DRAWLINE
;PRINTL 애널의 감도를 올립니다
;PRINTL A감각이 높아지면, 애널 섹스와 애널자극으로부터 보다 큰 쾌락을 얻을 수 있습니다
;PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
;最大Lvは5, [애널광]が付いている場合はLv10まで해방
IF ABL:3 >= 5 && TALENT:77 == 0
	PRINTW 이 이상 올리려면 소질이 필요합니다
	RETURN 0
ELSEIF ABL:3 >= 3 && TALENT:2 == 1
	PRINTW 이 이상 올리려면 애널비처녀여야합니다
	RETURN 0
ELSEIF ABL:3 >= 10
	PRINTW 이미 MAX입니다
	RETURN 0
ENDIF

;必要なA감각의 구슬
A = 0
;必要なA경험回数
B = 0


;条件別にOKかダメかを記録する
;A감각의 구슬による可否(I=0:可, I&1:珠不足, I&2:経験不足)
I = 0

CALL DECIDE_ABLUP3

PRINTFORM [0] - %PALAMNAME:2%의 구슬×{JUEL:2}/{A} ……
IF I == 0
	PRINT OK
ELSE
	SIF I & 1
		PRINT 구슬부족 
	SIF I & 2
		PRINT 경험부족 
ENDIF
PRINTL 
PRINTFORML       %EXPNAME:1%　　{EXP:1}/{B}
PRINTL [100] - 그만둔다


INPUT
IF (RESULT < 0 || RESULT > 0) && RESULT != 100
	RESTART
ELSEIF I != 0 && RESULT == 0
	PRINTL 조건을 만족하지 않았습니다
	RESTART
ELSEIF RESULT == 100
	RETURN 0
ENDIF

ABL:3 += 1

IF RESULT == 0
	JUEL:2 -= A
ENDIF

PRINTFORML %ABLNAME:3%의 레벨이 %조사처리(ABL:3,"가")% 되었습니다

RETURN 0

;-------------------------------------------------
;A감각のLvUP可否判定
;-------------------------------------------------
@DECIDE_ABLUP3
;A감각はLv5が上限, [애널광]が付いている場合はLv10まで해방
SIF ABL:3 >= 5 && TALENT:77 == 0
	RETURN 0
SIF ABL:3 >= 3 && TALENT:2 == 1
	RETURN 0
SIF ABL:3 >= 10
	RETURN 0

;判定変数を空に
A = 0
B = 0
I = 0

IF ABL:3 == 0
	A = 1
	B = 2
ELSEIF ABL:3 == 1
	A = 20
	B = 10
ELSEIF ABL:3 == 2
	A = 400
	B = 30
ELSEIF ABL:3 == 3
	A = 8000
	B = 75
ELSEIF ABL:3 == 4
	A = 20000
	B = 150
ELSEIF ABL:3 == 5
	A = 40000
	B = 180
ELSEIF ABL:3 == 6
	A = 60000
	B = 250
ELSEIF ABL:3 == 7
	A = 90000
	B = 350
ELSEIF ABL:3 == 8
	A = 120000
	B = 500
ELSEIF ABL:3 == 9
	A = 180000
	B = 600
ENDIF

;일선을 넘지않음
IF TALENT:27
	IF ABL:3 == 4
		TIMES A , 2.00
		TIMES B , 2.00
	ELSEIF ABL:3 == 5
		TIMES A , 2.50
		TIMES B , 2.50
	ELSEIF ABL:3 >= 6
		TIMES A , 3.00
		TIMES B , 3.00
	ENDIF
ENDIF

;A둔감
IF TALENT:105
	TIMES A , 1.20
	TIMES B , 1.10
ENDIF

;음란
IF TALENT:76
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF

;색정광
IF TALENT:440
	TIMES A , 0.20
	TIMES B , 0.20
ENDIF

;애널광
IF TALENT:77
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF
;A민감
IF TALENT:106
	TIMES A , 0.80
	TIMES B , 0.80
ENDIF
IF TALENT:505
	TIMES A , 0.01
	TIMES B , 0.1
ENDIF

;最低でも1個は必要
SIF A < 1
	A = 1
SIF B < 1
	B = 1

;快A의 구슬は足りている?
SIF JUEL:2 < A
	I |= 1
;A경험は足りているか?
SIF EXP:1 < B
	I |= 2

IF I == 0
	RETURN 1
ELSE
	RETURN 0
ENDIF

