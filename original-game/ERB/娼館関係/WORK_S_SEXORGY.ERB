;===========================================================
;乱交パーティーの処理はここで
;===========================================================
;eraIm@s_ver.0.17βdより流用して改造(pawapokya-)
;===========================================================
@SEX_ORGY
DRAWLINE

REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	;콘돔使用フラグ外す
	CFLAG:COUNT:13 = 0
	;売春時の状況フラグ初期化
	CFLAG:COUNT:50 = 0
	CFLAG:COUNT:51 = 0
	CFLAG:COUNT:52 = 0
	CFLAG:COUNT:53 = 0
REND

;特殊営業のフラグを初期化
FLAG:50 = 0
FLAG:51 = 0
FLAG:52 = 0
FLAG:53 = 0

S = 0
;特別イベント可否のチェック
;全員が자위중독レベル1以上なら자위コンテスト開催可
E = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 && ABL:COUNT:31 == 0
		E = 0
REND
SIF E == 1
	S |= 1
;全員が정액중독レベル1以上で主人がオトコか후타나리なら펠라치오コンテスト開催可
E = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 && ABL:COUNT:32 == 0
		E = 0
REND
SIF TALENT:MASTER:122 == 0 && TALENT:MASTER:121 == 0
	E = 0
SIF E == 1
	S |= 2
;全員が마조끼レベル1以上なら人間競馬開催可
E = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 && ABL:COUNT:21 == 0
		E = 0
REND
SIF E == 1
	S |= 4
;資金が最低でも1000포인트必要
SIF MONEY < 1000
	S = 0

;特別イベントを行うかどうか選択
$INPUT_LOOP_01
IF S
	PRINTL 파티에서 특별 이벤트를 할까요?
	PRINTL  [0] - 하지않는다
	SIF S & 1
		PRINTL  [1] - 자위 콘테스트
	SIF S & 2
		PRINTL  [2] - 펠라치오 콘테스트
	SIF S & 4
		PRINTL  [3] - 인간 경마
	INPUT
	IF RESULT == 0
		PRINTFORMW 통상 난교 파티를 실시합니다
	ELSEIF RESULT == 1 && (S & 1)
		PRINTFORMW 난교 파티 마지막에 자위 콘테스트를 합니다
		FLAG:50 = 1
	ELSEIF RESULT == 2 && (S & 2)
		PRINTFORMW 난교 파티 마지막에 펠라치오 콘테스트를 합니다
		FLAG:50 = 2
	ELSEIF RESULT == 3 && (S & 4)
		PRINTFORMW 난교 파티 마지막에 인간 경마를 합니다
		FLAG:50 = 3
	ELSEIF RESULT == 100
		RETURN 100
	ELSE
		GOTO INPUT_LOOP_01
	ENDIF
	DRAWLINE
ENDIF

;ローカル変数初期化
A = 0
B = 0
C = 0
D = 0
E = 0

;参加する客の人数
G = 0
M = 0
N = 0
O = 0
I = 0
J = 0

S = 0

Q = 0
R = 0
X = 0

;特別イベント勝利者
W = 0
;特別イベントで主人公とペアを組んだキャラ
Y = 0

X = 0
Z = 0

REPEAT 101
	T:COUNT = 0
	U:COUNT = 0
REND

;調教対象と助手を空に
TARGET = -1
ASSI = -1

;特殊営業参加キャラの相性をチェック
CALL WORK_SUB_RELATION

;客の数を計算
;参加するキャラの人気の평균値に応じて客が来ます
E = 0
REPEAT CHARANUM
	SIF CFLAG:COUNT:130
		E += EXP:COUNT:91
REND
E /= FLAG:42
C = E / 5
G = C / 4
IF C
	IF C < 13
		REPEAT C
			G += RAND:2
		REND
	ELSEIF C < 16
		TIMES B , 1.20
		REPEAT C
			G += RAND:2
		REND
	ELSEIF C < 20
		TIMES B , 1.50
		REPEAT C
			G += RAND:2
		REND
	ELSEIF C < 24
		TIMES B , 2.00
		REPEAT C
			G += RAND:2
		REND
	ELSE
		TIMES B , 2.00
		REPEAT C
			G += RAND:3
		REND
	ENDIF
ENDIF

;娼館の人気に応じてさらにプラス
C = (EXP:MASTER:91 / 10)
IF C
	REPEAT C
		G += RAND:2
	REND
ENDIF

;参加者が特定の素質を持っていた場合ボーナス
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	;인기인
	SIF TALENT:COUNT:126
		G += 1
	;娼婦
	SIF TALENT:COUNT:180
		G += 2
	;傾城
	SIF TALENT:COUNT:181
		G += 3
	;아이돌
	SIF TALENT:COUNT:203
		G += 3
	;아가씨
	SIF TALENT:COUNT:205
		G += 3
	;귀족
	SIF TALENT:COUNT:208
		G += 5
REND

;5人以下だった場合, 10人にします
SIF G < 5
	G = 5

;参加人数以下だった場合, 参加人数と同数にします
SIF G < FLAG:42
	G = FLAG:42

PRINTFORMW %NAME:MASTER% 주최 난교 파티를 개최했다……
PRINTFORML 이번 파티에 모인 {G-1}명의 손님들을, 
CALL WORK_SUB_PRINT_FULLNAME
PRINTFORML %조사만처리(RESULT+2,"가")% 맞이하러 나갔다
PRINTL
WAIT

;主人公が동정なら동정상실
IF TALENT:MASTER:1
	TALENT:MASTER:1 = 0
	;初体験の相手(乱交)はここで記録
		CSTR:MASTER:2 = 여자 손님
ENDIF


;特殊営業時メッセージ
CALL WORK_MESSAGE_ORGY_01

REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	TARGET = COUNT

	;口上の判定
	TFLAG:13 = 114
	CALL SELF_KOJO
	;念のため口上用フラグを空に
	TFLAG:13 = 0

	;처녀상실
	IF CFLAG:COUNT:54 == 0 && TALENT:COUNT:0
		IF CFLAG:COUNT:15 == 0
			CFLAG:COUNT:15 = 1
			;初体験の相手(乱交)はここで記録
				TALENT:COUNT:0 = 0
				CFLAG:COUNT:131 += RAND:6
					IF CFLAG:131 == 0 && NO:COUNT != 1
						CSTR:COUNT:0 = %CALLNAME:MASTER%
						CFLAG:COUNT:15 = 1
					ELSEIF CFLAG:131 == 0 && NO:COUNT == 1 && TALENT:COUNT:432 == 0
						CSTR:COUNT:0 = 오빠
						CFLAG:COUNT:15 = 1
					ELSEIF CFLAG:131 == 0 && NO:COUNT == 1 && TALENT:COUNT:432 == 0
						CSTR:COUNT:0 = 형님
						CFLAG:COUNT:15 = 1
					ELSEIF CFLAG:131 == 1
						CSTR:COUNT:0 = 모르는 남자
						CFLAG:COUNT:15 = 2
					ELSEIF CFLAG:131 == 2
						CSTR:COUNT:0 = 모르는 여자
						CFLAG:COUNT:15 = 3
					ELSEIF CFLAG:131 == 3
						CSTR:COUNT:0 = 바이브
						CFLAG:COUNT:15 = 4
					ELSEIF CFLAG:131 == 4
						CSTR:COUNT:0 = 극태 바이브
						CFLAG:COUNT:15 = 5
					ELSE
						CSTR:COUNT:0 = 누군지 모른다
						CFLAG:COUNT:15 = 6
					ENDIF
		ENDIF

	ENDIF
	IF TALENT:COUNT:2 == 1
		TALENT:COUNT:2 = 0
		CFLAG:COUNT:132 += RAND:3 
			IF CFLAG:COUNT:132 == 0 && NO:COUNT != 1
				CSTR:COUNT:3 = %CALLNAME:MASTER%
			ELSEIF CFLAG:COUNT:132 == 0 && NO:COUNT == 1 && TALENT:COUNT:432 == 0
				CSTR:COUNT:3 = 오빠
			ELSEIF CFLAG:COUNT:132 == 0 && NO:COUNT == 1 && TALENT:COUNT:432 == 1
				CSTR:COUNT:3 = 형님
			ELSEIF CFLAG:COUNT:132 == 1
				CSTR:COUNT:3 = 모르는 남자
			ELSEIF CFLAG:COUNT:132 == 2
				CSTR:COUNT:3 = 모르는 여자
			ELSE
				CSTR:COUNT:3 = 누군지 모른다
			ENDIF
	ENDIF
	IF TALENT:COUNT:1 == 1
		TALENT:1 = 0
		CFLAG:COUNT:133 += RAND:3
			IF CFLAG:COUNT:133 == 0
				CSTR:COUNT:2 = 모르는 여자
			ELSEIF CFLAG:COUNT:133 == 1 && TALENT:MASTER:122 == 0
				CSTR:COUNT:2 = %CALLNAME:MASTER%
					IF TALENT:MASTER:0 == 1 && CFLAG:MASTER:15 == 0
						CFLAG:MASTER:15 = 1
						CSTR:MASTER:0 = %CALLNAME:TARGET%
					ENDIF
			ELSE
				CSTR:COUNT:2 = 누군지 모른다
			ENDIF
	ENDIF
	IF CFLAG:COUNT:16 == -1
		CFLAG:COUNT:16 = 0
			CFLAG:COUNT:16 += RAND:8 
				IF CFLAG:COUNT:16 == 0 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%
				ELSEIF CFLAG:COUNT:16 == 0 && NO:COUNT == 1 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 오빠
				ELSEIF CFLAG:COUNT:16 == 0 && NO:COUNT == 1 && TALENT:COUNT:432 == 1
					CSTR:COUNT:1 = 형님
				ELSEIF CFLAG:COUNT:16 == 1
					CSTR:COUNT:1 = 모르는 남자
				ELSEIF CFLAG:COUNT:16 == 2
					CSTR:COUNT:1 = 모르는 여자
				ELSEIF CFLAG:COUNT:16 == 3 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%의 고○
				ELSEIF CFLAG:COUNT:16 == 3 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%의 자○
				ELSEIF CFLAG:COUNT:16 == 3 && TALENT:COUNT:432 == 1 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%의 자지
				ELSEIF CFLAG:COUNT:16 == 3 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0 && NO:COUNT == 1
					CSTR:COUNT:1 = 오빠의 고○
				ELSEIF CFLAG:COUNT:16 == 3 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0 && NO:COUNT == 1
					CSTR:COUNT:1 = 오빠의 자○
				ELSEIF CFLAG:COUNT:16 == 3 && TALENT:COUNT:432 == 1 && NO:COUNT == 1
					CSTR:COUNT:1 = 형님의 자지
				ELSEIF CFLAG:COUNT:16 == 4 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 남자의 고○
				ELSEIF CFLAG:COUNT:16 == 4 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 남자의 자○
				ELSEIF CFLAG:COUNT:16 == 4 && TALENT:COUNT:432 == 1
					CSTR:COUNT:1 = 모르는 남자의 자지
				ELSEIF CFLAG:COUNT:16 == 5 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 여자의 그곳
				ELSEIF CFLAG:COUNT:16 == 5 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 여자의 보지
				ELSEIF CFLAG:COUNT:16 == 5 && TALENT:COUNT:432 == 1
					CSTR:COUNT:1 = 모르는 여자의 보지
				ELSEIF CFLAG:COUNT:16 == 6 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%의 엉덩이 구멍
				ELSEIF CFLAG:COUNT:16 == 6 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%의 애널
				ELSEIF CFLAG:COUNT:16 == 6 && TALENT:COUNT:432 == 1 && NO:COUNT != 1
					CSTR:COUNT:1 = %CALLNAME:MASTER%의 똥구멍
				ELSEIF CFLAG:COUNT:16 == 6 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0 && NO:COUNT == 1
					CSTR:COUNT:1 = 오빠의 엉덩이 구멍
				ELSEIF CFLAG:COUNT:16 == 6 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0 && NO:COUNT == 1
					CSTR:COUNT:1 = 오빠의 애널
				ELSEIF CFLAG:COUNT:16 == 6 && TALENT:COUNT:432 == 1 && NO:COUNT == 1
					CSTR:COUNT:1 = 형님의 똥구멍
				ELSEIF CFLAG:COUNT:16 == 7 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 남자의 엉덩이 구멍
				ELSEIF CFLAG:COUNT:16 == 7 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 남자의 애널
				ELSEIF CFLAG:COUNT:16 == 7 && TALENT:COUNT:432 == 1
					CSTR:COUNT:1 = 모르는 남자의 똥구멍
				ELSEIF CFLAG:COUNT:16 == 8 && TALENT:COUNT:76 == 0 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 여자의 엉덩이 구멍
				ELSEIF CFLAG:COUNT:16 == 8 && TALENT:COUNT:76 == 1 && TALENT:COUNT:432 == 0
					CSTR:COUNT:1 = 모르는 여자의 애널
				ELSEIF CFLAG:COUNT:16 == 8 && TALENT:COUNT:432 == 1
					CSTR:COUNT:1 = 모르는 여자의 똥구멍
				ENDIF
	ENDIF
REND

;特別イベント処理
;자위コンテスト
IF FLAG:50 == 1
	CALL ONANY_CONTEST
;펠라치오コンテスト
ELSEIF FLAG:50 == 2
	CALL FELLATIO_CONTEST
;人間競馬
ELSEIF FLAG:50 == 3
	CALL HUMAN_RACING
ENDIF

;特別イベント口上
IF FLAG:50 != 0
	REPEAT CHARANUM
		SIF CFLAG:COUNT:130 == 0
			CONTINUE
		TARGET = COUNT

		;口上の判定
		TFLAG:13 = 115
		CALL SELF_KOJO
		;念のため口上用フラグを空に
		TFLAG:13 = 0
	REND
ENDIF

PRINTFORMW ……
PRINTFORML 

;成否判定
;客の욕망をチェック, 乱交パーティーでの値は5です
A = 0
B = 0
C = 0

A = 5
;客の욕망Aをキャラの욕망の평균値が上回った場合は二倍, 下回った場合は等倍が加算されます
E = 0
REPEAT CHARANUM
	SIF CFLAG:COUNT:130
		E += ABL:COUNT:11
REND
E /= FLAG:42

IF E >= A 
	B += E * 2
ELSE
	B += E
ENDIF
E = 0

;参加者全員の技能・素質による修正値を加算
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE

	;全員の売春中毒を加算
	B += ABL:COUNT:37

	;성교중독・정액중독は1/2を加算
	B += (ABL:COUNT:30 / 2) + (ABL:COUNT:31 / 2)

	;봉사기술, 성교기술は1/2を加算
	B += (ABL:COUNT:13 / 2) + (ABL:COUNT:14 / 2)

	;各素質に応じて加減
	;처녀だった
	SIF CFLAG:COUNT:50
		B += 10
	;反抗的
	SIF TALENT:COUNT:11
		B -= 3
	;무관심
	SIF TALENT:COUNT:21
		B -= 5
	;감정부족
	SIF TALENT:COUNT:22
		B -= 5
	;억압
	SIF TALENT:COUNT:32
		B -= 3
	;혀놀림
	SIF TALENT:COUNT:52
		B += 1
	;헌신적
	SIF TALENT:COUNT:63
		B += 2
	;쾌감에 솔직
	SIF TALENT:COUNT:70
		B += 3
	;음란
	SIF TALENT:COUNT:76
		B += 10
	;도착적
	SIF TALENT:COUNT:80
		B += 3
	;마조
	SIF TALENT:COUNT:88
		B += 5
	;노출광
	SIF TALENT:COUNT:89
		B += 5
	;매혹
	SIF TALENT:COUNT:91
		B += 2
	;수수께끼의 매력
	SIF TALENT:COUNT:92
		B += 5
	;폭유
	SIF TALENT:COUNT:114
		B += 3
	;거유
	SIF TALENT:COUNT:110
		B += 2
	;빈유をみる
	;작은체형・유치・미숙함があれば逆にボーナス
	IF TALENT:COUNT:109
		IF TALENT:COUNT:100 || TALENT:COUNT:132 || TALENT:COUNT:135
			B += 2
		ELSE
			B -= 2
		ENDIF
	ENDIF
	;절벽をみる
	;유치・미숙함があれば逆にボーナス
	IF TALENT:COUNT:116
		IF TALENT:COUNT:132 || TALENT:COUNT:135
			B += 3
		ELSE
			B -= 3
		ENDIF
	ENDIF
	;인기인
	SIF TALENT:COUNT:126
		B += 3
	;娼婦
	SIF TALENT:COUNT:180
		B += 5
	;傾城
	SIF TALENT:COUNT:181
		B += 10
	;단골손님
	SIF TALENT:COUNT:183
		B += 3
	
	;V使用不可キャラ
	SIF CFLAG:COUNT:54
		B -= 10

	;광기・붕괴があると満足度激減
	SIF TALENT:COUNT:123 || TALENT:COUNT:9
		B /= 5
	
REND
	
C = 30 + A

;合計が目標値C以上なら大成功, C*3/4以上なら成功, 下回れば失敗
IF B >= C
	PRINTFORML 이번 난교 파티에 손님들은 대단히 만족한 것 같다
	A = 4
ELSEIF B >= C * 3 / 4
	PRINTFORML 이번 난교 파티에 손님들은 만족한 것 같다
	A = 2
ELSE
	PRINTFORML 손님들의 욕망을 채울 수 없었던 것 같다……
	A = 1
ENDIF

WAIT

DRAWLINE

PLAYER = TARGET
;パラメータ変化
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	TARGET = COUNT
	PRINTFORML %NAME:TARGET%의 패러미터가 다음과 같이 변화되었습니다

	;参加人数が多ければ一人あたりの負担減
	;V使用回数は人数＋0~5
	T:0 = (G / FLAG:42) + RAND:6
	;V使用不可フラグチェック
	SIF CFLAG:54
		T:0 = 0
		
	;A使用回数は人数＋0~5
	T:1 = (G / FLAG:42) + RAND:6
		
	;フェラ回数は人数＋0~4
	T:22 = (G / FLAG:42) + RAND:5
		
	;정액경험はV＋A＋フェラ回数
	T:20 = T:0 + T:1 + T:22

	;総성교경험はV＋A使用回数
	T:5 = T:0 + T:1

	;부정의 구슬の計算(基礎値は人数ベースで, 従順に応じて減少)
	M = 12 - ABL:10
	;부정의 구슬が増加しないという事はない
	SIF M <= 0
		M = 1
	U:100 = G * M

	;プライドが高いと増える
	SIF TALENT:16
		TIMES U:100 , 1.50
	;무관심だと少なくなる
	SIF TALENT:21
		TIMES U:100 , 0.90
	;감정부족と少なくなる
	SIF TALENT:22
		TIMES U:100 , 0.90
	;튀고 싶어함だと少なくなる
	SIF TALENT:28
		TIMES U:100 , 0.80
	;억압だと増える
	SIF TALENT:32
		TIMES U:100 , 1.20
	;해방だと少なくなる
	SIF TALENT:33
		TIMES U:100 , 0.80
	;수줍음だと増える
	SIF TALENT:35
		TIMES U:100 , 1.10
	;노출광だと一気に少なくなる
	SIF TALENT:89
		TIMES U:100 , 0.50

	;成否に応じてさらに上下
	IF A >= 2
		TIMES U:100 , 0.80
	ELSE
		TIMES U:100 , 1.20
	ENDIF

	;特別イベントをやると増える
	IF FLAG:50 == 1
		TIMES U:100 , 1.20
	ELSEIF FLAG:50 == 2
		TIMES U:100 , 1.20
	ELSEIF FLAG:50 == 3
		TIMES U:100 , 1.50
	ENDIF

	;輪姦によって発生する経験・珠
	X = COUNT
	CALL WORK_SP_SEX_01

	;자위コンテストをやった
	IF FLAG:50 == 1
		T:2 += 3
		T:10 += 3
		T:11 += 3
	;펠라치오コンテストをやった
	ELSEIF FLAG:50 == 2
		T:22 += 1
		T:20 += 2
	;人間競馬をやった
	ELSEIF FLAG:50 == 3
		T:30 += 10 * ABL:21
	ENDIF

	PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

