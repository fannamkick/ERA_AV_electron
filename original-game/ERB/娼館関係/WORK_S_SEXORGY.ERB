$LOOP_RACING

REPEAT CHARANUM
	TARGET = COUNT

	SIF CFLAG:130 == 0
		CONTINUE
	SIF BASE:0 - CFLAG:55 < 100
		CONTINUE

	;判定変数の設定
	E = 20
	;残り체력による修正
	E += (BASE:0 - CFLAG:55) / 200
	;큰체구
	SIF TALENT:99
		E += 5
	;작은체형
	SIF TALENT:100
		E -= 5
	;미숙함
	SIF TALENT:135
		E -= 5
	;主人と組んで主人が작은체형
	SIF TARGET == Y && TALENT:MASTER:100
		E += 5
	;主人と組んで主人が큰체구
	SIF TARGET == Y && TALENT:MASTER:99
		E -= 5
	;反抗的
	SIF TALENT:11
		E -= 5
	;솔직함
	SIF TALENT:13
		E += 5

	;失敗時でも체력は2消耗
	CFLAG:55 += 2
	IF BASE:0 - CFLAG:55 < 100
		CFLAG:53 = -1
		Z += 1
		IF TARGET == Y && FLAG:53
			PRINTFORML 격렬하게 숨을 몰아쉬면서 비틀비틀 앞으로 나아가고 있던 %타겟은()%, 
			PRINTFORMW 결국 %플레이어를()% 태운채로 바닥에 쓰러졌다
			PRINTFORMW 몇번이나 엉덩이를 손바닥으로 때려보았지만, 이제 한 걸음도 갈 수 없는 것 같다
			PRINTFORML 유감이지만, 여기서 리타이어인 것 같다……
			PRINTFORML (남은인원 {FLAG:42-Z}명)
			WAIT
		ELSEIF FLAG:53
			PRINTFORML 손님을 등에 태우고 비틀비틀 나아가고 있던 %타겟은()%, 
			PRINTFORMW 풀썩 바닥에 쓰러져, 숨을 헐떡이며 움직이지 못하게 됐다
			PRINTFORML 유감이지만, 리타이어인 것 같다……
			PRINTFORML (남은인원 {FLAG:42-Z}명)
			WAIT
		ENDIF
		CONTINUE
	ENDIF

	;判定変数Eが乱数(0~99)より小さければ失敗
	SIF E < RAND:100
		CONTINUE

	;체력の消耗
	CFLAG:55 += 10 + RAND:5
	;큰체구
	SIF TALENT:99
		CFLAG:55 -= 5
	;작은체형
	SIF TALENT:100
		CFLAG:55 += 10
	;主人と組んで主人が작은체형
	SIF TARGET == Y && TALENT:MASTER:100
		CFLAG:55 -= 5
	;主人と組んで主人が큰체구
	SIF TARGET == Y && TALENT:MASTER:99
		CFLAG:55 += 10

	;走行距離を加算
	CFLAG:53 += 1

	IF (CFLAG:53 == 10 || CFLAG:53 == 30 || CFLAG:53 == 50 || CFLAG:53 == 70 || CFLAG:53 == 90) && FLAG:53
		IF TARGET == Y
			PRINTFORM %플레이어를()% 등에 태운 %타겟이()%, 
		ELSE
			PRINTFORM 손님을 등에 태운 %타겟이()%, 
		ENDIF
		CALL HUMAN_RACING_ORDER
		PRINTL  반대편 벽에 손을 짚었다
		PRINT (앞으로 
		IF CFLAG:53 == 90
		PRINTL 반 왕복)
		ELSE
		PRINTFORML {4 - (CFLAG:53 / 20)} 왕복 반)
		ENDIF
		WAIT
	ELSEIF (CFLAG:53 == 20 || CFLAG:53 == 40 || CFLAG:53 == 60 || CFLAG:53 == 80) && FLAG:53
		IF TARGET == Y
			PRINTFORM %플레이어를()% 태운 %타겟이()%, 
		ELSE
			PRINTFORM 손님을 등에 태운 %타겟이()%, 
		ENDIF
		CALL HUMAN_RACING_ORDER
		PRINTL  스타트 라인으로 돌아왔다
		PRINTFORML (앞으로 {5 - (CFLAG:53 / 20)} 왕복)
		IF BASE:0 - CFLAG:55 < 1200 && BASE:0 - CFLAG:55 >= 700
			PRINTFORML %타겟은()% 슬슬 숨이 거칠어져, 손발도 휘청휘청하고 있다
		ELSEIF BASE:0 - CFLAG:55 < 700 && BASE:0 - CFLAG:55 >= 300
			PRINTFORML %타겟은()% 얼굴이 새빨개져 숨을 헐떡이면서, 그러면서도 비틀비틀 앞으로 나아가고 있다
		ELSEIF BASE:0 - CFLAG:55 < 300 && BASE:0 - CFLAG:55 >= 100
			PRINTFORML 전신이 땀투성이인 %타겟은()% 거의 바닥에 몸이 닿을듯이, 기력만으로 더듬더듬 나아가고 있다
		ENDIF
		WAIT
	ELSEIF CFLAG:53 >= 100
		IF TARGET == Y
			PRINTFORM %플레이어를()% 태운 %타겟이()%, 
		ELSE
			PRINTFORM 손님을 등에 태운 %타겟이()%, 
		ENDIF
		PRINTL 난교 파티에 모인 손님들의 박수를 받으며, 첫번째로 골인 벽에 터치했다
		WAIT
		BREAK
	ENDIF

	IF BASE:0 - CFLAG:55 < 100
		CFLAG:53 = -1
		Z += 1
		IF TARGET == Y && FLAG:53
			PRINTFORML 격렬하게 숨을 몰아쉬면서 비틀비틀 앞으로 나아가고 있던 %타겟은()%, 
			PRINTFORMW 결국 %플레이어를()% 태운채로 바닥에 쓰러졌다
			PRINTFORMW 몇번이나 엉덩이를 손바닥으로 때려보았지만, 이제 한 걸음도 갈 수 없는 것 같다
			PRINTFORML 유감이지만, 여기서 리타이어인 것 같다……
			PRINTFORML (남은인원 {FLAG:42-Z}명)
			WAIT
		ELSEIF FLAG:53
			PRINTFORML 손님을 등에 태우고 비틀비틀 나아가고 있던 %타겟은()%, 
			PRINTFORMW 풀썩 바닥에 쓰러져, 숨을 헐떡이며 움직이지 못하게 됐다
			PRINTFORML 유감이지만, 리타이어인 것 같다……
			PRINTFORML (남은인원 {FLAG:42-Z}명)
			WAIT
		ENDIF
	ENDIF

REND

;完走者が出たか, あるいは全員リタイアしたかのチェック
E = 0
REPEAT CHARANUM
	TARGET = COUNT
	SIF CFLAG:130 == 0
		CONTINUE
	SIF CFLAG:53 >= 100
		E = TARGET
REND

IF E
	TARGET = E
	PRINTFORMW 《인간경마의 우승자는, %타겟으로(1)% 결정 됐습니다》
	W = TARGET
	CALL HUMAN_RACING_RESULT
	WAIT
	IF Y == TARGET
		PRINTFORML %플레이어와()% %CALLNAME:Y% 페어는 보기좋게 승리해, 
		PRINTFORML 다른 손님이 건 {FLAG:42*1000}포인트는 %CALLNAME:MASTER%의 것이 되었다
		MONEY += FLAG:42*1000
	ELSE
		PRINTFORML 유감이지만, %플레이어와()% %CALLNAME:Y% 페어는 패배했다……
		PRINTFORML %CALLNAME:Y%에게 건 1000포인트는 몰수되어버렸다
		MONEY -= 1000
	ENDIF
	
	WAIT
	
	RETURN 1
ELSEIF Z >= FLAG:42
	PRINTFORML 결과가 나오기 전에, 모든 말이 리타이어해버렸다
	PRINTFORML 《이번 인간 경마는 무승부입니다》
	WAIT
	RETURN 1
ELSE
	GOTO LOOP_RACING
ENDIF

