;===========================================================
;ストリップショー関係の処理はここで
;===========================================================
;eraIm@s_ver.0.17βdのダンスショーより流用して改造(pawapokya-)
;===========================================================
@STRIPTEASE
DRAWLINE

;特殊チケットフラグ初期化
FLAG:50 = 0

;ショーの形式を初期化
FLAG:53 = 0

;夜の場合, 通常ストリップショーか特殊ストリップショーかを選択
PRINTL 어떤 티켓을 판매하시겠습니까?
PRINTL  [0] - 보통티켓
SIF TIME == 1
	PRINTL  [1] - 특수티켓
PRINTL  [100] - 그만둔다
	
$INPUT_LOOP
INPUT

IF RESULT == 0
	PRINTFORMW 보통티켓을 판매합니다
ELSEIF RESULT == 1 && TIME == 1
	PRINTFORMW 특수티켓을 판매합니다。스트립쇼 후에 즐길거리가 있습니다
	FLAG:50 = 1
	;콘돔使用フラグ外す
	CFLAG:13 = 0
ELSEIF RESULT == 100
	RETURN 100
ELSE
	GOTO INPUT_LOOP
ENDIF

DRAWLINE

;ローカル変数初期化
A = 0
B = 0
C = 0
D = 0
E = 0
F = 0

G = 0
H = 0
I = 0
J = 0
N = 0
O = 0
P = 0
Q = 0
R = 0
S = 0
;L = 呼び出し元で代入される参加人数

;COUNT用待避変数
X = 0

REPEAT 101
	T:COUNT = 0
	U:COUNT = 0
REND


;調教対象と助手を空に
TARGET = -1
ASSI = -1
;参加人数が一人の場合はTARGETにそのキャラを代入
IF FLAG:42 == 1
	REPEAT CHARANUM
		SIF CFLAG:COUNT:130
			TARGET = COUNT
	REND
;参加人数が二人の場合は지도자위경험の高い方をTARGETに, もう一人をASSIに代入
ELSEIF FLAG:42 == 2
	REPEAT CHARANUM
		SIF CFLAG:COUNT:130 == 0
			CONTINUE
		IF TARGET == -1
			TARGET = COUNT
		ELSEIF EXP:COUNT:11 > EXP:TARGET:11
			ASSI = TARGET
			TARGET = COUNT
		ELSE
			ASSI = COUNT
		ENDIF
	REND
;参加人数が3人以上の場合は, 最も지도자위경험の高い者をTARGETに代入
ELSEIF FLAG:42 >= 3
	E = -1
	REPEAT CHARANUM
		SIF CFLAG:COUNT:130 == 0
			CONTINUE
		IF E < EXP:COUNT:11
			TARGET = COUNT
			E = EXP:COUNT:11
		ENDIF
	REND
	E = 0
ENDIF

;参加者が2人の場合はキャラ同志の近親チェック
IF FLAG:42 == 2
	PLAYER = ASSI
	TFLAG:14 = 0
	CALL INCEST
ENDIF

;FLAG:53でショーの形式を決定
FLAG:53 = 0
;&1:자위 &2:レズ &4:セックス &8:近親
;参加者2人で近親関係なら近親ショー
SIF FLAG:42 == 2 && ((TALENT:122 || TALENT:121) || (TALENT:ASSI:122 || TALENT:ASSI:121))
	FLAG:53 |= 4
E = 0
;参加者全員が자위중독3以上か자위광なら자위ショー
E = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	SIF ABL:COUNT:31 < 3 && TALENT:COUNT:74 == 0
		E = 0
REND
SIF E
	FLAG:53 |= 1
E = 0
;参加者複数で全員が레즈끼2以上ならレズショー
E = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	SIF ABL:COUNT:22 < 2
		E = 0
REND
SIF E && FLAG:42 >= 2
	FLAG:53 |= 2
E = 0

;特殊営業参加キャラの相性をチェック
CALL WORK_SUB_RELATION

;客の数を計算
;参加するキャラの人気の最大値に応じて客が来ます
E = 0
REPEAT CHARANUM
	SIF E < EXP:COUNT:91 && CFLAG:COUNT:130
		E = EXP:COUNT:91
REND
C = E / 4
G = C / 2
IF C
	IF C < 13
		REPEAT C
			G += RAND:2
		REND
	ELSEIF C < 16
		TIMES G , 1.10
		REPEAT C
			G += RAND:2
		REND
	ELSEIF C < 20
		TIMES G , 1.30
		REPEAT C
			G += RAND:2
		REND
	ELSEIF C < 24
		TIMES G , 1.50
		REPEAT C
			G += RAND:2
		REND
	ELSE
		TIMES G , 2.00
		REPEAT C
			G += RAND:3
		REND
	ENDIF
ENDIF

;娼館の人気に応じてさらにプラス
C = (EXP:MASTER:91 / 5)
IF C
	REPEAT C
		G += RAND:2
	REND
ENDIF

;参加者が特定の素質を持っていた場合ボーナス
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	;社会的ステータスが影響
	;인기인
	SIF TALENT:COUNT:126
		G += 10
	;아이돌
	SIF TALENT:COUNT:203
		G += 5
	;娼婦
	SIF TALENT:COUNT:180
		G += 2
	;傾城
	SIF TALENT:COUNT:181
		G += 3
	;요설스러움
	SIF TALENT:COUNT:182
		G += 2
	;단골손님
	SIF TALENT:COUNT:183
		G += 2
	;求愛
	SIF TALENT:COUNT:184
		G += 1
	;가희
	SIF TALENT:COUNT:185
		G += 5
	;무희
	SIF TALENT:COUNT:186
		G += 15
	;미희
	SIF TALENT:COUNT:187
		G += 10
	;우등생
	SIF TALENT:COUNT:224
		G += 5
	;인기 AV배우
	SIF TALENT:COUNT:401
		G += 3
	;패션모델
	SIF TALENT:COUNT:402
		G += 3
		
	;専用素質(まあ(差別化する必要もあるし)多少はね?)
	;야쿠자의 딸
	SIF TALENT:COUNT:502
		G += 20
	;음마
	SIF TALENT:COUNT:505
		G += 30
	;성우
	SIF TALENT:COUNT:506
		G += 5
	;하루우라레
	SIF TALENT:COUNT:507
		G += 10
	;Colorful Pure Girls
	SIF TALENT:COUNT:509
		G += 15
	;무당
	SIF TALENT:COUNT:510
		G += 25
	;천사
	SIF TALENT:COUNT:511
		G += 25
	;그랜드마스터
	SIF TALENT:COUNT:512
		G += 20
	;야쿠자의 아내
	SIF TALENT:COUNT:516
		G += 15
	;Mermaid girl
	SIF TALENT:COUNT:518
		G += 20
	;FallenFallAngel
	SIF TALENT:COUNT:519
		G += 15
REND

	;警備員の数に応じて観客数の限界が伸びます。500000Pをケチってはいけない(戒め)
	IF G > 50 && FLAG:40 < 10
		IF (50 + (FLAG:40 * 5)) < G
			G = (50 + (FLAG:40 * 5))
		ENDIF
	ENDIF

;通常チケットなら2/3程度の人数になる
SIF FLAG:50 == 0
	G = G * 2 / 3

;10人以下だった場合, 10人にします
SIF G < 10
	G = 10

;次に成功か失敗かの判定を計算
;参加者の지도자위경험の평균値によって基礎値が決定
E = 0
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	E += EXP:COUNT:11
REND
E /= FLAG:42
;지도자위경험によって基礎値が決定
IF E < 10
	D = 0 + RAND:5
ELSEIF E < 20
	D = 1 + RAND:5
ELSEIF E < 30
	D = 2 + RAND:6
ELSEIF E < 40
	D = 4 + RAND:6
ELSEIF E < 50
	D = 7 + RAND:7
ELSEIF E < 75
	D = 10 + RAND:8
ELSEIF E < 100
	D = 13 + RAND:9
ELSEIF E < 150
	D = 16 + RAND:10
ELSEIF E < 200
	D = 20 + RAND:12
ELSEIF E < 300
	D = 25 + RAND:14
ELSEIF E < 500
	D = 30 + RAND:16
ELSEIF E < 1000
	D = 40 + RAND:18
ELSE
	D = 50 + RAND:20
ENDIF
E = 0

;参加者全員の技能・素質による修正値を加算
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE

	;全員の노출벽をプラス
	D += ABL:COUNT:17

	;공개セックスがある場合は全員の성교중독の1/2をプラス
	SIF FLAG:53 & 4
		D += ABL:COUNT:30 / 2
	;レズショーがある場合は全員の레즈중독の1/2をプラス
	SIF FLAG:53 & 2
		D += ABL:COUNT:33 / 2
	;공개자위がある場合は全員の자위중독の1/2をプラス
	SIF FLAG:53 & 1
		D += ABL:COUNT:31 / 2

	;기교と무용기능は1/3をプラス
	D += ABL:COUNT:12 / 3
	D += ABL:COUNT:72 / 3

	;全員の미용감각をプラス
	D += ABL:COUNT:50

	;素質に応じて加減
	;性格的な素質が影響
	;겁쟁이
	SIF TALENT:COUNT:10
		D -= 1
	;얌전함
	SIF TALENT:COUNT:14
		D -= 1
	;프라이드 높음
	SIF TALENT:COUNT:15
		D += 2
	;프라이드 낮음
	SIF TALENT:COUNT:17
		D -= 2
	;감정부족
	SIF TALENT:COUNT:22
		D -= 1
	;호기심
	SIF TALENT:COUNT:23
		D += 1
	;튀고 싶어함
	SIF TALENT:COUNT:28
		D += 3
	;억압
	SIF TALENT:COUNT:32
		D -= 2
	;해방
	SIF TALENT:COUNT:33
		D += 2
	;저항
	SIF TALENT:COUNT:34
		D -= 2
	;수줍음
	SIF TALENT:COUNT:35
		D -= 2
	;부끄럼 없음
	SIF TALENT:COUNT:36
		D += 2
	;자위하기쉬움
	SIF TALENT:COUNT:60
		D += 5
	;쾌감에 솔직
	SIF TALENT:COUNT:70
		D += 3
	;음란
	SIF TALENT:COUNT:76
		D += 10
	;도착적
	SIF TALENT:COUNT:80
		D += 2
	;노출광
	SIF TALENT:COUNT:89
		D += 10
	;수수께끼의 매력
	SIF TALENT:COUNT:92
		D += 15

	;공개セックスがある場合
	IF FLAG:53 & 4
		;섹스광い
		SIF TALENT:COUNT:75
			D += 10
		;性別が同じで바이
		SIF TALENT:COUNT:81 && (TALENT:TARGET:122 == TALENT:ASSI:122)
			D += 5
		;片方が女で女嫌い
		SIF TALENT:COUNT:79 && (TALENT:TARGET:122 == 0 || TALENT:ASSI:122 == 0)
			D -= 3
		;片方が男で남성혐오
		SIF TALENT:COUNT:82 && (TALENT:TARGET:122 || TALENT:ASSI:122)
			D -= 3
	ENDIF

	;レズショーがある場合
	IF FLAG:53 & 2
		;바이
		SIF TALENT:COUNT:81
			D += 5
		;女嫌い
		SIF TALENT:COUNT:79
			D -= 5
	ENDIF

	;공개자위がある場合
	IF FLAG:53 & 1
		;자위하기쉬움
		SIF TALENT:COUNT:60
			D += 2
		;자위광
		SIF TALENT:COUNT:74
			D += 10
	ENDIF

	;비만があると満足度半減
	SIF TALENT:COUNT:115
		D /= 2

	;광기・붕괴があると満足度激減
	SIF TALENT:COUNT:123 || TALENT:COUNT:9
		D /= 5
REND

;相性による修正
IF FLAG:51 >= 200
	TIMES D , 2.00
ELSEIF FLAG:51 >= 150
	TIMES D , 1.50
ELSEIF FLAG:51 >= 120
	TIMES D , 1.20
ELSEIF FLAG:51 < 100
	TIMES D , 0.50
ENDIF

;満足度Dが目標値Pを上回れば成功, 下回れば失敗
;2週目以降は相性値込でなければまず超成功は狙えないでしょう。
IF FLAG:10 > 1
	P = 41 + RAND:10
ELSE
	P = 21 + RAND:5
ENDIF

;特殊チケットの場合は客の目的が目的なのでちょっと下がる
SIF FLAG:50 == 1
	P -= 5

;満足度DがPの50%未満だったら大失敗
IF D < (P / 2)
	A = 0
;P未満だったら小失敗
ELSEIF D < P
	A = 1
;Pの150%未満だったら普通
ELSEIF D < (P * 3) / 2
	A = 2
;Pの200%未満だったら小成功
ELSEIF D < P * 2
	A = 3
;Pの400%未満だったら大成功
ELSEIF D < P * 4
	A = 4
;それ以上だったら超成功
ELSE
	A = 5
ENDIF
Z = 0
Z = A

;成功値が低いと一部のショーは行われない
SIF A < 2
	FLAG:53 -= FLAG:53 & 1
SIF A < 3
	FLAG:53 -= FLAG:53 & 2
SIF A < 4
	FLAG:53 -= FLAG:53 & 4

IF FLAG:42 == 1
	PRINTFORM %NAME:TARGET%
ELSEIF FLAG:42 == 2
	PRINTFORM %타겟과(1)% %NAME:ASSI%
ELSE
	S = 0
	REPEAT CHARANUM
		SIF CFLAG:COUNT:130 == 0
			CONTINUE
		SIF S
			PRINTFORM %LSTR% 
		PRINTFORM %NAME:COUNT%
		LSTR = %조사만처리(NAME:COUNT,"와")%
		S = 1
	REND
ENDIF

IF FLAG:53 & 8
	IF TFLAG:14 == 2 && TALENT:PLAYER:122 == 0 && TALENT:ASSI:122 == 0
		PRINT 에 의한 모녀 
	ELSEIF TFLAG:14 == 2 && TALENT:122 == 0 && TALENT:ASSI:122
		PRINT 에 의한 모자 
	ELSEIF TFLAG:14 == 4 && TALENT:PLAYER:122 == 0 && TALENT:ASSI:122 == 0
		PRINT 에 의한 자매 
	ELSEIF TFLAG:14 == 4 && TALENT:122 == 0 && TALENT:ASSI:122
		PRINT 에 의한 남매 
	ELSEIF TFLAG:14 == 4 && TALENT:122 && TALENT:ASSI:122 == 0
		PRINT 에 의한 남매 
	ELSE
		PRINT 에 의한 근친 
	ENDIF
ELSE
	PRINT 의 
ENDIF
IF FLAG:53 & 4
	PRINT 공개섹스
ELSEIF FLAG:53 & 2
	PRINT 레즈비언
ELSEIF FLAG:53 & 1
	PRINT 공개자위
ELSE
	PRINT 스트립
ENDIF
PRINTL 쇼를 열었다……
PRINTFORML 이번의 스트립쇼에는 {G}명의 관객이 모였다
WAIT

;通常ストリップ
PRINT 스포트라이트를 받으며, 
CALL WORK_SUB_PRINT_MEMBER
PRINTFORML %조사만처리(RESULT+2,"는")% 관객에게 나체를 보이고 있다……

WAIT

;공개자위
IF FLAG:53 & 1
	PRINT 그리고
	CALL WORK_SUB_PRINT_MEMBER
	PRINTFORML %조사만처리(RESULT+2,"는")% 객석을 향해서 다리를 벌려 비소를 드러내고, 
	PRINTL 음란한 소리를내며 성기를 만지기 시작했다……
	WAIT
	;近親자위ショー
	IF FLAG:53 & 8
		PRINT 무수한 눈이 지켜보는 가운데 늘어서서 자위를 계속하고 있는 
		IF TFLAG:14 == 2
			SIF TALENT:122
				PRINT 부
			SIF TALENT:122 == 0
				PRINT 모
			SIF TALENT:ASSI:122
				PRINT 자
			SIF TALENT:ASSI:122 == 0
				PRINT 녀
		ELSEIF TFLAG:14 == 4
			SIF TALENT:122 && TALENT:ASSI:122
				PRINT 형제
			SIF TALENT:122 == 0 && TALENT:ASSI:122 == 0
				PRINT 자매
			SIF TALENT:122 ^^ TALENT:ASSI:122
				PRINT 남매
		ENDIF
		PRINTL 에게, 
		PRINTL 객석에서 추잡한 야유가 터졌다……
		WAIT
	ENDIF
ENDIF

;レズショー
IF FLAG:53 & 2
	PRINT 이윽고 
	CALL WORK_SUB_PRINT_MEMBER
	PRINTFORML %조사만처리(RESULT+2,"는")% 서로의 나체를 음란하게 얽기 시작했다……
	WAIT
	;近親レズビアンショー
	IF FLAG:53 & 8
		IF TFLAG:14 == 2
			PRINTL M자로 벌려진 모친의 가랑이에 얼굴을 묻고, 
			PRINT 자신이 태어났던 장소에 혀로 핥는 
			IF TALENT:ASSI:135
				PRINT 어린 소녀
			ELSEIF TALENT:ASSI:132
				PRINT 소녀
			ELSE
				PRINT 딸
			ENDIF
		ELSEIF TFLAG:14 == 4
			PRINT 식스나인 자세가 되어 상대의 성기를 핥는 언니와 여동생
		ENDIF
		PRINTL 의 모습을, 
		PRINTL 관객은 가만히 지켜보고 있다……
		WAIT
	ENDIF
ENDIF

;공개セックス
IF FLAG:53 & 4
	E = 0
	PRINTW 본방이 시작됐다……
	;TARGETとASSI双方が후타나리でV使用可
	IF TALENT:TARGET:121 && CFLAG:TARGET:54 == 0 && TALENT:ASSI:121 && CFLAG:ASSI:54 == 0
		PRINTFORM %타겟과()% %조수는()%
		PRINTFORMW 서로의 페니스로 서로의 바기나를 교대로 꿰뚫었다
		SIF TALENT:0
			E |= 1
		SIF TALENT:1
			E |= 2
		SIF TALENT:ASSI:0
			E |= 4
		SIF TALENT:ASSI:1
			E |= 8
		;助手→奴隷の임신フラグを加算
		SIF CFLAG:13 == 0
			CFLAG:103 += G / 10 + 1
		;奴隷→助手の임신フラグを加算
		SIF CFLAG:13 == 0
			CFLAG:104 += G / 10 + 1
	;TARGETがオトコor후타나리でASSIがV使用可
	ELSEIF (TALENT:TARGET:122 || TALENT:TARGET:121) && CFLAG:ASSI:54 == 0
		PRINTFORM %타겟은()% 발기한 자신의 페니스를
		PRINTFORMW %CALLNAME:ASSI%의 음순에 넣다뺐다 하는 모습을 관객에게 보여주었다
		SIF TALENT:1
			E |= 2
		SIF TALENT:ASSI:0
			E |= 4
		;奴隷→助手の임신フラグを加算
		SIF CFLAG:13 == 0
			CFLAG:104 += G / 10 + 1
	;ASSIがオトコor후타나리でTARGETがV使用可
	ELSEIF  (TALENT:ASSI:122 || TALENT:ASSI:121) && CFLAG:54 == 0
		PRINTFORM %타겟은()% 자신의 바기나가
		PRINTFORMW %CALLNAME:ASSI%의 음경으로 꿰뚫리는 모습을 관객에게 보여주었다
		SIF TALENT:0
			E |= 1
		SIF TALENT:ASSI:1
			E |= 8
		;助手→奴隷の임신フラグを加算
		SIF CFLAG:13 == 0
			CFLAG:103 += G / 10 + 1
	ENDIF

	;近親相姦ショー
	IF FLAG:53 & 8 
		IF TFLAG:14 == 2 && TALENT:ASSI:122 == 0
			PRINT 자신의 딸
		ELSEIF TFLAG:14 == 2 && TALENT:ASSI:122
			PRINT 자신의 아들
		ELSEIF TFLAG:14 == 4 && TALENT:ASSI:122 == 0
			PRINT 자신의 여동생
		ELSEIF TFLAG:14 == 4 && TALENT:ASSI:122
			PRINT 자신의 남동생
		ENDIF
		IF TALENT:121 && CFLAG:54 == 0 && TALENT:ASSI:121 && CFLAG:ASSI:54 == 0
			PRINT 과 서로 범하는 
		ELSEIF (TALENT:122 || TALENT:121) && CFLAG:ASSI:54 == 0
			PRINT 을 계속 범하는
		ELSEIF (TALENT:ASSI:122 || TALENT:ASSI:121) && CFLAG:54 == 0
			PRINT 에게 계속 범해지는 
		ENDIF
		IF TFLAG:14 == 2 && TALENT:122
			PRINT 부친
		ELSEIF TFLAG:14 == 2 && TALENT:122 == 0
			PRINT 모친
		ELSEIF TFLAG:14 == 4 && TALENT:122 && TALENT:ASSI:122 == 0
			PRINT 오빠
