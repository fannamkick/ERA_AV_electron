	;처녀ではなく, 노출벽4以上, 성교중독2以上
	IF TALENT:0 == 0 && ABL:30 >= 2 && ABL:17 >= 4
		CUSTOMDRAWLINE ‥
		PRINTFORM 해도 수평선 너머로 저물고 있지만, 
		PRINTFORML %타겟은()% 돌아가려 하질 않았다……
		PRINTFORM 거기다 인적이 드문 바위틈에 숨어들고는 
		PRINTFORMW 지금 바로 안아달라고 보채고 있다……
		PRINTL 
		;口上22番使用
		TFLAG:13 = 22
		CALL SELF_KOJO
		PRINTL 
		PRINTFORML %플레이어는()% 별이 빛나는 밤하늘 아래에서, %타겟과()% 밤새 사랑을 나눴다……
		N = 0
		N = ((ABL:11 + ABL:30) * 5) + RAND:5
		IF TALENT:440 == 1
			TIMES N , 1.80
		ELSEIF TALENT:440 == 1
			TIMES N , 1.50
		ENDIF
		N /= 10
		PRINTFORML 성교경험 +{N}
		EXP:5 += N
		PRINTFORML V경험 +{N + RAND:51}
		EXP:0 += N * ABL:2 / 2
		PRINTFORML 절정경험 +{N - RAND:11}
		EXP:2 += N / 4
		PRINTFORML 야외노출경험 +{N / 3}
		EXP:12 += N * ABL:17 / 10
		IF (TALENT:MASTER:121 == 1 || TALENT:MASTER:122 == 1)
			PRINTFORML 정액경험 +{N / 5}
			EXP:20 += N * ABL:32 / 5
		ENDIF
		PRINTFORML 봉사쾌락경험 +{N * 2}
		EXP:21 += N * ABL:16 / 5
		IF (TALENT:MASTER:121 == 1 || TALENT:MASTER:122 == 1)
			PRINTFORML 펠라경험 +{N / 3}
			EXP:22 += N * ABL:13 / 3
		ENDIF

		PRINTFORML 애정경험 +{N / 3}
		EXP:23 += N * ABL:10 / 2
		IF CFLAG:16 == -1
			CFLAG:16 = 1
			IF NO:TARGET != 1
				CSTR:1 = %CALLNAME:MASTER%
			ELSEIF (NO:TARGET == 1 || NO:TARGET == 91) && TALENT:11 == 0
				CSTR:1 = 오빠
			ELSEIF (NO:TARGET == 1 || NO:TARGET == 91) && TALENT:11 == 1
				CSTR:1 = 형님
			ENDIF
			CFLAG:820 = BASE:9
			CFLAG:821 = DAY:1
			CFLAG:822 = DAY:2
			;4は海
			CFLAG:823 = 4
			SETCOLOR 0xDDBBCC
				PRINTFORML 【첫 키스】
			RESETCOLOR
		ENDIF
		IF CFLAG:MASTER:16 == -1
			CFLAG:MASTER:16 = 1
			CSTR:MASTER:1 = %NAME:TARGET%
			CFLAG:MASTER:820 = BASE:PLAYER:9
			CFLAG:MASTER:821 = DAY:1
			CFLAG:MASTER:822 = DAY:2
			CFLAG:MASTER:823 = 4
			SETCOLOR 0xDDBBCC
				PRINTFORML 【첫 키스】(%CALLNAME:MASTER%)
			RESETCOLOR
		ENDIF
		IF TALENT:MASTER:1 == 1 && (TALENT:MASTER:121 == 1 || TALENT:MASTER:122 == 1)
			TALENT:MASTER:1 = 0
			CSTR:MASTER:2 = %NAME:TARGET%
			SETCOLOR 0xDDBBCC
				PRINTFORML 【동정상실】(%CALLNAME:MASTER%)
			RESETCOLOR
			CFLAG:MASTER:18 = 1
		ENDIF
	ENDIF

PRINTFORML 
PRINTFORMW %플레이어와()% 함께 보낸 여름의 추억을, %타겟은()% 가슴 깊이 새겼다……
IF CFLAG:155 == 0
	CFLAG:155 = 1
ENDIF
IF TFLAG:130 == 1 || RAND:11 >= 8
	PRINTFORML 《여름 바다를 만끽한 %타겟은()% 완전히 피부가 타버렸다……》
	TALENT:422 = 1
	CFLAG:614 = 4 + RAND:4
ENDIF

RETURN 1

