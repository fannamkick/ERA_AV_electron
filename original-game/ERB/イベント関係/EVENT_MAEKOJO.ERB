@MAEKOJO_LESPLAY,ARG,ARG:1

LOCAL = ARG
LOCAL:1 = ARG:1

;特殊処理: 
;레이첼, MIIは常に丁寧語
;카나데がMASTERを呼ぶときのいつもの処理

CHKFONT "あくびん"
	IF RESULT
		SETFONT "あくびん"
	ENDIF	
SETCOLOR 0xDDBBCC

PRINTFORM 「츕, 응…… 하앗, 안돼
	IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
		PRINTFORM 요…… 
	ELSE
		PRINTFORM …… 
	ENDIF
PRINTFORM 옆방에서 
	IF TALENT:LOCAL:504 == 1
		PRINTFORM 마스터가 
	ELSEIF NO:LOCAL == 1 && TALENT:LOCAL:432 == 0 && NO:MASTER == 0
		PRINTFORM 오빠가 
	ELSEIF (NO:LOCAL == 1 || NO:LOCAL == 91) && TALENT:LOCAL:432 == 1 && NO:MASTER == 0
		PRINTFORM 형님이 
	ELSE
		PRINTFORM 그 사람이 
	ENDIF
PRINTFORML 자고 있는데……」
PRINTFORM 「응……『%CALLNAME:LOCAL%
	IF (BASE:LOCAL:9 > BASE:(LOCAL:1):9) || NO:(LOCAL:1) == 9 || NO:(LOCAL:1) == 17
		PRINTFORM 씨
	ELSE
		PRINTFORM 짱
	ENDIF
PRINTFORML 하고 같이 목욕했을 때부터 참을 수가 없었다』니……
PRINTFORM 　참, %CALLNAME:(LOCAL:1)%
	IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
		PRINTFORM 씨는 
	ELSE
		PRINTFORM 짱은 
	ENDIF
PRINTFORM 너무 야하
	IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
		PRINTFORM 다니까요
	ELSE
		PRINTFORM 다니까
	ENDIF
PRINTFORML 」

IF TALENT:(LOCAL:1):121 == 1
	PRINTFORM 「꺅…… %CALLNAME:(LOCAL:1)%
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 씨
		ELSE
			PRINTFORM 짱
		ENDIF
	PRINTFORM 의 %CSTR:LOCAL:80%, 잠옷 너머로도 
		IF TALENT:LOCAL:76 == 1 && TALENT:LOCAL:432 == 0
			PRINTFORM 단단해진 
		ELSEIF TALENT:LOCAL:432 == 1
			PRINTFORM 발기한 
		ELSE
			PRINTFORM 커진 
		ENDIF
	PRINTFORML 게 보여……」
ENDIF
PRINTFORM 「그치만…… 사실 %CSTR:LOCAL:9%도 이제 더 이상 참을 수 없어
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 요
		ELSE
			PRINTFORM 
		ENDIF
PRINTFORML 
PRINTFORM 　그러니까……
	IF TALENT:LOCAL:504 == 1
		PRINTFORM 마스터
	ELSEIF NO:LOCAL == 1 && TALENT:LOCAL:432 == 0 && NO:MASTER == 0
		PRINTFORM 오빠
	ELSEIF (NO:LOCAL == 1 || NO:LOCAL == 91) && TALENT:LOCAL:432 == 1 && NO:MASTER == 0
		PRINTFORM 형님
	ELSE
		PRINTFORM 그 사람
	ENDIF
PRINTFORM 도 이제 잤을테니까…… 둘이서 기분좋아
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 져요
		ELSE
			PRINTFORM 지자
		ENDIF
PRINTFORML 」
PRINTFORM 「아……앙, %CALLNAME:(LOCAL:1)%
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 씨
		ELSE
			PRINTFORM 짱
		ENDIF
PRINTFORM 의 
	IF TALENT:(LOCAL:1):121 == 1
		PRINTFORM %CSTR:LOCAL:80%
	ELSE
		PRINTFORM 클리토리스
	ENDIF
PRINTFORM , %CSTR:LOCAL:9%의 
	IF TALENT:LOCAL:121 == 1
		PRINTFORM %조사처리(CSTR:LOCAL:80,"와")% 
	ELSE
		PRINTFORM 클리토리스와 
	ENDIF
PRINTFORML 키스하고 있어……♪」
IF TALENT:LOCAL:121 == 1 && TALENT:(LOCAL:1):121 == 1
	PRINTFORM 「아항, %CALLNAME:(LOCAL:1)%
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 씨
		ELSE
			PRINTFORM 짱
		ENDIF
	PRINTFORM 의 %CSTR:LOCAL:80%
	PRINTFORM , 
		IF CFLAG:LOCAL:609 < CFLAG:(LOCAL:1):609
			PRINTFORM %후치환(CSTR:COUNT:9+"의")% 것보다 컸
		ELSEIF CFLAG:LOCAL:609 > CFLAG:(LOCAL:1):609
			PRINTFORM %후치환(CSTR:COUNT:9+"의")% 것보다 작았
		ELSE
			PRINTFORM %후치환(CSTR:COUNT:9+"의")% 거하고 비슷하
		ENDIF
	PRINTFORM 네
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 요
		ELSE
			PRINTFORM 
		ENDIF
	PRINTFORML ……♪
	PRINTFORM 　그리고 
		IF CFLAG:(LOCAL:1):611 == 2 && TALENT:(LOCAL:1):1 == 0
			PRINTFORM 벗겨진 
		ELSEIF CFLAG:(LOCAL:1):611 == 3
			PRINTFORM 벗겨진 
		ELSE
			PRINTFORM 포경 
		ENDIF
		PRINTFORM %CSTR:LOCAL:80%
		IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
			PRINTFORM 에요
		ELSE
			PRINTFORM 고
		ENDIF
	PRINTFORML ……
	PRINTFORM 　
		IF CFLAG:(LOCAL:1):611 < 2 && CFLAG:LOCAL:611 == 2 && TALENT:LOCAL:1 == 0
			PRINTFORM %CSTR:LOCAL:9%처럼 벗겨진 %조사처리(CSTR:LOCAL:80,"가")% 더 발딱 서서 기분 좋아
				IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
					PRINTFORM 요
				ELSE
					PRINTFORM 
				ENDIF
			PRINTFORM ♪
		ELSEIF CFLAG:LOCAL:611 < 2  && CFLAG:(LOCAL:1):611 == 2 && TALENT:(LOCAL:1):1 == 0
			PRINTFORM %CSTR:LOCAL:9%도 %CALLNAME:(LOCAL:1)%
				IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
					PRINTFORM 씨
				ELSEIF NO:LOCAL != 10
					PRINTFORM 짱
				ENDIF
			PRINTFORM 처럼 벗겨진 %CSTR:LOCAL:80%면 더 기분 좋을텐데……♪
		ELSE
			PRINTFORM %CSTR:LOCAL:9%하고 똑같네
				IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
					PRINTFORM 요
				ELSE
					PRINTFORM 
				ENDIF
			PRINTFORM ♪
		ENDIF
	PRINTFORML 」
ENDIF
PRINTFORM 「응…… 더 기분 좋게 해줘
	IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
		PRINTFORM 요
	ELSE
		PRINTFORM 
	ENDIF
PRINTFORML ♪
PRINTFORM 　입하고 
	IF TALENT:LOCAL:121 == 1
		PRINTFORM %CSTR:LOCAL:80%
	ELSE
		PRINTFORM %CSTR:LOCAL:81%
	ENDIF
PRINTFORM , 양쪽으로 키스해줘
	IF (BASE:LOCAL:9 < BASE:(LOCAL:1):9) || NO:LOCAL == 9 || NO:LOCAL == 17
		PRINTFORM 요
	ELSE
		PRINTFORM 
	ENDIF
PRINTFORML ……」
	RESETCOLOR
	SETFONT ""
PRINTW

RETURN

