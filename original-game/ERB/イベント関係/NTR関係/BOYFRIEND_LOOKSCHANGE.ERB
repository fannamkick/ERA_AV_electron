;===========================================================
;見た目変更呼び出し
;===========================================================
@EVENT_LOOKSCHANGE

VARSET TCVAR, 0
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF TALENT:COUNT:184 == 1
		IF TALENT:COUNT:423 == 0 && EXP:COUNT:111 >= 9
			CONTINUE
		ELSEIF EXP:COUNT:111 >= 11
			CONTINUE
		ELSEIF CFLAG:COUNT:622 != 0
			CONTINUE
		ELSEIF CFLAG:COUNT:140 == 1 && (FLAG:101 & 128)
			CONTINUE
		ELSE
			LOCAL = RAND:100
			SIF TALENT:COUNT:423 == 1 || TALENT:COUNT:405 == 1
				LOCAL = 100
			SIF LOCAL >= 80
				CALL EVENT_LOOKSCHANGE_DETAIL
				VARSET TCVAR, 0
			LOCAL = 0
		ENDIF
	ENDIF
REND

;===========================================================
;見た目変更表示
;===========================================================
@EVENT_LOOKSCHANGE_DETAIL

TARGET = COUNT
LOCAL = CFLAG:622
VARSET TCVAR, 0

PRINTFORMW 주말이 지나고 월요일, 사무소에 들어온 %NAME:TARGET%에게 %플레이어는()% 위화감을 느꼈다……
PRINTFORM %타겟을()% 주의깊게 관찰해보니 

CALLFORM PARSONAL_CHANGE

PRINTFORML 것이 위화감의 원인이었다
PRINTFORML %CALLNAME:TARGET%에게 이야기를 들어보니, 사귀고 있는 남친인 %CSTR:7%의 취향이라고 한다
PRINTFORML %타겟은()% %CALLNAME:MASTER%에게 어울리는지 물어봤지만, %플레이어는()% 뭐라고 대답해야 좋을지 몰라 말이 나오지 않았다……

EXP:111 += 1

VARSET LOCAL:3
FOR LOCAL:3, 0 ,90
	IF TCVAR:(LOCAL:3)
		; 経験値の加算処理
		; 経験名が定義されているのみ加算処理を行う
		IF STRLENS(EXPNAME:(LOCAL:3)) > 0
			EXP:(LOCAL:3) += TCVAR:(LOCAL:3)
		ELSE
			DEBUGPRINTFORML %조사처리(EXP:{(LOCAL:3)},"는")% 정의되지 않았기에 가속처리를 스킵합니다
		ENDIF
			SIF TCVAR:(LOCAL:3) != 101
				PRINTFORML %EXPNAME:(LOCAL:3)% + {TCVAR:(LOCAL:3)}
	ENDIF
NEXT

VARSET TCVAR
WAIT
CUSTOMDRAWLINE ･･


