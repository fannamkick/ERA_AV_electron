		PRINT 반친구
	ELSEIF CFLAG:622 == 2
		PRINT 고등학생
	ELSEIF CFLAG:622 == 3
		PRINT 중학생
	ELSEIF CFLAG:622 == 4
		PRINT 대학생
	ELSEIF CFLAG:622 == 5
		PRINT 직장인
	ELSEIF CFLAG:622 == 6
		PRINT 호스트
	ELSEIF CFLAG:622 == 99
		PRINT 주인님
	ELSE
		PRINT 양키
	ENDIF
ENDIF

;===========================================================
;交際発覚
;===========================================================
@EVENT_BOYFRIEND
IF TALENT:COUNT:85 == 0 && TALENT:COUNT:430 == 0 && CFLAG:COUNT:621 != 1
	PRINTFORMW %CALLNAME:COUNT%의 모습이 이상하다……
	PRINTFORML %CALLNAME:COUNT%에게 직접 캐물어보니 남친이 생겼다고 한다.
	PRINTFORMW %조사처리(CALLNAME:COUNT,"는")% 홍조를 띄우며 남친과 깨가 쏟아지는 에피소드를 %CALLNAME:MASTER%에게 자랑했다……
	CALL DECIDE_BOYFRIEND,COUNT
		CFLAG:COUNT:621 = 1
		IF FLAG:541 == 0 || TALENT:COUNT:432 == 0
			CFLAG:COUNT:622 += RAND:7
				IF CFLAG:COUNT:622 == 1 && BASE:COUNT:9 > 18
					CFLAG:COUNT:622 = 5
				ENDIF
			BASE:COUNT:31 -= 5
		ENDIF
		TALENT:COUNT:184 = 1

	IF CFLAG:COUNT:16 == -1
		PRINTFORMW %조사처리(CALLNAME:COUNT,"는")% 이미 남친에게 첫 키스를 바쳤다고 한다……
		CFLAG:COUNT:16 = 8
		CSTR:COUNT:1 = %CSTR:COUNT:7% %CSTR:COUNT:8%
			BASE:COUNT:31 -= 5
		CFLAG:COUNT:820 = BASE:COUNT:9
		CFLAG:COUNT:821 = DAY:1
		CFLAG:COUNT:822 = DAY:2
	ENDIF
	PRINTW ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
ELSEIF TALENT:COUNT:85 == 1 && TALENT:COUNT:430 == 0 && CFLAG:COUNT:621 != 1
	PRINTFORMW %CALLNAME:COUNT%의 모습이 이상하다……
	PRINTFORML %CALLNAME:COUNT%에게 직접 캐물어보니 %CALLNAME:MASTER%보다 좋아하는 남자가 생겼다고 한다.
	PRINTFORML %조사처리(CALLNAME:COUNT,"는")% %CALLNAME:MASTER%에게 이전처럼 지내자고 말했다……
		CFLAG:COUNT:621 = 1 || TALENT:COUNT:432 == 0
		IF FLAG:541 == 0
			CFLAG:COUNT:622 += RAND:7
				IF CFLAG:COUNT:622 == 1 && BASE:COUNT:9 > 18
					CFLAG:COUNT:622 = 5
				ENDIF 
		ELSE
			CFLAG:COUNT:622 = 0
		ENDIF
		CALL DECIDE_BOYFRIEND,COUNT
		TALENT:COUNT:85 = 0
		TALENT:COUNT:184 = 1
			BASE:COUNT:31 -= 5
	IF CFLAG:COUNT:16 == -1
		PRINTFORMW %조사처리(CALLNAME:COUNT,"는")% 이미 다른 남자에게 첫 키스를 바쳤다고 한다……
		CFLAG:COUNT:16 = 8
		CSTR:COUNT:1 = %CSTR:COUNT:7% %CSTR:COUNT:8%
			BASE:COUNT:31 -= 5
		CFLAG:COUNT:820 = BASE:9
		CFLAG:COUNT:821 = DAY:1
		CFLAG:COUNT:822 = DAY:2
	ENDIF
	PRINTW ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
ENDIF


;===========================================================
;BFによる経験
;===========================================================
@EVENT_BOYFRIEND2

REPEAT 100
	J:COUNT = 0
	J = 0
REND
VARSET LOCAL, 0
VARSET TCVAR, 0
FOR LOCAL, 0, CHARANUM
	IF LOCAL == 0
		CONTINUE
	ELSEIF TALENT:LOCAL:184 == 0
		CONTINUE
	ELSEIF TALENT:LOCAL:153 == 1
		CONTINUE
	ELSEIF TALENT:LOCAL:154 == 1
		CONTINUE
	ELSEIF CFLAG:LOCAL:140 == 1 && (FLAG:101 & 128)
		CONTINUE
	ELSEIF TALENT:LOCAL:190 == 1
		CONTINUE
	ELSE
		TARGET = LOCAL
		LOCAL:1 = CFLAG:622
		LOCAL:2 = RAND:3
		SIF CFLAG:623 == 1
			LOCAL:2 = 0
			IF LOCAL:2 <= 1
				TRYCALLFORM BF_COMMONEV_{LOCAL:2}
			ELSE
				LOCAL:2 = RAND:2
				TRYCALLFORM BF_EV{LOCAL:1}_{LOCAL:2}
			ENDIF
		REPEAT 100
			IF J:COUNT >= 1
				PRINTL
				BREAK
			ENDIF
		REND
		FOR LOCAL:4, 0, 100
			IF J:(LOCAL:4)
				; 経験値の加算処理
				; 経験名が定義されているのみ加算処理を行う
				IF STRLENS(PALAMNAME:(LOCAL:4)) > 0
					JUEL:(LOCAL:4) += J:(LOCAL:4)
				ELSE
					DEBUGPRINTFORML %조사처리(JUEL:{(LOCAL:4)},"는")% 정의되지 않았기에 가속처리를 스킵합니다
				ENDIF
				SIF J:(LOCAL:4) > 0
					PRINTFORML %PALAMNAME:(LOCAL:4)%의 구슬 + {J:(LOCAL:4)}
			ENDIF
		NEXT
		FOR LOCAL:5, 0, 90
			SIF TCVAR:(LOCAL:5)
				LOCAL:6 = 1
		NEXT
		SIF LOCAL:6 == 1
			PRINTL
		FOR LOCAL:3, 0, 90
			IF TCVAR:(LOCAL:3)
				; 経験値の加算処理
				; 経験名が定義されているのみ加算処理を行う
				IF STRLENS(EXPNAME:(LOCAL:3)) > 0
					EXP:(LOCAL:3) += TCVAR:(LOCAL:3)
				ELSE
					DEBUGPRINTFORML %조사처리(EXP:{(LOCAL:3)},"는")% 정의되지 않았기에 가속처리를 스킵합니다
				ENDIF
				SIF TCVAR:(LOCAL:3) != 101
					PRINTFORML %EXPNAME:(LOCAL:3)% + {TCVAR:(LOCAL:3)}
			ENDIF
		NEXT

			IF TCVAR:5 >= 1
				CUSTOMDRAWLINE ･･
				WAIT
			ENDIF
		REPEAT 100
			J:COUNT = 0
			J = 0
		REND
		VARSET TCVAR:TARGET, 0
	ENDIF
NEXT

