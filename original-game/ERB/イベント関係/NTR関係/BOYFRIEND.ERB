	LOCAL += 1
ELSEIF ABL:2 == 5
	LOCAL += 2
ELSEIF ABL:2 >= 6
	LOCAL += 3
ENDIF
;성교중독によるボーナス
SIF ABL:30
	LOCAL += ABL:30 / 2 + 1
;PALAM:욕정がLV4以上
;욕망LV5以上봉사정신5以上で+1
SIF ABL:11 >= 5 && ABL:16 >= 5
	LOCAL += 2
;욕망LV4以上봉사정신4以上で+1
SIF ABL:11 >= 3 && ABL:16 >= 3
	LOCAL += 1
;PALAM:욕정がLV3以上
;욕망LV7以上V감각LV6以上で+1(下と合わせて+2)
SIF ABL:11 >= 7 && ABL:5 >= 6
	LOCAL += 1
;욕망LV4以上V감각LV3以上で+1
SIF ABL:11 >= 4 && ABL:2 >= 3
	LOCAL += 1
;남친있음によるボーナス
SIF TALENT:184
	LOCAL += 1
;섹스광によるボーナス
SIF TALENT:75
	LOCAL *= 2
;쾌감에 솔직
SIF TALENT:70
	LOCAL += 1
;음란によるボーナス
SIF TALENT:76
	LOCAL *= 2


SIF TALENT:432 == 1 && TALENT:422 == 0
	TIMES LOCAL, 1.50
SIF TALENT:422 == 1 && TALENT:432 == 0
	TIMES LOCAL, 1.50
SIF TALENT:422 == 1 && TALENT:432 == 1
	TIMES LOCAL, 2.00

;V경험
TCVAR:0 += LOCAL
;정액경험
TCVAR:20 += LOCAL*2
;성교경험
TCVAR:5 += LOCAL

IF TALENT:153 == 0 && TALENT:154 == 0
