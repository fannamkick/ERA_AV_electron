	ENDIF
	SIF TALENT:30 == 1
		LOCAL:1 = 0
	SIF TALENT:30 == 0 && TALENT:31 == 0
		LOCAL:1 /= 2
	SIF TALENT:420 == 1
		LOCAL:1 = 0
	SIF TALENT:500 == 1
		LOCAL:1 = 0
	SIF TALENT:501 == 1
		LOCAL:1 = 0
	SIF TALENT:504 == 1
		LOCAL:1 = 0
	SIF TALENT:505 == 1
		LOCAL:1 = 0
	SIF TALENT:508 == 1
		LOCAL:1 = 0
	SIF TALENT:511 == 1
		LOCAL:1 = 0
	SIF TALENT:520 == 1
		LOCAL:1 = 0
	SIF TALENT:521 == 1
		LOCAL:1 = 0
	IF LOCAL:1 >= 95
		CFLAG:102 = 7
		CFLAG:110 = DAY + 10 + RAND:3
		CFLAG:111 = -4
		CSTR:60 = %CSTR:7% %CSTR:8%(남친)
	ENDIF
ENDIF

J:0 += LOCAL * 25
J:1 += LOCAL * 250
J:14 += LOCAL * 10
J:5 += LOCAL * 500
