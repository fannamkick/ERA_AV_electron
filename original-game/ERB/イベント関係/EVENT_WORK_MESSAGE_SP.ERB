;========================================================
;特殊営業時メッセージ
;========================================================
;--------------------------------------------------------
;ストリップショー
;--------------------------------------------------------
@WORK_MESSAGE_STRIP_01
;調教テキスト省略設定の場合は戻る
SIF (FLAG:6 & 1)
	RETURN 0

;通常ストリップ
PRINT 스포트라이트를 받으면서, 
CALL WORK_SUB_PRINT_MEMBER
PRINTFORML %조사만처리(RESULT+2,"는")% 관객들에게 나체를 보이고 있다……
	
WAIT
	
;공개자위
IF FLAG:53 & 1
	PRINT 그리고, 
	CALL WORK_SUB_PRINT_MEMBER
	PRINTFORML %조사만처리(RESULT+2,"는")% 객석을 향해 다리를 열어 비밀스런 곳을 드러내고, 
	PRINTW 야시시한 소리를 내며 성기를 휘젖기 시작했다……
	;近親자위ショー
	IF FLAG:53 & 8
		PRINT 무수히 많은 눈이 지켜보는 가운데 이어서 계속해서 자위하고 있는 
		IF TFLAG:14 == 2
			SIF TALENT:122
				PRINT 부
			SIF TALENT:122 == 0
				PRINT 모
			SIF TALENT:ASSI:122
				PRINT 자
			SIF TALENT:ASSI:122 == 0
				PRINT 녀
		ELSEIF TFLAG:14 == 4
			SIF TALENT:122 && TALENT:ASSI:122
				PRINT 형제
			SIF TALENT:122 == 0 && TALENT:ASSI:122 == 0
				PRINT 자매
			SIF TALENT:122 ^^ TALENT:ASSI:122
				PRINT 남매
		ENDIF
		PRINTL 에게, 
		PRINTL 객석에서 추잡한 야유가 터졌다……
		PRINTL 에게, 
		PRINTW 객석으로부터 음란한 야유가 흘러나왔다……
	ENDIF
	PRINTL 
ENDIF

;レズショー
IF FLAG:53 & 2
	PRINT 이윽고 
	CALL WORK_SUB_PRINT_MEMBER
	PRINTFORMW %조사만처리(RESULT+2,"는")% 서로의 알몸을 음란하게 얽기 시작했다……
	;近親レズビアンショー
	IF FLAG:53 & 8
		IF TFLAG:14 == 2
			PRINTL M자로 열린 모친의 고간에 얼굴을 붙인채, 
			PRINT 자신이 태어난 장소를 혀로 햝는 
			IF TALENT:ASSI:135
				PRINT 유녀
			ELSEIF TALENT:ASSI:132
				PRINT 소녀
			ELSE
				PRINT 딸
			ENDIF
		ELSEIF TFLAG:14 == 4
			PRINT 서로 반대로 붙어 상대의 성기를 서로 햝고 있는 언니와 여동생
		ENDIF
		PRINTL 의 모습을, 
		PRINTW 관객은 숨을 죽이며 지켜보고 있다……
	ENDIF
	PRINTL 
ENDIF
	
;공개セックス
IF FLAG:53 & 4
	PRINTW 본방 행위가 시작되었다……
	;TARGETとASSI双方が후타나리でV使用可
	IF TALENT:TARGET:121 && CFLAG:TARGET:54 == 0 && TALENT:ASSI:121 && CFLAG:ASSI:54 == 0
		PRINTFORM %타겟과()% %조사처리(CALLNAME:ASSI,"는")%
		PRINTFORMW 서로의 페니스로 서로의 보지를 교대로 꿰뚫었다
	;TARGETがオトコor후타나리でASSIがV使用可
	ELSEIF (TALENT:TARGET:122 || TALENT:TARGET:121) && CFLAG:ASSI:54 == 0
		PRINTFORM %타겟은()% 발기된 자신의 페니스가 
		PRINTFORMW %CALLNAME:ASSI%의 보지에 출납하는 모습을 손님들에게 과시했다
	;ASSIがオトコor후타나리でTARGETがV使用可
	ELSEIF  (TALENT:ASSI:122 || TALENT:ASSI:121) && CFLAG:54 == 0
		PRINTFORM %타겟은()% 자신의 보지가 
		PRINTFORMW %CALLNAME:ASSI%의 페니스로 관철당하는 모습을 손님에게 과시했다
	ENDIF

	;近親相姦ショー
	IF FLAG:53 & 8
		WAIT
		IF TFLAG:14 == 2  && TALENT:122
			PRINT 아버지
		ELSEIF TFLAG:14 == 2  && TALENT:122 == 0
			PRINT 어머니
		ELSEIF TFLAG:14 == 4  && TALENT:122 && TALENT:ASSI:122
			PRINT 형
		ELSEIF TFLAG:14 == 4  && TALENT:122 && TALENT:ASSI:122 == 0
			PRINT 오빠
		ELSEIF TFLAG:14 == 4  && TALENT:122 == 0 && TALENT:ASSI:122
			PRINT 누나
		ELSEIF TFLAG:14 == 4  && TALENT:122 == 0 && TALENT:ASSI:122 == 0
			PRINT 언니
		ENDIF
		PRINT 가 
		IF TFLAG:14 == 2 && TALENT:ASSI:122 == 0
			PRINT 자신의 딸
		ELSEIF TFLAG:14 == 2 && TALENT:ASSI:122
			PRINT 자신의 아들
		ELSEIF TFLAG:14 == 4 && TALENT:ASSI:122 == 0
			PRINT 자신의 여동생
		ELSEIF TFLAG:14 == 4 && TALENT:ASSI:122
			PRINT 자신의 남동생
		ENDIF
		IF TALENT:121 && CFLAG:54 == 0 && TALENT:ASSI:121 && CFLAG:ASSI:54 == 0
			PRINT 과 서로서로 범하는 
		ELSEIF (TALENT:122 || TALENT:121) && CFLAG:ASSI:54 == 0
			PRINT 을 계속해서 범하는 
		ELSEIF (TALENT:ASSI:122 || TALENT:ASSI:121) && CFLAG:54 == 0
			PRINT 에게 계속해서 범해지는 
		ENDIF
		PRINTW 비정상적인 광경에, 관객석은 조용해졌다……
	ENDIF
	PRINTL 
ENDIF

;失敗時メッセージ
IF A <= 1
	PRINTFORM 수치심을 참을 수 없어졌는지  
	IF FLAG:42 == 1 && TARGET > 0
		PRINTFORM %타겟은()%
	ELSEIF FLAG:42 == 2
		PRINTFORM %타겟과()% %조사처리(CALLNAME:ASSI,"는")%
	ELSEIF FLAG:42 ==3
		PRINT 3명은
	ELSE
		PRINTFORM {FLAG:42}명은
	ENDIF
	PRINTFORMW  중간에 몸을 멈춰버렸다
;成功時メッセージ
ELSE
	;방뇨はサービス
	IF FLAG:42 == 2
		IF (FLAG:53 & 8) && ABL:17 >= 4 && TALENT:57 && ABL:ASSI:17 >= 4 && TALENT:ASSI:57
			PRINTFORML 쇼의 마지막에 %타겟이()% %CALLNAME:ASSI%의 양다리를 잡아들고 방뇨시키고, 
			PRINTFORML 자기 자신도 그 자세 그래도 가랑이를 열어 동시에 방뇨하자, 
			PRINTFORML 객석에서 대환성이 솟구쳐 올랐다……
		ELSEIF (FLAG:53 & 8) && ABL:ASSI:17 >= 4 && TALENT:ASSI:57
			PRINTFORML 쇼의 마지막에 %타겟이()% %CALLNAME:ASSI%의 양다리를 아기처럼 안아올리고, 
			PRINTFORML 객석을 향해 방뇨시키자, 대환성이 솟구쳐 올랐다……
		ELSEIF ABL:17 >= 4 && TALENT:57 && ABL:ASSI:17 >= 4 && TALENT:ASSI:57
			PRINTFORML 쇼의 마지막에 %타겟과()% %조사처리(CALLNAME:ASSI,"가")% 줄지어 양다리를 열고, 
			PRINTFORML 동시에 방뇨하자, 환성이 올랐다……
		ELSEIF ABL:17 >= 4 && TALENT:57
			IF ABL:22 + ABL:ASSI:22 >= 6 && ABL:20 + ABL:ASSI:21 >= 6
				PRINTFORML 쇼의 마지막에 %타겟이()% %CALLNAME:ASSI%의 입안에 방뇨하자, 
				PRINTFORML 대환성이 솟구쳐 올랐다……
			ELSE
				PRINTFORML 쇼의 마지막에 %타겟이()% 객석을 향해 방뇨하자, 환성이 올랐다……
			ENDIF
		ELSEIF ABL:ASSI:17 >= 4 && TALENT:ASSI:57
			IF ABL:22 + ABL:ASSI:22 >= 6 && ABL:ASSI:20 + ABL:21 >= 6
				PRINTFORML 쇼의 마지막에 %조사처리(CALLNAME:ASSI,"가")% %CALLNAME:TARGET%의 입안에 방뇨하자, 
				PRINTFORML 대환성이 솟구쳐 올랐다……
			ELSE
				PRINTFORML 쇼의 마지막에 %조사처리(CALLNAME:ASSI,"가")% 객석을 향해 방뇨하자, 환성이 올랐다……
			ENDIF
		ENDIF
		WAIT
	ELSEIF ABL:17 >= 4 && TALENT:57
		PRINTFORML 쇼의 마지막에 %타겟이()% 객석을 향해 방뇨하자, 환성이 올랐다……
		WAIT
	ENDIF
	IF FLAG:50 == 0
		CALL WORK_SUB_PRINT_MEMBER
		PRINTFORMW %조사만처리(RESULT+2,"는")% 부끄러운듯이 미소지으며, 스테이지에서 내려왔다……
	ENDIF
ENDIF

RETURN 1

;--------------------------------------------------------
;ストリップ・マナ板ショー
;--------------------------------------------------------
@WORK_MESSAGE_STRIP_02
;調教テキスト省略設定の場合は戻る
SIF (FLAG:6 & 1)
	RETURN 0

;メンバー全員が음란かつ娼婦持ちかのチェック
E = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	SIF TALENT:COUNT:76 == 0 || TALENT:COUNT:180 == 0
		E = 0
REND
;メンバー全員がV使用不可かのチェック
F = 1
REPEAT CHARANUM
	SIF CFLAG:COUNT:130 == 0
		CONTINUE
	SIF CFLAG:COUNT:54
		CONTINUE
	F = 0
REND

PRINT 매트 위에서 
IF E
	PRINT 다리가 반정도 열려있는 상태로 유혹하고 있는 
ELSE
	PRINT 긴장으로 몸을 딱딱하게 굳은 
ENDIF
CALL WORK_SUB_PRINT_MEMBER
PRINTFORML %조사만처리(RESULT+2,"를")%
PRINTFORML 스테이지에 오른 {G/3}명의 관객이 차례로 덮쳐,
SIF F == 0
	PRINT 보지와 
PRINTFORML 항문과 입을 마음껏 맛보았다……

RETURN 1

;--------------------------------------------------------
;乱交パーティー
;--------------------------------------------------------
@WORK_MESSAGE_ORGY_01
;調教テキスト省略設定の場合は戻る
SIF (FLAG:6 & 1)
