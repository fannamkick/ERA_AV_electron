ENDIF
;===========================================================
;캬바레녀のステータス決定
;===========================================================
@C_CLUBGIRL_STATUS
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 79
		IF CFLAG:MASTER:635 == 0
			NAME:COUNT = %CSTR:MASTER:50% %CSTR:MASTER:51%
			CALLNAME:COUNT = %CSTR:MASTER:51%
			BASE:COUNT:9 += RAND:5
			CFLAG:MASTER:635 = 1
			CFLAG:COUNT:600 = RAND:10
			CFLAG:COUNT:601 = RAND:1
			CFLAG:COUNT:602 = RAND:8
		ENDIF
	ENDIF
REND