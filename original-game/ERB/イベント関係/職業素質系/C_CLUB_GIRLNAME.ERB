ELSE
	CSTR:MASTER:50 = 키사카
ENDIF

;名前を生成
LOCAL = RAND:20

IF LOCAL == 0
	CSTR:MASTER:51 = 유키나
ELSEIF LOCAL == 1
	CSTR:MASTER:51 = 미유
ELSEIF LOCAL == 2
	CSTR:MASTER:51 = 란
ELSEIF LOCAL == 3
	CSTR:MASTER:51 = 안리
ELSEIF LOCAL == 4
	CSTR:MASTER:51 = 쿄
ELSEIF LOCAL == 5
	CSTR:MASTER:51 = 마치
ELSEIF LOCAL == 6
	CSTR:MASTER:51 = 나리카
ELSEIF LOCAL == 7
	CSTR:MASTER:51 = 시즈루
ELSEIF LOCAL == 8
	CSTR:MASTER:51 = 아키나
ELSEIF LOCAL == 9
	CSTR:MASTER:51 = 오토하
ELSEIF LOCAL == 10
	CSTR:MASTER:51 = 마키나
ELSEIF LOCAL == 11
	CSTR:MASTER:51 = 마히로
ELSEIF LOCAL == 12
	CSTR:MASTER:51 = 에리
ELSEIF LOCAL == 13
	CSTR:MASTER:51 = 아사히
ELSEIF LOCAL == 14
	CSTR:MASTER:51 = 아카리
