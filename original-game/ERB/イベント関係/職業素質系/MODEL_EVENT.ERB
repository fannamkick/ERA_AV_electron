;===========================================================
;ヘアスタイルの処理
;===========================================================
@MODEL_EVENT_CALL

LOCAL = 0
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF TALENT:COUNT:402
		LOCAL = RAND:3
		TARGET = COUNT
		TRYCALLFORM MODEL_EVENT(LOCAL)
	ENDIF
REND

