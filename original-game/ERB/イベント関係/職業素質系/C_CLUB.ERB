;===========================================================
;キャバクラ絡みのイベント
;===========================================================
@C_CLUB_EVENT
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF TALENT:COUNT:421 == 1
		CALL START_C_CLUBEVENT
	ENDIF
REND
;===========================================================
;イベント開始
;===========================================================
@START_C_CLUBEVENT
IF RAND:8 == 0
	CALL NOTHING
ELSEIF RAND:7 == 0
	CALL NOTHING
ELSEIF RAND:6 == 0
	CALL NOTHING
ELSEIF RAND:5 == 0 && MONEY > 10000
	CALL EVENT_C_CLUBHALL
	PRINTW ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
ELSEIF RAND:4 == 0
	CALL NOTHING
ELSEIF RAND:3 == 0 && MONEY > 10000
	CALL EVENT_C_CLUBHALL
	PRINTW ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
ELSEIF RAND:2 == 0
	CALL NOTHING
ELSEIF RAND:1 == 0
	CALL EVENT_C_CLUBAFTER
ELSE
	CALL NOTHING
ENDIF

;===========================================================
