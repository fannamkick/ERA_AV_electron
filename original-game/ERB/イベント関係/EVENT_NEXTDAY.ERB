;-------------------------------------------------
;왕도짓코
;-------------------------------------------------
@EVENT_NOROI
SIF CHARANUM <= 2 && (TALENT:MASTER:198 == 0 || CHARANUM <= 1)
	RETURN 0

REPEAT CHARANUM
	T = COUNT
	IF (TALENT:T:198 && RAND:10 <= ABL:T:10) || (T == 0 && TALENT:T:198 && RAND:10 <= 2 )
		PRINTFORMW %조사처리(NAME:T,"가")% 가지고 있는【%TALENTNAME:198%】가 발동해버렸다…
		S = CHARANUM - 1
		C = RAND:S + 1
		U = RAND:10
		;持ち主が呪いを受ける事はない
		SIF C == T
			U = 10
		;臨死中のキャラが呪いを受ける事はない
		SIF BASE:C:0 <= 0
			U = 10
		;체력減少(40%)
		IF U <= 3
			IF BASE:C:0 > 1100
				PRINTFORML %NAME:C%의 체력이 1000 감소했다
			ELSEIF BASE:C:0 > 100
				PRINTFORML %NAME:C%의 체력이 {BASE:C:0 - 100} 감소했다
			ELSE
				PRINTFORML 아무 일도 없었던 것 같다…
			ENDIF
			WAIT
			BASE:C:0 -= 1000
			SIF BASE:C:0 <= 100
				BASE:C:0 = 100
		;부정의 구슬倍増(40%)
		ELSEIF U <= 7
			PRINTFORML %NAME:C%의 마음이 부정적인 생각으로 뒤덮여버렸다
			WAIT
			JUEL:C:100 += 500
			JUEL:C:100 *= 2
		ELSEIF U <= 8
		;人気減少(10%)
			PRINTFORML %NAME:C%에 대한 안 좋은 소문이 퍼지고 있는 것 같다
			WAIT
