;=================================================
;日付変更時に起きるイベント
;=================================================
@EVENT_NEXTDAY

;キャラの素質変更に関わるチェック
REPEAT CHARANUM
	SIF COUNT == 0
		CONTINUE

	TARGET = COUNT

	;방뇨経験40以上(【유치】があれば15以上)で【오줌싸개】がつく
	IF TALENT:57 == 0
		SIF TALENT:132 && EXP:31 >= 50
			CALL EVENT_MORASI
		SIF TALENT:132 == 0 && EXP:31 >= 100
			CALL EVENT_MORASI
	ENDIF
	;반발각인3があり, かつ【유치】か【유리멘탈】である時に
	IF MARK:3 == 3 && (TALENT:132 || TALENT:134)
		;욕망が5かつ従順が5かつ마조끼が5かつ이상경험が5以上になると유아퇴행する
		SIF ABL:11 >= 5 && ABL:10 >= 5 && ABL:21 >= 5 && EXP:50 >= 5
			CALL EVENT_YOUJI

	;반발각인3があり
	ELSEIF MARK:3 == 3
		;욕망が5かつ従順が5かつ마조끼が5かつ露出5と이상경험が7以上に加え【오줌싸개】がつくと【유아퇴행】する	
		SIF ABL:11 >= 5 && ABL:10 >= 5 && ABL:21 >= 5 && ABL:17 >= 5 && EXP:50 >= 7 && TALENT:57 == 1
			CALL EVENT_YOUJI
	ENDIF

	;ストレス비만持ちで부정의 구슬が1000以上でかつ비만でない時に,【비만】に変化
	IF TALENT:115 == 0
		SIF TALENT:323 == 1  && JUEL:100 >= 1000
			CALL EVENT_HIMAN
	ENDIF

	;ストレス비만持ちで부정의 구슬がなく비만である時に,【비만】から回復
	IF TALENT:115 == 1
		SIF TALENT:323 == 1  && JUEL:100 == 0
			CALL EVENT_YASERU
	ENDIF

;一応コメントアウト。
;△進学イベ
;	;12歳で3月31日を終えた時,【중학생】に進学(【愛】がない場合, 素質は付かない)
;	IF BASE:9 == 12 && DAY:1 == 3 && DAY:2 == 31
;		CALL EVENT_JUNIORHIGHSCHOOL
;	ENDIF
;	;15歳で3月31日を終えた時,【고등학생】に進学(【愛】がない場合, 素質は付かない)
;	IF BASE:9 == 15 && DAY:1 == 3 && DAY:2 == 31
;		CALL EVENT_HIGHSCHOOL
;	ENDIF
	;약물중독
	CALL APHRODISIAC_ADDICT

	COUNT = TARGET

REND

;왕도짓코
CALL EVENT_NOROI

;お香の使用回数をクリア
FLAG:61 = 0

;임신発覚
CALL GET_CHILD_ALL
						;****슬라임パッチ追加ここから****
FOR LOCAL, 0, CHARANUM
	IF TALENT:LOCAL:153 || TALENT:LOCAL:154 || TALENT:LOCAL:157
		;出産2日前からは산월突入で調教不可に
		IF (CFLAG:LOCAL:110 - 2) == DAY
			DRAWLINE
			CALL REACH_FULL_TERM(LOCAL)
		;出産前日には육아室への訪問を問うイベント発生
		ELSEIF (CFLAG:LOCAL:110 - 1) == DAY
			DRAWLINE
			PRINTFORML %CALLNAME:LOCAL%의 출산일이 가까워졌다……
			DRAWLINE
		;出産予定日なら出産
		ELSEIF CFLAG:LOCAL:110 <= DAY && (TALENT:LOCAL:153 || TALENT:LOCAL:157)
			DRAWLINE
			C = LOCAL
			IF TALENT:LOCAL:153
				CALL CHILD_BIRTH
			ELSEIF TALENT:LOCAL:157
				CALL EGG_BIRTH
			ENDIF
		;出産20日で親離れで調教可能に
		;出産20日で親離れで調教可能に
		ELSEIF (CFLAG:LOCAL:110 + 20) <= DAY && CFLAG:LOCAL:141 != 3
			C = LOCAL
			DRAWLINE
			CALL DEPEARENT
		ELSEIF (CFLAG:LOCAL:110 + 10) <= DAY && CFLAG:LOCAL:141 == 3
			C = LOCAL
			DRAWLINE
			CALL DEPEARENT
		ENDIF
	ENDIF
NEXT
						;****슬라임パッチ追加ここまで****

;임신・육아 중はサイズが設定されているキャラは成長
REPEAT CHARANUM
	IF BASE:COUNT:22 >0 && FLAG:38 > 0
		SIF TALENT:COUNT:153 || TALENT:COUNT:154
			CALL GROW_3_SIZE_IWS
	ENDIF
REND

;着衣設定の場合, 汚れた衣類を洗濯する
SIF FLAG:37
	CALL WASHING_CLOTH

;前回の調教対象がいる場合
IF FLAG:1 > 0
	TARGET = FLAG:1
ENDIF

;성교중독による夜這いチェック
CALL NIGHT_STALKING_CHECK

;運営費
CALL RUNNING_COST

CALL SYSTEM_KIKENBI

RETURN 1
