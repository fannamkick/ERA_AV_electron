;>売却と助手化の処理を削除(SHOPでまとめて行う)

;=================================================
;BEGIN TURNEND後最初に呼び出される関数
;=================================================
@EVENTTURNEND
#PRI
IF TARGET > 0
	;売却可・조수 가능判定の処理
	CALL CHECK_SELLASSIABLE

	;特殊素質獲得判定の処理
	CALL CHECK_SPECIALSKIL

	;임신判定の処理
	CALL IN_VAGINA_ALL
	
	;임신確定時の処理
	CALL CONCEPTION_CHECK_ALL
ENDIF
;キャラクリのチェック
CALL CHARACLEAR_CALC

;休息処理
CALL RESTTIME

;위험일の算出
CALL OVULATION_CALC

;ヴァギナ形状の処理
CALL VAGINAFORM_CHANGE

;수명処理
;CALL RESTLIFE

;陰毛処理
CALL PUBLIC_HAIR

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 11
		IF CFLAG:COUNT:1 == 2
			LOADGLOBAL
			GLOBAL:51 = 1
			SAVEGLOBAL
		ENDIF
	ENDIF
REND


;完全に死んだキャラがいたら削除
REPEAT CHARANUM
	;主人公は除外
	SIF COUNT == 0
		CONTINUE
	;キャラ人数がCOUNT以下になっていたらREPEAT抜ける
	SIF COUNT >= CHARANUM
		BREAK

	IF BASE:COUNT:0 <= -1
		T = -1
		SIF TARGET != COUNT
			T = TARGET
		TARGET = COUNT
		C = COUNT
		CALL KILL_TARGET
		COUNT = C - 1
		SIF T != -1
			TARGET = T
	ENDIF
REND

;매력치が0以下なら0にする
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSE
		IF BASE:COUNT:31 <= 0
			BASE:COUNT:31 = 0
		ENDIF
	ENDIF
REND


;休憩フラグ外す
FLAG:0 = 0

;오후라면 다음날, 오전이면 오후에 한다
IF TIME == 1
	;娼館영업 결과のイベントの呼び出し
	CALL YUUKAKU_RESULT

	;売春による임신判定
	CALL IN_VAGINA_EXTRA
	CALL CONCEPTION_CHECK_EXTRA

	;日付変更時のイベント呼び出し
	CALL EVENT_LESPLAY_NEW
	CALL EVENT_NEXTDAY
	;スカウト周りの処理
	CALL EVENT_SCOUT

	SIF FLAG:554 == 0
		CALL IDOL_PRODUCE_CALC
	SIF FLAG:554 == 1 && MONEY > 500000
		CALL IDOL_PRODUCE_ADD

	;불량배 강간이벤트
	SIF FLAG:540 == 0
		CALL BADBOY_RAPE_CALC

	;치한의 판정
	SIF FLAG:540 == 0
		CALL EVENT_MOLESTER

	SIF FLAG:540 == 0
		CALL COMPA_START

	;연애도의 판정
	IF FLAG:540 == 0
		REPEAT CHARANUM
			IF COUNT == 0
				CONTINUE
			ELSEIF CFLAG:COUNT:140 == 1 && (FLAG:101 & 128)
				CONTINUE
			ELSEIF TALENT:COUNT:122 == 0
				CFLAG:COUNT:619 += RAND:5
					IF TALENT:COUNT:416
						CFLAG:COUNT:619 += RAND:5
					ENDIF
					IF TALENT:COUNT:432
						CFLAG:COUNT:619 += RAND:5
					ENDIF
				SIF CFLAG:COUNT:619 > CFLAG:COUNT:620
				CALL EVENT_BOYFRIEND
			ENDIF
		REND
	ENDIF
	;외견 변경의 판정
	IF FLAG:540 == 0
		REPEAT CHARANUM
			IF COUNT == 0
				CONTINUE
			ELSEIF CFLAG:COUNT:140 == 1 && (FLAG:101 & 128)
				CONTINUE
			ELSE
				CALL EVENT_LOOKSCHANGE
			ENDIF
		REND
	ENDIF
	;남자친구와의 섹스체크
	IF FLAG:540 == 0
		REPEAT CHARANUM
			IF COUNT == 0
				CONTINUE
			ELSEIF CFLAG:COUNT:621 == 1
				CALL EVENT_BOYFRIEND2
			ENDIF
		REND
	ENDIF

;	IF FLAG:540 == 0
;		CALL EVENT_BFMARRIED
;	ENDIF

	;직원에 의한 강간이벤트
	SIF FLAG:540 == 0
		CALL NTR_STAFF_BEGIN
	SIF FLAG:540 == 0 && CFLAG:MASTER:694 == 0
		CALL BASE_NTR_STAFF

	;흑갸루周りの処理
	;△見直し対象
	IF FLAG:542 == 0
		CALL BLACKGIRL_EVENT
	ENDIF
	
	REPEAT CHARANUM
		IF COUNT == 0
			CONTINUE
		ELSEIF CFLAG:COUNT:691 == 0
			CONTINUE
		ELSE
			CALL EVENT_BGSEX
		ENDIF
	REND

	REPEAT CHARANUM
		SIF CFLAG:COUNT:692
			CFLAG:COUNT:692 = 0
	REND
	;여기까지

	CALL IDOL_EVENT
	CALL MODEL_EVENT_CALL
	CALL C_CLUB_EVENT
	IF CFLAG:MASTER:634 == 1 && CFLAG:MASTER:635 == 0
		CALL C_CLUBGIRL_STATUS
	ENDIF
	CALL GETTALENT_GAL
	CALL CHECK_SPECIALSKIL

	CALL ADD_EXABL
	CALL EXABL_B
	CALL EXABL_P
	CALL EXABL_S
	CALL EXABL_O
	CALL SUNBURN_AFTER

	CALL ARBEIT_EXEC
	CALL JOB_EXEC
	CALL MISSION_DAY

	SIF FLAG:100
		CALL LYCEE_EVENT_WEEKEND
	DAY = DAY+1
	PRINTW 한 주가 끝났다……

	;배란유발제の効果終了処理
	REPEAT CHARANUM
		IF CFLAG:COUNT:109 >= 1
			PRINTFORML %NAME:COUNT%의 배란유발제 효과가 다했다
			DRAWLINE
			CFLAG:COUNT:109 = 0
		ELSEIF CFLAG:COUNT:109 == -1
			PRINTFORML %NAME:COUNT%의 배란억제제 효과가 다했다
			DRAWLINE
			CFLAG:COUNT:109 = 0
		ENDIF
	REND
	;育毛剤の効果終了処理
	REPEAT CHARANUM
		IF CFLAG:COUNT:34
			PRINTFORML %NAME:COUNT%의 강모제 효과가 다했다
			CFLAG:COUNT:34 = 0
		ENDIF
	REND

	DAY:2 = DAY:2 + 1
	;毎月29日以上になってたら月替わり処理
	SIF DAY:2 > 4
		CALL EVENT_NEXTMONTH
	
	TIME = 0

	;翌朝に起こる出来事
	CALL EVENT_NEWDAY

ELSE
	TIME = 1
ENDIF

;エンディングチェック
CALL ENDING_CHECK

;아이템の自動購入
CALL AUTO_BUYING

;아이템の自動購入
SIF FLAG:76 
	CALL AUTO_ITEMUSE


;調教対象と助手を空に
TARGET = -1
ASSI = -1

SIF CFLAG:MASTER:65 == 1
	CALL EVENT_MORNING_PICKUP

;実績判定
CALL CHECK_ACHIEVEMENT

BEGIN SHOP

;-------------------------------------------------
;休息処理
;-------------------------------------------------
@RESTTIME
;질투と광기持ちのチェック
;질투か광기持ちのキャラの人数(調教対象だったなら除外)
J = 0
REPEAT CHARANUM
	SIF COUNT != TARGET && TALENT:COUNT:84
		J += 1
	SIF COUNT != TARGET && TALENT:COUNT:123
		J += 2
REND

H = 0
;助手全体から【치료】を持つ人数を検索
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF ISASSI:COUNT && TALENT:COUNT:117
		H += 1
	ENDIF
REND
;助手全体から【치료】を持つ人数を検索

REPEAT CHARANUM
	;死んでるか臨死中なら回復しない
	SIF BASE:COUNT:0 < 1
		CONTINUE

	;체력の回復
	IF TIME == 0
		A = MAXBASE:COUNT:0 / 20
	;午後の調教後は夜の休みが入るので回復大きい
	ELSE
		A = MAXBASE:COUNT:0 / 4
	ENDIF
	
	;今回の調教対象でなく営業中でなければ回復量増加
	SIF COUNT != TARGET && CFLAG:COUNT:12 == 0
		A += 100
	
	;회복 빠름, 회복 느림, 가이노이드, サイボーグ, ヒーロー
	SIF TALENT:COUNT:419
		A += 3000
	SIF TALENT:COUNT:501
		A += 3000
	SIF TALENT:COUNT:505
		A += 3000
	SIF TALENT:COUNT:511
		A += 3000
	SIF TALENT:COUNT:504
		A += 3000

	A += ABL:COUNT:51 * 30

	;瀕死状態では체력回復が遅れる
	SIF BASE:COUNT:0 < 500
		A /= 5

	;主人か助手に치료があれば, 全調教対象の回復量上昇
	;ただし自分自身が唯一の치료持ちの場合は上昇しない
	;(自分で自分は치료できないため)
	IF TALENT:MASTER:117
		A += 100
	ELSEIF H >= 2
		A += 100
	ELSEIF H == 1 && TALENT:COUNT:117 == 100
		A += 100
	ENDIF

	;営業中なら체력回復が遅れる
	SIF CFLAG:COUNT:12
		A /= 5

	;질투
	IF TALENT:COUNT:84 && EXP:COUNT:10
		;자위경험が増える(主人には知らせない)
		TIMES A , 0.80
		EXP:COUNT:10 += ABL:COUNT:11 * 2
	ENDIF
	;질투or광기がいると他の調教対象の체력回復が遅れる
;	IF TALENT:COUNT:123 && J > 2
;		A -= (J - 2) * 100
;	ELSEIF TALENT:COUNT:84 && J > 1
;		A -= (J - 1) * 100
;	ELSEIF J > 0
;		A -= J * 100
;	ENDIF

	;休息によって체력が減ってしまうということはない
	SIF A < 0
		A = 0
	;午後の調教後は最低でも必ず10回復
	SIF TIME == 1 && A < 10
		A = 10

	IF TALENT:COUNT:111
		A *= 2
	ELSEIF TALENT:COUNT:112
		A /= 2
	ENDIF

	;체력の回復
	BASE:COUNT:0 += A
	SIF BASE:COUNT:0 > MAXBASE:COUNT:0
		BASE:COUNT:0 = MAXBASE:COUNT:0

	;기력の回復
	BASE:COUNT:1 = MAXBASE:COUNT:1
REND

RETURN 0

;-------------------------------------------------
;수명処理
;-------------------------------------------------
@RESTLIFE
;難易度EASYの場合は수명制限なし
SIF FLAG:5 == 1
	RETURN 0

REPEAT CHARANUM
	IF  BASE:COUNT:10 > 0
		BASE:COUNT:10 -= 1
		IF BASE:COUNT:10 == 0
			;수명による消滅時口上
			TARGET = COUNT
			TFLAG:13 = 998
			CALL SELF_KOJO
			PRINTFORMW %조사처리(CALLNAME:COUNT,"는")% 사라져버렸다……
			BASE:COUNT:0 = -1
			;消滅フラグを残す
			C = NO:COUNT + 999
			FLAG:C = -3
		ENDIF
	ENDIF
REND
RETURN 0

;-------------------------------------------------
;陰毛処理
;-------------------------------------------------
@PUBLIC_HAIR
;陰毛を生やさない設定ならそのまま帰る
SIF FLAG:36 == 0
	RETURN 0

REPEAT CHARANUM
	;剛毛剤사용중か剛毛体質
	SIF (CFLAG:COUNT:34 || TALENT:COUNT:128) && CFLAG:COUNT:6 <= 25
		CFLAG:COUNT:6 += 1

	;【음모 없음】消失
	IF TALENT:COUNT:125 && CFLAG:COUNT:6 > 5
		PRINTFORMW %NAME:COUNT%의 성기에서 희미하게 털이 돋아나기 시작했다……
		PRINTFORMW %NAME:COUNT%는【%TALENTNAME:125%】이 아니게 되었다.	
		TALENT:COUNT:125 = 0
	ENDIF
	;【剛毛体質】獲得
	IF TALENT:COUNT:128 == 0 && CFLAG:COUNT:6 > 18
		PRINTFORML %NAME:COUNT%의 하복부는 치구에서 항문까지, 
		PRINTFORMW 무성한 음모로 뒤덮였다……
		PRINTFORMW %NAME:COUNT%는【%TALENTNAME:128%】이 되었다.		
		TALENT:COUNT:128 = 1
	ENDIF

	;음모 없음ならそのまま
	SIF TALENT:COUNT:125
		CONTINUE
	;永久脱毛してるならそのまま
	SIF CFLAG:COUNT:6 < 0
		CONTINUE
	;유치か중학생なら7までしか伸びない
	SIF CFLAG:COUNT:6 >= 9 && (TALENT:COUNT:132 || TALENT:COUNT:221)
		CONTINUE
	SIF CFLAG:COUNT:6 >= 9 && TALENT:COUNT:422
		CONTINUE
	;고등학생なら9までしか伸びない
	SIF CFLAG:COUNT:6 >= 12 && TALENT:COUNT:220
		CONTINUE
	;通常の場合の上限は12
	SIF CFLAG:COUNT:6 >= 12
		CONTINUE
	
	CFLAG:COUNT:6 += 1

REND

;-------------------------------------------------
;아이템の自動購入処理
;-------------------------------------------------
@AUTO_BUYING
;로션
IF (FLAG:34 & 1) && MONEY >= 200 && ITEM:25 == 0
	ITEM:25 += 1
	MONEY -= 200
ENDIF
;;비디오테이프
;IF (FLAG:34 & 2) && MONEY >= 500 && ITEM:6 && ITEM:28 == 0
;	ITEM:28 += 1
;	MONEY -= 500
;ENDIF
;콘돔
IF (FLAG:34 & 8)
	REPEAT 10
		IF MONEY >= 100 && ITEM:24 < 10
			ITEM:24 += 1
			MONEY -= 100
		ENDIF
	REND
ENDIF

;-------------------------------------------------
;아이템の自動購入処理
;-------------------------------------------------
@AUTO_ITEMUSE
;로션
SIF TALENT:MASTER:55 == 0
	RETURN

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSE
		LOCAL += COUNT
	ENDIF
REND

;영양제
IF (FLAG:76 & 1)
	REPEAT CHARANUM
		IF COUNT == 0
			CONTINUE
		ELSEIF BASE:COUNT:0 == MAXBASE:COUNT:0
			CONTINUE
		ELSE
			LOCAL:1 = MAXBASE:COUNT:0 - BASE:COUNT:0
			IF LOCAL:1 <= 499
				LOCAL:1 = 500
			ELSEIF LOCAL:1 <= 1000 && LOCAL:1 >= 500
				LOCAL:1 = 1000
			ELSEIF LOCAL:1 <= 1500 && LOCAL:1 >= 999
				LOCAL:1 = 1500
			ELSEIF LOCAL:1 <= 2000 && LOCAL:1 >= 1499
				LOCAL:1 = 2000
			ELSEIF LOCAL:1 <= 2500 && LOCAL:1 >= 1999
				LOCAL:1 = 2500
			ELSEIF LOCAL:1 <= 3000 && LOCAL:1 >= 2499
				LOCAL:1 = 3000
			ELSEIF LOCAL:1 <= 3500 && LOCAL:1 >= 2999
				LOCAL:1 = 3500
			ELSEIF LOCAL:1 <= 4000 && LOCAL:1 >= 3499
				LOCAL:1 = 4000
			ELSEIF LOCAL:1 <= 4500 && LOCAL:1 >= 3999
				LOCAL:1 = 4500
			ELSEIF LOCAL:1 <= 5000 && LOCAL:1 >= 4499
				LOCAL:1 = 5000
			ENDIF
			LOCAL:2 = LOCAL:1 / 500
			SIF MONEY < 1000 * LOCAL:2
				BREAK
			PRINTFORML 《%NAME:COUNT%에게 {LOCAL:2}번 영양제를 먹였습니다》
			BASE:COUNT:0 = MAXBASE:COUNT:0
			MONEY -= LOCAL:2 * 1000
			LOCAL:1 = 0
			LOCAL:2 = 0
		ENDIF
	REND
ENDIF

VARSET LOCAL, 0
IF (FLAG:76 & 8)
	REPEAT CHARANUM
		IF LOCAL == 0
			CONTINUE
		ELSEIF JUEL:COUNT:100 <= 0
			CONTINUE
		ELSE
			$REPEAT_OKOU
			LOCAL:1 = JUEL:COUNT:100
			LOCAL:1 /= 2
			LOCAL:2 += 1
			SIF LOCAL:1 != 0
				GOTO REPEAT_OKOU
			SIF MONEY < 3000 * LOCAL:2
				BREAK
			PRINTFORML 《%NAME:COUNT%에게 {LOCAL:2}번 향을 맡게 했습니다》
			JUEL:COUNT:100 = 0
			MONEY -= LOCAL:2 * 3000
			LOCAL:1 = 0
			LOCAL:2 = 0
		ENDIF
	REND
ENDIF
	
;배란유발제
IF (FLAG:76 & 2) && MONEY >= 2000 * LOCAL
	REPEAT CHARANUM
		IF COUNT == 0
			CONTINUE
		ELSEIF TALENT:COUNT:122 == 1
			CONTINUE
		ELSEIF CFLAG:COUNT:109 >= 1
			CONTINUE
		ELSE
			CFLAG:COUNT:109 = 1
			SIF PBAND:303 == 3
				CFLAG:COUNT:109 += RAND:2
			MONEY -= 2000
			PRINTFORML 《%NAME:COUNT%에게 배란유발제를 먹였습니다》
		ENDIF
	REND
ENDIF
;배란억제제
IF (FLAG:76 & 4) && MONEY >= 50000 * LOCAL
	REPEAT CHARANUM
		IF COUNT == 0
			CONTINUE
		ELSEIF TALENT:COUNT:122 == 1
			CONTINUE
		ELSEIF CFLAG:COUNT:109 == -1
			CONTINUE
		ELSE
			CFLAG:COUNT:109 = -1
			MONEY -= 50000
			PRINTFORML 《%NAME:COUNT%에게 배란억제제를 먹였습니다》
		ENDIF
	REND
ENDIF
