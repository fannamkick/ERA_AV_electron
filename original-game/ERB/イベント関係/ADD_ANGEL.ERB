;===========================================================
;천사の取得
;===========================================================
@ADD_ANGEL

; 経験をクリア
FOR LOCAL, 0, 150
	EXP:LOCAL = 0
NEXT
; 珠をクリア
FOR LOCAL, 0, 100
	JUEL:LOCAL = 0
	PALAM:LOCAL = 0
NEXT
; 能力をクリア
FOR LOCAL, 0, 100
	SIF LOCAL == 50 || LOCAL == 51 || LOCAL == 52 || LOCAL == 81
		CONTINUE
	ABL:LOCAL = 0
NEXT
; 刻印をクリア
FOR LOCAL, 0, 4
	MARK:LOCAL = 0
NEXT

;CFLAGをクリアする前にFLAG関係を戻す
SIF CFLAG:684 == 1
	FLAG:557 -= 1
SIF CFLAG:60 == 1
	CFLAG:MASTER:65 = 0

; CFLAGをクリア
FOR LOCAL, 0, 999
	SIF LOCAL == 40
		CONTINUE
	SIF LOCAL == 41
		CONTINUE
	SIF LOCAL == 42
		CONTINUE
	SIF LOCAL == 170
		CONTINUE
	SIF LOCAL == 171
		CONTINUE
	SIF LOCAL == 172
		CONTINUE
	SIF LOCAL == 173
		CONTINUE
	SIF LOCAL == 174
		CONTINUE
	SIF LOCAL == 175
		CONTINUE
	SIF LOCAL == 176
		CONTINUE
	SIF LOCAL == 177
		CONTINUE
	SIF LOCAL == 178
		CONTINUE
	SIF LOCAL == 179
		CONTINUE
	SIF LOCAL == 180
		CONTINUE
	SIF LOCAL == 600
		CONTINUE
	SIF LOCAL == 602
		CONTINUE
	SIF LOCAL == 609 && (TALENT:121 || TALENT:122)
		CONTINUE
	SIF LOCAL == 610 && (TALENT:121 || TALENT:122)
		CONTINUE
	SIF LOCAL == 611 && (TALENT:121 || TALENT:122)
		CONTINUE
	CFLAG:LOCAL = 0
NEXT

