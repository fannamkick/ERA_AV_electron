;========================================================
;調教時メッセージ
;========================================================
;eratohoRR v1.31.6より一部改変して流用
;========================================================
;調教ソース確認後に表示されるテキスト
;SOURCR.ERBより呼び出し
;主にパラメータの上昇による反応や, 「その調教の結果どういう事が起こったか」を描写するのに使う
;表示される順番はTRAIN_MESSAGE_B→TRAIN_MESSAGE_Aである事に注意
;>@TEXT→@TRAIN_MESSAGE_Cに改名
;@TRAIN_MESSAGE_CをTRAIN_MESSAGE_Aにマージ
;失神パッチ適応用の処理を追加
;========================================================
@TRAIN_MESSAGE_A
;調教テキスト省略設定の場合は戻る
SIF (FLAG:6 & 1)
	RETURN 0

PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥

;--------------------------------------------------------
;스마타で사정
;--------------------------------------------------------
IF TFLAG:9 == 1
	;투구비비기の場合
	IF SELECTCOM == 122
		;相手も사정
		IF TFLAG:10 >= 1
			PRINTL 두 사람은 동시에 사정해, 서로의 페니스에 정액을 뿌렸다…
		;主人のみ사정
		ELSE
			PRINTFORML 뿜어져나온 정액이 %CALLNAME:TARGET%의 페니스를 더럽혔다…
		ENDIF
	;스마타
	ELSE
	SIF SELECTCOM == 33
		PRINTFORML 뿜어져나온 정액이 %CALLNAME:TARGET%의 몸을 더럽혔다…
	SIF SELECTCOM == 62
		PRINTL 뿜어져나온 정액이 두 사람의 몸을 더럽혔다…
	ENDIF

;--------------------------------------------------------
;스마타で대량사정
;--------------------------------------------------------
ELSEIF TFLAG:9 == 2
	;투구비비기の場合
	IF SELECTCOM == 122
		;相手も사정
		IF TFLAG:10 >= 1
			PRINTL 두 사람은 동시에 사정해, 서로의 페니스에 대량의 정액을 뿌렸다…
		;主人のみ사정
		ELSE
			PRINTFORML 뿜어져나온 대량의 정액이 %CALLNAME:TARGET%의 페니스를 질퍽질퍽하게 더럽혔다…
		ENDIF
	;스마타
	ELSE
	SIF SELECTCOM == 33
		PRINTFORML %CALLNAME:TARGET%의 몸은 뿜어져나온 대량의 정액에 범벅이 되었다…
	SIF SELECTCOM == 62
		PRINTL 두 사람의 몸은 뿜어져나온 대량의 정액에 범벅이 되었다…
	ENDIF
ENDIF

;--------------------------------------------------------
;촉수が사정
;--------------------------------------------------------
SIF TFLAG:15 == 1
	PRINTFORML %CALLNAME:TARGET%에게 들러붙은 촉수가 끈적끈적한 체액을 뿜어냈다…

;--------------------------------------------------------
;촉수が대량사정
;--------------------------------------------------------
SIF TFLAG:15 == 2
	PRINTFORML %CALLNAME:TARGET%의 전신에 들러붙은 촉수가 일제히 끈적끈적한 체액을 뿜어냈다…

;--------------------------------------------------------
;犬が사정
;--------------------------------------------------------
IF TFLAG:16 > 0
	IF SELECTCOM == 21 || SELECTCOM == 34
		PRINTFORML %CALLNAME:TARGET%의 질내에, 짐승의 악취가 나는 뜨거운 정액이 뿜어져나왔다…
	ELSEIF SELECTCOM == 27
		PRINTFORML %CALLNAME:TARGET%의 직장에, 짐승의 악취가 나는 뜨거운 정액이 뿜어져나왔다…
	ELSEIF SELECTCOM == 31
		PRINTFORML %CALLNAME:TARGET%의 입속에, 짐승의 악취가 나는 뜨거운 정액이 뿜어져나왔다…
	ELSEIF SELECTCOM == 30
		PRINTFORML %CALLNAME:TARGET%의 손바닥에, 짐승의 악취가 나는 뜨거운 정액이 뿜어져나왔다…
	ENDIF
ENDIF
;--------------------------------------------------------
;조수를 범한다で사정
;--------------------------------------------------------
IF TFLAG:7 > 0
	SIF TFLAG:7 == 1
		PRINTFORML %CALLNAME:TARGET%의 눈앞에서, %CALLNAME:ASSI%의 안쪽에 정액을 쏟아부었다…
	SIF TFLAG:7 == 2
		PRINTFORML %CALLNAME:TARGET%의 눈앞에서, %CALLNAME:ASSI%의 안쪽에 흘러넘칠 정도로 정액을 쏟아부었다…
	SIF ABL:11 > 3 || ABL:32 > 2 && TFLAG:899 <= 1
		PRINTFORML %타겟은()% 그 모습을 부러운듯이 바라보고 있다…
ENDIF

;--------------------------------------------------------
;フェラ系コマンドや파이즈리で, 사정＋절정の際の冠頭文(修正)
;--------------------------------------------------------
IF TFLAG:0 > 0 && TFLAG:29 > 0
	IF SELECTCOM == 32
		IF RAND:3 == 0
			PRINTFORM 양 가슴에 눌려서 감싸이는 압박감에
		ELSEIF RAND:2 == 0
			PRINTFORM ――
			SIF TALENT:76
				PRINTFORM 요염하게 
			IF TALENT:114
				PRINTFORM 흘러넘칠 것만같은 유방을 
			ELSEIF TALENT:110
				PRINTFORM 풍만한 유방을 
			ELSEIF TALENT:109
				PRINTFORM 조금 부족한 느낌이 드는 유방을 
			ELSEIF TALENT:116
				PRINTFORM 납짝한 가슴을 
			ELSE
				PRINTFORM 부드러운 유방을 
			ENDIF
			SIF TALENT:85
				PRINTFORM 사랑스럽게 
			PRINTFORM 문질러오는 
			PRINTFORM %CALLNAME:TARGET%에게 
		ELSE
			PRINTFORM 음경이 %CALLNAME:TARGET%의 
			IF TALENT:114
				PRINTFORM 흘러넘칠 듯한 유방에 
			ELSEIF TALENT:110
				PRINTFORM 포근한 가슴에 
			ELSEIF TALENT:109
				PRINTFORM 살짝 부풀어오른 유방에 
			ELSEIF TALENT:116
				PRINTFORM 부드러운 가슴의 피부에 
			ELSE 
				PRINTFORM 모양 좋은 유방에 
			ENDIF
			IF TALENT:110 || TALENT:114
				PRINTFORM 파묻히는 감촉에
			ELSE
				PRINTFORM 쓸어올려지는 감촉에
			ENDIF
		ENDIF
	ELSE
		IF RAND:4 == 0
			PRINT 달라붙어오는 입안 점막의 자극에
		ELSEIF RAND:3 == 0
			PRINT 뒤에서부터 귀두를 기어다니는 혀의 감각에
		ELSEIF RAND:2 == 0
			PRINT 음경을 
			SIF TALENT:76
				PRINT 음란하게 
			SIF TALENT:85
				PRINT 관능적으로 
			PRINT 훑는 목구멍의 쾌감에
		ELSEIF RAND:2 == 0
			PRINT 귀두 뒷쪽을 문질러올리는 입술의 부드러움에
		ELSE
			PRINT 요도를 핥는 혀끝의 움직임에
		ENDIF
	ENDIF
	;더블 펠라, 더블 파이즈리
	IF SELECTCOM == 68 || SELECTCOM == 71
		IF RAND:4 == 0
			PRINTFORMW , %플레이어가()% 넘쳐오는 정액을 털어놓자 
		ELSEIF RAND:3 == 0
			PRINTFORMW  자극을 받아, %플레이어는()% 사정을 막을 수가 없었다.
		ELSEIF RAND:2 == 0
			PRINTFORML  짜내어진 %CALLNAME:MASTER%의 정액이
			PRINTFORMW %CALLNAME:TARGET%들의 몸을 더럽혀갔다.
			PRINTFORM 그것이 방아쇠가 되었는지 
		ELSE
			PRINTFORMW  격렬하게 욕정해, %플레이어는()% 두사람의 상기된 얼굴을 향해 사정을 했다.
			PRINTFORM 그리고 
		ENDIF
	;두개 펠라
	ELSEIF SELECTCOM == 6
		IF TFLAG:6
			PRINTFORMW , %플레이어와()% %플레이어가()% 넘쳐오는 정액을 털어놓자마자, 
		ELSE
			PRINTFORMW , %플레이어가()% 넘쳐오는 정액을 털어놓자 
		ENDIF
	;その他
	ELSE
		IF RAND:4 == 0
			PRINTFORMW , %플레이어가()% 넘쳐오는 정액을 털어놓자 
		ELSEIF RAND:3 == 0
			PRINTFORMW  자극을 받아, %플레이어는()% 사정을 막을 수가 없었다.
		ELSEIF RAND:2 == 0
