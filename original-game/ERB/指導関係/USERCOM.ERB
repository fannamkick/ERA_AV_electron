$INPUT_LOOP
INPUT

IF RESULT < 0 || RESULT > 8
	GOTO INPUT_LOOP
ELSEIF RESULT == 8 && CFLAG:42 != 80 && CFLAG:42 != 81
	GOTO INPUT_LOOP
ELSEIF CFLAG:33 != RESULT
	CFLAG:33 = RESULT
	PRINTFORM 《%CALLNAME:TARGET%에게 사정하는 곳을 
	CALL SHOOT_POSITION_PRINT
	SIF RESULT == 1
		PRINT 으
	PRINT 로 변경했습니다》
	WAIT
	RETURN 1
ELSE
	GOTO INPUT_LOOP
ENDIF

RETURN 1

