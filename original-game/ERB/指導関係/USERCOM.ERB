PRINT >

;-------------------------------------------------
;지도중のユーザーコマンド判定
;-------------------------------------------------
@USERCOM
IF RESULT == 120
	CALL SHOW_EQUIP
	RETURN 1
ELSEIF RESULT == 121
	CALL STAIN_INFO
	RETURN 1
ELSEIF RESULT == 122
	CALL SHOW_INFO
	WAIT
	RETURN 1
						;****슬라임パッチ追加ここから****
ELSEIF RESULT == 200 && ASSI > 0 && TEQUIP:90 == 0 && TEQUIP:150 == 0
						;****슬라임パッチ追加ここまで****
	IF ASSIPLAY
		ASSIPLAY = 0
		PLAYER = MASTER
	ELSE
		ASSIPLAY = 1
		PLAYER = ASSI
	ENDIF
	RETURN 1
ELSEIF RESULT == 202
	T = TARGET
	TARGET = PLAYER
	CALL SHOW_INFO
	WAIT
	TARGET = T
	RETURN 1
ELSEIF RESULT == 300 && TALENT:PLAYER:560 && TALENT:PLAYER:121 == 0
	PRINTFORM 《%플레이어는()% 페니스를 구현시켰다》
	SIF CFLAG:PLAYER:18 == 0
		TALENT:PLAYER:1 = 1
	TALENT:PLAYER:121 = 1
	WAIT
	RETURN 1
ELSEIF RESULT == 300 && TALENT:PLAYER:560 && TALENT:PLAYER:121 == 1
	PRINTFORM 《%플레이어는()% 구현시킨 페니스를 소멸시켰다》
	SIF CFLAG:PLAYER:18 == 0
		TALENT:PLAYER:1 = 0
	TALENT:PLAYER:121 = 0
	WAIT
	RETURN 1
ELSEIF RESULT == 400
	CALL SHOOT_POSITION
ELSEIF RESULT == 500 && ITEM:24 >= 1 && TEQUIP:35 == 0 && (TALENT:PLAYER:121 || TALENT:PLAYER:122)
	CALL SET_CONDOM
ELSEIF RESULT == 990
	CALL COMSEQ_REGISTER_BEGIN
	RETURN 1
ELSEIF RESULT == 991
	CALL SHOW_COMSEQ_REGISTER
	RETURN 1
ELSEIF RESULT == 992
	CALL COMSEQ_REGISTER_TRAIN
	RETURN 1

ELSEIF RESULT == 888
	CALL CHEAT_TRAIN
	RETURN 1

ELSEIF RESULT == 999

;終了時に失神していた場合は口上を表示しない
	IF TFLAG:899 >= 1 && FLAG:7 > 0
		IF FLAG:7 == 1
			FLAG:7 = 0
			TFLAG:860 = 1
		ELSEIF FLAG:7 == 2
			FLAG:7 = 0
			TFLAG:860 = 2
		ENDIF
	ENDIF
	BEGIN AFTERTRAIN
	RETURN 1
ENDIF
RETURN 0

