;-------------------------------------------------
;조수를 범하게 한다
;助手系コマンド: 調教対象に조수를 범하게 한다
;-------------------------------------------------
@COM65

;近親チェック
TFLAG:14 = 0
CALL INCEST

PRINTL 조수를 범하게 한다

;-------------------------------------------------
;実行できるかの判定
;-------------------------------------------------
A = 0
S = 0

;すべての命令に共通の要素を考慮
;(従順が高いと命令に従いやすいなど)
CALL COM_ORDER

;ABL:욕망
IF ABL:11
	SIF S
		PRINT  + 
	A += ABL:11 * 2
	PRINTS ABLNAME:11
	PRINTV 'LV,ABL:11,'(,ABL:11 * 2,')
	S = 1
ENDIF
;ABL:봉사정신
IF ABL:16
	SIF S
		PRINT  + 
	A += ABL:16 * 4
	PRINTS ABLNAME:16
	PRINTV 'LV,ABL:16,'(,ABL:16 * 4,')
	S = 1
ENDIF

IF MARK:1
	SIF S
		PRINT  + 
	A += MARK:1 * 2
	PRINTS MARKNAME:1
	PRINTV 'LV,MARK:1,'(,MARK:1 * 2,')
	S = 1
ENDIF


;PALAM:욕정
IF PALAM:5 < PALAMLV:1
	L = 0
ELSEIF PALAM:5 < PALAMLV:2
	L = 1
ELSEIF PALAM:5 < PALAMLV:3
	L = 2
ELSEIF PALAM:5 < PALAMLV:4
	L = 3
ELSEIF PALAM:5 < PALAMLV:5
	L = 4
ELSE
	L = 5
ENDIF
IF L
	SIF S
		PRINT  + 
	A += L * 2
	PRINTS PALAMNAME:5
	PRINTV 'LV,L,'(,L * 2,')
	S = 1
ENDIF

;수줍음
IF TALENT:35
	PRINT  - 
	A -= 1
	PRINTS TALENTNAME:35
	PRINTV '(,1,')
	S = 1
ENDIF
;헌신적
IF TALENT:63
	SIF S
		PRINT  + 
	A += 6
	PRINTS TALENTNAME:63
	PRINTV '(,6,')
	S = 1
ENDIF
;쾌감에 솔직
IF TALENT:70
	SIF S
		PRINT  + 
	A += 2
	PRINTS TALENTNAME:70
	PRINTV '(,2,')
	S = 1
ENDIF
;쾌감을 부정
IF TALENT:71
	PRINT  - 
	A -= 2
	PRINTS TALENTNAME:71
	PRINTV '(,2,')
	S = 1
ENDIF
;女嫌い
IF TALENT:79 && TALENT:PLAYER:122 == 0
	PRINT  - 
	A -= 5
	PRINTS TALENTNAME:79
	PRINTV '(,5,')
	S = 1
ENDIF
;愛
IF TALENT:85 && ASSIPLAY == 0
	SIF S
		PRINT  + 
	A += 5
	PRINTS TALENTNAME:85
	PRINTV '(,5,')
	S = 1
ENDIF

;조수가 처녀
IF EXP:PLAYER:0 == 0
	PRINT  - 
	A -= 15
	PRINT 조수가 처녀
	PRINTV '(,15,')
	S = 1
ENDIF

;助手が調教対象の肉親
IF TFLAG:14 == 1
	PRINT  - 
	A -= 10
	PRINT 조수가 모친
	PRINTV '(,10,')
	S = 1
ELSEIF TFLAG:14 == 2
	PRINT  - 
	A -= 20
	PRINT 조수가 딸
	PRINTV '(,20,')
	S = 1
ELSEIF TFLAG:14 == 3
	PRINT  - 
	A -= 5
	PRINT 조수가 언니
	PRINTV '(,5,')
	S = 1
ELSEIF TFLAG:14 == 4
	PRINT  - 
	A -= 5
	PRINT 조수가 여동생
	PRINTV '(,5,')
	S = 1
ENDIF

;合計を表示(40以上で実行)
PRINT  = 
PRINTV A

V = 40
SIF A < V
	PRINT  < 
SIF A == V
	PRINT  = 
SIF A > V
	PRINT  > 
PRINT 실행치 
PRINTV V

WAIT

;実行できない
SIF A < V
	RETURN 0

SAVESTR:0 = 조수를 범하게 한다
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;実行決定
;-------------------------------------------------
;助手の처녀を奪うかどうかの確認
$INPUT_LOOP_01
IF TALENT:ASSI:0
	PRINTFORML %CALLNAME:ASSI%의 처녀를 %CALLNAME:TARGET%에게 빼앗게 합니까?
	PRINTL  [0] - 네
	PRINTL  [1] - 아니오
	INPUT
	IF RESULT == 1
		RETURN 0
	ELSEIF RESULT != 0
		GOTO INPUT_LOOP_01
	ENDIF
ENDIF
;콘돔を使うかの確認
$INPUT_LOOP_02
IF TEQUIP:37 == 0 && ITEM:24 && (TALENT:TARGET:121 || TALENT:TARGET:122)
	PRINTFORML %CALLNAME:TARGET%에게 콘돔을 사용하게 합니까?
	PRINTL  [0] - 사용하게 한다
	PRINTL  [1] - 그냥 하게 한다
	INPUT
	IF RESULT == 0
		PRINTFORML %타겟은()% 콘돔을 장착했다
		ITEM:24 -= 1
		TEQUIP:37 = 1
	ELSEIF RESULT != 1
		GOTO INPUT_LOOP_02
	ENDIF
ENDIF
;-------------------------------------------------
;사정게이지チェック(후타나리の場合)
;-------------------------------------------------
B = 0

;ABL:기교をみる
IF ABL:12 == 0
	B = 50
ELSEIF ABL:12 == 1
	B = 300
ELSEIF ABL:12 == 2
	B = 800
ELSEIF ABL:12 == 3
	B = 1500
ELSEIF ABL:12 == 4
	B = 2000
ELSE
	B = 3200
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES B , 0.80
ELSEIF ABL:10 == 1
	TIMES B , 0.90
ELSEIF ABL:10 == 2
	TIMES B , 1.00
ELSEIF ABL:10 == 3
	TIMES B , 1.10
ELSEIF ABL:10 == 4
	TIMES B , 1.20
ELSE
	TIMES B , 1.30
ENDIF

;ABL:봉사정신をみる
IF ABL:16 == 0
	TIMES B , 0.50
ELSEIF ABL:16 == 1
	TIMES B , 0.80
ELSEIF ABL:16 == 2
	TIMES B , 1.20
ELSEIF ABL:16 == 3
	TIMES B , 1.50
ELSEIF ABL:16 == 4
	TIMES B , 1.80
ELSE
	TIMES B , 2.40
ENDIF

;助手のABL:V감각をみる
IF ABL:ASSI:2 == 0
	TIMES B , 0.50
ELSEIF ABL:ASSI:2 == 1
	TIMES B , 0.80
ELSEIF ABL:ASSI:2 == 2
	TIMES B , 1.00
ELSEIF ABL:ASSI:2 == 3
	TIMES B , 1.20
ELSEIF ABL:ASSI:2 == 4
	TIMES B , 1.50
ELSE
	TIMES B , 2.00
ENDIF

;助手のEXP:V경험をみる
IF EXP:ASSI:0 < EXPLV:1
	TIMES B , 0.20
ELSEIF EXP:ASSI:0 < EXPLV:2
	TIMES B , 0.50
ELSEIF EXP:ASSI:0 < EXPLV:3
	TIMES B , 0.80
ELSEIF EXP:ASSI:0 < EXPLV:4
	TIMES B , 1.00
ELSEIF EXP:ASSI:0 < EXPLV:5
	TIMES B , 1.20
ELSE
	TIMES B , 1.40
ENDIF

;ABL:C感覚をみる
IF ABL:0 == 0
	TIMES B , 1.00
ELSEIF ABL:0 == 1
	TIMES B , 1.50
ELSEIF ABL:0 == 2
	TIMES B , 2.00
ELSEIF ABL:0 == 3
	TIMES B , 2.50
ELSEIF ABL:0 == 4
	TIMES B , 3.50
ELSE
	TIMES B , 5.00
ENDIF

SIF TALENT:PLAYER:121 || TALENT:PLAYER:122
	BASE:PLAYER:2 += B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:1 += 40
LOSEBASE:1 += 220

SOURCE:13 = 1500
SOURCE:14 = 800

;ABL:봉사정신をみる
IF ABL:16 == 0
	SOURCE:0 = 800
	SOURCE:4 = 1600
	SOURCE:5 = 200
ELSEIF ABL:16 == 1
	SOURCE:0 = 1400
	SOURCE:4 = 1900
	SOURCE:5 = 400
ELSEIF ABL:16 == 2
	SOURCE:0 = 2000
	SOURCE:4 = 2300
	SOURCE:5 = 750
ELSEIF ABL:16 == 3
	SOURCE:0 = 2500
	SOURCE:4 = 2700
	SOURCE:5 = 1150
ELSEIF ABL:16 == 4
	SOURCE:0 = 2900
	SOURCE:4 = 3100
	SOURCE:5 = 1750
ELSE
	SOURCE:0 = 3200
	SOURCE:4 = 3500
	SOURCE:5 = 2500
ENDIF


;ABL:기교をみる
IF ABL:12 == 0
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 0.50
	TIMES SOURCE:5 , 0.50
ELSEIF ABL:12 == 1
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 0.80
	TIMES SOURCE:5 , 0.80
ELSEIF ABL:12 == 2
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 1.00
	TIMES SOURCE:5 , 1.00
ELSEIF ABL:12 == 3
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 1.50
	TIMES SOURCE:5 , 1.50
ELSEIF ABL:12 == 4
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 2.00
	TIMES SOURCE:5 , 2.00
ELSEIF ABL:12 == 5
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 2.50
	TIMES SOURCE:5 , 2.50
ELSEIF ABL:12 == 6
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 3.00
	TIMES SOURCE:5 , 3.00
ELSEIF ABL:12 == 7
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 3.50
	TIMES SOURCE:5 , 3.50
ELSE
	TIMES SOURCE:0 , 0.50
	TIMES SOURCE:4 , 4.00
	TIMES SOURCE:5 , 4.00
ENDIF

;調教対象・助手が共に女ならABL:레즈끼をみる
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	IF ABL:22 == 0
		TIMES SOURCE:4 , 0.20
		TIMES SOURCE:5 , 0.20
	ELSEIF ABL:22 == 1
		TIMES SOURCE:4 , 0.40
		TIMES SOURCE:5 , 0.40
	ELSEIF ABL:22 == 2
		TIMES SOURCE:4 , 0.60
		TIMES SOURCE:5 , 0.60
	ELSEIF ABL:22 == 3
		TIMES SOURCE:4 , 0.80
		TIMES SOURCE:5 , 0.80
	ELSEIF ABL:22 == 4
		TIMES SOURCE:4 , 1.00
		TIMES SOURCE:5 , 1.00
	ELSE
		TIMES SOURCE:4 , 1.20
		TIMES SOURCE:5 , 1.20
	ENDIF
ENDIF

;調教対象・助手が共にオトコならABL:ホモっ気をみる
IF TALENT:122 && TALENT:PLAYER:122
	IF ABL:23 == 0
		TIMES SOURCE:4 , 0.20
		TIMES SOURCE:5 , 0.20
	ELSEIF ABL:23 == 1
		TIMES SOURCE:4 , 0.40
		TIMES SOURCE:5 , 0.40
	ELSEIF ABL:23 == 2
		TIMES SOURCE:4 , 0.60
		TIMES SOURCE:5 , 0.60
	ELSEIF ABL:23 == 3
		TIMES SOURCE:4 , 0.80
		TIMES SOURCE:5 , 0.80
	ELSEIF ABL:23 == 4
		TIMES SOURCE:4 , 1.00
		TIMES SOURCE:5 , 1.00
	ELSE
		TIMES SOURCE:4 , 1.20
		TIMES SOURCE:5 , 1.20
	ENDIF
ENDIF

;조수가 처녀
IF TALENT:ASSI:0 == 1
	TIMES SOURCE:13 , 20.00
	TIMES SOURCE:14 , 3.00
	TALENT:PLAYER:0 = 0

	PRINTL ＜조수가 처녀＞

	EXP:50 += 1
	PRINTFORML %EXPNAME:50% +1

	IF ABL:10 < 3
		PRINTFORML 그리고 %ABLNAME:10%가 3이 되었다
		ABL:10 = 3
	ENDIF

	;助手の初体験を記録
	IF CFLAG:ASSI:15 == 0
		CFLAG:ASSI:15 = 1
		CSTR:ASSI:0 = %NAME:TARGET%
		CFLAG:ASSI:160 = BASE:9
		CFLAG:ASSI:161 = DAY:1
		CFLAG:ASSI:162 = DAY:2
		CFLAG:ASSI:163 = 14
		CFLAG:ASSI:164 = 1
	ENDIF
ENDIF

;調教者(=助手)のV경험と성교경험UP
EXP:PLAYER:0 += 1
EXP:PLAYER:5 += 1

;助手が調教対象の肉親
IF TFLAG:14 == 1 
	IF TALENT:122
		PRINTL ＜강제모자상간＞
	ELSE
		PRINTL ＜강제모녀상간＞
	ENDIF
ELSEIF TFLAG:14 == 2
	IF TALENT:122
		PRINTL ＜강제부녀상간＞
	ELSE
		PRINTL ＜강제모녀상간＞
	ENDIF
ELSEIF TFLAG:14 == 3
	IF TALENT:122
		PRINTL ＜강제남매상간1＞
	ELSE
		PRINTL ＜강제자매상간＞
	ENDIF
ELSEIF TFLAG:14 == 4
	IF TALENT:122
		PRINTL ＜강제남매상간2＞
	ELSE
		PRINTL ＜강제자매상간＞
	ENDIF
ELSEIF TFLAG:14 == 6
	IF TALENT:122 == 0
		PRINTL ＜강제사촌상간＞
	ENDIF
ENDIF
;母や娘を自分の手で犯したら屈従と逸脱3倍
IF TFLAG:14 == 1 || TFLAG:14 == 2
	TIMES SOURCE:13 , 3.00
	TIMES SOURCE:14 , 3.00
	IF ABL:10 < 3
		PRINTFORML 그리고 %ABLNAME:10%가 3이 되었다
		ABL:10 = 3
	ENDIF
;언니か妹を自分の手で犯したら屈従と逸脱2倍
ELSEIF TFLAG:14 == 3 || TFLAG:14 == 4
	TIMES SOURCE:13 , 2.00
	TIMES SOURCE:14 , 2.00
	IF ABL:10 < 2
		PRINTFORML 그리고 %ABLNAME:10%가 2가 되었다
		ABL:10 = 2
	ENDIF
;従姉か従弟を自分の手で犯したら屈従と逸脱1．5倍
ELSEIF TFLAG:14 == 5 || TFLAG:14 == 6
	TIMES SOURCE:13 , 1.50
	TIMES SOURCE:14 , 1.50
	IF ABL:10 < 2
		PRINTFORML 그리고 %ABLNAME:10%가 2가 되었다
		ABL:10 = 2
	ENDIF
ENDIF

;調教対象が동정なら동정상실
IF TALENT:1
	TALENT:1 = 0
	PRINTFORML 【동정상실】
	;初体験の相手を記録
	SIF CFLAG:18 == 0
		CFLAG:18 = 1
	IF CFLAG:611 == 2
		CFLAG:611 = 3
	ENDIF
	CSTR:2 = %NAME:ASSI%
	TFLAG:133 = 1
ENDIF

TFLAG:14 = 0

;-------------------------------------------------
;사정チェック
;-------------------------------------------------
S = BASE:PLAYER:2
EJAC = MAXBASE:PLAYER:2

IF  S > EJAC * 2
	E = 2
ELSEIF S > EJAC
	E = 1
ELSE
	E = 0
ENDIF

IF E
;사정している
	TIMES SOURCE:4 , 3.00

	;ABL:정액중독をみる
	IF ABL:32 == 0
		SOURCE:7 = 0
		TIMES SOURCE:5 , 2.00
		TIMES SOURCE:13, 2.00
	ELSEIF ABL:32 == 1
		SOURCE:7 = 50
		TIMES SOURCE:5 , 2.50
		TIMES SOURCE:13, 1.60
	ELSEIF ABL:32 == 2
		SOURCE:7 = 150
		TIMES SOURCE:5 , 3.00
		TIMES SOURCE:13, 1.00
	ELSEIF ABL:32 == 3
		SOURCE:7 = 300
		TIMES SOURCE:5 , 4.50
		TIMES SOURCE:13, 0.70
	ELSEIF ABL:32 == 4
		SOURCE:7 = 600
		TIMES SOURCE:5 , 6.00
		TIMES SOURCE:13, 0.40
	ELSE
		SOURCE:7 = 1200
		TIMES SOURCE:5 , 8.00
		TIMES SOURCE:13, 0.10
	ENDIF
ENDIF

;대량사정
IF E == 2
	TIMES SOURCE:7 , 2.00
	TIMES SOURCE:5 , 1.50

	EXP:PLAYER:3 += 2
	EXP:20 += 1
	SETCOLOR 0x00ffff
	PRINTFORML %NAME:PLAYER% 대량사정⚡
	RESETCOLOR
	PRINTL 정액경험 +1
	;精液汚れ
	STAIN:PLAYER:2 |= 4

	BASE:PLAYER:2 -= EJAC*2
	SIF BASE:PLAYER:2 >= EJAC
		BASE:PLAYER:2 = EJAC-1

	;助手が사정フラグ
	TFLAG:6 = 2
;通常の사정
ELSEIF E == 1
	EXP:PLAYER:3 += 1
	SETCOLOR 0x00ffff
	PRINTFORML %NAME:PLAYER% 사정⚡
	RESETCOLOR
	;精液汚れ
	STAIN:PLAYER:2 |= 4

	BASE:PLAYER:2 -= EJAC
	SIF BASE:PLAYER:2 >= EJAC
		BASE:PLAYER:2 = EJAC-1

	;助手が사정フラグ
	TFLAG:6 = 1
ENDIF

IF TALENT:119 || TALENT:121 || TALENT:122
	;奴隷のP⇔調教者のVの汚れが移動
	STAIN:2 |= STAIN:PLAYER:3
	STAIN:PLAYER:3 |= STAIN:2
ENDIF

IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +10
	EXP:40 += 10
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +10
	EXP:41 += 10
ENDIF

;굴복각인2に相当
TFLAG:200 = 2

VARSET LOCAL, 0
IF ABL:20 <= 1
	SIF TFLAG:600 == 1
		LOCAL = 8
	LOCAL = 1
ELSEIF ABL:20 <= 2
	SIF TFLAG:600 == 1
		LOCAL = 16
	LOCAL = 2
ELSEIF ABL:20 <= 3
	SIF TFLAG:600 == 1
		LOCAL = 32
	LOCAL = 3
ELSEIF ABL:20 <= 4
	SIF TFLAG:600 == 1
		LOCAL = 64
	LOCAL = 4
ELSE
	SIF TFLAG:600 == 1
		LOCAL = 128
	LOCAL = 5
ENDIF


EXP:33 += LOCAL
PRINTFORML %EXPNAME:33%+{LOCAL}

TFLAG:100 = 1

;굴복각인2に相当
TFLAG:200 = 2

RETURN 1
