@EVENTTRAIN
#PRI
;主人公の사정を0に
BASE:MASTER:2 = 0
;いちおう調教対象と助手も
BASE:TARGET:2 = 0
SIF ASSI >= 0
	BASE:ASSI:2 = 0
BASE:TARGET:3 = 0
BASE:MASTER:4 = 0

;사정フラグ, 처녀상실フラグなどをリセット
REPEAT 1000
	TFLAG:COUNT = 0
REND

;前回の調教テキストを空に
SAVESTR:0 = 　

;調教者は誰か
IF ASSIPLAY == 0
	PLAYER = MASTER
ELSE
	PLAYER = ASSI
ENDIF

;항상발정ボーナス: 潤滑と欲情が3000からスタート
IF TALENT:TARGET:271
	PALAM:TARGET:3 = 3000
	PALAM:TARGET:5 = 3000
ENDIF

CALL PRITRAIN_MESSAGE

;=================================================
;EVENTTRAINの後に毎ターン呼び出される関数
;=================================================
@SHOW_STATUS
DRAWLINE
PRINTV DAY+1
PRINT 주차
IF TIME == 0
	PRINTL (전반)
ELSE
	PRINTL (후반)
ENDIF
PRINTFORM %NAME:TARGET% 지도중   지도자:
IF ASSIPLAY
	PRINTS NAME:ASSI
	PRINT (조수)
ELSE
	PRINTS NAME:MASTER
ENDIF
SIF ASSI  > 0 && ASSIPLAY == 0
	PRINTFORM   조수:%NAME:ASSI%
PRINT   

CALL SHOW_EQUIP_2
CALL LIFE_BAR
CALL VITAL_BAR

;元はPRINT_PALAM TARGET
CALL NEW_PRINT_PALAM


;절정回数
SIF EX:0 || EX:1 || EX:2 || EX:3 || EX:4 || EX:5
	PRINT 　 
SIF EX:0
	PRINTFORM C절정:{EX:0}회 
SIF EX:1
	PRINTFORM V절정:{EX:1}회 
SIF EX:2
	PRINTFORM A절정:{EX:2}회 
SIF EX:3
	PRINTFORM B절정:{EX:3}회 
SIF EX:4
	PRINTFORM 분유:{EX:4}회 
SIF EX:5
	PRINTFORM 사정:{EX:5}회
SIF EX:0 || EX:1 || EX:2 || EX:3 || EX:4 || EX:5
	PRINTL 

SIF MAXBASE:2 == 0
	MAXBASE:2 = 10000
SIF MAXBASE:2 != 5000 && TALENT:133
	MAXBASE:2 = 5000
SIF MAXBASE:MASTER:2 == 0
	MAXBASE:MASTER:2 = 10000
SIF MAXBASE:MASTER:2 != 5000 && TALENT:MASTER:133
	MAXBASE:MASTER:2 = 5000
IF ASSI >= 0
	IF MAXBASE:ASSI:2 == 0
		MAXBASE:ASSI:2 = 10000
	ELSEIF MAXBASE:ASSI:2 != 0 && TALENT:ASSI:133
		MAXBASE:ASSI:2 = 5000
	ENDIF
ENDIF

IF (TALENT:MASTER:119 || TALENT:MASTER:121 || TALENT:MASTER:122) && TALENT:MASTER:135 == 0
	PRINT 사정
	BAR BASE:MASTER:2,MAXBASE:MASTER:2,32
	PRINTFORM ({BASE:MASTER:2}/{MAXBASE:MASTER:2})
	SIF TEQUIP:35
		PRINT 콘돔 착용
	PRINTL 
ENDIF

IF ASSIPLAY
	IF (TALENT:ASSI:119 || TALENT:ASSI:121 || TALENT:ASSI:122) && TALENT:ASSI:135 == 0
		PRINT 사정(조수)
		BAR BASE:ASSI:2,MAXBASE:ASSI:2,32
		PRINTFORM ({BASE:ASSI:2}/{MAXBASE:ASSI:2})
		SIF TEQUIP:36
			PRINT 콘돔 착용
		PRINTL 
	ENDIF
ENDIF

IF (TALENT:TARGET:119 || TALENT:TARGET:121 || TALENT:TARGET:122) && TALENT:TARGET:135 == 0
	PRINT 사정(
	PRINTS NAME:TARGET
	PRINT )
	BAR BASE:2,MAXBASE:2,32
	PRINTFORM ({BASE:2}/{MAXBASE:2})
	SIF TEQUIP:37
		PRINT 콘돔 착용
	PRINTL 
ENDIF

IF TALENT:TARGET:130
	SIF MAXBASE:3 == 0
		MAXBASE:3 = 10000
	PRINT 모유(
	PRINTS NAME:TARGET
	PRINT )
	BAR BASE:3,MAXBASE:3,32
	PRINTFORML ({BASE:3}/{MAXBASE:3})
ENDIF

IF TEQUIP:89
	SIF MAXBASE:MASTER:4 == 0
		MAXBASE:MASTER:4 = 10000
	PRINT 사정(개)
	BAR BASE:MASTER:4,MAXBASE:MASTER:4,32
	PRINTFORML ({BASE:MASTER:4}/{MAXBASE:MASTER:4})
ENDIF

IF TEQUIP:90
	SIF MAXBASE:MASTER:4 == 0
		MAXBASE:MASTER:4 = 10000
	PRINT 사정(촉수)
	BAR BASE:MASTER:4,MAXBASE:MASTER:4,32
	PRINTFORML ({BASE:MASTER:4}/{MAXBASE:MASTER:4})
ENDIF

						;****슬라임パッチ追加ここから****
IF TEQUIP:150
	SIF MAXBASE:MASTER:4 == 0
		MAXBASE:MASTER:4 = 10000
	PRINT 쾌감(슬라임)
	BAR BASE:MASTER:4,MAXBASE:MASTER:4,32
	PRINTFORML ({BASE:MASTER:4}/{MAXBASE:MASTER:4})
ENDIF
						;****슬라임パッチ追加ここまで****

CALL SHOW_EQUIP_1

;=================================================
;TRAINでコマンド選択時最初に呼び出されるイベント関数
;=================================================
@EVENTCOM
#PRI
;TFLAG:0~30はコマンドを選択する度に空にする
REPEAT 30
	TFLAG:COUNT = 0
REND
TFLAG:100 = 0

;=================================================
;TRAINでコマンド選択終了後に呼び出される関数
;=================================================
@EVENTCOMEND
#PRI
;調教キャラの死亡・衰弱判定
IF BASE:0 <= 0
	DRAWLINE
	;死亡時にビデオを使用していた?
	SIF TEQUIP:53
		TFLAG:34 = 1
	PRINTFORML %타겟이()% 미동도 하지 않는다
	PRINTFORML 무슨 짓을 해도 반응이 없다……
	WAIT
	BEGIN AFTERTRAIN
;瀕死時に調教を自動終了設定
ELSEIF BASE:0 < 500 && FLAG:35
	DRAWLINE
	PRINTL (체력이 한계에 도달했습니다. 지도를 종료합니다)
	WAIT
	BEGIN AFTERTRAIN
ENDIF
;連続コマンド実行時の呼び出し
IF TFLAG:901
	CALL COMSEQ_REGISTER_TRAIN
ENDIF

;=================================================
;BEGIN AFTERTRAIN後最初に呼び出される関数
;=================================================
@EVENTEND
#LATER
PRINTL 지도를 종료했습니다.
WAIT

;失神時の口上非表示の回復
IF TFLAG:860 == 1
	FLAG:7 = 1
	TFLAG:860 = 0
ELSEIF TFLAG:860 == 2
	FLAG:7 = 2
	TFLAG:860 = 0
ENDIF

;今回の調教対象と助手を記録
FLAG:1 = TARGET
FLAG:2 = ASSI

;調教後に死んでいる可能性をチェック
CALL CHARADEAD_CHECK

;生きていれば調教後行為のチェック
IF RESULT == 0
	CALL SELF_CHECK
	DRAWLINE
ENDIF

;착유した모유の売却
CALL SELL_MILK

;調教時に録画したビデオを売却
CALL SELL_VIDEO

;살면서 착의모드라면 조교후 의류처리
;IF FLAG:37 && BASE:0 > 0
IF BASE:0 > 0
	CALL AFTERTRAIN_CLOTH
	;衣類の再着衣
	CALL RE_CLOTHED
ENDIF

;調教後に死ぬか臨死状態なら珠を獲得せずに, ターゲットを空にしてターン終了
IF BASE:0 < 1
	TARGET = -1
	FLAG:1 = -1
	BEGIN TURNEND
ENDIF

;항상발정
IF FLAG:75 == 0 && TALENT:271 == 0
	;潤滑の10000分の1を蓄積　潤滑が10000を下回る場合はリセット
	IF PALAM:3 >= 10000
		CFLAG:81 += PALAM:3 / 10000
	ELSE
		CFLAG:81 = 0
	ENDIF
	;욕정の10000分の1を蓄積　欲情が10000を下回る場合はリセット
	IF PALAM:5 >= 10000
		CFLAG:82 += PALAM:5 / 10000
	ELSE
		CFLAG:82 = 0
	ENDIF
ENDIF

;何의 구슬を得られたか
CALL JUEL_CHECK

;能力値の上昇はメイン画面で行わせる
CALL CALC_B_TRAINEND
