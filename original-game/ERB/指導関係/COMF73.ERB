@COM73
;유두 맞대기
;エラー出て発見。消してもよかったけどうん
;全力で未完成。

PRINTL 유두 맞대기
SAVESTR:0 = 유두 맞대기
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:1 += 30
LOSEBASE:1 += 90

;△中毒充足の中毒度分岐
SOURCE:7 = 500
SOURCE:12 = 250
SOURCE:13 = 400
SOURCE:14 = 300

;ABL:従順をみる
IF ABL:10 == 0
	SOURCE:11 = 200
ELSEIF ABL:10 == 1
	SOURCE:11 = 120
ELSEIF ABL:10 == 2
	SOURCE:11 = 60
ELSEIF ABL:10 == 3
	SOURCE:11 = 20
ELSEIF ABL:10 == 4
	SOURCE:11 = 0
ELSE
	SOURCE:11 = 0
ENDIF

;ABL:B感覚をみる
IF ABL:1 == 0
	SOURCE:17 = 20
	SOURCE:4 = 0
	SOURCE:5 = 0
	SOURCE:13 = 20
	TIMES SOURCE:12 , 0.80
ELSEIF ABL:1 == 1
	SOURCE:17 = 80
	SOURCE:4 = 10
	SOURCE:5 = 50
	SOURCE:13 = 20
	TIMES SOURCE:12 , 0.90
ELSEIF ABL:1 == 2
	SOURCE:17 = 350
	SOURCE:4 = 50
	SOURCE:5 = 100
	SOURCE:13 = 20
	TIMES SOURCE:12 , 1.00
ELSEIF ABL:1 == 3
	SOURCE:17 = 750
	SOURCE:4 = 100
	SOURCE:5 = 300
	SOURCE:13 = 20
	TIMES SOURCE:12 , 1.10
ELSEIF ABL:1 == 4
	SOURCE:17 = 1200
	SOURCE:4 = 700
	SOURCE:5 = 600
	SOURCE:13 = 20
	TIMES SOURCE:12 , 1.20
ELSE
	SOURCE:17 = 1750
	SOURCE:4 = 2000
	SOURCE:5 = 1000
	SOURCE:13 = 20
	TIMES SOURCE:12 , 1.30
ENDIF

;ABL:기교をみる
IF ABL:12 == 0
	TIMES SOURCE:4  , 1.00
	TIMES SOURCE:5  , 0.60
	TIMES SOURCE:13 , 0.50
ELSEIF ABL:12 == 1
	TIMES SOURCE:4  , 1.00
	TIMES SOURCE:5  , 0.60
	TIMES SOURCE:13 , 0.50
ELSEIF ABL:12 == 2
	TIMES SOURCE:4  , 1.00
	TIMES SOURCE:5  , 0.60
	TIMES SOURCE:13 , 0.50
ELSEIF ABL:12 == 3
	TIMES SOURCE:4  , 1.00
	TIMES SOURCE:5  , 0.60
	TIMES SOURCE:13 , 0.50
ELSEIF ABL:12 == 4
	TIMES SOURCE:4  , 1.00
	TIMES SOURCE:5  , 0.60
	TIMES SOURCE:13 , 0.50
ELSE
	TIMES SOURCE:4  , 1.00
	TIMES SOURCE:5  , 0.60
	TIMES SOURCE:13 , 0.50
ENDIF

;ABL:봉사정신をみる
IF ABL:16 == 0
	TIMES SOURCE:5 , 0.50
ELSEIF ABL:16 == 1
	TIMES SOURCE:5 , 1.00
ELSEIF ABL:16 == 2
	TIMES SOURCE:5 , 1.20
ELSEIF ABL:16 == 3
	TIMES SOURCE:5 , 1.40
ELSEIF ABL:16 == 4
	TIMES SOURCE:5 , 1.70
ELSE
	TIMES SOURCE:5 , 2.00
ENDIF


;調教者のABL:B感覚をみる
IF ABL:PLAYER:1 == 0
	TIMES SOURCE:4 , 0.80
	TIMES SOURCE:5 , 0.50
ELSEIF ABL:PLAYER:1 == 1
	TIMES SOURCE:4 , 0.90
	TIMES SOURCE:5 , 0.70
ELSEIF ABL:PLAYER:1 == 2
	TIMES SOURCE:4 , 1.00
	TIMES SOURCE:5 , 1.00
ELSEIF ABL:PLAYER:1 == 3
	TIMES SOURCE:4 , 1.10
	TIMES SOURCE:5 , 1.20
ELSEIF ABL:PLAYER:1 == 4
	TIMES SOURCE:4 , 1.20
	TIMES SOURCE:5 , 1.40
ELSE
	TIMES SOURCE:4 , 1.30
	TIMES SOURCE:5 , 1.70
ENDIF


;奴隷のB⇔調教者のBの汚れが移動
STAIN:5 |= STAIN:PLAYER:5
STAIN:PLAYER:5 |= STAIN:5

IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +8
	EXP:40 += 8
ENDIF

SIF ASSIPLAY == 0 && ABL:0 >= 3
		TFLAG:30 += 1

TFLAG:100 = 1

RETURN 1

