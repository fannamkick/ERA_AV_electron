@COM53
;비디오카메라

SAVESTR:0 = 비디오카메라
CALL TRAIN_MESSAGE_B

;カウントは10回とします
K = 10

IF TEQUIP:53
;ビデオ撮影がされていれば終了させる
;テープは終了時に数を減らす
	TEQUIP:53 = 0
;	ITEM:28 -= 1
ELSE
;ビデオ撮影してなければ初期化して開始
	TEQUIP:53 = 1
	TFLAG:70 = 0
	REPEAT K
		S = COUNT + 11
		FLAG:S = 0
	REND
	;撮影開始時の状態を記録
	FLAG:22 = 0
	SIF TEQUIP:54
		FLAG:22 |= 1
	SIF TEQUIP:58
		FLAG:22 |= 2
	SIF TEQUIP:59
		FLAG:22 |= 4
	SIF TEQUIP:44
		FLAG:22 |= 8
	SIF TEQUIP:11
		FLAG:22 |= 16
	SIF TEQUIP:13
		FLAG:22 |= 32
	SIF TEQUIP:46
		FLAG:22 |= 64
	SIF TEQUIP:89
		FLAG:22 |= 128
	SIF TEQUIP:90
		FLAG:22 |= 256
	SIF TEQUIP:18
		FLAG:22 |= 512
ENDIF

RETURN 1

;-------------------------------------------------
;비디오 촬영중･･･
;-------------------------------------------------
@EQUIP_COM53

;カウントは10回とします
K = 10

IF TFLAG:70 == 0
;初回はカウントに入れない
	TFLAG:70 += 1
ELSEIF TFLAG:70 > 0 && TFLAG:70 <= K
	S = TFLAG:70 + 10
	FLAG:S = SELECTCOM
	SIF ASSIPLAY
		FLAG:S += 1000

	PRINTFORML ＜비디오 촬영중 {TFLAG:70}/{K}＞

	TFLAG:70 += 1

	;パラメータ変化
	;TODO バランス調整(ビデオによるパラメータ変化は考慮しないか?)
	LOSEBASE:0 += 0
	LOSEBASE:1 += 50

	A = 370
	B = 1750
	C = 700

	;PALAM:욕정をみる
	IF PALAM:5 < PALAMLV:1
		TIMES A , 0.80
	ELSEIF PALAM:5 < PALAMLV:2
		TIMES A , 0.90
	ELSEIF PALAM:5 < PALAMLV:3
		TIMES A , 1.00
	ELSEIF PALAM:5 < PALAMLV:4
		TIMES A , 1.10
	ELSEIF PALAM:5 >= PALAMLV:4
		TIMES A , 1.20
	ENDIF

	;ABL:従順をみる
	IF ABL:10 == 0
		TIMES A , 0.40
	ELSEIF ABL:10 == 1
		TIMES A , 0.60
	ELSEIF ABL:10 == 2
		TIMES A , 0.80
	ELSEIF ABL:10 == 3
		TIMES A , 1.00
	ELSEIF ABL:10 == 4
		TIMES A , 1.10
	ELSE
		TIMES A , 1.20
	ENDIF

	;ABL:노출벽をみる
	IF ABL:17 == 0
		TIMES A , 0.80
		TIMES C , 2.00
	ELSEIF ABL:17 == 1
		TIMES A , 1.00
		TIMES C , 1.70
	ELSEIF ABL:17 == 2
		TIMES A , 1.30
		TIMES C , 1.40
	ELSEIF ABL:17 == 3
		TIMES A , 1.60
		TIMES C , 1.00
	ELSEIF ABL:17 == 4
		TIMES A , 2.00
		TIMES C , 0.80
	ELSE
		TIMES A , 3.00
		TIMES C , 0.60
	ENDIF

	;도착적
	SIF TALENT:80
		TIMES A , 2.00
	;튀고 싶어함
	SIF TALENT:28
		TIMES A , 1.50
	;겁쟁이
	SIF TALENT:10
		TIMES C , 1.70
	;노출광
	IF TALENT:89
		TIMES A , 2.00
		TIMES B , 1.20
		TIMES C , 0.50
	ENDIF

	SOURCE:10 += A
	SOURCE:12 += B
	SOURCE:14 += C

ENDIF

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
IF TFLAG:70 > 1
	EXP:70 += 1
	PRINTL 피사경험 +1
ENDIF

SIF ASSIPLAY == 0 && ABL:7 >= 3
	TFLAG:30 += 1

RETURN 1

;-------------------------------------------------
;テープ終了
;-------------------------------------------------

@REJECT_CAMERA
;テープ残量がなくなると強制的にEQUIPフラグを外す
IF TFLAG:70 > K && TEQUIP:53
	TEQUIP:53 = 0
;	ITEM:28 -= 1
	PRINTL ＜테이프를 전부 사용했습니다. 비디오 촬영을 종료합니다＞
ENDIF

