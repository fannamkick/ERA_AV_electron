;-------------------------------------------------
;수간 플레이
;-------------------------------------------------
@COM89
PRINTL 수간 플레이
SAVESTR:0 = 수간 플레이
CALL TRAIN_MESSAGE_B

IF TEQUIP:89
	TEQUIP:89 = 0
ELSE
	TEQUIP:89 = 1
ENDIF
T = 0
RETURN 1

;-------------------------------------------------
;-------------------------------------------------
;수간 플레이중
;-------------------------------------------------
@EQUIP_COM89
PRINTL ＜수간 플레이중＞

T = 1

;EXP:수간경험をみる
IF EXP:56 < EXPLV:1
	A = 400
	B = 2000
ELSEIF EXP:56 < EXPLV:2
	A = 200
	B = 1000
ELSEIF EXP:56 < EXPLV:3
	A = 100
	B = 500
ELSEIF EXP:56 < EXPLV:4
	A = 50
	B = 200
ELSEIF EXP:56 < EXPLV:5
	A = 20
	B = 100
ELSE
	A = 10
	B = 50
ENDIF

;ABL:수간중독をみる
IF ABL:40 == 0
	TIMES A , 1.50
	TIMES B , 1.50
ELSEIF ABL:40 == 1
	TIMES A , 1.00
	TIMES B , 1.00
	SOURCE:7 += 100
ELSEIF ABL:40 == 2
	TIMES A , 0.80
	TIMES B , 0.80
	SOURCE:7 += 400
ELSEIF ABL:40 == 3
	TIMES A , 0.60
	TIMES B , 0.60
	SOURCE:7 += 1200
ELSEIF ABL:40 == 4
	TIMES A , 0.40
	TIMES B , 0.40
	SOURCE:7 += 3000
ELSE
	TIMES A , 0.20
	TIMES B , 0.20
	SOURCE:7 += 5000
ENDIF

;감정부족
SIF TALENT:22
	TIMES B , 0.60
;동물귀
SIF TALENT:124
	TIMES B , 0.50
;암캐
IF TALENT:136
	TIMES A , 0.20
	TIMES B , 0.20
ENDIF

LOSEBASE:1 += A

SOURCE:8 += B
SOURCE:14 += B

SOURCE:10 += 200

TIMES SOURCE:0 , 1.50
TIMES SOURCE:2 , 1.50
TIMES SOURCE:17 , 1.50
TIMES SOURCE:6 , 1.50
TIMES SOURCE:13 , 3.00

;동물귀なら屈従半減
SIF TALENT:124
	SOURCE:13 /= 2

;암캐なら効果増大
IF TALENT:136
	TIMES SOURCE:3 , 1.20
	TIMES SOURCE:4 , 1.20
	TIMES SOURCE:5 , 1.20
	TIMES SOURCE:7 , 2.00
	TIMES SOURCE:10 , 3.00
ENDIF

IF SELECTCOM == 21 || SELECTCOM == 27 || SELECTCOM == 37
	TIMES SOURCE:14 , 2.00
ENDIF

IF EXP:56 == 0
	EXP:50 += 1
	PRINTL 이상경험 +1
ENDIF

;-------------------------------------------------
;사정チェック
;-------------------------------------------------
SIF MAXBASE:MASTER:4 == 0
	GOTO END_EJAC

B = 0

;ABL:기교をみる
IF ABL:12 == 0
	B = 450
ELSEIF ABL:12 == 1
	B = 1000
ELSEIF ABL:12 == 2
	B = 1600
ELSEIF ABL:12 == 3
	B = 2200
ELSEIF ABL:12 == 4
	B = 2700
ELSE
	B = 3200
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES B , 0.30
ELSEIF ABL:10 == 1
	TIMES B , 0.50
ELSEIF ABL:10 == 2
	TIMES B , 0.70
ELSEIF ABL:10 == 3
	TIMES B , 1.00
ELSEIF ABL:10 == 4
	TIMES B , 1.20
ELSE
	TIMES B , 1.30
ENDIF

;ABL:수간중독をみる
IF ABL:39 == 0
	TIMES B , 1.00
ELSEIF ABL:39 == 1
	TIMES B , 1.20
ELSEIF ABL:39 == 2
	TIMES B , 1.80
ELSEIF ABL:39 == 3
	TIMES B , 2.60
ELSEIF ABL:39 == 4
	TIMES B , 4.00
ELSE
	TIMES B , 5.00
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES B , 1.00
ELSEIF PALAM:5 < PALAMLV:2
	TIMES B , 1.10
ELSEIF PALAM:5 < PALAMLV:3
	TIMES B , 1.20
ELSEIF PALAM:5 < PALAMLV:4
	TIMES B , 1.30
ELSEIF PALAM:5 < PALAMLV:5
	TIMES B , 1.40
ELSE
	TIMES B , 1.50
ENDIF

;동물귀
SIF TALENT:124
	TIMES B , 1.20
;암캐
SIF TALENT:136
	TIMES B , 2.00

;キス
IF SELECTCOM == 6
	B = 0
	T += 2
;후배위
ELSEIF SELECTCOM == 21
	TIMES B , 1.00
	T += 2
;후배위애널
ELSEIF SELECTCOM == 27
	TIMES B , 1.50
	T += 2
;수음
ELSEIF SELECTCOM == 30
	TIMES B , 0.80
	T += 1
;펠라치오
ELSEIF SELECTCOM == 31
	TIMES B , 1.20
	T += 2
;기승위
ELSEIF SELECTCOM == 34
	TIMES B , 1.50
	T += 3
ELSE
	B = 0
ENDIF

BASE:MASTER:4 += B

S = BASE:MASTER:4
EJAC = MAXBASE:MASTER:4

IF  S > EJAC * 2
	E = 2
ELSEIF S > EJAC
	E = 1
ELSE
	E = 0
ENDIF

IF E
;사정している
	TIMES SOURCE:4 , 3.00

	;ABL:정액중독をみる
	IF ABL:32 == 0
		SOURCE:7 = 0
		TIMES SOURCE:5 , 2.00
		TIMES SOURCE:13, 2.00
	ELSEIF ABL:32 == 1
		SOURCE:7 = 200
		TIMES SOURCE:5 , 2.50
		TIMES SOURCE:13, 1.60
	ELSEIF ABL:32 == 2
		SOURCE:7 = 500
		TIMES SOURCE:5 , 3.00
		TIMES SOURCE:13, 1.00
	ELSEIF ABL:32 == 3
		SOURCE:7 = 1200
		TIMES SOURCE:5 , 4.50
		TIMES SOURCE:13, 0.70
	ELSEIF ABL:32 == 4
		SOURCE:7 = 2500
		TIMES SOURCE:5 , 6.00
		TIMES SOURCE:13, 0.40
	ELSE
		SOURCE:7 = 5000
		TIMES SOURCE:5 , 8.00
		TIMES SOURCE:13, 0.10
	ENDIF
ENDIF

;대량사정
IF E == 2
	EXP:20 += 3
	SETCOLOR 0x00ffff
	PRINTL 수간대량사정
	RESETCOLOR
	PRINTL 정액경험 +3
	T += 5

	BASE:MASTER:4 -= EJAC*2
	SIF BASE:MASTER:4 >= EJAC
		BASE:MASTER:4 = EJAC-1
	;질내사정フラグ(犬)
	SIF SELECTCOM == 21 || SELECTCOM == 34
		TFLAG:38 = 2
	
;通常の사정
ELSEIF E == 1
	EXP:20 += 1
	SETCOLOR 0x00ffff
	PRINTL 수간사정
	RESETCOLOR
	PRINTL 정액경험 +1
	T += 2

	BASE:MASTER:4 -= EJAC
	SIF BASE:MASTER:4 >= EJAC
		BASE:MASTER:4 = EJAC-1
	;질내사정フラグ(犬)
	SIF SELECTCOM == 21 || SELECTCOM == 34
		TFLAG:38 = 1
ENDIF

$END_EJAC

;-------------------------------------------------
;汚れ
;-------------------------------------------------
SIF SELECTCOM == 21
	STAIN:3 |= 2
SIF SELECTCOM == 27
	STAIN:4 |= 2
SIF SELECTCOM == 30
	STAIN:1 |= 2
SIF SELECTCOM == 31
	STAIN:0 |= 2
SIF SELECTCOM == 37
	STAIN:0 |= 8
SIF SELECTCOM == 21 && E > 0
	STAIN:3 |= 4
SIF SELECTCOM == 27 && E > 0
	STAIN:4 |= 4
SIF SELECTCOM == 30 && E > 0
	STAIN:1 |= 4
SIF SELECTCOM == 31 && E > 0
	STAIN:0 |= 4

;犬が사정フラグ
TFLAG:16 = E

PRINTFORML 수간경험 +{T}
EXP:56 += T

T = 0

;獣姦で처녀상실だと이상경험が2付く(【동물귀】除く)
IF TALENT:0 && TFLAG:19 && TALENT:124 == 0
	EXP:50 += 2
	PRINTL 이상경험 +2
ENDIF

;獣姦で수음なら굴복각인2
IF SELECTCOM == 30
	;굴복각인2に相当
	TFLAG:200 = 2
;獣姦で펠라치오・후배위・후배위애널・애널봉사・기승위だと굴복각인3
ELSEIF SELECTCOM == 31 || SELECTCOM == 21 || SELECTCOM == 27 || SELECTCOM == 34 || SELECTCOM == 37
	;굴복각인3に相当
	TFLAG:200 = 3
ENDIF

RETURN 1
;
