;-------------------------------------------------
;바늘
;SM系コマンド
;-------------------------------------------------
@COM144

PRINTL 배빵
SAVESTR:0 = 배빵
CALL TRAIN_MESSAGE_B

;実際には苦痛があるためもっと체력기력をもっていかれる
LOSEBASE:0 += 0
LOSEBASE:1 += 100

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
SOURCE:14 = 1000

;PALAM:苦痛をみる
IF PALAM:9 < PALAMLV:1
	SOURCE:6 = 5000
ELSEIF PALAM:9 < PALAMLV:2
	SOURCE:6 = 5300
ELSEIF PALAM:9 < PALAMLV:3
	SOURCE:6 = 5600
ELSEIF PALAM:9 < PALAMLV:4
	SOURCE:6 = 6000
ELSEIF PALAM:9 >= PALAMLV:4
	SOURCE:6 = 6500
ENDIF

;-------------------------------------------------
;経験上昇
;-------------------------------------------------
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +1
	EXP:40 += 1
ELSEIF TALENT:122 == 1 && TALENT:PLAYER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +1
	EXP:41 += 1
ENDIF

;굴복각인3に相当
TFLAG:200 = 3

SIF ASSIPLAY == 0 && ABL:21 >= 3
	TFLAG:30 += 1

RETURN 1
