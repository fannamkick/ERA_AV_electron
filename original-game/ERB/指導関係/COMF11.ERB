;-------------------------------------------------
;바이브
;道具使用コマンド: 調教対象のヴァギナを바이브で刺激
;-------------------------------------------------
@COM11
;처녀を奪うかどうかの確認
CALL CONFIRM_LOST_VIRGIN
SIF RESULT == 0
	RETURN 0

IF TEQUIP:90
	PRINTL 촉수 삽입
	SAVESTR:0 = 촉수 삽입
ELSE
	PRINTL 바이브
	SAVESTR:0 = 바이브
ENDIF
CALL TRAIN_MESSAGE_B

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 30
LOSEBASE:1 += 100

;ABL:V감각をみる
IF ABL:2 == 0
	SOURCE:1 = 80
ELSEIF ABL:2 == 1
	SOURCE:1 = 250
ELSEIF ABL:2 == 2
	SOURCE:1 = 600
ELSEIF ABL:2 == 3
	SOURCE:1 = 1000
ELSEIF ABL:2 == 4
	SOURCE:1 = 1300
ELSE
	SOURCE:1 = 1700
ENDIF

;EXP:V경험をみる
IF EXP:0 < EXPLV:1
	TIMES SOURCE:1 , 0.20
	SOURCE:6 = 5500
ELSEIF EXP:0 < EXPLV:2
	TIMES SOURCE:1 , 0.60
	SOURCE:6 = 300
ELSEIF EXP:0 < EXPLV:3
	TIMES SOURCE:1 , 1.00
	SOURCE:6 = 50
ELSEIF EXP:0 < EXPLV:4
	TIMES SOURCE:1 , 1.20
	SOURCE:6 = 10
ELSEIF EXP:0 < EXPLV:5
	TIMES SOURCE:1 , 1.40
	SOURCE:6 = 0
ELSE
	TIMES SOURCE:1 , 1.60
	SOURCE:6 = 0
ENDIF

;PALAM:윤활をみる
IF PALAM:3 < PALAMLV:1
	TIMES SOURCE:1 , 0.10
	SOURCE:6 += 1000
	TIMES SOURCE:6 , 3.00
ELSEIF PALAM:3 < PALAMLV:2
	TIMES SOURCE:1 , 0.40
	SOURCE:6 += 400
	TIMES SOURCE:6 , 1.00
ELSEIF PALAM:3 < PALAMLV:3
	TIMES SOURCE:1 , 1.00
	TIMES SOURCE:6 , 0.50
ELSEIF PALAM:3 < PALAMLV:4
	TIMES SOURCE:1 , 1.40
	TIMES SOURCE:6 , 0.20
ELSEIF PALAM:3 >= PALAMLV:4
	TIMES SOURCE:1 , 1.80
	TIMES SOURCE:6 , 0.10
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES SOURCE:1 , 0.80
ELSEIF PALAM:5 < PALAMLV:2
	TIMES SOURCE:1 , 0.90
ELSEIF PALAM:5 < PALAMLV:3
	TIMES SOURCE:1 , 1.00
ELSEIF PALAM:5 < PALAMLV:4
	TIMES SOURCE:1 , 1.10
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES SOURCE:1 , 1.20
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES SOURCE:1 , 0.80
ELSEIF ABL:10 == 1
	TIMES SOURCE:1 , 0.90
ELSEIF ABL:10 == 2
	TIMES SOURCE:1 , 1.00
ELSEIF ABL:10 == 3
	TIMES SOURCE:1 , 1.10
ELSEIF ABL:10 == 4
	TIMES SOURCE:1 , 1.20
ELSE
	TIMES SOURCE:1 , 1.30
ENDIF

;큰체구
SIF TALENT:99
	TIMES SOURCE:6 , 0.80
;작은체형
SIF TALENT:100
	TIMES SOURCE:6 , 2.00
;미숙함
SIF TALENT:135
	TIMES SOURCE:6 , 4.00

						;****슬라임パッチ追加ここから****
IF ITEM:201 >= 1 && TEQUIP:90 == 0
	TIMES LOSEBASE:0 , 0.80
	TIMES LOSEBASE:1 , 0.80
	TIMES SOURCE:1 , 1.20
	TIMES SOURCE:6 , 0.80
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
S = 0
;V감각が高いほどV경험が入る
IF ABL:2 <= 1
	S = 1
ELSEIF ABL:2 <= 4
	S = 2
ELSEIF ABL:2 <= 7
	S = 3
ELSE
	S = 4
ENDIF
EXP:0 += S
PRINTFORML V경험 +{S}
S = 0

;레즈경험
IF TALENT:122 == 0 && TALENT:PLAYER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +3
	EXP:40 += 3
ENDIF

;-------------------------------------------------
;바이브の着脱
;-------------------------------------------------
TEQUIP:11 = 1 - TEQUIP:11
SIF TEQUIP:90
	T = 0

;-------------------------------------------------
;汚れ(촉수)
;-------------------------------------------------
IF TEQUIP:90 && TEQUIP:11
	STAIN:3 |= 2
	STAIN:3 |= 4
ENDIF

RETURN 1

;-------------------------------------------------
;-------------------------------------------------
;바이브 삽입중
;-------------------------------------------------
@EQUIP_COM11

;V経験を伴うコマンドのフラグ(처녀膜再生対応)
TFLAG:19 = 1

IF TEQUIP:90
	PRINTL ＜촉수 삽입중＞
ELSEIF TALENT:76 == 1
	PRINTL ＜극태 바이브 삽입중＞
ELSEIF TALENT:76 == 0
	PRINTL ＜바이브 삽입중＞
ELSE
	PRINTL ＜바이브 삽입중＞
ENDIF

LOSEBASE:0 += 10
LOSEBASE:1 += 50

;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
;ABL:V감각をみる
IF ABL:2 == 0
	A = 40
ELSEIF ABL:2 == 1
	A = 120
ELSEIF ABL:2 == 2
	A = 300
ELSEIF ABL:2 == 3
	A = 500
ELSEIF ABL:2 == 4
	A = 650
ELSE
	A = 850
ENDIF

;EXP:V경험をみる
;처녀はありえない
IF EXP:0 < EXPLV:2
	TIMES A , 0.60
	B = 150
ELSEIF EXP:0 < EXPLV:3
	TIMES A , 1.00
	B = 20
ELSEIF EXP:0 < EXPLV:4
	TIMES A , 1.20
	B = 0
ELSEIF EXP:0 < EXPLV:5
	TIMES A , 1.40
	B = 0
ELSE
	TIMES A , 1.60
	B = 0
ENDIF

;PALAM:윤활をみる
IF PALAM:3 < PALAMLV:1
	TIMES A , 0.10
	B += 400
	TIMES B , 3.00
	C += 1000
ELSEIF PALAM:3 < PALAMLV:2
	TIMES A , 0.40
	B += 150
	TIMES B , 1.00
	C += 200
ELSEIF PALAM:3 < PALAMLV:3
	TIMES A , 1.00
	TIMES B , 0.50
	C += 80
ELSEIF PALAM:3 < PALAMLV:4
	TIMES A , 1.40
	TIMES B , 0.20
ELSEIF PALAM:3 >= PALAMLV:4
	TIMES A , 1.80
	TIMES B , 0.10
ENDIF

;PALAM:욕정をみる
IF PALAM:5 < PALAMLV:1
	TIMES A , 0.80
ELSEIF PALAM:5 < PALAMLV:2
	TIMES A , 0.90
ELSEIF PALAM:5 < PALAMLV:3
	TIMES A , 1.00
ELSEIF PALAM:5 < PALAMLV:4
	TIMES A , 1.10
ELSEIF PALAM:5 >= PALAMLV:4
	TIMES A , 1.20
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES A , 0.80
ELSEIF ABL:10 == 1
	TIMES A , 0.90
ELSEIF ABL:10 == 2
	TIMES A , 1.00
ELSEIF ABL:10 == 3
	TIMES A , 1.10
ELSEIF ABL:10 == 4
	TIMES A , 1.20
ELSE
	TIMES A , 1.30
ENDIF


;큰체구
SIF TALENT:99
	TIMES B , 0.80
;작은체형
SIF TALENT:100
	TIMES B , 2.00
;미숙함
SIF TALENT:135
	TIMES B , 4.00

;정조관념
IF TALENT:30
	;처녀はありえない
	TIMES B, 3.00
ENDIF

SOURCE:1 += A
SOURCE:6 += B

						;****슬라임パッチ追加ここから****
IF ITEM:201 >= 1 && TEQUIP:90 == 0
	LOSEBASE:0 -= 2
	LOSEBASE:1 -= 10
	TIMES SOURCE:1 , 1.20
	TIMES SOURCE:6 , 0.80
ENDIF
						;****슬라임パッチ追加ここまで****
;-------------------------------------------------
;経験上昇
;-------------------------------------------------
S = 0
;자위実行時は経験 +1
SIF SELECTCOM == 3
	S = 1
;V감각が高いほどV경험が入る
IF ABL:2 <= 1
	S += 1
ELSEIF ABL:2 <= 4
	S += 2
ELSEIF ABL:2 <= 7
	S += 3
ELSE
	S += 4
ENDIF
EXP:0 += S
PRINTFORML V경험 +{S}
S = 0

;-------------------------------------------------
;その他の処理
;-------------------------------------------------
SIF TEQUIP:90
	T += 1

RETURN 1
