;マスターと奴隷のレズorホモ
IF TALENT:122 == 0 && TALENT:MASTER:122 == 0
	PRINTS EXPNAME:40
	PRINTL +7
	EXP:40 += 7
ELSEIF TALENT:122 == 1 && TALENT:MASTER:122 == 1
	PRINTS EXPNAME:41
	PRINTL +7
	EXP:41 += 7
ENDIF

;助手と奴隷のレズorホモ
IF TALENT:122 == 0 && TALENT:ASSI:122 == 0
	PRINTS EXPNAME:40
	PRINTL +5
	EXP:40 += 5
ELSEIF TALENT:122 == 1 && TALENT:ASSI:122 == 1
	PRINTS EXPNAME:41
	PRINTL +5
	EXP:41 += 5
