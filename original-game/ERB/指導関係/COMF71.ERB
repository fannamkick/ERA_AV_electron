;사정게이지チェック
;-------------------------------------------------
B = 0

;ABL:기교をみる
IF ABL:12 == 0
	B = 1200
ELSEIF ABL:12 == 1
	B = 1500
ELSEIF ABL:12 == 2
	B = 2000
ELSEIF ABL:12 == 3
	B = 2500
ELSEIF ABL:12 == 4
	B = 3000
ELSE
	B = 4000
ENDIF

;ABL:従順をみる
IF ABL:10 == 0
	TIMES B , 0.80
ELSEIF ABL:10 == 1
	TIMES B , 0.90
ELSEIF ABL:10 == 2
	TIMES B , 1.00
ELSEIF ABL:10 == 3
	TIMES B , 1.10
ELSEIF ABL:10 == 4
	TIMES B , 1.20
ELSE
	TIMES B , 1.30
ENDIF

;ABL:봉사정신をみる
IF ABL:16 == 0
	TIMES B , 0.50
ELSEIF ABL:16 == 1
	TIMES B , 0.80
ELSEIF ABL:16 == 2
	TIMES B , 1.20
ELSEIF ABL:16 == 3
	TIMES B , 1.50
ELSEIF ABL:16 == 4
	TIMES B , 1.80
ELSE
	TIMES B , 2.40
ENDIF

;ABL:정액중독をみる
IF ABL:32 == 0
	TIMES B , 1.00
ELSEIF ABL:32 == 1
	TIMES B , 1.20
ELSEIF ABL:32 == 2
	TIMES B , 1.30
ELSEIF ABL:32 == 3
	TIMES B , 1.50
ELSEIF ABL:32 == 4
	TIMES B , 1.70
ELSE
	TIMES B , 2.00
ENDIF

;TALENT:혀놀림をみる
SIF TALENT:52
	TIMES B , 2.00

;助手のABL:기교をみる
IF ABL:ASSI:12 >= 2
	TIMES B , 1.00
ELSEIF ABL:ASSI:12 == 3
	TIMES B , 1.20
ELSEIF ABL:ASSI:12 == 4
	TIMES B , 1.50
ELSE
	TIMES B , 1.80
ENDIF

;助手のTALENT:혀놀림をみる
SIF TALENT:ASSI:52
	TIMES B , 2.00

;プレイヤーのABL:C感覚をみる
IF ABL:MASTER:0 == 0
	TIMES B , 1.00
ELSEIF ABL:MASTER:0 == 1
	TIMES B , 1.50
ELSEIF ABL:MASTER:0 == 2
	TIMES B , 2.00
ELSEIF ABL:MASTER:0 == 3
	TIMES B , 2.50
ELSEIF ABL:MASTER:0 == 4
	TIMES B , 3.50
ELSE
	TIMES B , 5.00
ENDIF


SIF TALENT:MASTER:121 || TALENT:MASTER:122
	BASE:MASTER:2 += B

;-------------------------------------------------
;사정チェック
;-------------------------------------------------
S = BASE:MASTER:2
EJAC = MAXBASE:MASTER:2

IF  S > EJAC * 2
	E = 2
ELSEIF S > EJAC
	E = 1
ELSE
	E = 0
ENDIF

IF E
;사정している
	TIMES SOURCE:4 , 3.00

	;ABL:정액중독をみる
	IF ABL:32 == 0
		SOURCE:7 = 0
		TIMES SOURCE:5 , 2.00
		TIMES SOURCE:13, 4.00
	ELSEIF ABL:32 == 1
		SOURCE:7 = 500
		TIMES SOURCE:5 , 3.00
		TIMES SOURCE:13, 3.00
	ELSEIF ABL:32 == 2
		SOURCE:7 = 1200
		TIMES SOURCE:5 , 4.00
		TIMES SOURCE:13, 2.50
	ELSEIF ABL:32 == 3
		SOURCE:7 = 3000
		TIMES SOURCE:5 , 6.00
		TIMES SOURCE:13, 2.00
	ELSEIF ABL:32 == 4
		SOURCE:7 = 6000
		TIMES SOURCE:5 , 9.00
		TIMES SOURCE:13, 1.50
	ELSE
		SOURCE:7 = 12000
		TIMES SOURCE:5 , 15.00
		TIMES SOURCE:13, 1.00
	ENDIF
ENDIF

;대량사정
IF E == 2
	TIMES SOURCE:7 , 2.00
	TIMES SOURCE:5 , 1.50

	EXP:MASTER:3 += 2
	EXP:40 += 6
	SETCOLOR 0x00ffff
	PRINTL 대량사정⚡
	RESETCOLOR
	PRINTL 정액경험 +6
	;精液汚れ
	STAIN:MASTER:2 |= 4

	BASE:MASTER:2 -= EJAC*2
	SIF BASE:MASTER:2 >= EJAC
		BASE:MASTER:2 = EJAC-1

	;口で사정させたフラグ
	TFLAG:0 = 2
;通常の사정
ELSEIF E == 1
	EXP:MASTER:3 += 1
	EXP:40 += 3
	SETCOLOR 0x00ffff
	PRINTL 사정⚡
	RESETCOLOR
	PRINTL 정액경험 +3
	;精液汚れ
	STAIN:MASTER:2 |= 4

	BASE:MASTER:2 -= EJAC
	SIF BASE:MASTER:2 >= EJAC
		BASE:MASTER:2 = EJAC-1

	;口で사정させたフラグ
	TFLAG:0 = 1
ENDIF



;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;奴隷のB⇔調教者のPの汚れが移動
STAIN:5 |= STAIN:MASTER:2
STAIN:MASTER:2 |= STAIN:5

;助手のB⇔調教者のPの汚れが移動
STAIN:ASSI:5 |= STAIN:MASTER:2
STAIN:MASTER:2 |= STAIN:ASSI:5


;봉사정신LV2以上, 기교LV2以上なら汚れをなめ取る
IF ABL:16 >= 2 && ABL:12 >= 2
	STAIN:MASTER:2 = 2
	SIF E >= 1
		TFLAG:8 = 2
	
	;펠라경험
	PRINTFORML %EXPNAME:22%+1
	EXP:22 += 1
	
	;奴隷の口⇔調教者のPの汚れが移動
	STAIN:0 |= STAIN:MASTER:2
	STAIN:MASTER:2 |= STAIN:0
ENDIF

;奴隷と助手が共に女性でどちらかが정액중독を持っているとき, 奴隷の口⇔助手の口の汚れが移動
IF TALENT:122 == 0 && TALENT:ASSI:122 == 0 && (ABL:32 >= 1 || ABL:ASSI:32 >= 1)
	STAIN:0 |= STAIN:ASSI:2
	STAIN:ASSI:0 |= STAIN:0
	SIF E >= 1
		TFLAG:8 = 3
ENDIF


