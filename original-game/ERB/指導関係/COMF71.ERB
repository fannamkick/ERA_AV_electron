;-------------------------------------------------
;ソースの計算
;-------------------------------------------------
LOSEBASE:0 += 10
LOSEBASE:1 += 100

SOURCE:13 = 1800
SOURCE:14 = 900

;ABL:봉사정신をみる
IF ABL:16 == 0
	SOURCE:4 = 420
	SOURCE:5 = 150
	SOURCE:8 = 400
ELSEIF ABL:16 == 1
	SOURCE:4 = 500
	SOURCE:5 = 300
	SOURCE:8 = 300
ELSEIF ABL:16 == 2
	SOURCE:4 = 580
	SOURCE:5 = 600
	SOURCE:8 = 150
ELSEIF ABL:16 == 3
	SOURCE:4 = 660
	SOURCE:5 = 900
	SOURCE:8 = 50
ELSEIF ABL:16 == 4
	SOURCE:4 = 740
	SOURCE:5 = 1500
	SOURCE:8 = 20
ELSE
	SOURCE:4 = 820
	SOURCE:5 = 2200
	SOURCE:8 = 0
ENDIF

;ABL:B感覚をみる
IF ABL:1 == 0
	A = 100
ELSEIF ABL:1 == 1
	A = 200
ELSEIF ABL:1 == 2
	A = 400
ELSEIF ABL:1 == 3
	A = 800
ELSEIF ABL:1 == 4
	A = 1200
ELSE
	A = 1500
ENDIF

;거유
IF TALENT:110
	TIMES A , 1.20
ENDIF
;B민감
IF TALENT:108
	TIMES A , 1.20
;B둔감
ELSEIF TALENT:107
	TIMES A , 0.70
ENDIF

SOURCE:17 += A
;ABL:기교をみる
IF ABL:12 == 0
	TIMES SOURCE:4 , 0.50
	TIMES SOURCE:5 , 0.50
ELSEIF ABL:12 == 1
	TIMES SOURCE:4 , 0.80
	TIMES SOURCE:5 , 0.80
ELSEIF ABL:12 == 2
	TIMES SOURCE:4 , 1.00
	TIMES SOURCE:5 , 1.00
ELSEIF ABL:12 == 3
	TIMES SOURCE:4 , 1.20
	TIMES SOURCE:5 , 1.20
ELSEIF ABL:12 == 4
	TIMES SOURCE:4 , 1.50
	TIMES SOURCE:5 , 1.50
ELSE
	TIMES SOURCE:4 , 2.00
	TIMES SOURCE:5 , 2.00
ENDIF

;助手のABL:B感覚をみる
IF ABL:ASSI:1 == 0
	TIMES SOURCE:4 , 0.80
	TIMES SOURCE:5 , 0.50
ELSEIF ABL:ASSI:1 == 1
	TIMES SOURCE:4 , 0.90
	TIMES SOURCE:5 , 0.70
ELSEIF ABL:ASSI:1 == 2
	TIMES SOURCE:4 , 1.00
	TIMES SOURCE:5 , 1.00
ELSEIF ABL:ASSI:1 == 3
	TIMES SOURCE:4 , 1.10
	TIMES SOURCE:5 , 1.20
ELSEIF ABL:ASSI:1 == 4
	TIMES SOURCE:4 , 1.20
	TIMES SOURCE:5 , 1.40
ELSE
	TIMES SOURCE:4 , 1.30
	TIMES SOURCE:5 , 1.70
ENDIF

