		TIMES SOURCE:0 , 0.80
		TIMES SOURCE:17 , 0.80
	ELSEIF E <= 7
		TIMES SOURCE:0 , 0.70
		TIMES SOURCE:17 , 0.70
	ELSEIF E <= 9
		TIMES SOURCE:0 , 0.60
		TIMES SOURCE:17 , 0.60
	ELSE
		TIMES SOURCE:0 , 0.50
		TIMES SOURCE:17 , 0.50
	ENDIF
