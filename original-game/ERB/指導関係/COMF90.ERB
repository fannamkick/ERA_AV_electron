@COM90

;前回と今回の調教者が同じ
IF (ASSIPLAY && TFLAG:50) || (ASSIPLAY == 0 && TFLAG:50 == 0)
	;前回の調教がフェラか파이즈리펠라か딥스로트か수음펠라か바큠펠라だと펠라자위に
	IF PREVCOM == 31 || PREVCOM == 123 || PREVCOM == 124 || PREVCOM == 126 || PREVCOM == 127
		CALL COM_ABLE125
		SIF RESULT == 1
			JUMP COM125
	ENDIF
ENDIF

;자위
;바이브, 애널바이브, ビデオ撮影の時に内容変化

;비디오 촬영중なら공개자위
;샤워사용중なら샤워자위
;바이브, 애널바이브, 或いは両方装備で바이브자위
SIF TEQUIP:53
	PRINT 공개 
SIF TEQUIP:54
	PRINT 야외 
SIF TEQUIP:18
	PRINT 샤워 
IF TEQUIP:11 && TEQUIP:13
	PRINT 양구멍 바이브 
ELSEIF TEQUIP:11
	PRINT 바이브 
ELSEIF TEQUIP:13
	PRINT 애널바이브 
ENDIF

IF TEQUIP:53 || TEQUIP:54 || TEQUIP:11 || TEQUIP:13 || TEQUIP:18
	PRINTL 로터자위 
ELSE
	PRINTL 로터자위 
ENDIF

;-------------------------------------------------
;実行できるかの判定
;-------------------------------------------------
A = 0
S = 0

;すべての命令に共通の要素を考慮
;(従順が高いと命令に従いやすいなど)
CALL COM_ORDER

;ABL:욕망
IF ABL:11
	SIF S
		PRINT  + 
	A += ABL:11 * 3
	PRINTS ABLNAME:11
	PRINTV 'LV,ABL:11,'(,ABL:11 * 3,')
	S = 1
ENDIF
;ABL:노출벽
IF ABL:17
	SIF S
		PRINT  + 
	A += ABL:17 * 4
	PRINTS ABLNAME:17
	PRINTV 'LV,ABL:17,'(,ABL:17 * 4,')
	S = 1
ENDIF
;ABL:자위중독
IF ABL:31
	SIF S
		PRINT  + 
	A += ABL:31 * 3
	PRINTS ABLNAME:31
	PRINTV 'LV,ABL:31,'(,ABL:31 * 3,')
	S = 1
ENDIF
;MARK:쾌락각인
IF MARK:1
	SIF S
		PRINT  + 
	A += MARK:1 * 3
	PRINTS MARKNAME:1
	PRINTV 'LV,MARK:1,'(,MARK:1 * 3,')
	S = 1
ENDIF

;PALAM:욕정
IF PALAM:5 < PALAMLV:1
