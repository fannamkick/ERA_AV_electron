SIF TEQUIP:11
	V += 5
SIF TEQUIP:13
	V += 5
SIF TEQUIP:60
	V += 5

SIF A < V
	PRINT  < 
SIF A == V
	PRINT  = 
SIF A > V
	PRINT  > 
PRINT 실행치 
PRINTV V

WAIT

;実行できない
SIF A < V
