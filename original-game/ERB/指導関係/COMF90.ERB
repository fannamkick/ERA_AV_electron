	ELSEIF ABL:3 == 1
		B += 120
		D += 400
	ELSEIF ABL:3 == 2
		B += 300
		D += 700
	ELSEIF ABL:3 == 3
		B += 500
		D += 900
	ELSEIF ABL:3 == 4
		B += 650
		D += 1000
	ELSE
		B += 850
		D += 1200
