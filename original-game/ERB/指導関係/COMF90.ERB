;바이브, 애널바이브だけ先に計算
IF TEQUIP:11 || TEQUIP:13
	;PALAM:윤활をみる
	IF PALAM:3 < PALAMLV:1
		TIMES A , 0.40
		TIMES B , 0.40
		C += 800
	ELSEIF PALAM:3 < PALAMLV:2
