;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_11
ADDCHARA 210
LOADGLOBAL
GLOBAL:410 += 1
SAVEGLOBAL
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(210)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_11
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(210)
SIF TALENT:LOCAL:82 == 0
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
