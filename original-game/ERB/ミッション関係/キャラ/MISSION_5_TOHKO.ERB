;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_5
ADDCHARA 204
LOADGLOBAL
GLOBAL:404 += 1
SAVEGLOBAL
	TARGET = GETCHARA(204)
	CALL CLEARBONUS_CALL


;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_5
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(204)
LOCAL:1 = 0
;両穴비처녀
SIF TALENT:LOCAL:0 == 0
	LOCAL:1++
SIF TALENT:LOCAL:2 == 0
	LOCAL:1++
;V감각
SIF ABL:LOCAL:2 >= 6
	LOCAL:1++
;노출벽
SIF ABL:LOCAL:17 >= 7
	LOCAL:1++
;성교중독
SIF ABL:LOCAL:30 >= 3
	LOCAL:1++
;음란
SIF TALENT:LOCAL:76 == 1
	LOCAL:1++
;첫 키스判定
SIF CFLAG:LOCAL:16 >= 1
	LOCAL:1++
;성교경험
SIF EXP:LOCAL:5 >= 500
	LOCAL:1++
;最大매력치
SIF MAXBASE:LOCAL:31 >= 150
	LOCAL:1++
SIF LOCAL:1 == 9
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_5(ARG)
LOCAL = GETCHARA(204)
; 失敗ならキャラ削除
IF ARG == 0
	SIF LOCAL >= 0
		CALL キャラ削除, LOCAL
ELSE
	TALENT:LOCAL:330 = 0
ENDIF

