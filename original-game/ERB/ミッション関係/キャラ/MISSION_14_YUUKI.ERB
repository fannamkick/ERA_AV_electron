;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_14
ADDCHARA 213
LOADGLOBAL
GLOBAL:413 += 1
SAVEGLOBAL
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(213)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_14
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(213)
LOCAL:1 = 0

SIF TALENT:LOCAL:430 == 1
	LOCAL:1++
SIF TALENT:LOCAL:203 == 1
	LOCAL:1++
SIF MAXBASE:LOCAL:31 >= 190
	LOCAL:1++

SIF LOCAL:1 >= 3
	RETURN 1
RETURN 0

