;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_15
ADDCHARA 214
LOADGLOBAL
GLOBAL:414 += 1
SAVEGLOBAL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_15
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(214)
LOCAL:1 = 0

SIF ABL:LOCAL:10 > 4
	LOCAL:1++
SIF ABL:LOCAL:16 > 4
	LOCAL:1++
SIF TALENT:LOCAL:85 == 1
	LOCAL:1++
SIF TALENT:LOCAL:430 == 1
	LOCAL:1++

IF LOCAL:1 >= 3
	SIF LOCAL:1 == 4
		RETURN 2
	RETURN 1
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_15(ARG)
LOCAL = GETCHARA(214)

IF ARG <= 1
	IF ARG == 1
		PRINTFORML  「이제 더이상 미련은 없어…… 고마워」
		PRINTFORML  %조사처리(CALLNAME:LOCAL, "는")% 미련을 해결하고 성불했다……
	ELSEIF ARG == 0
		PRINTFORML  %조사처리(CALLNAME:LOCAL, "를")% 성불 시키지 못했다
		PRINTFORML  어쩔 수 없이 %플레이어가()% 책임지고 사무소의 돈으로 %조사처리(CALLNAME:LOCAL, "를")% 제령했다……
	ENDIF
	SIF LOCAL >= 0
		CALL キャラ削除, LOCAL
ELSE
	PRINTFORML  「메이코, %플레이어와()% 헤어지기 싫어……」
	PRINTFORML  「앞으로도 쭉 같이 있자!」
	PRINTFORML  %조사처리(CALLNAME:LOCAL, "는")% 미련을 해결했지만, 아무래도 상태가 이상하다
	PRINTFORML  %CALLNAME:MASTER%에게【영원한 사랑】을 맹세한 %조사처리(CALLNAME:LOCAL, "는")% 미련과 상관없이 %CALLNAME:MASTER%에게서 떨어지지 못하게 된 것 같다
	PRINTFORML  %플레이어는()% %CALLNAME:LOCAL%에게 평생 사랑받으며 살게 됐다
	PRINTL 
	TALENT:LOCAL:330 = 0
ENDIF

