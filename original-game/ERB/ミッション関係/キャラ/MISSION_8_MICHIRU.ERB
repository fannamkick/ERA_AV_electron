;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_8
ADDCHARA 207
LOADGLOBAL
GLOBAL:407 += 1
SAVEGLOBAL
TARGET = GETCHARA(207)
CALL CLEARBONUS_CALL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_8
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(207)
LOCAL:1 = 0
;V経験
SIF EXP:LOCAL:0 >= 1000
	LOCAL:1++
;V拡張
SIF EXP:LOCAL:52 >= 10
	LOCAL:1++
;성교기술
SIF ABL:LOCAL:14 == 10
	LOCAL:1++
;굴복각인
SIF MARK:LOCAL:2 == 3
	LOCAL:1++
;성교중독
SIF ABL:LOCAL:30 >= 5
	LOCAL:1++
SIF LOCAL:1 == 5
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_8(ARG)
LOCAL = GETCHARA(207)
; 失敗ならキャラ削除
IF ARG == 0
	SIF LOCAL >= 0
		CALL キャラ削除, LOCAL
ELSE
	TALENT:LOCAL:330 = 0
ENDIF

