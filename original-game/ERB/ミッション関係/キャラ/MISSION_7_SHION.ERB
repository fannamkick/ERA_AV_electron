;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_7
ADDCHARA 206
LOADGLOBAL
GLOBAL:406 += 1
SAVEGLOBAL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_7
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(206)
LOCAL:1 = 0
;A처녀
SIF TALENT:LOCAL:2 == 0
	LOCAL:1++
;애널광
SIF TALENT:LOCAL:77 == 1
	LOCAL:1++
;助手
SIF CFLAG:LOCAL:1 == 2
	LOCAL:1++
;굴복각인
SIF MARK:LOCAL:2 == 3
	LOCAL:1++
SIF LOCAL:1 == 4
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_7(ARG)
LOCAL = GETCHARA(206)
; 失敗ならキャラ削除
IF ARG == 0
	SIF LOCAL >= 0
		CALL キャラ削除, LOCAL
ELSE
	TALENT:LOCAL:330 = 0
ENDIF

;=================================================
; 미션対象キャラクターNOの記述
;--------------------------------------------
; 미션対象キャラクターのNOを戻す
; この関数は存在しなくても動作するが期日が取得できなくなる
; 受領時にキャラを追加し, 
; 期日のある미션では記述した方が良い
;=================================================
@MISSION_CHARA_NO_7
; 미션対象キャラクターのNOを戻す
RETURN 206
