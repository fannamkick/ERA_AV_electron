;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_20
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(190)
;共通条件
LOCAL:1 = 0
;撮影あり
LOCAL:2 = 0
;撮影なし
LOCAL:3 = 0

SIF ABL:LOCAL:12 >= 5
	LOCAL:1++
SIF ABL:LOCAL:70 >= 4
	LOCAL:1++
SIF ABL:LOCAL:11 >= 5
	LOCAL:2++
SIF ABL:LOCAL:17 >= 3
	LOCAL:2++
SIF EXP:LOCAL:76 >= 1
	LOCAL:2++
SIF ABL:LOCAL:71 >= 4
	LOCAL:3++
SIF ABL:LOCAL:72 >= 4
	LOCAL:3++
SIF EXP:LOCAL:76 == 0
	LOCAL:3++

LOCAL = GETCHARA(191)

SIF ABL:LOCAL:12 >= 5
	LOCAL:1++
SIF ABL:LOCAL:70 >= 4
	LOCAL:1++
SIF ABL:LOCAL:11 >= 5
	LOCAL:2++
SIF ABL:LOCAL:17 >= 3
	LOCAL:2++
SIF EXP:LOCAL:76 >= 1
	LOCAL:2++
SIF ABL:LOCAL:71 >= 4
	LOCAL:3++
SIF ABL:LOCAL:72 >= 4
	LOCAL:3++
SIF EXP:LOCAL:76 == 0
	LOCAL:3++

LOCAL = GETCHARA(192)

SIF ABL:LOCAL:12 >= 5
	LOCAL:1++
SIF ABL:LOCAL:70 >= 4
	LOCAL:1++
SIF ABL:LOCAL:11 >= 5
	LOCAL:2++
SIF ABL:LOCAL:17 >= 3
	LOCAL:2++
SIF EXP:LOCAL:76 >= 1
	LOCAL:2++
SIF ABL:LOCAL:71 >= 4
	LOCAL:3++
SIF ABL:LOCAL:72 >= 4
	LOCAL:3++
SIF EXP:LOCAL:76 == 0
	LOCAL:3++

;2,3は3つずつ。1は2つずつ。すべて満たすこと。
IF (LOCAL:2 == 9 || LOCAL:3 == 9) && LOCAL:1 == 6
	SIF LOCAL:2 == 9
		RETURN 1
	SIF LOCAL:3 == 9
		RETURN 2
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_20(ARG)

IF ARG <= 1
	LOCAL = GETCHARA(190)
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
	LOCAL = GETCHARA(191)
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
	LOCAL = GETCHARA(192)
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
ELSE
	PRINTFORMW  CPG의『정멤버 교체 총선거』결과가 발표됐다……
	PRINTFORML  2군으로 떨어지는 정멤버도 있는 한편, 꽤 많은 득표수를 모아 스즈모토 스즈카・나가에 사츠키・우노 미호 세명은
	PRINTFORML  무사히 정멤버로 승격할 수 있었다
	PRINTFORML 
	PRINTFORMW  《스즈모토 스즈카・나가에 사츠키・우노 미호가【%TALENTNAME:509%】의 정멤버가 됐다》
	LOCAL = GETCHARA(190)
		TALENT:LOCAL:509 = 1
		TALENT:LOCAL:203 = 1
		TALENT:LOCAL:330 = 0
		MAXBASE:LOCAL:31 += 60
		BASE:LOCAL:31 += 60
		CFLAG:LOCAL:801 = 0
	LOCAL = GETCHARA(191)
		TALENT:LOCAL:509 = 1
		TALENT:LOCAL:203 = 1
		TALENT:LOCAL:330 = 0
		MAXBASE:LOCAL:31 += 60
		BASE:LOCAL:31 += 60
		CFLAG:LOCAL:801 = 0
	LOCAL = GETCHARA(192)
		TALENT:LOCAL:509 = 1
		TALENT:LOCAL:203 = 1
		TALENT:LOCAL:330 = 0
		MAXBASE:LOCAL:31 += 60
		BASE:LOCAL:31 += 60
		CFLAG:LOCAL:801 = 0
ENDIF
