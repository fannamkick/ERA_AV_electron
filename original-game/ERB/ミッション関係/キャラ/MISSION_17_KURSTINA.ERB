;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_17
ADDCHARA 216
LOADGLOBAL
GLOBAL:416 += 1
SAVEGLOBAL
MAXBASE:(GETCHARA(216)):40 = 500000
BASE:(GETCHARA(216)):40 = 300
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(216)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_17
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(216)
LOCAL:1 = 0

SIF BASE:LOCAL:40 >= 500000
	LOCAL:1++
SIF TALENT:LOCAL:9 == 0
	LOCAL:1++
SIF TALENT:LOCAL:400 == 0
	LOCAL:1++
SIF CFLAG:LOCAL:17 == 0
	LOCAL:1++

IF LOCAL:1 >= 4
	RETURN 1
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_17(ARG)
LOCAL = GETCHARA(216)

IF ARG == 0
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
ELSEIF ARG == 1
	FLAG:553 = 0
	SIF TALENT:LOCAL:153
		CALL ADD_ELFALIA
	LOCAL = GETCHARA(216)
	WAIT
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
	TARGET = GETCHARA(104)
ENDIF

;=================================================
; 미션対象キャラクターNOの記述
;--------------------------------------------
; 미션対象キャラクターのNOを戻す
; この関数は存在しなくても動作するが, 
; 期日のある미션かつ関数が存在しないでは, 
; 期日が取得できなくなる
;=================================================
@MISSION_CHARA_NO_17
; 미션対象キャラクターのNOを戻す
RETURN 216


;=================================================
;엘파리아呼び出し
;=================================================
@ADD_ELFALIA

F = 0

LOCAL:10 = GETCHARA(216)
LOCAL:20 = GETCHARA(104)

IF LOCAL:10 != -1
	SIF CFLAG:(LOCAL:10):111 >= 0
		F = CFLAG:(LOCAL:10):111

	ADDCHARA 104
	LOADGLOBAL
		GLOBAL:304 += 1
	SAVEGLOBAL
		IF CFLAG:(LOCAL:10):111 >= 0 && F == 0
			PRINTFORML %조사처리(CALLNAME:(LOCAL:10),"가")% 낳은 당신의 딸?이 아빠인 당신을 돕기위해 와줬다 한다
			MAXBASE:(GETCHARA(104)):0 += 200
			MAXBASE:(GETCHARA(104)):1 += 100
			MAXBASE:(GETCHARA(104)):31 += 20
			BASE:(GETCHARA(104)):0 += 200
			BASE:(GETCHARA(104)):1 += 100
			BASE:(GETCHARA(104)):31 += 20
			TALENT:(GETCHARA(104)):408 = 0
			TALENT:(GETCHARA(104)):409 = 1
			TALENT:(GETCHARA(104)):161 = 1
			RELATION:(GETCHARA(104)):(NO:F) = 1000
			RELATION:F:GETCHARA(104) = 1000
		ELSEIF CFLAG:(LOCAL:10):111 >= 0 && F >= 0
			PRINTFORML %조사처리(CALLNAME:(LOCAL:10),"와")% %CALLNAME:(GETCHARA(F))%의 딸?이 은혜를 갚으러 엄마 대신 당신을 돕기 위해 와줬다 한다
			MAXBASE:(GETCHARA(104)):0 += 100
			MAXBASE:(GETCHARA(104)):1 += 200
			MAXBASE:(GETCHARA(104)):31 += 10
			BASE:(GETCHARA(104)):0 += 100
			BASE:(GETCHARA(104)):1 += 200
			BASE:(GETCHARA(104)):31 += 10
			IF TALENT:(GETCHARA(F)):408 == 0
				TALENT:(GETCHARA(104)):408 = 0
				TALENT:(GETCHARA(104)):409 = 1
			ENDIF
			IF TALENT:(GETCHARA(F)):121 == 1
				TALENT:(GETCHARA(104)):121 = 1
				TALENT:(GETCHARA(104)):1 = 1
				BASE:(GETCHARA(104)):50 = 13 + RAND:5
				CFLAG:(GETCHARA(104)):611 = 1 + RAND:3
			ENDIF
			RELATION:(GETCHARA(104)):(GETCHARA(F)) = 500
			RELATION:(GETCHARA(F)):GETCHARA(104) = 500
		ELSEIF CFLAG:(LOCAL:10):111 == -1
			PRINTFORML %조사처리(CALLNAME:(LOCAL:10),"가")% 낳은 아빠 불명의 딸?이 은혜를 갚으러 엄마 대신 당신을 돕기 위해 와줬다 한다
			MAXBASE:(GETCHARA(104)):0 += 100
			MAXBASE:(GETCHARA(104)):1 += 100
			BASE:(GETCHARA(104)):0 += 100
			BASE:(GETCHARA(104)):1 += 100
		ELSEIF CFLAG:(LOCAL:10):111 == -2
			PRINTFORML %조사처리(CALLNAME:(LOCAL:10),"가")% 낳은 개의 딸?이 은혜를 갚으러 엄마 대신 당신을 돕기 위해 와줬다 한다
			MAXBASE:(GETCHARA(104)):0 += 400
			TALENT:(GETCHARA(104)):408 = 0
			TALENT:(GETCHARA(104)):409 = 1
			TALENT:(GETCHARA(104)):124 = 1
		ELSEIF CFLAG:(LOCAL:10):111 == -3
			PRINTFORML %조사처리(CALLNAME:(LOCAL:10),"가")% 낳은 촉수의 딸?이 은혜를 갚으러 엄마 대신 당신을 돕기 위해 와줬다 한다
			MAXBASE:(GETCHARA(104)):0 += 500
			MAXBASE:(GETCHARA(104)):1 += 500
		ENDIF
ENDIF