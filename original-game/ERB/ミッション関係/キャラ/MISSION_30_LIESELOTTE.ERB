;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_30
ADDCHARA 230
LOADGLOBAL
GLOBAL:430 += 1
SAVEGLOBAL
MAXBASE:(GETCHARA(230)):40 = 2000000
BASE:(GETCHARA(230)):40 = 300
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(230)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_30
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(230)
LOCAL:1 = 0
LOCAL:2 = GETCHARA(104)

SIF BASE:LOCAL:40 >= 200000
	LOCAL:1++
SIF TALENT:LOCAL:9 == 0
	LOCAL:1++
SIF TALENT:LOCAL:400 == 0
	LOCAL:1++
SIF CFLAG:LOCAL:17 == 0
	LOCAL:1++
SIF TALENT:LOCAL:505 == 0
	LOCAL:1++
SIF TALENT:LOCAL:511 == 0
	LOCAL:1++
SIF RELATION:LOCAL:(NO:(LOCAL:2)) >= 200
	LOCAL:1++

IF LOCAL:1 >= 7
	RETURN 1
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_30(ARG)
LOCAL = GETCHARA(230)

IF ARG == 0
	SIF LOCAL != -1
		CALL キャラ削除, LOCAL
ELSEIF ARG == 1
	FLAG:553 = 0
	PRINTFORML  %타겟은()%【성마술】덕분에
	PRINTFORML  이제 휠체어 없이 일상생활이 가능할 정도로 회복한 것 같다……
	PRINTFORMW  《%조사처리(CALLNAME:TARGET, "는")%【%TALENTNAME:434%】%조사만처리(TALENTNAME:434,"를")% 잃었다》
	PRINTFORMW  《%조사처리(CALLNAME:TARGET, "는")%【%TALENTNAME:520%】%조사만처리(TALENTNAME:520,"를")% 잃었다》
	PRINTFORMW  《%CALLNAME:TARGET%의 최대 체력이 1000늘었다》
	PRINTFORMW 
	TALENT:LOCAL:434 = 0
	TALENT:LOCAL:520 = 0
	MAXBASE:LOCAL:0 += 1000
	BASE:LOCAL:0 = MAXBASE:LOCAL:0
	BASE:31 = MAXBASE:31
	TALENT:330 = 0
ENDIF

