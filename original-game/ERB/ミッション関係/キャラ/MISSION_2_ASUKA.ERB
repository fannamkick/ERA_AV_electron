;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_2
ADDCHARA 201
LOADGLOBAL
GLOBAL:401 += 1
SAVEGLOBAL
	TARGET = GETCHARA(201)
	CALL CLEARBONUS_CALL


;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_2
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(201)
LOCAL:1 = 0
;영원한 사랑
SIF TALENT:LOCAL:430
	LOCAL:1++
;学力
SIF ABL:LOCAL:52 >= 3
	LOCAL:1++
SIF LOCAL:1 == 2
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_2(ARG)
LOCAL = GETCHARA(201)
TALENT:LOCAL:330 = 0

;=================================================
; 미션対象キャラクターNOの記述
;--------------------------------------------
; 미션対象キャラクターのNOを戻す
; この関数は存在しなくても動作するが期日が取得できなくなる
; 受領時にキャラを追加し, 
; 期日のある미션では記述した方が良い
;=================================================
@MISSION_CHARA_NO_2
