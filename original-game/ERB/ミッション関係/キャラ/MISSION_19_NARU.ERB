;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_19
ADDCHARA 218
LOADGLOBAL
GLOBAL:418 += 1
SAVEGLOBAL
IF GLOBAL:200 >= 0
	TARGET = GETCHARA(218)
	CALL CLEARBONUS_CALL
ENDIF

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_19
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(218)
LOCAL:1 = 0

SIF TALENT:LOCAL:85 == 1
	LOCAL:1++
SIF TALENT:LOCAL:184 == 1
	LOCAL:1++
SIF ABL:LOCAL:0 == 10
	LOCAL:1++
SIF ABL:LOCAL:22 >= 5
	LOCAL:1++
SIF TALENT:LOCAL:1 == 0
	LOCAL:1++

;연심と남친있음は両立しないためこれでよい
IF LOCAL:1 >= 4
	RETURN 1
ENDIF
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_19(ARG)
LOCAL = GETCHARA(218)

SIF ARG != 0
	TALENT:LOCAL:330 = 0

