;=================================================
; 미션受領時処理
;--------------------------------------------
; キャラクターの追加など, 
; 미션の受領時に行う処理を記述する
;=================================================
@MISSION_RECEIVE_6
ADDCHARA 205
LOADGLOBAL
GLOBAL:405 += 1
SAVEGLOBAL
TARGET = GETCHARA(205)
CALL CLEARBONUS_CALL

;=================================================
; 미션達成判定計算
;--------------------------------------------
; 미션の成否判定を記述する
;=================================================
@MISSION_CALC_6
; 失敗なら0, 成功なら1, 大成功なら2をRETURNで戻す
LOCAL = GETCHARA(205)
LOCAL:1 = 0
SIF TALENT:LOCAL:0 == 0
	LOCAL:1++
SIF TALENT:LOCAL:2 == 0
	LOCAL:1++
;기교
SIF ABL:LOCAL:12 == 10
	LOCAL:1++
;奉仕
SIF ABL:LOCAL:13 == 10
	LOCAL:1++
;성교기술
SIF ABL:LOCAL:14 == 10
	LOCAL:1++
;봉사정신
SIF ABL:LOCAL:16 >= 5
	LOCAL:1++
;마조
SIF TALENT:LOCAL:88 == 1
	LOCAL:1++
;キス経験済み
SIF CFLAG:LOCAL:16 >= 1
	LOCAL:1++
;이상경험
SIF EXP:LOCAL:50 >= 5
	LOCAL:1++
;마조끼
SIF ABL:LOCAL:21 >= 5
	LOCAL:1++
SIF LOCAL:1 == 10
	RETURN 1
RETURN 0

;=================================================
; 미션報告後処理
;--------------------------------------------
; 経験や素質の変化など, 
; 미션報告後に行う処理を記述する
;--------------------------------------------
; 引数
;  ARG 成否判定の結果(0:失敗, 1:成功, 2:大成功)
;=================================================
@MISSION_REPORT_6(ARG)
LOCAL = GETCHARA(205)
; 失敗ならキャラ削除
IF ARG == 0
	SIF LOCAL >= 0
		CALL キャラ削除, LOCAL
ELSE
	SIF TALENT:LOCAL:400
		ITEM:60 = 1
	TALENT:LOCAL:330 = 0
ENDIF

;=================================================
; 미션対象キャラクターNOの記述
;--------------------------------------------
; 미션対象キャラクターのNOを戻す
