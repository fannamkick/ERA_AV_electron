	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

$INPUT_LOOP

PRINTL 개조대상의 클리토리스를 변형시켜 페니스를 형성합니다
PRINTL 난소에서 의사정액을 만들어 사정도 가능합니다
PRINTL 누구를 후타나리로 만듭니까?

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
ELSEIF TALENT:RESULT:121 || TALENT:RESULT:122
	PRINTFORMW %NAME:RESULT%에겐 이미 페니스가 있습니다
	RETURN 0
ELSEIF TALENT:RESULT:199
	PRINTFORMW 【%TALENTNAME:199%】인 캐릭터는 개조할 수 없습니다
	RETURN 0
ENDIF

T = RESULT

PRINTFORML %조사처리(NAME:RESULT,"를")% 후타나리로 만듭니까?

PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0 
	IF FLAG:564 == 0
		PRINTFORMW 《%조사처리(NAME:T,"는")%【%TALENTNAME:121%】가 됐다》
		TALENT:T:121 = 1
		TALENT:T:326 = 0
		SIF CFLAG:T:18 == 0
			TALENT:T:1 = 1
		CFLAG:T:609 = RAND:3
		CFLAG:T:611 = RAND:4
			IF CFLAG:T:609 >= 2
				CFLAG:T:609 = 2
			ENDIF
			IF CFLAG:T:611 >= 3
				CFLAG:T:611 = 3
			ENDIF
		CALL DECIDE_PENISSIZE
		EXP:T:50 += 1
		PRINTL 이상경험 +1
	ELSEIF FLAG:564 == 1
		CALL DECIDE_PENISSELECT
		EXP:T:50 += 1
		PRINTL 이상경험 +1
	ENDIF
ELSE
	GOTO INPUT_LOOP
ENDIF

MONEY -= C

RETURN 1
