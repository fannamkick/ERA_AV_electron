;=================================================
;비밀 연구소
;=================================================
@SECRET_LABO

$INPUT_LOOP

DRAWLINE
PRINTL 비밀 연구소
PRINTL 《여배우 후보들의 육체와 정신을 마개조합니다》
DRAWLINE
PRINTV DAY+1
PRINT 주차
IF TIME == 0
	PRINTL  전반
ELSE
	PRINTL  후반
ENDIF

PRINTFORML 소지금: {MONEY}포인트
DRAWLINE

PRINTL □육체개조
PRINTL  [0] - 거유로 만든다           (20000포인트)
PRINTL  [1] - 빈유로 만든다           (10000포인트)
PRINTL  [2] - 모유가 나오게 한다      (50000포인트)
PRINTL  [3] - 후타나리로 만든다       (50000포인트)
PRINTL  [4] - 후타나리를 지운다       (10000포인트)
PRINTL  [5] - 동물귀를 붙인다         ( 2000포인트)
PRINTL  [6] - 동물귀를 지운다         ( 1000포인트)
PRINTL  [7] - 미숙함을 지운다         (10000포인트)
SIF FLAG:36
	PRINTL  [9] - 음모 영구탈모           ( 5000포인트)
PRINTL 
PRINTL  [10] - 모유가 안나오게 한다   (10000포인트)
PRINTL  [11] - 오줌싸게를 지운다      (10000포인트)
PRINTL  [12] - 처녀막을 재생한다      (100000포인트)
PRINTL
PRINTL □세뇌 (조수용)
PRINTL  [30] -【불결무시】로 만든다   ( 5000포인트)
PRINTL  [31] -【조루】로 만든다       ( 8000포인트)
PRINTL  [32] -【유치】로 만든다       (10000포인트)
;PRINTL  [33] -【새드】にする(10000포인트)
DRAWLINE
PRINTL  [999] - 돌아간다

INPUT

IF RESULT == 0
	CALL MODIFY_BUSTUP
ELSEIF RESULT == 1
	CALL MODIFY_BUSTDOWN
ELSEIF RESULT == 2
	CALL MODIFY_BONYU
ELSEIF RESULT == 3
	CALL MODIFY_FUTANARI
ELSEIF RESULT == 4
	CALL MODIFY_FUTANARI_ERASE
ELSEIF RESULT == 5
	CALL MODIFY_ANIMAL
ELSEIF RESULT == 6
	CALL MODIFY_ANIMAL_ERASE
ELSEIF RESULT == 7
	CALL MODIFY_DEIMMATURITY
ELSEIF RESULT == 9 && FLAG:36
	CALL MODIFY_REMOVEHAIR
ELSEIF RESULT == 10
	CALL MODIFY_BONYU_ERASE
ELSEIF RESULT == 11
	CALL MODIFY_OMORASHI_ERASE
ELSEIF RESULT == 12
	CALL SHOJO_SAISEI
ELSEIF RESULT == 30
	C = 5000
	B = 64
	CALL BRAIN_WASHING
ELSEIF RESULT == 31
	C = 8000
	B = 133
	CALL BRAIN_WASHING
ELSEIF RESULT == 32
	C = 10000
	B = 132
	CALL BRAIN_WASHING
;ELSEIF RESULT == 33
;	C = 10000
;	B = 83
;	CALL BRAIN_WASHING
ELSEIF RESULT == 999
	RETURN 0
ELSE
	GOTO INPUT_LOOP
ENDIF

GOTO INPUT_LOOP
;
;-------------------------------------------------
;거유화
;-------------------------------------------------
@MODIFY_BUSTUP
C = 20000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

$INPUT_LOOP

PRINTL 개조대상의 유방을 강제로 확대시킵니다
PRINTL 누구를 거유화 시킵니까?

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
;가슴が設定されているキャラはIWS用処理へ
ELSEIF BASE:RESULT:22 > 0 && FLAG:38 > 0
	CALL MODIFY_BUSTUP_IWS
	RETURN 1
ELSEIF TALENT:RESULT:122
	PRINTFORMW 【%TALENTNAME:122%】는 거유화 시킬 수 없습니다
	RETURN 0
ELSEIF TALENT:RESULT:199
	PRINTFORMW 【%TALENTNAME:199%】인 캐릭터는 개조할 수 없습니다
	RETURN 0
ELSEIF TALENT:RESULT:114
	PRINTFORMW %조사처리(NAME:RESULT,"는")% 더 이상 거유화 시킬 수 없습니다
	RETURN 0
ENDIF

IF TALENT:RESULT:110
	PRINTFORML %NAME:RESULT%의 가슴을 더 크게 만들려면 50000포인트가 필요합니다
	C = 50000
	SIF MONEY < C
		GOTO INPUT_LOOP
	PRINTL 그래도 진행합니까?
ELSE
	PRINTFORML %조사처리(NAME:RESULT,"를")% 거유화 시킵니까?
ENDIF

T = RESULT

PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0 && TALENT:T:116
	PRINTFORMW 《%조사처리(NAME:T,"는")%【%TALENTNAME:109%】가 됐다》
	TALENT:T:116 = 0
	TALENT:T:109 = 1
ELSEIF RESULT == 0 && TALENT:T:109
	PRINTFORMW 《%NAME:T%의 가슴사이즈가 보통이 됐다》
	TALENT:T:109 = 0
ELSEIF RESULT == 0 && TALENT:T:110
	PRINTFORMW 《%조사처리(NAME:T,"는")%【%TALENTNAME:114%】가 됐다》
	TALENT:T:110 = 0
	TALENT:T:114 = 1
ELSEIF RESULT == 0 
	PRINTFORMW 《%조사처리(NAME:T,"는")%【%TALENTNAME:110%】가 됐다》
	TALENT:T:110 = 1
ELSE
	RETURN 0
ENDIF

MONEY -= C

RETURN 1
