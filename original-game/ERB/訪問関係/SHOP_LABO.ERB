;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
ELSEIF TALENT:RESULT:122
	PRINTFORMW 그걸 버린다니 당치도 않다!
	RETURN 0
ELSEIF TALENT:RESULT:121 == 0
	PRINTFORMW 지울 페니스가 없습니다
	RETURN 0
ELSEIF TALENT:RESULT:511 == 1 && TALENT:RESULT:505 == 0
	PRINTFORMW 【천사】는【후타나리】를 지울 수 없습니다
	RETURN 0
ELSEIF TALENT:RESULT:511 == 1 && TALENT:RESULT:505 == 1
	PRINTFORMW 【타천사】는【후타나리】를 지울 수 없습니다
	RETURN 0
ELSEIF TALENT:RESULT:199
	PRINTFORMW 【%TALENTNAME:199%】인 캐릭터는 개조할 수 없습니다
	RETURN 0
ENDIF

T = RESULT

PRINTFORML %NAME:RESULT%의 페니스를 지웁니까?

PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0 
	PRINTFORMW 《%조사처리(NAME:T,"는")%【%TALENTNAME:121%】가 아니게 됐다》
	TALENT:T:121 = 0
	SIF TALENT:T:1 == 0
		CFLAG:T:610 = 1
	TALENT:T:1 = 0
ELSE
	GOTO INPUT_LOOP
ENDIF

MONEY -= C

RETURN 1
