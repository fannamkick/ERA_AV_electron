;=================================================
;미션など
;=================================================
@ELLEN_MISSION

DRAWLINE
PRINTL 엘렌씨의 부탁
PRINTL 《엘렌에게서 부탁을 받을 수 있습니다》
DRAWLINE
PRINTV DAY+1
PRINT 주차
IF TIME == 0
	PRINTL  전반
ELSE
	PRINTL  후반
ENDIF

PRINTFORML 소지금: {MONEY}포인트
DRAWLINE

PRINTL  [0] - 여배우 후보 소개

REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 10
		IF TALENT:COUNT:430 == 1
			IF FLAG:570 == 0
				PRINTL  [1] - 미션스타트!
			ENDIF
		ENDIF
	ENDIF
REND

SIF PBAND:14 == 3
	PRINTL  [2] - 카미나 유우키의 옛 친구들을 구출한다

DRAWLINE
PRINTL  [999] - 돌아간다

$INPUT_LOOP
INPUT

IF RESULT == 0
	CALL ELLEN_EXTRAACTRESS
	RETURN 0
ELSEIF RESULT == 1 && FLAG:570 == 0
	CALL MISSION_START
ELSEIF RESULT == 2 && PBAND:14== 3
	CALL KOISORA_ADD
ELSEIF RESULT == 999
	RETURN 0
ELSE
	GOTO INPUT_LOOP
ENDIF

