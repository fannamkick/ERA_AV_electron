	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

CHKFONT "あくびん"
	IF RESULT
		SETFONT "あくびん"
	ENDIF
SETCOLOR 0xDDBBCC
PRINTL 「인기있는 여자란, 곧 얌전한 여자다!　……아마도」
RESETCOLOR
SETFONT ""
$INPUT_LOOP
DRAWLINE

CALL LIFE_LIST_NEW,1

IF RESULT == 999
	RETURN 0
ELSEIF RESULT < 0 || RESULT >= CHARANUM
	GOTO INPUT_LOOP
;臨死中のキャラは排除
ELSEIF BASE:RESULT:0 < 1
	GOTO INPUT_LOOP
ELSEIF TALENT:RESULT:330
	PRINTFORMW 【%TALENTNAME:330%】대상은 세미나에 참가할 수 없습니다
	GOTO INPUT_LOOP
;안드로이드は排除
ELSEIF TALENT:RESULT:504
	PRINTFORMW 【%TALENTNAME:504%】는 그쪽 전문가에 의뢰해 주세요
	GOTO INPUT_LOOP
;사쿠라코は排除
ELSEIF NO:RESULT == 26
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 해당 세미나의 강사입니다
	GOTO INPUT_LOOP
;얌전함は排除
ELSEIF TALENT:RESULT:14 == 1
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 얌전합니다
	GOTO INPUT_LOOP
;활발함は排除
ELSEIF TALENT:RESULT:16 == 1
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 이번 세미나에 관심이 없나봅니다
	GOTO INPUT_LOOP
ENDIF

T = RESULT

$INPUT_LOOP_2
PRINTFORML  %CALLNAME:T%에게 세미나를 듣게 할까요?
PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0
	PRINTFORMW %조사처리(NAME:T,"는")% RB단이 주최한 세미나에 참가했다……
	PRINTFORML 이 세상엔 얌전한 여자를 좋아하는 남자가 많다는 것을 알고, 느낀 점이 있어보인다
	PRINTFORMW %CALLNAME:T%의 성격이【%TALENTNAME:14%】이 됐다
	TALENT:T:14 = 1
	EXP:T:110 += 1
ELSE
	GOTO INPUT_LOOP_2
ENDIF

MONEY -= C

RETURN 1
