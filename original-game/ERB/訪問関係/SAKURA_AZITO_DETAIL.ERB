;임신중は排除
ELSEIF TALENT:RESULT:30
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 이번 세미나에 관심이 없나봅니다
	GOTO INPUT_LOOP
;정조무관심は排除
ELSEIF TALENT:RESULT:31
	PRINTFORMW %조사처리(CALLNAME:RESULT,"는")% 이미 한창 육식계입니다
	GOTO INPUT_LOOP
ENDIF

T = RESULT

$INPUT_LOOP_2
PRINTFORML  %CALLNAME:T%에게 세미나를 듣게 할까요?
PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0
	PRINTFORMW %조사처리(NAME:T,"는")% RB단이 주최한 세미나에 참가했다……
	PRINTFORML 이 세상엔 들이대는 여자에게 약한 남자가 많다는 것을 알고, 느낀 점이 있어보인다
	PRINTFORMW %CALLNAME:T%의 정조관념은【%TALENTNAME:31%】이 됐다
	TALENT:T:31 = 1
	EXP:T:110 += 1
ELSE
	GOTO INPUT_LOOP_2
ENDIF

MONEY -= C

RETURN 1
