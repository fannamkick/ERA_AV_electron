;-------------------------------------------------
;工作活動: 킥킹 호스
;-------------------------------------------------
@KICKINGHORSE
C = 100000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

CHKFONT "あくびん"
	IF RESULT
		SETFONT "あくびん"
	ENDIF
SETCOLOR 0xDDBBCC
PRINTL 「그래, 인싸에게 벌을 내리는 거구나!　성공할지는…… 음, 반반이려나?」
RESETCOLOR
SETFONT ""

$INPUT_LOOP_3
PRINTFORML  커플의 연애를 방해합니까?
PRINTL  [0] - 네
PRINTL  [1] - 그만둔다

INPUT

IF RESULT == 1
	RETURN 0
ELSEIF RESULT == 0
	REPEAT CHARANUM
		SIF COUNT == 0
			CONTINUE
			CFLAG:COUNT:629 += RAND:3
				IF CFLAG:COUNT:629 == 2 && TALENT:COUNT:184 == 1 && CFLAG:COUNT:621 == 1
					PRINTFORMW 《RB단의 방해공작에 의해 %조사처리(NAME:COUNT,"는")% %CSTR:COUNT:7% %조사처리(CSTR:COUNT:8,"와")% 헤어졌습니다》
					TALENT:COUNT:184 = 0
					TALENT:COUNT:190 = 0
					CFLAG:COUNT:619 = 0
					CFLAG:COUNT:621 = 2
					CFLAG:COUNT:629 = 0
					IF CFLAG:15 == 8 && CFLAG:624 == 0
						CSTR:0 = %CSTR:7% %CSTR:8%(전 남친)
						CFLAG:624 += 1
					ENDIF

					IF CFLAG:16 == 3 && CFLAG:628 == 0
						CSTR:1 = %CSTR:7% %CSTR:8%(전 남친)
						CFLAG:628 += 1
					ENDIF
					EXP:COUNT:109 += 1
				ELSEIF CFLAG:COUNT:629 == 1
					PRINTFORMW 《RB단의 방해공작에 의해 %NAME:COUNT%에게 작업거는 남자를 쫓아냈습니다》
					CFLAG:COUNT:619 -= 30
					SIF CFLAG:COUNT:619 <= 0
						CFLAG:COUNT:619 = 0
					CFLAG:COUNT:629 = 0
				ELSE
					PRINTFORMW 《RB단의 방해공작은 실패했습니다》
					CFLAG:COUNT:629 = 0
				ENDIF
	REND
ELSE
	GOTO INPUT_LOOP_3
ENDIF

MONEY -= C

RETURN 1
;
