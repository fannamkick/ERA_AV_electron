;-------------------------------------------------
;治安強化
;-------------------------------------------------
@SECURITY_UP
C = 10000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

$INPUT_LOOP

PRINTFORMW 《아야노에게 뒤에서 압력을 넣어 순찰을 강화하도록 부탁했습니다》
FLAG:300 = -10
;ここで立てないと立てる機会がなさそう
FLAG:600 = 1

SIF FLAG:300 <= 0
	FLAG:300 = 0

IF FLAG:300 <= 24
	FLAG:301 = 0
ELSEIF FLAG:300 <= 49
	FLAG:301 = 1
ELSEIF FLAG:300 <= 75
	FLAG:301 = 2
ELSE
	FLAG:301 = 3
ENDIF

MONEY -= C
WAIT

RETURN 1
;-------------------------------------------------
;治安弱化
;-------------------------------------------------
@SECURITY_DOWN
C = 10000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

$INPUT_LOOP

PRINTFORMW 《아야노에게 뒤에서 압력을 넣어 순찰을 적게하도록 부탁했습니다》
;治安マイナスが仕込まれていないがまあいいか
FLAG:600 = 0
MONEY -= C
WAIT

RETURN 1
;-------------------------------------------------
;EXキャラ: 카세 후미카
;-------------------------------------------------
@ADD_FUMIKA

C = 100000

IF MONEY < C
	PRINTW 소지금이 부족합니다
	RETURN 0
ENDIF

PRINTFORML 「그럼, 이쪽을 봐주세요」
PRINTFORML 토모요시댁 응접실에서, 아야노는 메이드에게 종이 한장을 가져오게 했다
PRINTFORML 그것은 사진과 간단한 프로필이 적힌, 이력서 비슷한 것이었다
PRINTFORML 「그녀는 절 섬기는 메이드입니디만, 당신이 전에 좋은 여배우 후보가 없을지
PRINTFORML 찾고 있던게 생각났기에……
PRINTFORML 제가 선택한 메이드이니 소질은 보증하겠어요.
PRINTFORML ――그렇다고 공짜로 넘겨 드릴수는 없지많요……」
PRINTFORML 사진만 봐도 확실한 느낌이 올 정도니, 가격에 걸맞는 가치는 있을 것이다
PRINTFORML 흥미가 생긴 %플레이어는()% 프로필을 정독해봤다……
PRINTW
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
PRINTFORML 【카세 후미카】
PRINTFORML 토모요시가를 모시는 메이드
PRINTFORML 토모요시가의 사용인은 대부분 각자의 분야의 전문가로
PRINTFORML 그 중에 딱히 특출난 점이 없는 자신이 있는 것을 의문시하고 있다
PRINTFORML 사실 그녀는 아야노가 성적으로 희롱하기 위해 고용한, 말하자면 성노예 후보이며
PRINTFORML 물론 본인은 그 사실을 티끌만큼도 모르고, 일하다 실수하여 침울해하는 일상을 보내고 있다
PRINTFORML 당신(=감독)의 실력을 인정한 아야노가 그녀를 당신에게 맡기기로 했다 한다
PRINTFORML 소심한 성격이지만, 연애에 관해선 보수적이다
PRINTFORML 연령: 19세　난이도: D　성장도: B　공헌도: B　매각치: B
PRINTL ‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥‥
PRINTW 

$INPUT_LOOP_FUMIKA
PRINTFORML 「어떤가요?　10만 포인트로 이 아이를…… 아깝지만, 당신에게 맡길까요?」
PRINTL [0] - 맡는다
PRINTL [1] - 관둔다
INPUT

;なぜか教会勢雇用判定を見ていた
IF RESULT == 0
	PRINTFORML 아야노가 손뼉을 치니, 후미카가 황급히 응접실로 들어왔다
	PRINTFORM 아야노에게 %플레이어를()% 소개받은 후미카는 
	PRINTFORML 갑작스러운 아야노의 말에 눈을 동그랗게 뜨고 울먹였다……
	PRINTW
	PRINTFORM 아야노가 그녀에게 앞으로 %플레이어를()% 모실것과, 그곳에서 하게 될 일을 설명해주자 
	PRINTFORML 후미카는 눈물을 흘리며 떨리는 손으로 계약서에 싸인했다……
	PRINTFORMW
	PRINTFORML 《카세 후미카가 여배우 후보가 됐습니다》
	PRINTFORMW
		ADDCHARA 90
		CFLAG:MASTER:761 = 1
		LOADGLOBAL
		GLOBAL:290 += 1
		SAVEGLOBAL
			IF GLOBAL:200 >= 0 && FLAG:540 == 0
				IF GETCHARA(90, 0) >= 0
					TARGET = GETCHARA(90)
					CALL CLEARBONUS_CALL
				ENDIF
			ENDIF
ELSEIF RESULT == 1
	RETURN 0
ELSE
	GOTO INPUT_LOOP_FUMIKA
ENDIF

MONEY -= C

RETURN 0