;=================================================
;訪問
;=================================================
@HOUMON

$INPUT_LOOP

DRAWLINE
PRINTL 방문
PRINTL 《이곳저곳을 방문해 특수한 행동이 가능합니다》
DRAWLINE
PRINTV DAY+1
PRINT 주차
IF TIME == 0
	PRINTL  전반
ELSE
	PRINTL  후반
ENDIF

PRINTFORML 소지금: {MONEY}포인트
DRAWLINE

PRINTL 어딜 가볼까……
PRINTL  [10] - 키류 조직 사무소
;一文字変数UはSHOW_SHOPで비밀지식有無の判定に使われている。
;訪問内でいじらない限りは問題なさそう
IF U == 1
PRINTL  [11] - 비밀 연구소
ENDIF
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 9
		IF CFLAG:COUNT:1 == 2
			PRINTL  [12] - 레이첼의 공방
			LOCAL:2 = 1
		ENDIF
	ENDIF
REND
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 11
		IF CFLAG:COUNT:1 == 2
			PRINTL  [13] - 이쿠미의 연구소
			LOCAL:3 = 1
		ENDIF
	ENDIF
REND
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 26
		IF CFLAG:COUNT:1 == 2
			PRINTL  [14] - RB단 아지트
			LOCAL:4 = 1
		ENDIF
	ENDIF
REND
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 27
		IF CFLAG:COUNT:1 == 2
			PRINTL  [15] - 토모요시댁
			LOCAL:5 = 1
		ENDIF
	ENDIF
REND
REPEAT CHARANUM
	IF COUNT == 0
		CONTINUE
	ELSEIF NO:COUNT == 86
		IF TALENT:COUNT:430 == 1 && TALENT:COUNT:440 == 1
			PRINTL  [16] - 아카샤 본부
			LOCAL:6 = 1
		ENDIF
	ENDIF
REND
DRAWLINE
PRINTL  [999] - 돌아간다

INPUT

IF RESULT == 10
	CALL KIRYU_GUMI
ELSEIF RESULT == 11
	CALL SECRET_LABO
ELSEIF RESULT == 12 && LOCAL:2 == 1
	CALL RACHEL_LABO
ELSEIF RESULT == 13 && LOCAL:3 == 1
	CALL IKUMI_LABO
ELSEIF RESULT == 14 && LOCAL:4 == 1
	CALL SAKURA_AZITO
ELSEIF RESULT == 15 && LOCAL:5 == 1
	CALL AYANO_ORDER
ELSEIF RESULT == 16 && LOCAL:6 == 1
	CALL EUNICE_LABO
ELSEIF RESULT == 999
	RETURN 0
ELSE
	GOTO INPUT_LOOP
ENDIF

GOTO INPUT_LOOP
